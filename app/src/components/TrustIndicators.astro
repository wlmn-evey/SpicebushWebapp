---
import { Award, Users, Heart, Calendar } from 'lucide-astro';
---

<!-- Trust Indicators Banner -->
<section class="py-8 bg-moss-green text-white">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="flex flex-col items-center">
        <Calendar className="w-8 h-8 mb-2 opacity-80" />
        <div class="text-2xl font-bold">15+</div>
        <div class="text-sm opacity-90">Years Serving Families</div>
      </div>
      
      <div class="flex flex-col items-center">
        <Users className="w-8 h-8 mb-2 opacity-80" />
        <div class="text-2xl font-bold">60+</div>
        <div class="text-sm opacity-90">Happy Families</div>
      </div>
      
      <div class="flex flex-col items-center">
        <Award className="w-8 h-8 mb-2 opacity-80" />
        <div class="text-2xl font-bold">AMS</div>
        <div class="text-sm opacity-90">Certified Teachers</div>
      </div>
      
      <div class="flex flex-col items-center">
        <Heart className="w-8 h-8 mb-2 opacity-80" />
        <div class="text-2xl font-bold">100%</div>
        <div class="text-sm opacity-90">Inclusive Community</div>
      </div>
    </div>
  </div>
</section>