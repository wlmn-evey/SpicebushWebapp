---
import { Home, Clock, DollarSign, Users, Settings, Image as ImageIcon, CircleHelp, MessageSquare, Mail, LineChart } from 'lucide-astro';

const currentPath = Astro.url.pathname;
---

<!-- Admin Navigation Sidebar Component -->
<nav class="bg-white border-r border-gray-200 w-64 h-full fixed left-0 top-0 z-40 transform -translate-x-full lg:translate-x-0 transition-transform" id="admin-sidebar">
  <div class="flex flex-col h-full">
    <!-- Header -->
    <div class="p-6 border-b border-gray-200">
      <div class="flex items-center">
        <img 
          src="/SpicebushLogo-03.png" 
          alt="Spicebush Montessori" 
          class="h-10 w-auto mr-3"
        />
        <div>
          <h2 class="text-lg font-semibold text-earth-brown">Admin Panel</h2>
          <p class="text-sm text-gray-600">Management Center</p>
        </div>
      </div>
    </div>
    
    <!-- Navigation Links -->
    <div class="flex-1 overflow-y-auto py-6">
      <div class="px-3 space-y-1">
        <a 
          href="/admin" 
          aria-current={currentPath === '/admin' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <Home className="w-5 h-5 mr-3" />
          Dashboard
        </a>
        
        <a 
          href="/admin/hours" 
          aria-current={currentPath === '/admin/hours' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <Clock className="w-5 h-5 mr-3" />
          School Hours
        </a>
        
        <a 
          href="/admin/tuition" 
          aria-current={currentPath === '/admin/tuition' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <DollarSign className="w-5 h-5 mr-3" />
          Tuition & Programs
        </a>
        
        <a 
          href="/admin/staff" 
          aria-current={currentPath === '/admin/staff' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <Users className="w-5 h-5 mr-3" />
          Staff
        </a>

        <a
          href="/admin/testimonials"
          aria-current={currentPath === '/admin/testimonials' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <MessageSquare className="w-5 h-5 mr-3" />
          Testimonials
        </a>

        <a
          href="/admin/contact-submissions"
          aria-current={currentPath === '/admin/contact-submissions' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <Mail className="w-5 h-5 mr-3" />
          Contact Submissions
        </a>

        <a
          href="/admin/seo"
          aria-current={currentPath === '/admin/seo' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <LineChart className="w-5 h-5 mr-3" />
          SEO & Analytics
        </a>
        
        <a 
          href="/admin/settings" 
          aria-current={currentPath === '/admin/settings' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <Settings className="w-5 h-5 mr-3" />
          System Settings
        </a>

        <a
          href="/admin/media"
          aria-current={currentPath === '/admin/media' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <ImageIcon className="w-5 h-5 mr-3" />
          Media
        </a>

        <a
          href="/admin/faq"
          aria-current={currentPath === '/admin/faq' ? 'page' : undefined}
          class="admin-nav-link group flex items-center px-3 py-2 text-sm font-medium rounded-lg"
        >
          <CircleHelp className="w-5 h-5 mr-3" />
          FAQs
        </a>
      </div>
    </div>
    
    <!-- Footer -->
    <div class="p-6 border-t border-gray-200">
      <div class="flex items-center">
        <div class="w-8 h-8 bg-forest-canopy rounded-full flex items-center justify-center">
          <span class="text-white text-sm font-medium">A</span>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-earth-brown">Admin User</p>
          <p class="text-xs text-gray-600">Administrator</p>
        </div>
      </div>
    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div class="fixed inset-0 bg-gray-600 bg-opacity-75 z-30 lg:hidden hidden" id="admin-sidebar-overlay"></div>

<style>
  .admin-nav-link {
    @apply text-gray-700 hover:bg-gray-100 hover:text-forest-canopy transition-colors;
  }
  
  .admin-nav-link[aria-current="page"] {
    @apply bg-forest-canopy text-white;
  }
</style>
