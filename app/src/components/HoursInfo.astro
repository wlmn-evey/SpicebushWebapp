---
import { getCollection } from 'astro:content';
import { Clock } from 'lucide-astro';

interface Props {
  showIcon?: boolean;
  showAllDays?: boolean;
  inline?: boolean;
  className?: string;
}

const { showIcon = true, showAllDays = false, inline = false, className = '' } = Astro.props;

// Get hours from content collection
const allHours = await getCollection('hours');
const sortedHours = allHours.sort((a, b) => a.data.order - b.data.order);

// Get current day
const currentDay = new Date().toLocaleDateString('en-US', { weekday: 'long' });

// Find today's hours
const todayHours = sortedHours.find(h => h.data.day === currentDay);

// Format time
const formatTime = (time: string) => {
  return time.replace(/(\d{1,2}):(\d{2})/, (_match, hour, minute) => {
    const h = parseInt(hour);
    const period = h >= 12 ? 'PM' : 'AM';
    const displayHour = h > 12 ? h - 12 : h === 0 ? 12 : h;
    return `${displayHour}:${minute} ${period}`;
  });
};

const containerClass = inline ? 'flex flex-wrap gap-4 items-center' : 'space-y-2';
---

<div class={`${containerClass} ${className}`}>
  {showIcon && <Clock className="w-4 h-4 text-forest-canopy" />}
  
  {showAllDays ? (
    <div class="space-y-1">
      {sortedHours.map((hour) => (
        <div class="flex justify-between gap-4 text-sm">
          <span class="font-medium text-earth-brown">{hour.data.day}:</span>
          {hour.data.is_closed ? (
            <span class="text-earth-brown/70">Closed</span>
          ) : (
            <span class="text-earth-brown">
              {formatTime(hour.data.open_time)} - {formatTime(hour.data.close_time)}
              {hour.data.note && <span class="text-earth-brown/70 ml-1">({hour.data.note})</span>}
            </span>
          )}
        </div>
      ))}
    </div>
  ) : (
    <div class="text-earth-brown">
      {todayHours ? (
        todayHours.data.is_closed ? (
          <span>Closed today</span>
        ) : (
          <span>
            Today: {formatTime(todayHours.data.open_time)} - {formatTime(todayHours.data.close_time)}
            {todayHours.data.note && <span class="text-earth-brown/70 ml-1">({todayHours.data.note})</span>}
          </span>
        )
      ) : (
        <span>Hours not available</span>
      )}
    </div>
  )}
</div>
