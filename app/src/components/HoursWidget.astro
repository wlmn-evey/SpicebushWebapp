---
// Hours Widget Component
// Styled specifically for footer integration
import { getCollection } from 'astro:content';

// Fetch hours data from markdown files with error handling
let hoursData = [];
try {
  const hoursEntries = await getCollection('hours');
  if (hoursEntries && hoursEntries.length > 0) {
    hoursData = hoursEntries.sort((a, b) => a.data.order - b.data.order);
  }
} catch (error) {
  console.error('Error loading hours in HoursWidget:', error);
  // Will show loading state if no data available
}
---

<div id="sbms-hours-widget" class="bg-white rounded-lg p-4 text-earth-brown shadow-sm" data-hours={JSON.stringify(hoursData)}>
  <h3 class="text-xl font-bold text-center text-forest-canopy mb-2">School Hours</h3>
  <div id="current-time-container" class="text-center text-xs opacity-80 mb-3">
    Current Time: <span id="current-time" class="font-medium text-forest-canopy"></span>
  </div>
  
  <!-- Legend -->
  <div id="sbms-legend" class="flex justify-around mb-4 text-xs">
    <span class="flex items-center">
      <span class="w-2.5 h-2.5 bg-moss-green rounded-sm mr-1"></span>
      Before Care
    </span>
    <span class="flex items-center">
      <span class="w-2.5 h-2.5 bg-forest-canopy rounded-sm mr-1"></span>
      Regular Hours
    </span>
    <span class="flex items-center">
      <span class="w-2.5 h-2.5 bg-sunlight-gold rounded-sm mr-1"></span>
      After Care
    </span>
    <span class="flex items-center lg:hidden">
      <span class="w-2.5 h-2.5 bg-orange-600 rounded-sm mr-1"></span>
      Holiday
    </span>
  </div>
  
  <!-- Loading State -->
  <div id="loading-state" class="text-center py-4 text-sm text-gray-500">
    Loading hours...
  </div>
  
  <!-- Hours List -->
  <ul id="hours-list" class="space-y-2 hidden"></ul>
  
  <!-- Holiday Messages -->
  <div id="holiday-messages" class="mt-4"></div>
  
  <!-- Debug Info (hidden by default) -->
  <div id="debug-info" class="hidden mt-4 p-2 bg-gray-100 rounded text-xs">
    <div>Data Source: <span id="data-source">Loading...</span></div>
    <div>Days Loaded: <span id="days-count">0</span></div>
    <div>Holidays Found: <span id="holidays-count">0</span></div>
  </div>
</div>

<script type="module">
  // Utility functions moved inline to avoid TypeScript import issues in production
  
  // Format time helper with improved formatting
  function formatTime(value) {
    if (value === 0) return '';
    
    const hours = Math.floor(value);
    const minutes = Math.round((value - hours) * 60);
    const ampm = hours >= 12 ? 'PM' : 'AM';
    const displayHour = hours === 0 ? 12 : hours > 12 ? hours - 12 : hours;
    
    if (minutes === 0) {
      return `${displayHour} ${ampm}`;
    } else {
      return `${displayHour}:${minutes.toString().padStart(2, '0')} ${ampm}`;
    }
  }

  // Update current time display
  function updateCurrentTime(timeElement) {
    const now = new Date();
    const hours = now.getHours();
    const minutes = now.getMinutes();
    const ampm = hours >= 12 ? 'PM' : 'AM';
    const displayHour = hours === 0 ? 12 : hours > 12 ? hours - 12 : hours;
    timeElement.textContent = `${displayHour}:${minutes.toString().padStart(2, '0')} ${ampm}`;
  }

  // Fetch US holidays from public API
  async function fetchUpcomingHolidays() {
    try {
      const currentYear = new Date().getFullYear();
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const sevenDaysFromNow = new Date();
      sevenDaysFromNow.setDate(today.getDate() + 7);
      sevenDaysFromNow.setHours(23, 59, 59, 999);
      
      const response = await fetch(`https://date.nager.at/api/v3/publicholidays/${currentYear}/US`);
      
      if (!response.ok) {
        console.warn('Holiday API request failed, using fallback');
        return getFallbackHolidays(today, sevenDaysFromNow);
      }
      
      const allHolidays = await response.json();
      return allHolidays.filter((holiday) => {
        const [year, month, day] = holiday.date.split('-').map(Number);
        const holidayDate = new Date(year, month - 1, day);
        return holidayDate >= today && holidayDate <= sevenDaysFromNow;
      });
      
    } catch (error) {
      console.error('Error fetching holidays from API:', error);
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const sevenDaysFromNow = new Date();
      sevenDaysFromNow.setDate(today.getDate() + 7);
      sevenDaysFromNow.setHours(23, 59, 59, 999);
      
      return getFallbackHolidays(today, sevenDaysFromNow);
    }
  }

  // Fallback holiday data
  function getFallbackHolidays(today, sevenDaysFromNow) {
    const currentYear = today.getFullYear();
    
    const commonHolidays = [
      { date: `${currentYear}-01-01`, name: "New Year's Day" },
      { date: `${currentYear}-01-15`, name: 'Martin Luther King Jr. Day' },
      { date: `${currentYear}-02-19`, name: 'Presidents Day' },
      { date: `${currentYear}-05-27`, name: 'Memorial Day' },
      { date: `${currentYear}-07-04`, name: 'Independence Day' },
      { date: `${currentYear}-09-02`, name: 'Labor Day' },
      { date: `${currentYear}-10-14`, name: 'Columbus Day' },
      { date: `${currentYear}-11-11`, name: 'Veterans Day' },
      { date: `${currentYear}-11-28`, name: 'Thanksgiving Day' },
      { date: `${currentYear}-12-25`, name: 'Christmas Day' }
    ];
    
    return commonHolidays.filter(holiday => {
      const [year, month, day] = holiday.date.split('-').map(Number);
      const holidayDate = new Date(year, month - 1, day);
      return holidayDate >= today && holidayDate <= sevenDaysFromNow;
    });
  }

  // Helper function to get appropriate emoji for holidays
  function getHolidayEmoji(holidayName) {
    const name = holidayName.toLowerCase();
    
    if (name.includes('new year')) return '🎊';
    if (name.includes('martin luther king')) return '✊';
    if (name.includes('president')) return '🇺🇸';
    if (name.includes('memorial')) return '🇺🇸';
    if (name.includes('independence') || name.includes('july')) return '🎆';
    if (name.includes('labor')) return '⚒️';
    if (name.includes('columbus')) return '⛵';
    if (name.includes('veteran')) return '🇺🇸';
    if (name.includes('thanksgiving')) return '🦃';
    if (name.includes('christmas')) return '🎄';
    
    return '🎉'; // Default holiday emoji
  }

  // Helper function to format holiday date
  function formatHolidayDate(dateString) {
    const [year, month, day] = dateString.split('-').map(Number);
    const date = new Date(year, month - 1, day);
    
    const today = new Date();
    const tomorrow = new Date();
    tomorrow.setDate(today.getDate() + 1);
    
    const todayMidnight = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    const tomorrowMidnight = new Date(tomorrow.getFullYear(), tomorrow.getMonth(), tomorrow.getDate());
    const dateMidnight = new Date(date.getFullYear(), date.getMonth(), date.getDate());
    
    if (dateMidnight.getTime() === todayMidnight.getTime()) {
      return 'Today';
    } else if (dateMidnight.getTime() === tomorrowMidnight.getTime()) {
      return 'Tomorrow';
    } else {
      return date.toLocaleDateString('en-US', { 
        weekday: 'long',
        month: 'short', 
        day: 'numeric' 
      });
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const widget = document.getElementById('sbms-hours-widget');
    const list = document.getElementById('hours-list');
    const timeEl = document.getElementById('current-time');
    const holidayMessagesEl = document.getElementById('holiday-messages');
    const loadingEl = document.getElementById('loading-state');
    const debugInfo = document.getElementById('debug-info');
    
    // Get hours data from data attribute
    let hoursData = [];
    try {
      const dataAttr = widget.getAttribute('data-hours');
      if (dataAttr) {
        hoursData = JSON.parse(dataAttr);
      }
    } catch (error) {
      console.error('Error parsing hours data:', error);
    }
    
    const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    
    let processedHoursData = {};
    let upcomingHolidays = [];
    let dataSource = 'content-collection';
    
    // Enable debug mode if URL contains ?debug=true
    const urlParams = new URLSearchParams(window.location.search);
    const debugMode = urlParams.get('debug') === 'true';
    if (debugMode) {
      debugInfo.classList.remove('hidden');
    }
    
    function updateDebugInfo() {
      if (debugMode) {
        document.getElementById('data-source').textContent = dataSource;
        document.getElementById('days-count').textContent = Object.keys(processedHoursData).length;
        document.getElementById('holidays-count').textContent = upcomingHolidays.length;
      }
    }
    
    // Convert time string to decimal hours
    function parseTimeToDecimal(timeStr) {
      const [time, period] = timeStr.split(' ');
      let [hours, minutes = 0] = time.split(':').map(Number);
      
      if (period === 'PM' && hours !== 12) hours += 12;
      if (period === 'AM' && hours === 12) hours = 0;
      
      return hours + (minutes / 60);
    }
    
    // Process hours data from content collection
    async function fetchHoursData() {
      try {
        // Transform content collection data to widget format
        const transformedData = {};
        
        hoursData.forEach(entry => {
          const data = entry.data;
          const dayName = data.day;
          
          if (data.is_closed) {
            transformedData[dayName] = {
              start: 0,
              end: 0,
              before_care_offset: 0,
              after_care_offset: 0,
              aftercare_available: false,
              closed: true
            };
          } else {
            const openTime = parseTimeToDecimal(data.open_time);
            const closeTime = parseTimeToDecimal(data.close_time);
            
            // Determine before/after care based on standard hours
            // Standard hours: 8:30 AM - 3:00 PM
            const standardStart = 8.5; // 8:30 AM
            const standardEnd = 15; // 3:00 PM
            
            // Calculate offsets
            const beforeCareOffset = standardStart - openTime;
            let afterCareOffset = 0;
            let aftercareAvailable = false;
            
            // Check if aftercare is available based on note or closing time
            if (dayName === 'Friday') {
              // Friday has no aftercare
              afterCareOffset = 0;
              aftercareAvailable = false;
            } else if (closeTime > standardEnd) {
              // Monday-Thursday have aftercare until 5:30 PM
              afterCareOffset = closeTime - standardEnd;
              aftercareAvailable = true;
            }
            
            transformedData[dayName] = {
              start: standardStart,
              end: standardEnd,
              before_care_offset: beforeCareOffset,
              after_care_offset: afterCareOffset,
              aftercare_available: aftercareAvailable,
              closed: false
            };
          }
        });
        
        processedHoursData = transformedData;
        dataSource = 'content-collection';
        
        // Fetch holidays
        const holidaysData = await fetchUpcomingHolidays();
        upcomingHolidays = holidaysData || [];
        
      } catch (error) {
        console.error('Error processing hours data:', error);
        // Fallback to default hours
        processedHoursData = {
          Sunday: { start: 0, end: 0, before_care_offset: 0, after_care_offset: 0, aftercare_available: false, closed: true },
          Monday: { start: 8.5, end: 15, before_care_offset: 0.5, after_care_offset: 2.5, aftercare_available: true, closed: false },
          Tuesday: { start: 8.5, end: 15, before_care_offset: 0.5, after_care_offset: 2.5, aftercare_available: true, closed: false },
          Wednesday: { start: 8.5, end: 15, before_care_offset: 0.5, after_care_offset: 2.5, aftercare_available: true, closed: false },
          Thursday: { start: 8.5, end: 15, before_care_offset: 0.5, after_care_offset: 2.5, aftercare_available: true, closed: false },
          Friday: { start: 8.5, end: 15, before_care_offset: 0.5, after_care_offset: 0, aftercare_available: false, closed: false },
          Saturday: { start: 0, end: 0, before_care_offset: 0, after_care_offset: 0, aftercare_available: false, closed: true }
        };
        upcomingHolidays = [];
        dataSource = 'fallback';
      }
      
      updateDebugInfo();
    }
    
    
    // Enhanced render widget function
    function renderWidget() {
      // Hide loading state and show list
      loadingEl.classList.add('hidden');
      list.classList.remove('hidden');
      list.innerHTML = '';
      
      const now = new Date();
      const todayIdx = now.getDay();
      const currentTime = now.getHours() + now.getMinutes() / 60;
      
      // Reorder days starting with today, then continue through the week
      const orderedDays = [...days.slice(todayIdx), ...days.slice(0, todayIdx)];
      
      orderedDays.forEach((day, index) => {
        const info = processedHoursData[day];
        const li = document.createElement('li');
        li.className = 'p-3 rounded-lg transition-all duration-300';
        
        // Add today highlight
        if (day === days[todayIdx]) {
          li.classList.add('bg-white', 'shadow-md', 'border', 'border-stone-beige');
        }
        
        if (!info || info.closed) {
          li.classList.add('opacity-60');
          li.innerHTML = `
            <div class="flex justify-between items-center">
              <span class="font-semibold text-sm">${day}</span>
              <span class="text-xs opacity-75">Closed</span>
            </div>
          `;
        } else {
          const beforeCareStart = Math.max(0, info.start - info.before_care_offset);
          
          // Check if aftercare is available for this day
          const aftercareAvailable = info.aftercare_available === true;
          const actualAfterCareOffset = aftercareAvailable ? (info.after_care_offset || 0) : 0;
          const afterCareEnd = info.end + actualAfterCareOffset;
          
          // Calculate total span for percentage calculations
          const totalSpan = afterCareEnd - beforeCareStart;
          
          // Calculate widths for visual bars
          const beforeCareWidth = totalSpan > 0 ? (info.before_care_offset / totalSpan) * 100 : 0;
          const regularWidth = totalSpan > 0 ? ((info.end - info.start) / totalSpan) * 100 : 0;
          const afterCareWidth = (totalSpan > 0 && aftercareAvailable) ? (actualAfterCareOffset / totalSpan) * 100 : 0;
          
          li.innerHTML = `
            <div class="flex justify-between items-center mb-2">
              <span class="font-semibold text-sm">${day}</span>
              <span class="text-xs opacity-85">${formatTime(beforeCareStart)}${afterCareEnd > beforeCareStart ? `–${  formatTime(afterCareEnd)}` : ''}</span>
            </div>
            <div class="relative h-3 bg-gray-200 rounded-full overflow-hidden">
              ${beforeCareWidth > 0 ? `
                <div class="absolute h-full bg-moss-green flex items-center justify-center text-xs text-white font-medium" 
                     style="width: ${beforeCareWidth}%; left: 0%">
                  ${beforeCareWidth > 15 ? formatTime(beforeCareStart) : ''}
                </div>
              ` : ''}
              <div class="absolute h-full bg-forest-canopy flex items-center justify-center text-xs text-white font-medium" 
                   style="width: ${regularWidth}%; left: ${beforeCareWidth}%; min-width: 20%;">
                ${regularWidth > 20 ? formatTime(info.start) : ''}
              </div>
              ${afterCareWidth > 0 ? `
                <div class="absolute h-full bg-sunlight-gold flex items-center justify-center text-xs text-white font-medium" 
                     style="width: ${afterCareWidth}%; left: ${beforeCareWidth + regularWidth}%">
                  ${afterCareWidth > 15 ? formatTime(info.end) : ''}
                </div>
              ` : ''}
            </div>
            ${!aftercareAvailable ? `
              <div class="text-xs text-center mt-1 opacity-60">
                ${day === 'Friday' ? '⏰ Closes at 3:00 PM' : '🚫 No aftercare available'}
              </div>
            ` : ''}
          `;
          
          // Add current time indicator for today
          if (day === days[todayIdx] && currentTime >= beforeCareStart && currentTime <= afterCareEnd) {
            const position = ((currentTime - beforeCareStart) / totalSpan) * 100;
            const indicator = document.createElement('div');
            indicator.className = 'absolute w-0.5 h-5 bg-red-500 shadow-lg rounded-sm -top-1 z-10';
            indicator.style.left = `${Math.min(98, Math.max(1, position))}%`;
            li.querySelector('.relative').appendChild(indicator);
            
            // Add current time tooltip
            const tooltip = document.createElement('div');
            tooltip.className = 'absolute -top-8 left-1/2 transform -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded whitespace-nowrap';
            tooltip.textContent = `Now: ${formatTime(currentTime)}`;
            indicator.appendChild(tooltip);
          }
        }
        
        // Add staggered fade-in animation
        li.style.opacity = '0';
        li.style.transform = 'translateY(10px)';
        li.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        li.style.transitionDelay = `${index * 100}ms`;
        
        list.appendChild(li);
        
        // Trigger animation
        setTimeout(() => {
          li.style.opacity = '1';
          li.style.transform = 'translateY(0)';
        }, 50 + index * 100);
      });
      
      // Render holiday messages
      renderHolidayMessages();
      
    }
    
    // Render holiday messages with clean styling
    function renderHolidayMessages() {
      holidayMessagesEl.innerHTML = '';
      
      if (upcomingHolidays.length === 0) {
        return;
      }
      
      upcomingHolidays.forEach((holiday, index) => {
        const holidayEl = document.createElement('div');
        holidayEl.className = 'flex items-start bg-orange-100 border-l-4 border-orange-600 p-3 rounded text-sm font-medium text-earth-brown shadow-sm mt-3';
        holidayEl.style.opacity = '0';
        holidayEl.style.transform = 'translateY(10px)';
        holidayEl.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        holidayEl.style.transitionDelay = `${(days.length + index) * 100}ms`;
        
        // Determine holiday emoji based on the holiday name
        const holidayEmoji = getHolidayEmoji(holiday.name || holiday.localName);
        
        // Create message about potential hour changes
        const holidayMessage = 'School may be closed or have modified hours. Please check with the school office for specific holiday scheduling.';
        
        holidayEl.innerHTML = `
          <span class="mr-2 text-lg">${holidayEmoji}</span>
          <div class="flex-1">
            <div class="font-semibold">${holiday.name || holiday.localName}</div>
            <div class="text-xs opacity-90 mt-1 leading-tight">${holidayMessage}</div>
            <div class="text-xs opacity-75 mt-1">
              ${formatHolidayDate(holiday.date)}
            </div>
          </div>
        `;
        
        holidayMessagesEl.appendChild(holidayEl);
        
        // Trigger animation
        setTimeout(() => {
          holidayEl.style.opacity = '1';
          holidayEl.style.transform = 'translateY(0)';
        }, 50 + (days.length + index) * 100);
      });
    }
    
    
    // Initialize the widget
    try {
      await fetchHoursData();
      updateCurrentTime(timeEl);
      renderWidget();
      
      // Update time every minute
      setInterval(() => updateCurrentTime(timeEl), 60000);
      
    } catch (error) {
      console.warn('⚠️ Hours Widget initialized with fallback data:', error.message);
      // Widget should still render with fallback data, so don't show error message
    }
  });
</script>

<style>
  /* Ensure proper visibility and layout */
  #sbms-hours-widget * {
    box-sizing: border-box;
  }
  
  #hours-list li {
    min-height: 60px;
  }
  
  /* Improve visual hierarchy */
  .relative .absolute {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  /* Responsive adjustments */
  @media (max-width: 480px) {
    #sbms-legend {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    
    #sbms-legend span {
      font-size: 0.75rem;
    }
  }
</style>