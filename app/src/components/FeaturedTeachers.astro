---
import { db, type ContentEntry } from '@lib/db';
import { logServerError } from '@lib/server-logger';
import { ArrowRight } from 'lucide-astro';
import OptimizedImage from '@components/OptimizedImage.astro';
import { buildPhotoSlugResolver, toPhotoLookupEntry } from '@lib/photo-slug-resolver';

interface StaffData {
  name?: unknown;
  role?: unknown;
  photo?: unknown;
  order?: unknown;
  startYear?: unknown;
  certificationBadge?: unknown;
}

interface StaffCard {
  id: string;
  name: string;
  role?: string;
  photo?: string;
  photoSlug?: string;
  certificationBadge?: string;
  startYearLabel?: string;
  initials: string;
  bioSnippet?: string;
  order: number;
}

const normalizeString = (value: unknown): string | undefined => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.length > 0) {
      return trimmed;
    }
  }
  return undefined;
};

const normalizeNumber = (value: unknown): number | undefined => {
  if (typeof value === 'number' && Number.isFinite(value)) {
    return value;
  }
  if (typeof value === 'string') {
    const parsed = Number.parseInt(value, 10);
    if (!Number.isNaN(parsed)) {
      return parsed;
    }
  }
  return undefined;
};

const asRecord = (value: unknown): Record<string, unknown> => {
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    return value as Record<string, unknown>;
  }
  return {};
};

const photoEntries = await db.content.getCollection('photos');
const resolvePhotoSlug = buildPhotoSlugResolver(
  photoEntries.map((entry) => toPhotoLookupEntry(entry.slug, asRecord(entry.data)))
);

const createStaffCard = (entry: ContentEntry): StaffCard | null => {
  const data = entry.data as StaffData;
  const name = normalizeString(data.name);
  if (!name) {
    return null;
  }

  const role = normalizeString(data.role);
  const photo = normalizeString(data.photo);
  const photoSlug = resolvePhotoSlug(photo) ?? undefined;
  const order = normalizeNumber(data.order) ?? 999;
  const certificationBadge = normalizeString(data.certificationBadge);

  const startYearValue = normalizeString(data.startYear) ?? normalizeNumber(data.startYear)?.toString();
  const startYearLabel = startYearValue ? `Since ${startYearValue}` : undefined;

  const bodyText = typeof entry.body === 'string' ? entry.body : '';
  const firstSentence = bodyText
    .split('.')
    .map((sentence) => sentence.trim())
    .filter(Boolean)[0];
  const bioSnippet = firstSentence ? `${firstSentence}.` : undefined;

  const initials = name
    .split(' ')
    .filter(Boolean)
    .map((segment) => segment.charAt(0).toUpperCase())
    .join('')
    .slice(0, 3);

  return {
    id: entry.id,
    name,
    role,
    photo,
    photoSlug,
    certificationBadge,
    startYearLabel,
    initials: initials || name.charAt(0).toUpperCase(),
    bioSnippet,
    order
  };
};

let featuredStaff: StaffCard[] = [];

try {
  const staffEntries = await db.content.getCollection('staff');
  const staffCards = staffEntries
    .map(createStaffCard)
    .filter((card): card is StaffCard => card !== null)
    .sort((a, b) => a.order - b.order)
    .slice(0, 3);

  featuredStaff = staffCards;
} catch (error) {
  logServerError('Failed to load staff entries', error, { component: 'FeaturedTeachers' });
}
---

<!-- Featured Teachers Section -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-4 tracking-tight">
        Meet Our Teachers
      </h2>
      <p class="text-lg text-earth-brown max-w-3xl mx-auto leading-relaxed-plus font-light">
        Experienced Montessori guides who see the unique light in every child
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      {featuredStaff.length > 0 ? (
        featuredStaff.map((teacher) => (
          <div class="text-center">
            <div class="mb-6 relative inline-block">
              {teacher.photo ? (
                teacher.photoSlug ? (
                  <OptimizedImage
                    photoSlug={teacher.photoSlug}
                    alt={`${teacher.name}${teacher.role ? `, ${teacher.role}` : ''} at Spicebush Montessori School`}
                    className="w-48 h-48 rounded-full object-cover mx-auto shadow-lg"
                    slotId={`featured-teachers-${teacher.id}`}
                    mediaCategory="teachers"
                  />
                ) : (
                  <img
                    src={teacher.photo}
                    alt={`${teacher.name}${teacher.role ? `, ${teacher.role}` : ''} at Spicebush Montessori School`}
                    class="w-48 h-48 rounded-full object-cover mx-auto shadow-lg"
                    loading="lazy"
                  />
                )
              ) : (
                <div class="w-48 h-48 rounded-full bg-gradient-to-br from-forest-canopy to-moss-green flex items-center justify-center mx-auto shadow-lg">
                  <span class="text-white text-4xl font-bold">
                    {teacher.initials}
                  </span>
                </div>
              )}
              {teacher.certificationBadge && (
                <div class="absolute -bottom-2 -right-2 bg-sunlight-gold text-white rounded-full w-12 h-12 flex items-center justify-center text-xs font-bold shadow-md">
                  {teacher.certificationBadge}
                </div>
              )}
            </div>
          
            <h3 class="text-xl font-semibold text-earth-brown mb-1">
              {teacher.name}
            </h3>
            {teacher.role && (
              <p class="text-forest-canopy font-medium mb-2">
                {teacher.role}
              </p>
            )}
            {teacher.startYearLabel && (
              <p class="text-sm text-earth-brown/80 mb-3">
                {teacher.startYearLabel}
              </p>
            )}

            {teacher.bioSnippet && (
              <p class="text-earth-brown leading-relaxed text-sm max-w-sm mx-auto">
                {teacher.bioSnippet}
              </p>
            )}
          </div>
        ))
      ) : (
        <div class="col-span-3 text-center py-12">
          <p class="text-earth-brown/60">Teacher information is temporarily unavailable.</p>
        </div>
      )}
    </div>
    
    <div class="text-center">
      <a 
        href="/about#teachers" 
        class="inline-flex items-center text-forest-canopy hover:text-moss-green transition-colors font-semibold text-lg"
      >
        Meet Our Full Team
        <ArrowRight className="w-5 h-5 ml-2" />
      </a>
    </div>
  </div>
</section>
