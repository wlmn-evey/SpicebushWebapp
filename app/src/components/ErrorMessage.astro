---
export interface Props {
  error?: string | null;
  fieldId: string;
}

const { error, fieldId } = Astro.props;
---

{error && (
  <span 
    id={`${fieldId}-error`}
    role="alert"
    aria-live="assertive"
    aria-atomic="true"
    class="error-message text-sm text-red-600 mt-1 block"
  >
    {error}
  </span>
)}