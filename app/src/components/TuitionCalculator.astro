---
import { Calculator, DollarSign, Users, Percent, CreditCard, Baby, AlertCircle, Heart } from 'lucide-astro';

interface Props {
  programs: any[];
  rates: any[];
  settings: Record<string, any>;
}

const { programs = [], rates = [], settings = {} } = Astro.props;

// Pass data to client-side script
const tuitionData = {
  programs,
  rates,
  settings
};
---

<div class="max-w-7xl mx-auto">
  <!-- Calculator Header -->
  <div class="bg-white rounded-lg shadow-lg p-8 mb-8">
    <div class="text-center mb-8">
      <div class="flex justify-center mb-4">
        <div class="w-16 h-16 bg-forest-canopy rounded-full flex items-center justify-center">
          <Calculator className="w-8 h-8 text-white" />
        </div>
      </div>
      <h2 class="text-3xl font-bold text-earth-brown mb-4">
        Calculate Your Family's Tuition Rate
      </h2>
      <p class="text-lg text-earth-brown max-w-3xl mx-auto">
        Our income-based sliding scale ensures quality Montessori education is accessible to families from all backgrounds.
        Enter your basic information below to see tuition rates for all our programs.
      </p>
    </div>

    <!-- Simplified Calculator Form -->
    <form id="tuition-calculator-form" class="max-w-3xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Family Size -->
        <div>
          <label for="family-size" class="block text-sm font-medium text-earth-brown mb-2">
            <Baby className="w-4 h-4 inline mr-2" />
            Family Size
          </label>
          <select 
            id="family-size" 
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
            required
          >
            <option value="">Select Size</option>
            <option value="2">2 people</option>
            <option value="3">3 people</option>
            <option value="4">4 people</option>
            <option value="5">5 people</option>
            <option value="6">6 people</option>
            <option value="7">7 people</option>
            <option value="8">8+ people</option>
          </select>
        </div>

        <!-- Annual Income -->
        <div>
          <label for="annual-income" class="block text-sm font-medium text-earth-brown mb-2">
            <DollarSign className="w-4 h-4 inline mr-2" />
            Annual Household Income
          </label>
          <input 
            type="number" 
            id="annual-income" 
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
            placeholder="75,000"
            min="0"
            step="1000"
            required
          />
        </div>

        <!-- Number of Children -->
        <div>
          <label for="children-count" class="block text-sm font-medium text-earth-brown mb-2">
            <Users className="w-4 h-4 inline mr-2" />
            Children Attending
          </label>
          <select 
            id="children-count" 
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
            required
          >
            <option value="1">1 child</option>
            <option value="2">2 children</option>
            <option value="3">3 children</option>
            <option value="4">4+ children</option>
          </select>
        </div>
      </div>

      <!-- Calculate Button -->
      <div class="text-center">
        <button 
          type="submit" 
          class="bg-forest-canopy hover:bg-moss-green text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 inline-flex items-center"
        >
          <Calculator className="w-5 h-5 mr-2" />
          Calculate My Tuition Options
        </button>
      </div>
    </form>
  </div>

  <!-- Results Section -->
  <div id="results-section" class="hidden space-y-8">
    <!-- Family Profile Summary -->
    <div class="bg-white rounded-lg p-8">
      <h3 class="text-2xl font-bold text-earth-brown mb-6 text-center">Your Family's Tuition Options</h3>
      <div id="family-profile" class="bg-stone-beige rounded-lg p-6 mb-6 text-center">
        <!-- Profile info will be populated -->
      </div>

      <!-- Tuition D Notice (Financial Assistance Qualification) -->
      <div id="tuition-d-notice" class="hidden bg-gradient-to-r from-green-50 to-blue-50 border-l-4 border-green-500 rounded-lg p-6 mb-8 shadow-sm">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <Heart className="w-6 h-6 text-green-600 mt-1" />
          </div>
          <div class="ml-4">
            <h4 class="text-lg font-bold text-green-800 mb-3">Important Note for Tuition D Families:</h4>
            <p class="text-green-700 mb-4">
              Based on your income level, you may qualify for additional financial assistance. Please see the information below based on your residency:
            </p>
            
            <div class="bg-white rounded-lg p-4 border border-green-200 mb-4">
              <ul class="space-y-3 text-sm text-green-700">
                <li>
                  <strong class="text-green-800">Pennsylvania Residents:</strong> You are expected to apply for the PA Child Care Works (CCW) subsidized child care program. 
                  <a href="https://www.dhs.pa.gov/Services/Children/Pages/Child-Care-Works-Program.aspx" 
                     target="_blank" 
                     rel="noopener noreferrer"
                     class="text-green-600 hover:text-green-800 underline font-medium transition-colors focus:ring-2 focus:ring-green-300 focus:ring-offset-1 rounded">
                    Learn more about the PA CCW Program here.
                  </a>
                </li>
                <li>
                  <strong class="text-green-800">Non-Pennsylvania Residents:</strong> While the PA CCW program is for state residents, families at Tuition D levels may be eligible for a $200 monthly transportation stipend from Spicebush Montessori.
                </li>
              </ul>
            </div>
            
            <div class="bg-green-100 rounded-lg p-4 border border-green-300">
              <p class="text-green-800 font-medium text-center">
                Spicebush Montessori School is happy to offer assistance with any application processes or to discuss these options further. 
                <a href="/contact" class="text-green-600 hover:text-green-800 underline font-semibold transition-colors focus:ring-2 focus:ring-green-300 focus:ring-offset-1 rounded">
                  Please contact us for support.
                </a>
              </p>
            </div>
          </div>
        </div>
      </div>

      <div id="program-results" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Pre-rendered program cards will be populated here -->
      </div>
    </div>

    <!-- Payment Options Explanation -->
    <div class="bg-white rounded-lg shadow-lg p-8">
      <h3 class="text-2xl font-bold text-earth-brown mb-6 text-center">Payment Options & Savings</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <Percent className="w-6 h-6 text-green-600 mr-3" />
            <h4 class="font-bold text-green-800">Pay Full Year Upfront</h4>
          </div>
          <p class="text-green-700 mb-3">Save 5% on your total annual tuition by paying the full year in advance.</p>
          <p class="text-sm text-green-600">This discount is automatically calculated in your results above when you select this option.</p>
        </div>
        
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <CreditCard className="w-6 h-6 text-blue-600 mr-3" />
            <h4 class="font-bold text-blue-800">Extended Care</h4>
          </div>
          <p class="text-blue-700 mb-3">Before and after school care is available for Full Day programs at an additional cost.</p>
          <p class="text-sm text-blue-600">Extended care pricing varies by tuition tier and is shown in your program results above.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Tuition Reference Table -->
  <div class="bg-white rounded-lg shadow-lg p-6">
    <div class="mb-6">
      <h3 class="text-2xl font-bold text-earth-brown mb-4 text-center">
        2025-2026 Tuition Rates by Family Income
      </h3>
      <p class="text-center text-earth-brown mb-6">
        Select your family size to highlight the relevant income thresholds for your situation.
      </p>
      
      <!-- Family Size Selector Buttons -->
      <div class="flex flex-wrap justify-center gap-2 mb-6 p-4 bg-forest-canopy rounded-lg">
        <span class="text-white font-medium mr-4">Select Family Size to Highlight Your Column:</span>
        <button class="family-size-btn px-3 py-1 rounded bg-white/20 text-white hover:bg-white/30 transition-colors" data-size="2">2</button>
        <button class="family-size-btn px-3 py-1 rounded bg-white/20 text-white hover:bg-white/30 transition-colors" data-size="3">3</button>
        <button class="family-size-btn px-3 py-1 rounded bg-white/20 text-white hover:bg-white/30 transition-colors" data-size="4">4</button>
        <button class="family-size-btn px-3 py-1 rounded bg-white/20 text-white hover:bg-white/30 transition-colors" data-size="5">5</button>
        <button class="family-size-btn px-3 py-1 rounded bg-white/20 text-white hover:bg-white/30 transition-colors" data-size="6">6</button>
        <button class="family-size-btn px-3 py-1 rounded bg-white/20 text-white hover:bg-white/30 transition-colors" data-size="7">7</button>
        <button class="family-size-btn px-3 py-1 rounded bg-white/20 text-white hover:bg-white/30 transition-colors" data-size="8">8+</button>
        <button id="clear-highlight" class="px-3 py-1 rounded bg-red-500/80 text-white hover:bg-red-500 transition-colors">Clear</button>
      </div>
    </div>

    <!-- Responsive Table Container -->
    <div class="w-full overflow-x-auto -webkit-overflow-scrolling-touch rounded-lg border border-gray-200">
      <div class="min-w-full block">
        <table id="tuition-table" class="w-full min-w-[1000px] border-collapse bg-white text-sm">
          <thead>
            <tr class="bg-gradient-to-r from-forest-canopy to-moss-green">
              <th class="px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 text-white font-semibold border-b-2 border-forest-canopy min-w-[280px] max-w-[280px] text-left">
                <div class="flex flex-col items-center gap-1">
                  <strong>Rate & Price</strong>
                  <div class="text-xs opacity-90 font-normal">Program & Annual Cost</div>
                </div>
              </th>
              <th class="family-column px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 text-white font-semibold border-b-2 border-forest-canopy min-w-[120px] max-w-[120px]" data-family="2">
                <div class="flex flex-col items-center gap-1">
                  <strong>Family</strong>
                  <div class="text-xs opacity-90 font-normal">of 2</div>
                </div>
              </th>
              <th class="family-column px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 text-white font-semibold border-b-2 border-forest-canopy min-w-[120px] max-w-[120px]" data-family="3">
                <div class="flex flex-col items-center gap-1">
                  <strong>Family</strong>
                  <div class="text-xs opacity-90 font-normal">of 3</div>
                </div>
              </th>
              <th class="family-column px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 text-white font-semibold border-b-2 border-forest-canopy min-w-[120px] max-w-[120px]" data-family="4">
                <div class="flex flex-col items-center gap-1">
                  <strong>Family</strong>
                  <div class="text-xs opacity-90 font-normal">of 4</div>
                </div>
              </th>
              <th class="family-column px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 text-white font-semibold border-b-2 border-forest-canopy min-w-[120px] max-w-[120px]" data-family="5">
                <div class="flex flex-col items-center gap-1">
                  <strong>Family</strong>
                  <div class="text-xs opacity-90 font-normal">of 5</div>
                </div>
              </th>
              <th class="family-column px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 text-white font-semibold border-b-2 border-forest-canopy min-w-[120px] max-w-[120px]" data-family="6">
                <div class="flex flex-col items-center gap-1">
                  <strong>Family</strong>
                  <div class="text-xs opacity-90 font-normal">of 6</div>
                </div>
              </th>
              <th class="family-column px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 text-white font-semibold border-b-2 border-forest-canopy min-w-[120px] max-w-[120px]" data-family="7">
                <div class="flex flex-col items-center gap-1">
                  <strong>Family</strong>
                  <div class="text-xs opacity-90 font-normal">of 7</div>
                </div>
              </th>
              <th class="family-column px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 text-white font-semibold border-b-2 border-forest-canopy min-w-[120px] max-w-[120px]" data-family="8">
                <div class="flex flex-col items-center gap-1">
                  <strong>Family</strong>
                  <div class="text-xs opacity-90 font-normal">of 8+</div>
                </div>
              </th>
            </tr>
          </thead>
          <tbody id="tuition-table-body">
            <!-- Table rows will be populated by JavaScript -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-6 text-center text-sm text-gray-600">
      <p>* Income thresholds determine which tuition rate applies to your family.</p>
      <p>Rates may be adjusted annually. Contact us for the most current information.</p>
    </div>
  </div>
</div>

<style>
  /* Program card styles */
  .program-card {
    @apply bg-white rounded-lg shadow-lg p-6 transition-all duration-300 hover:shadow-xl;
  }
  
  .program-card.tuition-d {
    @apply border-2 border-green-500;
  }
  
  .program-header {
    @apply flex justify-between items-start mb-6;
  }
  
  .program-title {
    @apply text-xl font-bold text-earth-brown mb-2;
  }
  
  .program-description {
    @apply text-sm text-gray-600 mb-3;
  }
  
  .program-rate-badge {
    @apply inline-block px-3 py-1 bg-forest-canopy text-white text-xs font-semibold rounded-full;
  }
  
  .program-rate-badge.tuition-d {
    @apply bg-green-600;
  }
  
  .price-section {
    @apply text-right;
  }
  
  .program-price {
    @apply text-3xl font-bold text-earth-brown;
  }
  
  .program-price.tuition-d {
    @apply text-green-600;
  }
  
  .program-monthly {
    @apply text-sm text-gray-600 mt-1;
  }
  
  .savings-badge {
    @apply inline-block px-3 py-1 bg-green-100 text-green-800 text-xs font-semibold rounded-full mt-2;
  }
  
  .option-buttons {
    @apply grid grid-cols-2 gap-3 mb-4;
  }
  
  .option-btn {
    @apply px-4 py-3 border-2 border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:border-forest-canopy hover:bg-forest-canopy/5 transition-all text-center;
  }
  
  .option-btn.active {
    @apply border-forest-canopy bg-forest-canopy/10 text-forest-canopy;
  }
  
  .enroll-button {
    @apply block w-full bg-forest-canopy text-white py-3 px-4 rounded-lg font-semibold text-center hover:bg-moss-green transition-colors;
  }
  
  /* Table styles */
  .table-row {
    @apply border-b border-gray-200 hover:bg-gray-50 transition-colors;
  }
  
  .table-row:last-child {
    @apply border-b-0;
  }
  
  .rate-info {
    @apply text-left;
  }
  
  .rate-name {
    @apply font-semibold text-earth-brown;
  }
  
  .rate-program {
    @apply text-sm text-gray-600;
  }
  
  .rate-price {
    @apply text-sm font-bold text-forest-canopy mt-1;
  }
  
  .income-cell {
    @apply bg-white;
  }
  
  .income-amount {
    @apply font-medium text-earth-brown;
  }
  
  .threshold-symbol {
    @apply text-gray-500 mr-1;
  }
  
  /* Highlight styles */
  .highlighted {
    @apply bg-sunlight-gold/20 font-bold;
  }
  
  .family-size-btn.active {
    @apply bg-white text-forest-canopy;
  }
</style>

<script define:vars={{ tuitionData }}>
  // Use the data passed from server-side
  const { programs, rates, settings } = tuitionData;

  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('tuition-calculator-form');
    const familySizeSelect = document.getElementById('family-size');
    const resultsSection = document.getElementById('results-section');
    const tableBody = document.getElementById('tuition-table-body');
    const familySizeButtons = document.querySelectorAll('.family-size-btn');
    const clearButton = document.getElementById('clear-highlight');
    const programResults = document.getElementById('program-results');

    let preRenderedCards = new Map(); // Store pre-rendered cards by program-rate key

    // Pre-render all possible program cards
    function preRenderAllCards() {
      // Clear existing cards
      programResults.innerHTML = '';
      preRenderedCards.clear();
      
      // Group rates by program
      const ratesByProgram = {};
      rates.forEach(rate => {
        if (!ratesByProgram[rate.program_id]) {
          ratesByProgram[rate.program_id] = [];
        }
        ratesByProgram[rate.program_id].push(rate);
      });

      // Create cards for each program and its rates
      programs.forEach(program => {
        const programRates = ratesByProgram[program.id] || [];
        
        programRates.forEach(rate => {
          const cardKey = `${program.id}-${rate.id}`;
          
          // Create the card element with full styling
          const cardElement = createProgramCard(program, rate);
          
          // Store card data
          preRenderedCards.set(cardKey, {
            element: cardElement,
            program: program,
            rate: rate,
            baseTuition: rate.tuition_price,
            extendedCarePrice: rate.extended_care_price || 0,
            extendedCareAvailable: rate.extended_care_available
          });
          
          // Add to DOM (hidden by default)
          programResults.appendChild(cardElement);
        });
      });
    }

    // Create a complete program card element with full styling
    function createProgramCard(program, rate) {
      const isTuitionD = rate.rate_label === 'Tuition D';
      const baseTuition = rate.tuition_price;
      const extendedCarePrice = rate.extended_care_price || 0;
      
      // Calculate upfront discount price
      const upfrontDiscount = settings.upfront_discount_rate || 0.05;
      const baseUpfront = baseTuition * (1 - upfrontDiscount);
      const upfrontSavings = baseTuition - baseUpfront;

      // Create the card element
      const cardElement = document.createElement('div');
      
      // Apply all CSS classes immediately for proper styling
      cardElement.className = `program-card ${isTuitionD ? 'tuition-d' : ''} hidden`;
      
      // Add all the styling attributes and content
      cardElement.innerHTML = `
        <div class="program-header">
          <div>
            <h4 class="program-title">${program.name}</h4>
            <p class="program-description">${program.description}</p>
            <div class="program-rate-badge ${isTuitionD ? 'tuition-d' : ''}">${rate.rate_label}</div>
          </div>
          <div class="price-section">
            <div class="program-price ${isTuitionD ? 'tuition-d' : ''}" data-base-price="${baseTuition}">$${baseTuition.toLocaleString()}</div>
            <div class="program-monthly">$${(baseTuition / 10).toLocaleString()}/month</div>
            <div class="sibling-discount-badge hidden">
              <div class="savings-badge">Sibling Discount Applied!</div>
            </div>
          </div>
        </div>

        <div class="option-buttons">
          <button class="option-btn active" data-price="${baseTuition}" data-type="standard">
            📅 Standard Payment
          </button>
          <button class="option-btn" data-price="${baseUpfront}" data-type="upfront">
            💰 Pay Upfront<br><small>Save $${upfrontSavings.toLocaleString()}</small>
          </button>
          ${rate.extended_care_available ? `
            <button class="option-btn" data-price="${baseTuition + extendedCarePrice}" data-type="extended">
              ⏰ + Extended Care<br><small>+$${extendedCarePrice.toLocaleString()}</small>
            </button>
            <button class="option-btn" data-price="${(baseTuition + extendedCarePrice) * (1 - upfrontDiscount)}" data-type="extended-upfront">
              🎯 Extended + Upfront<br><small>Best Value</small>
            </button>
          ` : ''}
        </div>

        ${isTuitionD ? `
          <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <svg class="w-5 h-5 text-green-600 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h5 class="text-sm font-semibold text-green-800 mb-1">Your Final Rate May Be Lower</h5>
                <p class="text-xs text-green-700 leading-relaxed">
                  Families qualifying for Tuition D are encouraged to apply for additional financial assistance programs. 
                  Your actual tuition cost will likely be significantly reduced through these programs.
                </p>
              </div>
            </div>
          </div>
        ` : ''}

        <a href="/contact" class="enroll-button">
          🎓 Enroll in ${program.name}
        </a>
      `;
      
      // Add event listeners to the buttons
      const buttons = cardElement.querySelectorAll('.option-btn');
      buttons.forEach(button => {
        button.addEventListener('click', function() {
          const price = parseFloat(this.dataset.price);
          const type = this.dataset.type;
          updatePriceDisplay(cardElement, price, program.name, type);
          
          // Update button states
          buttons.forEach(btn => btn.classList.remove('active'));
          this.classList.add('active');
        });
      });
      
      return cardElement;
    }

    // Update price display for a specific card
    function updatePriceDisplay(cardElement, newPrice, programName, optionType) {
      const priceElement = cardElement.querySelector('.program-price');
      const monthlyElement = cardElement.querySelector('.program-monthly');
      
      priceElement.textContent = `$${newPrice.toLocaleString()}`;
      monthlyElement.textContent = `$${(newPrice / 10).toLocaleString()}/month`;
    }

    // Update card prices based on family size and sibling discounts
    function updateCardPrices(cardData, familyData) {
      const { element, baseTuition, extendedCarePrice } = cardData;
      const { childrenCount } = familyData;
      
      // Apply sibling discount
      let adjustedBaseTuition = baseTuition;
      let adjustedExtendedTuition = baseTuition + extendedCarePrice;
      
      if (childrenCount > 1) {
        const siblingDiscount = (childrenCount - 1) * (settings.sibling_discount_rate || 0.1);
        adjustedBaseTuition = adjustedBaseTuition * (1 - siblingDiscount);
        adjustedExtendedTuition = adjustedExtendedTuition * (1 - siblingDiscount);
      }
      
      // Calculate upfront prices
      const upfrontDiscount = settings.upfront_discount_rate || 0.05;
      const baseUpfront = adjustedBaseTuition * (1 - upfrontDiscount);
      const extendedUpfront = adjustedExtendedTuition * (1 - upfrontDiscount);
      const upfrontSavings = adjustedBaseTuition - baseUpfront;
      
      // Update price display
      const priceElement = element.querySelector('.program-price');
      const monthlyElement = element.querySelector('.program-monthly');
      const siblingBadge = element.querySelector('.sibling-discount-badge');
      
      priceElement.textContent = `$${adjustedBaseTuition.toLocaleString()}`;
      monthlyElement.textContent = `$${(adjustedBaseTuition / 10).toLocaleString()}/month`;
      
      if (childrenCount > 1) {
        siblingBadge.classList.remove('hidden');
      } else {
        siblingBadge.classList.add('hidden');
      }
      
      // Update button prices
      const buttons = element.querySelectorAll('.option-btn');
      
      if (buttons[0]) {
        buttons[0].dataset.price = adjustedBaseTuition;
      }
      if (buttons[1]) {
        buttons[1].dataset.price = baseUpfront;
        buttons[1].innerHTML = `💰 Pay Upfront<br><small>Save $${upfrontSavings.toLocaleString()}</small>`;
      }
      
      if (buttons[2]) { // Extended care button
        buttons[2].dataset.price = adjustedExtendedTuition;
        buttons[2].innerHTML = `⏰ + Extended Care<br><small>+$${extendedCarePrice.toLocaleString()}</small>`;
      }
      
      if (buttons[3]) { // Extended care + upfront button
        buttons[3].dataset.price = extendedUpfront;
      }
    }

    // Show relevant cards based on user input and hide others
    function showRelevantCards(programResults) {
      // Hide all cards first
      preRenderedCards.forEach((cardData) => {
        cardData.element.classList.add('hidden');
      });
      
      // Show and update relevant cards
      programResults.forEach(result => {
        const cardKey = `${result.program.id}-${result.rate.id}`;
        const cardData = preRenderedCards.get(cardKey);
        
        if (cardData) {
          cardData.element.classList.remove('hidden');
          updateCardPrices(cardData, {
            childrenCount: result.childrenCount || 1
          });
        }
      });
    }

    // Populate tuition table
    function populateTable() {
      tableBody.innerHTML = '';

      // Group rates by program
      const ratesByProgram = {};
      rates.forEach(rate => {
        if (!ratesByProgram[rate.program_id]) {
          ratesByProgram[rate.program_id] = [];
        }
        ratesByProgram[rate.program_id].push(rate);
      });

      // Create rows for each program and its rates
      programs.forEach(program => {
        const programRates = ratesByProgram[program.id] || [];
        
        programRates.forEach((rate, index) => {
          const row = document.createElement('tr');
          row.className = 'table-row';
          
          row.innerHTML = `
            <td class="px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 min-w-[280px] max-w-[280px] text-left">
              <div class="rate-info">
                <div class="rate-name">${rate.rate_label}</div>
                <div class="rate-program">${program.name}</div>
                <div class="rate-price">$${rate.tuition_price?.toLocaleString()}</div>
              </div>
            </td>
            ${generateIncomeColumns(rate)}
          `;

          tableBody.appendChild(row);
        });
      });
    }

    // Generate income threshold columns
    function generateIncomeColumns(rate) {
      const familySizes = [2, 3, 4, 5, 6, 7, 8];
      let columns = '';

      familySizes.forEach(size => {
        const fieldName = size === 8 ? 'income_threshold_family_8_plus' : `income_threshold_family_${size}`;
        const threshold = rate[fieldName];
        
        let content = '';
        if (rate.is_constant_rate || !threshold) {
          content = '<div class="income-amount">All Families</div>';
        } else {
          const symbol = rate.income_threshold_type === 'Less Than' ? '<' : '≥';
          content = `
            <div class="income-amount">
              <span class="threshold-symbol">${symbol}</span>
              $${threshold.toLocaleString()}
            </div>
          `;
        }

        columns += `
          <td class="family-column income-cell px-4 py-5 text-center align-middle whitespace-nowrap border-r border-gray-200 last:border-r-0 min-w-[120px] max-w-[120px]" data-family="${size === 8 ? '8' : size}">
            ${content}
          </td>
        `;
      });

      return columns;
    }

    // Family size highlighting
    familySizeButtons.forEach(button => {
      button.addEventListener('click', function() {
        const selectedSize = this.dataset.size;
        highlightFamilySize(selectedSize);
      });
    });

    clearButton.addEventListener('click', function() {
      clearHighlights();
    });

    function highlightFamilySize(size) {
      // Clear previous highlights
      clearHighlights();

      // Highlight header column
      const headerColumns = document.querySelectorAll('.family-column');
      headerColumns.forEach(col => {
        if (col.dataset.family === size) {
          col.classList.add('highlighted');
        }
      });

      // Highlight table cells in that column
      const tableCells = document.querySelectorAll(`td[data-family="${size}"]`);
      tableCells.forEach(cell => {
        cell.classList.add('highlighted');
      });

      // Update button state
      familySizeButtons.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.size === size);
      });

      // Update form selection if not already set
      if (familySizeSelect.value !== size) {
        const mappedValue = size === '8' ? '8' : size;
        familySizeSelect.value = mappedValue;
      }
    }

    function clearHighlights() {
      document.querySelectorAll('.highlighted').forEach(el => {
        el.classList.remove('highlighted');
      });
      familySizeButtons.forEach(btn => {
        btn.classList.remove('active');
      });
    }

    // Form submission
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      calculateTuition();
    });

    // Auto-highlight when family size is selected in form
    familySizeSelect.addEventListener('change', function() {
      if (this.value) {
        const size = this.value === '8' ? '8' : this.value;
        highlightFamilySize(size);
      }
    });

    function calculateTuition() {
      const familySize = parseInt(familySizeSelect.value);
      const annualIncome = parseFloat(document.getElementById('annual-income').value);
      const childrenCount = parseInt(document.getElementById('children-count').value);

      if (!familySize || !annualIncome) {
        alert('Please fill in all required fields.');
        return;
      }

      // Calculate tuition for all programs
      const programResults = [];
      let qualifiesForTuitionD = false;

      programs.forEach(program => {
        const programRates = rates.filter(r => r.program_id === program.id);
        let applicableRate = null;

        // Find the appropriate rate based on income and family size
        for (const rate of programRates) {
          if (rate.is_constant_rate) {
            applicableRate = rate;
            continue;
          }

          const thresholdField = familySize >= 8 ? 'income_threshold_family_8_plus' : `income_threshold_family_${familySize}`;
          const threshold = rate[thresholdField];

          if (threshold) {
            if (rate.income_threshold_type === 'Less Than' && annualIncome < threshold) {
              applicableRate = rate;
              // Check if this is Tuition D (highest assistance)
              if (rate.rate_label === 'Tuition D') {
                qualifiesForTuitionD = true;
              }
              break;
            } else if (rate.income_threshold_type === 'Greater Than or Equal To' && annualIncome >= threshold) {
              applicableRate = rate;
              break;
            }
          }
        }

        if (applicableRate) {
          programResults.push({
            program,
            rate: applicableRate,
            baseTuition: applicableRate.tuition_price,
            extendedCarePrice: applicableRate.extended_care_price || 0,
            extendedCareAvailable: applicableRate.extended_care_available,
            childrenCount: childrenCount
          });
        }
      });

      // Display results
      displayResults({
        familySize,
        annualIncome,
        childrenCount,
        programResults,
        qualifiesForTuitionD
      });
    }

    function displayResults(data) {
      const familyProfile = document.getElementById('family-profile');
      const tuitionDNotice = document.getElementById('tuition-d-notice');
      
      // Display family profile
      familyProfile.innerHTML = `
        <div class="text-center">
          <h4 class="text-xl font-bold text-earth-brown mb-2">Your Family Profile</h4>
          <div class="flex flex-wrap justify-center gap-6 text-sm">
            <div><strong>Family Size:</strong> ${data.familySize} people</div>
            <div><strong>Annual Income:</strong> $${data.annualIncome.toLocaleString()}</div>
            <div><strong>Children Attending:</strong> ${data.childrenCount}</div>
          </div>
        </div>
      `;

      // Show Tuition D notice if applicable
      if (data.qualifiesForTuitionD) {
        tuitionDNotice.classList.remove('hidden');
      } else {
        tuitionDNotice.classList.add('hidden');
      }

      // Show relevant pre-rendered cards
      showRelevantCards(data.programResults);

      resultsSection.classList.remove('hidden');
    }

    function showErrorMessage(message) {
      const errorDiv = document.createElement('div');
      errorDiv.className = 'bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-4';
      errorDiv.textContent = message;
      
      const form = document.getElementById('tuition-calculator-form');
      form.parentNode.insertBefore(errorDiv, form);
      
      setTimeout(() => {
        errorDiv.remove();
      }, 5000);
    }

    // Initialize
    // Initialize tuition calculator
    
    populateTable();
    preRenderAllCards();
  });
</script>