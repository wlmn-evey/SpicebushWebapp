---
// Donation amount options component
---

<div class="donation-options">
  <h3 class="text-lg font-semibold text-earth-brown mb-4">Choose Your Gift Amount</h3>
  
  <!-- Donation Type Toggle -->
  <div class="flex justify-center mb-6">
    <div class="bg-gray-100 p-1 rounded-lg inline-flex">
      <button 
        type="button"
        class="donation-type-btn px-6 py-2 rounded-md text-sm font-medium transition-colors active"
        data-type="one-time"
      >
        One-Time
      </button>
      <button 
        type="button"
        class="donation-type-btn px-6 py-2 rounded-md text-sm font-medium transition-colors"
        data-type="monthly"
      >
        Monthly
      </button>
    </div>
  </div>

  <!-- Preset Amounts -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    <button 
      type="button"
      class="amount-btn bg-white border-2 border-gray-300 rounded-lg py-4 px-4 text-center hover:border-forest-canopy hover:bg-forest-canopy/5 transition-all focus:outline-none focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2"
      data-amount="25"
    >
      <span class="text-2xl font-bold text-earth-brown">$25</span>
      <span class="block text-xs text-gray-600 mt-1 monthly-text hidden">per month</span>
    </button>
    
    <button 
      type="button"
      class="amount-btn bg-white border-2 border-gray-300 rounded-lg py-4 px-4 text-center hover:border-forest-canopy hover:bg-forest-canopy/5 transition-all focus:outline-none focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2"
      data-amount="50"
    >
      <span class="text-2xl font-bold text-earth-brown">$50</span>
      <span class="block text-xs text-gray-600 mt-1 monthly-text hidden">per month</span>
    </button>
    
    <button 
      type="button"
      class="amount-btn bg-white border-2 border-gray-300 rounded-lg py-4 px-4 text-center hover:border-forest-canopy hover:bg-forest-canopy/5 transition-all focus:outline-none focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 selected"
      data-amount="100"
    >
      <span class="text-2xl font-bold text-earth-brown">$100</span>
      <span class="block text-xs text-gray-600 mt-1 monthly-text hidden">per month</span>
    </button>
    
    <button 
      type="button"
      class="amount-btn bg-white border-2 border-gray-300 rounded-lg py-4 px-4 text-center hover:border-forest-canopy hover:bg-forest-canopy/5 transition-all focus:outline-none focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2"
      data-amount="250"
    >
      <span class="text-2xl font-bold text-earth-brown">$250</span>
      <span class="block text-xs text-gray-600 mt-1 monthly-text hidden">per month</span>
    </button>
  </div>

  <!-- Custom Amount -->
  <div class="mb-6">
    <label for="custom-amount" class="block text-sm font-medium text-gray-700 mb-2">
      Or enter a custom amount
    </label>
    <div class="relative">
      <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-500">$</span>
      <input 
        type="number" 
        id="custom-amount"
        name="customAmount"
        min="1"
        step="1"
        placeholder="0"
        class="w-full pl-8 pr-3 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-forest-canopy focus:border-forest-canopy"
      />
    </div>
  </div>

  <!-- Impact Messages -->
  <div class="bg-sunlight-gold/10 p-4 rounded-lg mb-6">
    <p class="text-sm text-earth-brown impact-message" data-range="25-49">
      <strong>$25-49:</strong> Provides art supplies for one child for a month
    </p>
    <p class="text-sm text-earth-brown impact-message hidden" data-range="50-99">
      <strong>$50-99:</strong> Supports our garden program with seeds and tools
    </p>
    <p class="text-sm text-earth-brown impact-message hidden" data-range="100-249">
      <strong>$100-249:</strong> Funds Montessori learning materials for a classroom
    </p>
    <p class="text-sm text-earth-brown impact-message hidden" data-range="250+">
      <strong>$250+:</strong> Provides tuition assistance for a family in need
    </p>
  </div>
</div>

<style>
  .amount-btn.selected {
    @apply border-forest-canopy bg-forest-canopy text-white;
  }
  
  .amount-btn.selected span {
    @apply text-white;
  }
  
  .donation-type-btn.active {
    @apply bg-white shadow-sm;
  }
</style>

<script>
  // Handle donation type toggle
  const typeButtons = document.querySelectorAll('.donation-type-btn');
  const monthlyTexts = document.querySelectorAll('.monthly-text');
  
  typeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      typeButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const isMonthly = btn.dataset.type === 'monthly';
      monthlyTexts.forEach(text => {
        text.classList.toggle('hidden', !isMonthly);
      });
      
      // Update form data
      const event = new CustomEvent('donation-type-change', {
        detail: { type: btn.dataset.type }
      });
      document.dispatchEvent(event);
    });
  });
  
  // Handle amount selection
  const amountButtons = document.querySelectorAll('.amount-btn');
  const customAmountInput = document.getElementById('custom-amount') as HTMLInputElement;
  
  amountButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      amountButtons.forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      customAmountInput.value = '';
      
      const amount = parseInt(btn.dataset.amount || '0');
      updateImpactMessage(amount);
      
      // Update form data
      const event = new CustomEvent('donation-amount-change', {
        detail: { amount }
      });
      document.dispatchEvent(event);
    });
  });
  
  // Handle custom amount
  customAmountInput.addEventListener('input', () => {
    const amount = parseInt(customAmountInput.value) || 0;
    if (amount > 0) {
      amountButtons.forEach(b => b.classList.remove('selected'));
      updateImpactMessage(amount);
      
      // Update form data
      const event = new CustomEvent('donation-amount-change', {
        detail: { amount }
      });
      document.dispatchEvent(event);
    }
  });
  
  // Update impact message based on amount
  function updateImpactMessage(amount: number) {
    const messages = document.querySelectorAll('.impact-message');
    messages.forEach(msg => msg.classList.add('hidden'));
    
    let range = '25-49';
    if (amount >= 250) range = '250+';
    else if (amount >= 100) range = '100-249';
    else if (amount >= 50) range = '50-99';
    
    const activeMessage = document.querySelector(`.impact-message[data-range="${range}"]`);
    if (activeMessage) {
      activeMessage.classList.remove('hidden');
    }
  }
  
  // Initialize with default amount
  updateImpactMessage(100);
</script>