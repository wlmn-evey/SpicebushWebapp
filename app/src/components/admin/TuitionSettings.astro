---
import { Save } from 'lucide-astro';
---

<!-- Settings Management Section -->
<div id="settings-section" class="bg-white border border-gray-200 rounded-lg p-6">
  <div class="flex items-center mb-6">
    <Save className="w-6 h-6 text-sunlight-gold mr-3" />
    <h2 class="text-2xl font-bold text-earth-brown">Calculator Settings</h2>
  </div>
  
  <form id="settings-form" class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label class="block text-sm font-medium text-earth-brown mb-2">Current School Year</label>
      <input type="text" id="school-year" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sunlight-gold focus:border-transparent" placeholder="2025-2026" />
    </div>
    
    <div>
      <label class="block text-sm font-medium text-earth-brown mb-2">Upfront Discount Rate (%)</label>
      <input type="number" id="upfront-discount" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sunlight-gold focus:border-transparent" step="0.01" min="0" max="100" />
    </div>
    
    <div>
      <label class="block text-sm font-medium text-earth-brown mb-2">Sibling Discount Rate (%)</label>
      <input type="number" id="sibling-discount" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sunlight-gold focus:border-transparent" step="0.01" min="0" max="100" />
    </div>
    
    <div>
      <label class="block text-sm font-medium text-earth-brown mb-2">Annual Increase Rate (%)</label>
      <input type="number" id="annual-increase" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sunlight-gold focus:border-transparent" step="0.01" min="0" max="100" />
    </div>
    
    <div class="md:col-span-2">
      <button type="submit" class="bg-sunlight-gold hover:bg-orange-600 text-white px-6 py-3 rounded-lg font-semibold transition-colors">
        Save Settings
      </button>
    </div>
  </form>
</div>