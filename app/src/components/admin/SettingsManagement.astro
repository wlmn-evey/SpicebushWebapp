---
/**
 * Settings Management Component
 * Simple interface for managing site settings
 */
import FormField from '@components/forms/FormField.astro';
import TextInput from '@components/forms/TextInput.astro';
import TextArea from '@components/forms/TextArea.astro';
import ToggleSwitch from '@components/forms/ToggleSwitch.astro';
import { supabase } from '@lib/supabase';

// Load current settings
const { data: settingsData } = await supabase
  .from('settings')
  .select('key, value')
  .order('key');

// Convert to object
const settings: Record<string, any> = {};
settingsData?.forEach(row => {
  settings[row.key] = row.value;
});

// Set defaults for any missing settings
const defaultSettings = {
  coming_soon_enabled: false,
  coming_soon_launch_date: '2025-02-01',
  coming_soon_message: "We're preparing something special for you. Our new website will launch soon with exciting features and resources for families interested in Montessori education.",
  coming_soon_newsletter: true,
  current_school_year: '2025-2026',
  sibling_discount_rate: '0.10',
  upfront_discount_rate: '0.05',
  annual_increase_rate: '0.04',
  site_message: ''
};

// Merge defaults with actual settings
const finalSettings = { ...defaultSettings, ...settings };
---

<div class="settings-management">
  <form id="settings-form" class="space-y-8">
    
    <!-- Coming Soon Section -->
    <div class="settings-section">
      <h3 class="settings-section__title">Coming Soon Mode</h3>
      <p class="settings-section__description">
        Control maintenance mode and launch messaging for your website.
      </p>
      
      <div class="grid md:grid-cols-2 gap-6">
        <FormField
          label="Enable Coming Soon Mode"
          name="coming_soon_enabled"
          help="Show maintenance page to visitors (admins can still access)"
        >
          <ToggleSwitch
            name="coming_soon_enabled"
            checked={finalSettings.coming_soon_enabled === true || finalSettings.coming_soon_enabled === 'true'}
          />
        </FormField>
        
        <FormField
          label="Launch Date"
          name="coming_soon_launch_date"
          help="Expected launch date to display to visitors"
        >
          <TextInput
            name="coming_soon_launch_date"
            type="date"
            value={finalSettings.coming_soon_launch_date}
          />
        </FormField>
      </div>
      
      <FormField
        label="Coming Soon Message"
        name="coming_soon_message"
        help="Message displayed to visitors during maintenance"
      >
        <TextArea
          name="coming_soon_message"
          rows={3}
          value={finalSettings.coming_soon_message}
          placeholder="Explain what visitors can expect..."
        />
      </FormField>
      
      <FormField
        label="Show Newsletter Signup"
        name="coming_soon_newsletter"
        help="Allow visitors to subscribe for launch updates"
      >
        <ToggleSwitch
          name="coming_soon_newsletter"
          checked={finalSettings.coming_soon_newsletter === true || finalSettings.coming_soon_newsletter === 'true'}
        />
      </FormField>
    </div>

    <!-- Academic Settings Section -->
    <div class="settings-section">
      <h3 class="settings-section__title">Academic Settings</h3>
      <p class="settings-section__description">
        Configure school year and academic information.
      </p>
      
      <FormField
        label="Current School Year"
        name="current_school_year"
        help="Academic year for enrollment and tuition calculations"
      >
        <TextInput
          name="current_school_year"
          value={finalSettings.current_school_year}
          placeholder="2025-2026"
          pattern="^\d{4}-\d{4}$"
        />
      </FormField>
    </div>

    <!-- Financial Settings Section -->
    <div class="settings-section">
      <h3 class="settings-section__title">Tuition & Financial Settings</h3>
      <p class="settings-section__description">
        Manage discount rates and financial policies.
      </p>
      
      <div class="grid md:grid-cols-3 gap-6">
        <FormField
          label="Sibling Discount Rate"
          name="sibling_discount_rate"
          help="Discount for families with multiple children (0.10 = 10%)"
        >
          <TextInput
            name="sibling_discount_rate"
            type="number"
            step="0.01"
            min="0"
            max="1"
            value={finalSettings.sibling_discount_rate}
            placeholder="0.10"
          />
        </FormField>
        
        <FormField
          label="Upfront Payment Discount"
          name="upfront_discount_rate"
          help="Discount for paying full year upfront (0.05 = 5%)"
        >
          <TextInput
            name="upfront_discount_rate"
            type="number"
            step="0.01"
            min="0"
            max="1"
            value={finalSettings.upfront_discount_rate}
            placeholder="0.05"
          />
        </FormField>
        
        <FormField
          label="Annual Increase Rate"
          name="annual_increase_rate"
          help="Yearly tuition increase rate (0.04 = 4%)"
        >
          <TextInput
            name="annual_increase_rate"
            type="number"
            step="0.01"
            min="0"
            max="1"
            value={finalSettings.annual_increase_rate}
            placeholder="0.04"
          />
        </FormField>
      </div>
    </div>

    <!-- Site Communications Section -->
    <div class="settings-section">
      <h3 class="settings-section__title">Site Communications</h3>
      <p class="settings-section__description">
        Manage site-wide messages and announcements.
      </p>
      
      <FormField
        label="Site Message"
        name="site_message"
        help="Optional message to display site-wide (leave blank to hide)"
      >
        <TextArea
          name="site_message"
          rows={2}
          value={finalSettings.site_message}
          placeholder="Important announcement for families..."
        />
      </FormField>
    </div>

    <!-- Actions -->
    <div class="settings-actions">
      <button 
        type="submit" 
        class="btn btn--primary"
        disabled
      >
        <span class="btn-text">Save Changes</span>
        <span class="btn-loading hidden">Saving...</span>
      </button>
      
      <button 
        type="button" 
        id="reset-button"
        class="btn btn--secondary"
      >
        Reset Form
      </button>
    </div>
    
    <!-- Status Messages -->
    <div id="status-message" class="hidden"></div>
  </form>
</div>

<style>
  .settings-management {
    @apply max-w-4xl;
  }
  
  .settings-section {
    @apply bg-white rounded-lg shadow-sm border border-gray-200 p-6;
  }
  
  .settings-section__title {
    @apply text-lg font-semibold text-gray-900 mb-2;
  }
  
  .settings-section__description {
    @apply text-sm text-gray-600 mb-6;
  }
  
  .settings-actions {
    @apply flex gap-4 pt-6 border-t border-gray-200;
  }
  
  .btn {
    @apply px-6 py-2 rounded-md font-medium transition-colors duration-200;
    @apply focus:outline-none focus:ring-2 focus:ring-offset-2;
  }
  
  .btn--primary {
    @apply bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500;
  }
  
  .btn--primary:disabled {
    @apply bg-gray-400 cursor-not-allowed;
  }
  
  .btn--secondary {
    @apply bg-gray-100 text-gray-700 hover:bg-gray-200 focus:ring-gray-500;
  }
  
  .status-success {
    @apply bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg;
  }
  
  .status-error {
    @apply bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg;
  }
</style>

<script>
  class SettingsManager {
    private form: HTMLFormElement;
    private saveButton: HTMLButtonElement;
    private resetButton: HTMLButtonElement;
    private statusMessage: HTMLElement;
    private originalData: FormData;
    
    constructor() {
      this.form = document.getElementById('settings-form') as HTMLFormElement;
      this.saveButton = this.form.querySelector('button[type="submit"]') as HTMLButtonElement;
      this.resetButton = document.getElementById('reset-button') as HTMLButtonElement;
      this.statusMessage = document.getElementById('status-message') as HTMLElement;
      
      this.originalData = new FormData(this.form);
      this.init();
    }
    
    private init() {
      // Enable save button when form changes
      this.form.addEventListener('input', () => {
        this.saveButton.disabled = false;
      });
      
      // Handle form submission
      this.form.addEventListener('submit', (e) => {
        e.preventDefault();
        this.saveSettings();
      });
      
      // Handle reset
      this.resetButton.addEventListener('click', () => {
        this.resetForm();
      });
    }
    
    private async saveSettings() {
      const formData = new FormData(this.form);
      const updates: Record<string, any> = {};
      
      // Convert FormData to object, handling checkboxes properly
      for (const [key, value] of formData.entries()) {
        updates[key] = value;
      }
      
      // Handle unchecked checkboxes (they don't appear in FormData)
      const toggles = this.form.querySelectorAll('input[type="checkbox"]');
      toggles.forEach((toggle: HTMLInputElement) => {
        if (!formData.has(toggle.name)) {
          updates[toggle.name] = false;
        } else {
          updates[toggle.name] = true;
        }
      });
      
      try {
        this.setLoading(true);
        
        const response = await fetch('/api/admin/settings', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(updates)
        });
        
        const result = await response.json();
        
        if (result.success) {
          this.showMessage(result.message, 'success');
          this.originalData = new FormData(this.form);
          this.saveButton.disabled = true;
        } else {
          this.showMessage(result.message || 'Failed to save settings', 'error');
        }
        
      } catch (error) {
        console.error('Settings save error:', error);
        this.showMessage('Network error. Please try again.', 'error');
      } finally {
        this.setLoading(false);
      }
    }
    
    private resetForm() {
      // Reset to original values
      for (const [key, value] of this.originalData.entries()) {
        const field = this.form.querySelector(`[name="${key}"]`) as HTMLInputElement;
        if (field) {
          if (field.type === 'checkbox') {
            field.checked = value === 'true';
          } else {
            field.value = value as string;
          }
        }
      }
      
      this.saveButton.disabled = true;
      this.hideMessage();
    }
    
    private setLoading(loading: boolean) {
      const btnText = this.saveButton.querySelector('.btn-text') as HTMLElement;
      const btnLoading = this.saveButton.querySelector('.btn-loading') as HTMLElement;
      
      if (loading) {
        btnText.classList.add('hidden');
        btnLoading.classList.remove('hidden');
        this.saveButton.disabled = true;
      } else {
        btnText.classList.remove('hidden');
        btnLoading.classList.add('hidden');
      }
    }
    
    private showMessage(message: string, type: 'success' | 'error') {
      this.statusMessage.textContent = message;
      this.statusMessage.className = `status-${type}`;
      this.statusMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      
      // Auto-hide success messages after 5 seconds
      if (type === 'success') {
        setTimeout(() => this.hideMessage(), 5000);
      }
    }
    
    private hideMessage() {
      this.statusMessage.classList.add('hidden');
      this.statusMessage.className = 'hidden';
    }
  }
  
  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    new SettingsManager();
  });
</script>