---
import { DollarSign, Plus } from 'lucide-astro';
---

<!-- Tuition Rates Management Section -->
<div id="rates-section" class="bg-white border border-gray-200 rounded-lg p-6 mb-8">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center">
      <DollarSign className="w-6 h-6 text-forest-canopy mr-3" />
      <h2 class="text-2xl font-bold text-earth-brown">Tuition Rates Management</h2>
    </div>
    <button id="add-rate-btn" class="bg-forest-canopy hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center">
      <Plus className="w-4 h-4 mr-2" />
      Add Rate
    </button>
  </div>
  
  <div class="overflow-x-auto">
    <table id="rates-table" class="min-w-full divide-y divide-gray-200">
      <thead class="bg-stone-beige">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-earth-brown uppercase tracking-wider">Rate Label</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-earth-brown uppercase tracking-wider">Program</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-earth-brown uppercase tracking-wider">Price</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-earth-brown uppercase tracking-wider">Family 4 Threshold</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-earth-brown uppercase tracking-wider">Extended Care</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-earth-brown uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody id="rates-table-body" class="bg-white divide-y divide-gray-200">
        <!-- Rates will be loaded here -->
      </tbody>
    </table>
  </div>
</div>