---
/**
 * TextArea Component
 * 
 * A multi-line text input component with auto-resize capability and
 * character count display. Provides consistent styling and accessibility.
 * 
 * @prop {string} name - The textarea name attribute
 * @prop {string} value - The current value
 * @prop {number} rows - Initial number of visible rows
 * @prop {string} placeholder - Placeholder text
 * @prop {boolean} required - Whether the field is required
 * @prop {boolean} disabled - Whether the field is disabled
 * @prop {boolean} readonly - Whether the field is readonly
 * @prop {number} maxLength - Maximum character length
 * @prop {boolean} autoResize - Whether to auto-resize based on content
 * @prop {boolean} showCount - Whether to show character count
 * @prop {string} className - Additional CSS classes
 * @prop {string} fieldId - ID for the textarea (usually provided by FormField)
 * @prop {string} ariaDescribedBy - IDs of elements that describe this textarea
 */
export interface Props {
  name: string;
  value?: string;
  rows?: number;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  maxLength?: number;
  autoResize?: boolean;
  showCount?: boolean;
  className?: string;
  fieldId?: string;
  ariaDescribedBy?: string;
}

const {
  name,
  value = '',
  rows = 4,
  placeholder,
  required = false,
  disabled = false,
  readonly = false,
  maxLength,
  autoResize = false,
  showCount = false,
  className = '',
  fieldId,
  ariaDescribedBy
} = Astro.props;

const textareaId = fieldId || `field-${name}`;
const countId = showCount ? `${textareaId}-count` : undefined;
const ariaDescribedByIds = [ariaDescribedBy, countId].filter(Boolean).join(' ');
---

<div class="textarea-wrapper">
  <textarea
    id={textareaId}
    name={name}
    rows={rows}
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    readonly={readonly}
    maxlength={maxLength}
    aria-describedby={ariaDescribedByIds || undefined}
    class={`textarea-input ${autoResize ? 'textarea-input--auto-resize' : ''} ${className}`}
    data-auto-resize={autoResize}
  >{value}</textarea>
  
  {showCount && maxLength && (
    <div id={countId} class="textarea-count" aria-live="polite">
      <span data-count>{value.length}</span> / {maxLength}
    </div>
  )}
</div>

<script>
  // Auto-resize functionality
  const autoResizeTextareas = document.querySelectorAll('[data-auto-resize="true"]');
  
  autoResizeTextareas.forEach((textarea) => {
    const resize = () => {
      textarea.style.height = 'auto';
      textarea.style.height = `${textarea.scrollHeight  }px`;
    };
    
    // Initial resize
    resize();
    
    // Resize on input
    textarea.addEventListener('input', resize);
  });
  
  // Character count functionality
  const textareasWithCount = document.querySelectorAll('.textarea-wrapper:has(.textarea-count) textarea');
  
  textareasWithCount.forEach((textarea) => {
    const wrapper = textarea.closest('.textarea-wrapper');
    const countSpan = wrapper.querySelector('[data-count]');
    
    textarea.addEventListener('input', () => {
      countSpan.textContent = textarea.value.length;
      
      // Add warning class when approaching limit
      const maxLength = parseInt(textarea.getAttribute('maxlength'));
      if (maxLength && textarea.value.length > maxLength * 0.9) {
        wrapper.querySelector('.textarea-count').classList.add('textarea-count--warning');
      } else {
        wrapper.querySelector('.textarea-count').classList.remove('textarea-count--warning');
      }
    });
  });
</script>

<style>
  .textarea-wrapper {
    @apply relative;
  }
  
  .textarea-input {
    @apply block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm;
    @apply text-gray-900 placeholder-gray-400;
    @apply focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500;
    @apply disabled:bg-gray-50 disabled:text-gray-500 disabled:cursor-not-allowed;
    @apply read-only:bg-gray-50 read-only:cursor-not-allowed;
    @apply transition-colors duration-200;
    @apply resize-y min-h-[100px];
  }
  
  .textarea-input--auto-resize {
    @apply resize-none overflow-hidden;
  }
  
  /* Invalid state (HTML5 validation) */
  .textarea-input:invalid:not(:placeholder-shown) {
    @apply border-red-300 focus:border-red-500 focus:ring-red-500;
  }
  
  .textarea-count {
    @apply absolute bottom-2 right-2 text-xs text-gray-400;
    @apply pointer-events-none;
  }
  
  .textarea-count--warning {
    @apply text-orange-500 font-medium;
  }
  
  /* Adjust padding to make room for count */
  .textarea-wrapper:has(.textarea-count) .textarea-input {
    @apply pb-6;
  }
</style>