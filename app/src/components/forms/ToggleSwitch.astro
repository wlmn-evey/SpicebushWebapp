---
/**
 * ToggleSwitch Component
 * 
 * A boolean toggle switch component with accessible keyboard navigation
 * and screen reader support. Provides a modern alternative to checkboxes
 * for on/off states.
 * 
 * @prop {string} name - The input name attribute
 * @prop {boolean} checked - Whether the toggle is on
 * @prop {string} label - Label text displayed next to the toggle
 * @prop {string} helpText - Optional help text displayed below
 * @prop {boolean} disabled - Whether the toggle is disabled
 * @prop {string} className - Additional CSS classes
 * @prop {string} fieldId - ID for the input
 */
export interface Props {
  name: string;
  checked?: boolean;
  label: string;
  helpText?: string;
  disabled?: boolean;
  className?: string;
  fieldId?: string;
}

const {
  name,
  checked = false,
  label,
  helpText,
  disabled = false,
  className = '',
  fieldId
} = Astro.props;

const toggleId = fieldId || `toggle-${name}`;
const helpId = helpText ? `${toggleId}-help` : undefined;
---

<div class={`toggle-container ${className}`}>
  <div class="toggle-wrapper">
    <input
      type="checkbox"
      id={toggleId}
      name={name}
      checked={checked}
      disabled={disabled}
      aria-describedby={helpId}
      class="toggle-input"
      role="switch"
      aria-checked={checked}
    />
    <label for={toggleId} class="toggle-label">
      <span class="toggle-switch" aria-hidden="true">
        <span class="toggle-switch-handle"></span>
      </span>
      <span class="toggle-text">{label}</span>
    </label>
  </div>
  
  {helpText && (
    <p id={helpId} class="toggle-help">
      {helpText}
    </p>
  )}
</div>

<script>
  // Update aria-checked when toggle state changes
  const toggleInputs = document.querySelectorAll('.toggle-input');
  
  toggleInputs.forEach((toggle) => {
    toggle.addEventListener('change', () => {
      toggle.setAttribute('aria-checked', toggle.checked.toString());
    });
  });
</script>

<style>
  .toggle-container {
    @apply space-y-1;
  }
  
  .toggle-wrapper {
    @apply flex items-center;
  }
  
  /* Hide the actual checkbox */
  .toggle-input {
    @apply sr-only;
  }
  
  .toggle-label {
    @apply flex items-center cursor-pointer select-none;
  }
  
  .toggle-switch {
    @apply relative inline-block w-10 h-6 mr-3;
    @apply bg-gray-300 rounded-full;
    @apply transition-colors duration-200 ease-in-out;
  }
  
  .toggle-switch-handle {
    @apply absolute top-0.5 left-0.5;
    @apply w-5 h-5 bg-white rounded-full shadow;
    @apply transition-transform duration-200 ease-in-out;
    @apply transform translate-x-0;
  }
  
  .toggle-text {
    @apply text-sm font-medium text-gray-700;
  }
  
  .toggle-help {
    @apply ml-3 text-sm text-gray-500;
  }
  
  /* Checked state */
  .toggle-input:checked ~ .toggle-label .toggle-switch {
    @apply bg-blue-600;
  }
  
  .toggle-input:checked ~ .toggle-label .toggle-switch-handle {
    @apply translate-x-4;
  }
  
  /* Focus state */
  .toggle-input:focus ~ .toggle-label .toggle-switch {
    @apply ring-2 ring-offset-2 ring-blue-500;
  }
  
  /* Disabled state */
  .toggle-input:disabled ~ .toggle-label {
    @apply cursor-not-allowed;
  }
  
  .toggle-input:disabled ~ .toggle-label .toggle-switch {
    @apply bg-gray-200;
  }
  
  .toggle-input:disabled ~ .toggle-label .toggle-text {
    @apply text-gray-400;
  }
  
  .toggle-input:disabled:checked ~ .toggle-label .toggle-switch {
    @apply bg-blue-300;
  }
  
  /* Hover state (when not disabled) */
  .toggle-input:not(:disabled) ~ .toggle-label:hover .toggle-switch {
    @apply bg-gray-400;
  }
  
  .toggle-input:checked:not(:disabled) ~ .toggle-label:hover .toggle-switch {
    @apply bg-blue-700;
  }
</style>