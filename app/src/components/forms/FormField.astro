---
/**
 * FormField Component
 * 
 * A reusable wrapper component that provides consistent layout for form fields,
 * including labels, help text, error messages, and required indicators.
 * 
 * @prop {string} label - The label text for the field
 * @prop {string} name - The field name (used for id generation)
 * @prop {boolean} required - Whether the field is required
 * @prop {string} help - Optional help text displayed below the field
 * @prop {string} error - Optional error message to display
 * @prop {string} className - Additional CSS classes for the wrapper
 */
export interface Props {
  label: string;
  name: string;
  required?: boolean;
  help?: string;
  error?: string;
  className?: string;
}

const { label, name, required = false, help, error, className = '' } = Astro.props;
const fieldId = `field-${name}`;
const helpId = help ? `${fieldId}-help` : undefined;
const errorId = error ? `${fieldId}-error` : undefined;
---

<div class={`form-field ${error ? 'form-field--error' : ''} ${className}`}>
  <label for={fieldId} class="form-field__label">
    {label}
    {required && <span class="form-field__required" aria-label="required">*</span>}
  </label>
  
  <div class="form-field__input-wrapper">
    <slot />
  </div>
  
  {help && !error && (
    <p id={helpId} class="form-field__help">
      {help}
    </p>
  )}
  
  {error && (
    <p id={errorId} class="form-field__error" role="alert">
      {error}
    </p>
  )}
</div>

<style>
  .form-field {
    @apply mb-6;
  }
  
  .form-field__label {
    @apply block text-sm font-medium text-gray-700 mb-2;
  }
  
  .form-field__required {
    @apply text-red-500 ml-1;
  }
  
  .form-field__input-wrapper {
    @apply relative;
  }
  
  .form-field__help {
    @apply mt-2 text-sm text-gray-500;
  }
  
  .form-field__error {
    @apply mt-2 text-sm text-red-600;
  }
  
  /* Error state styling */
  .form-field--error .form-field__label {
    @apply text-red-600;
  }
  
  .form-field--error .form-field__input-wrapper :global(input),
  .form-field--error .form-field__input-wrapper :global(textarea),
  .form-field--error .form-field__input-wrapper :global(select) {
    @apply border-red-300 focus:border-red-500 focus:ring-red-500;
  }
</style>