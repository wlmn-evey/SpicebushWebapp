---
import { Heart, Users, DollarSign, Award } from 'lucide-astro';
---

<!-- Our Community Values Section -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-4 tracking-tight">
        What Makes Our Community Special
      </h2>
      <p class="text-lg text-earth-brown max-w-3xl mx-auto leading-relaxed-plus font-light">
        Every day, we're amazed by the children in our care. Here's what we've learned creates the best environment for them to grow and flourish.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" role="list" aria-label="What makes our community special">
      <!-- Each Child is Unique -->
      <div class="text-center p-8 rounded-lg bg-white shadow-sm hover:shadow-md transition-shadow" role="listitem">
        <div class="w-16 h-16 bg-forest-canopy rounded-full flex items-center justify-center mx-auto mb-4">
          <Heart className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-semibold text-earth-brown mb-3">Each Child is Unique</h3>
        <p class="text-earth-brown leading-relaxed-plus">
          We see and celebrate who each child truly is. Their pace, their interests, their way of learning—it's all honored here.
        </p>
      </div>
      
      <!-- Everyone Belongs -->
      <div class="text-center p-8 rounded-lg bg-white shadow-sm hover:shadow-md transition-shadow" role="listitem">
        <div class="w-16 h-16 bg-moss-green rounded-full flex items-center justify-center mx-auto mb-4">
          <Users className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-semibold text-earth-brown mb-3">Everyone Belongs</h3>
        <p class="text-earth-brown leading-relaxed-plus">
          Our classroom thrives because of our differences. Every child, every family, every way of being—you belong in our community.
        </p>
      </div>
      
      <!-- Learning Should Be Joyful -->
      <div class="text-center p-8 rounded-lg bg-white shadow-sm hover:shadow-md transition-shadow" role="listitem">
        <div class="w-16 h-16 bg-sunlight-gold rounded-full flex items-center justify-center mx-auto mb-4">
          <DollarSign className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-semibold text-earth-brown mb-3">Learning Should Be Accessible</h3>
        <p class="text-earth-brown leading-relaxed-plus">
          Beautiful education shouldn't depend on family income. We work with each family to make this possible.
        </p>
      </div>
      
      <!-- Growing Together -->
      <div class="text-center p-8 rounded-lg bg-white shadow-sm hover:shadow-md transition-shadow" role="listitem">
        <div class="w-16 h-16 bg-sky-blue rounded-full flex items-center justify-center mx-auto mb-4">
          <Award className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-semibold text-earth-brown mb-3">Growing Together</h3>
        <p class="text-earth-brown leading-relaxed-plus">
          Children, families, and teachers—we're all learning and growing alongside each other in this beautiful journey.
        </p>
      </div>
    </div>
  </div>
</section>