---
import { User, LogOut } from 'lucide-astro';
---

<!-- Authentication Navigation Component -->
<div id="auth-nav" class="relative">
  <!-- Not authenticated state -->
  <div id="auth-nav-guest" class="hidden space-x-4">
    <a 
      href="/auth/login" 
      class="text-earth-brown hover:text-forest-canopy transition-colors font-medium focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 rounded px-2 py-1"
    >
      Sign In
    </a>
  </div>

  <!-- Authenticated state -->
  <div id="auth-nav-user" class="hidden relative">
    <!-- User Menu Button -->
    <button 
      id="user-menu-button" 
      class="flex items-center space-x-2 text-earth-brown hover:text-forest-canopy transition-colors font-medium focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 rounded px-2 py-1"
      aria-expanded="false"
      aria-haspopup="true"
    >
      <User className="w-5 h-5" />
      <span id="user-email" class="hidden sm:inline"></span>
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </button>

    <!-- Dropdown Menu -->
    <div 
      id="user-menu" 
      class="hidden absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-50"
      role="menu"
      aria-orientation="vertical"
      aria-labelledby="user-menu-button"
    >
      <div class="py-1">
        <button 
          id="sign-out-btn" 
          class="w-full flex items-center px-4 py-2 text-sm text-earth-brown hover:bg-stone-beige transition-colors text-left"
          role="menuitem"
        >
          <LogOut className="w-4 h-4 mr-3" />
          Sign Out
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { auth } from '../lib/supabase.ts';

  document.addEventListener('DOMContentLoaded', async function() {
    const authNav = document.getElementById('auth-nav');
    const guestNav = document.getElementById('auth-nav-guest');
    const userNav = document.getElementById('auth-nav-user');
    const userEmail = document.getElementById('user-email');
    const userMenuButton = document.getElementById('user-menu-button');
    const userMenu = document.getElementById('user-menu');
    const signOutBtn = document.getElementById('sign-out-btn');

    // Check current user
    async function checkUser() {
      try {
        const user = await auth.getCurrentUser();
        
        if (user) {
          // User is authenticated
          guestNav.classList.add('hidden');
          userNav.classList.remove('hidden');
          if (userEmail) {
            userEmail.textContent = user.email;
          }
        } else {
          // User is not authenticated
          guestNav.classList.remove('hidden');
          userNav.classList.add('hidden');
        }
      } catch (error) {
        console.error('Error checking user:', error);
        guestNav.classList.remove('hidden');
        userNav.classList.add('hidden');
      }
    }

    // Toggle user menu
    if (userMenuButton && userMenu) {
      userMenuButton.addEventListener('click', function() {
        const isExpanded = userMenuButton.getAttribute('aria-expanded') === 'true';
        userMenuButton.setAttribute('aria-expanded', (!isExpanded).toString());
        userMenu.classList.toggle('hidden');
      });

      // Close menu when clicking outside
      document.addEventListener('click', function(event) {
        if (!authNav.contains(event.target)) {
          userMenu.classList.add('hidden');
          userMenuButton.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Sign out functionality
    if (signOutBtn) {
      signOutBtn.addEventListener('click', async function() {
        try {
          const { error } = await auth.signOut();
          if (error) throw error;
          
          window.location.href = '/';
        } catch (error) {
          console.error('Error signing out:', error);
        }
      });
    }

    // Listen for auth state changes
    auth.onAuthStateChange((event, session) => {
      checkUser();
    });

    // Initial check
    checkUser();
  });
</script>