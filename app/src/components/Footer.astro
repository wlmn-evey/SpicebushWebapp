---
import { Facebook, Instagram } from 'lucide-astro';
import OptimizedImage from '@components/OptimizedImage.astro';
import ContactInfo from '@components/ContactInfo.astro';
import HoursWidget from '@components/HoursWidget.astro';
import { db } from '@lib/db';
import { logServerError } from '@lib/server-logger';
import { getTourLink } from '@lib/tour-settings';

interface SocialMediaLinks {
  facebook: string | null;
  instagram: string | null;
}

const toUrlOrNull = (value: unknown): string | null => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.startsWith('http')) {
      return trimmed;
    }
    if (trimmed.length > 0) {
      return `https://${trimmed.replace(/^https?:\/\//, '')}`;
    }
  }
  return null;
};

let socialMedia: SocialMediaLinks = { facebook: null, instagram: null };
const copyrightYear = new Date().getFullYear();
const tourLink = await getTourLink();
const locals = Astro.locals as unknown as Record<string, unknown>;
const isAdminUser = locals.isAdmin === true;
const adminFooterHref = isAdminUser ? '/admin' : '/auth/sign-in?next=%2Fadmin';
const adminFooterLabel = isAdminUser ? 'Admin Panel' : 'Admin Login';

try {
  const [facebookSetting, instagramSetting] = await Promise.all([
    db.content.getSetting('school_facebook').catch(() => null),
    db.content.getSetting('school_instagram').catch(() => null)
  ]);

  socialMedia = {
    facebook: toUrlOrNull(facebookSetting),
    instagram: toUrlOrNull(instagramSetting)
  };
} catch (error) {
  logServerError('Failed to load social media links', error, { component: 'Footer' });
}
---

<footer class="bg-forest-canopy text-white">
  <div class="container mx-auto px-4 pt-12 pb-24 md:pb-12">
    <!-- Main Footer Layout -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-10 xl:gap-12 mb-10">
      <!-- Left Column -->
      <div class="space-y-8">
        <div class="space-y-4 max-w-xl">
          <OptimizedImage
            photoSlug="homepage-spicebush-logo-brand-identity"
            className="h-16 sm:h-20 md:h-24 w-auto object-contain"
            style="max-width: 300px;"
            loading="lazy"
            alt="Spicebush Montessori School"
          />
          <p class="text-light-stone text-sm leading-relaxed-plus font-light tracking-wide">
            A warm community where every child can be exactly who they are.
          </p>
          <div class="flex items-center gap-3">
            {socialMedia?.facebook && (
              <a href={socialMedia.facebook} class="text-light-stone hover:text-sunlight-gold transition-colors" aria-label="Facebook">
                <Facebook className="w-5 h-5" />
              </a>
            )}
            {socialMedia?.instagram && (
              <a href={socialMedia.instagram} class="text-light-stone hover:text-sunlight-gold transition-colors" aria-label="Instagram">
                <Instagram className="w-5 h-5" />
              </a>
            )}
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div class="space-y-4">
            <h3 class="text-lg font-semibold text-sunlight-gold">Quick Links</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/about" class="text-light-stone hover:text-sunlight-gold transition-colors block py-0.5">About Us</a></li>
              <li><a href="/our-principles" class="text-light-stone hover:text-sunlight-gold transition-colors block py-0.5">Our Principles</a></li>
              <li><a href="/admissions" class="text-light-stone hover:text-sunlight-gold transition-colors block py-0.5">Admissions</a></li>
              <li><a href="/admissions/tuition-calculator" class="text-light-stone hover:text-sunlight-gold transition-colors block py-0.5">Tuition Calculator</a></li>
            </ul>
          </div>

          <div class="space-y-4">
            <h3 class="text-lg font-semibold text-sunlight-gold">Resources</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/resources/faq" class="text-light-stone hover:text-sunlight-gold transition-colors block py-0.5">FAQ</a></li>
              <li><a href="/blog" class="text-light-stone hover:text-sunlight-gold transition-colors block py-0.5">Blog</a></li>
              <li><a href="/contact" class="text-light-stone hover:text-sunlight-gold transition-colors block py-0.5">Contact</a></li>
            </ul>
          </div>
        </div>

        <div class="space-y-4 max-w-xl">
          <h3 class="text-lg font-semibold text-sunlight-gold">Get in Touch</h3>
          <ContactInfo 
            className="text-sm [&_a]:text-light-stone [&_a]:hover:text-sunlight-gold [&_address]:text-light-stone [&_svg]:text-moss-green"
          />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-1">
            <a 
              href={tourLink}
              class="block text-center bg-sunlight-gold hover:bg-orange-600 text-white px-4 py-2.5 rounded-lg font-semibold transition-colors text-sm tracking-wide"
              data-analytics-event="tour_click"
              data-analytics-label="footer-come-visit"
              data-analytics-location="footer-cta"
            >
              Come Visit
            </a>
            <a 
              href="/contact" 
              class="block text-center border border-gray-300 text-light-stone hover:border-sunlight-gold hover:text-sunlight-gold px-4 py-2 rounded-lg font-medium transition-colors text-sm tracking-wide"
              data-analytics-event="contact_cta_click"
              data-analytics-label="footer-get-in-touch"
              data-analytics-location="footer-cta"
            >
              Get in Touch
            </a>
          </div>
        </div>
      </div>

      <!-- Right Column: Hours Widget -->
      <div class="w-full">
        <div class="bg-white/5 backdrop-blur-sm rounded-xl p-3 lg:p-4 border border-white/10 overflow-hidden">
          <HoursWidget />
        </div>
      </div>
    </div>
    
    <!-- Bottom Section -->
    <div class="border-t border-gray-600 pt-6">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div class="text-light-stone text-sm text-center lg:text-left">
          <p>&copy; {copyrightYear} Spicebush Montessori School. All rights reserved.</p>
        </div>
        <div class="flex flex-wrap items-center justify-center lg:justify-end gap-x-5 gap-y-2 text-sm">
          <a
            href={adminFooterHref}
            class="inline-flex items-center rounded-lg border border-sunlight-gold/50 bg-sunlight-gold/15 px-3 py-1.5 font-semibold text-sunlight-gold transition-colors hover:bg-sunlight-gold hover:text-white"
          >
            {adminFooterLabel}
          </a>
          <a href="/privacy-policy" class="text-light-stone hover:text-sunlight-gold transition-colors">Privacy Policy</a>
          <a href="/non-discrimination-policy" class="text-light-stone hover:text-sunlight-gold transition-colors">Non-Discrimination</a>
          <a href="/accessibility" class="text-light-stone hover:text-sunlight-gold transition-colors">Accessibility</a>
        </div>
      </div>
    </div>
  </div>
</footer>
