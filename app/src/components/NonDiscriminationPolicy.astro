---
import { Heart } from 'lucide-astro';
---

<section class="py-12 bg-stone-beige">
  <div class="container mx-auto px-4 max-w-4xl">
    <div class="bg-warm-white rounded-2xl p-8 lg:p-12 shadow-sm">
      <!-- Header with Icon -->
      <div class="flex items-center mb-8">
        <div class="w-16 h-16 bg-forest-canopy rounded-full flex items-center justify-center mr-6 flex-shrink-0">
          <Heart className="w-8 h-8 text-white" />
        </div>
        <h2 class="text-3xl lg:text-4xl font-bold text-earth-brown">
          Our Non-Discrimination Policy
        </h2>
      </div>
      
      <!-- Main Policy Text -->
      <div class="prose prose-lg max-w-none mb-8">
        <p class="text-earth-brown leading-relaxed-plus mb-6">
          Spicebush Montessori School admits students of any race, color, gender, national and ethnic origin, and sexual orientation to all the rights, privileges, programs, and activities generally accorded or made available to students at the school. It does not discriminate on the basis of gender, race, color, national and ethnic origin, or sexual orientation in administration of its educational policies, admissions policies, scholarship and loan programs, and athletic and other school-administered programs.
        </p>
        
        <p class="text-earth-brown leading-relaxed-plus mb-6">
          Below are ways to reach out to the U.S. Department of Health and Human Services' Office of Civil Rights, the Office of Civil Rights Compliance, the Pennsylvania Human Relations Commission, or our school directly if you have been subjected to implicit bias or discrimination.
        </p>
      </div>
      
      <!-- Contact Links -->
      <div class="space-y-4 mb-8">
        <div class="text-center">
          <a 
            href="https://www.hhs.gov/ocr/index.html"
            target="_blank"
            rel="noopener"
            class="inline-block text-lg font-bold text-forest-canopy hover:text-moss-green transition-colors focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 rounded px-2 py-1"
          >
            Office for Civil Rights
          </a>
        </div>
        
        <div class="text-center">
          <a 
            href="https://www.dhs.pa.gov/contact/DHS-Offices/Pages/OA-Bureau%20of%20Equal%20Opportunity.aspx"
            target="_blank"
            rel="noopener"
            class="inline-block text-lg font-bold text-forest-canopy hover:text-moss-green transition-colors focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 rounded px-2 py-1"
          >
            Bureau of Equal Opportunity
          </a>
        </div>
        
        <div class="text-center">
          <a 
            href="https://www.phrc.pa.gov/File-a-Complaint/Pages/default.aspx"
            target="_blank"
            rel="noopener"
            class="inline-block text-lg font-bold text-forest-canopy hover:text-moss-green transition-colors focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 rounded px-2 py-1"
          >
            Pennsylvania Human Rights Commission
          </a>
        </div>
      </div>
      
      <!-- Anonymous Feedback -->
      <div class="mb-8">
        <p class="text-earth-brown text-center">
          If you would like to file an anonymous complaint or offer feedback to teachers leaders, please use this 
          <a 
            href="https://docs.google.com/forms/d/e/1FAIpQLSd9x0mdbCKXBjbWuVme2SeRX9enMfUAf7Y_80VqFUDFs4qfRg/viewform?usp=sf_link"
            target="_blank"
            rel="noopener"
            class="text-forest-canopy hover:text-moss-green font-bold transition-colors focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 rounded px-1"
          >
            Google Form
          </a>.
        </p>
      </div>
      
      <!-- Direct Contact CTA -->
      <div class="bg-gradient-to-r from-forest-canopy to-moss-green text-center py-6 px-8 rounded-xl shadow-md">
        <a 
          href="/contact"
          class="text-white hover:text-light-stone transition-colors focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-forest-canopy rounded px-2 inline-block"
        >
          <p class="text-lg font-semibold mb-1">
            Please contact us directly here if you or your family has been subjected to implicit bias or discrimination.
          </p>
        </a>
      </div>
    </div>
  </div>
</section>