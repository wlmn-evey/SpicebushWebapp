---
import OptimizedImage from './OptimizedImage.astro';
import { getTourLink } from '@lib/tour-settings';

const tourLink = await getTourLink();
---

<!-- Enhanced Photography-Focused Hero Section -->
<section class="relative h-[80vh] overflow-hidden">
  <!-- Large hero image -->
  <div class="absolute inset-0 z-0">
    <OptimizedImage
      photoSlug="group-montessori-collaboration-img-6543-1933x1450"
      className="w-full h-full"
      objectFit="cover"
      objectPosition="center"
      priority={true}
      loading="eager"
    />
    <!-- Gradient overlay for better text contrast -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/20 via-transparent to-transparent"></div>
  </div>
  
  <!-- Content positioned over the autumn scene -->
  <div class="container mx-auto px-4 h-full flex items-center relative z-10">
    <div class="max-w-2xl bg-white/90 backdrop-blur-sm p-8 lg:p-12 rounded-lg shadow-2xl">
      
      <!-- Full-Width Headline -->
      <div class="text-center mb-8">
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-heading font-bold leading-tight tracking-tight text-earth-brown mb-2">
          Where Your Child
        </h1>
        <div class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-heading font-black leading-none tracking-tighter text-forest-canopy">
          Belongs & Blossoms
        </div>
      </div>
      
      <p class="text-lg lg:text-xl mb-8 leading-relaxed text-earth-brown font-medium">
        Here, your child will find a caring community and a warm welcome. They will joyfully explore their world, discovering the path of authentic Montessori learning.
      </p>
      
      <div class="flex justify-center">
        <a 
          href={tourLink}
          class="bg-sunlight-gold hover:bg-orange-600 text-white px-8 py-4 rounded-md font-semibold text-lg transition-colors inline-flex items-center justify-center shadow-lg transform hover:scale-105 tracking-wide"
          aria-label="Apply and schedule a tour of Spicebush Montessori"
        >
          Apply & Schedule Tour
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 z-10">
    <a href="#about" class="text-white opacity-80 hover:opacity-100 transition-opacity">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
      <span class="sr-only">Scroll down</span>
    </a>
  </div>
</section>
