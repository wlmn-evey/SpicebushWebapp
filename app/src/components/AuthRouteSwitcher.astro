---
/**
 * Auth Route Switcher Component
 * Redirects to appropriate auth pages based on feature flag
 */

interface Props {
  route: 'sign-in' | 'sign-up' | 'callback' | 'sign-out';
}

const { route } = Astro.props;

// Determine which auth system to use
const runtimeEnv = typeof process !== 'undefined' ? process.env?.USE_CLERK_AUTH : undefined;
const buildEnv = (import.meta as any)?.env?.USE_CLERK_AUTH;
const rawFlag = runtimeEnv ?? buildEnv ?? '';
const normalizedFlag = typeof rawFlag === 'string' ? rawFlag.toLowerCase() : '';
const useClerk = ['clerk', 'true', '1', 'yes', 'on'].includes(normalizedFlag);

const redirectMap: Record<Props['route'], string> = useClerk
  ? {
      'sign-in': '/auth/sign-in',
      'sign-up': '/auth/sign-up',
      'callback': '/auth/login',
      'sign-out': '/auth/logout'
    }
  : {
      'sign-in': '/auth/sign-in',
      'sign-up': '/auth/sign-up',
      'callback': '/auth/login',
      'sign-out': '/auth/logout'
    };

return Astro.redirect(redirectMap[route]);
---
