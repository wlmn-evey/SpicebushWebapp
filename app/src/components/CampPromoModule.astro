---
import { ArrowRight, Calendar } from 'lucide-astro';
import { db } from '@lib/db';
import type { CampPromotionSummary } from '@lib/db/camp';
import { evaluateCampMode, parseCampModeSettings } from '@lib/camp-mode';
import { logServerError } from '@lib/server-logger';

type PromoPlacement = 'homepage' | 'programs' | 'contact';

export interface Props {
  placement?: PromoPlacement;
}

const { placement = 'homepage' } = Astro.props;

const asString = (value: unknown, fallback = ''): string => {
  if (typeof value !== 'string') return fallback;
  const trimmed = value.trim();
  return trimmed.length > 0 ? trimmed : fallback;
};

const formatDate = (value: string): string => {
  const parsed = Date.parse(`${value}T00:00:00`);
  if (!Number.isFinite(parsed)) return value;
  return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(
    new Date(parsed)
  );
};

let settings: Record<string, unknown> = {};
try {
  settings = await db.content.getAllSettings();
} catch (error) {
  logServerError('Failed to load settings for camp promo module', error, {
    component: 'CampPromoModule'
  });
}

const campMode = evaluateCampMode(parseCampModeSettings(settings));
const locals = Astro.locals as Record<string, unknown>;
const isAdmin = locals.isAdmin === true;
const promoEnabled = campMode.settings.promotionsEnabled;
const showCampEntryPoints = campMode.reason !== 'forced_off' && (!campMode.prepMode || isAdmin);
const showCampPage = campMode.active || (campMode.prepMode && isAdmin);
const campLink = showCampPage ? '/camp' : '/camp-coming-soon';

let promoSummary: CampPromotionSummary | null = null;
if (promoEnabled && showCampEntryPoints) {
  try {
    promoSummary = await db.camp.getCampPromotionSummary();
  } catch (error) {
    logServerError('Failed to load camp promotion summary', error, {
      component: 'CampPromoModule'
    });
  }
}

const seasonLabel = asString(settings.camp_current_season_label, 'Summer Camp');
const openDateLabel = asString(settings.camp_open_date_label);
const activeMessageSetting = asString(
  settings.camp_promo_active_message,
  'Summer camp is open with weekly themes and live seat updates.'
);
const inactiveMessageSetting = asString(
  settings.camp_promo_inactive_message,
  'Summer camp details are coming soon. See updates and opening windows.'
);

const activeStatusLine = (() => {
  if (!promoSummary || !promoSummary.available || promoSummary.totalPublishedWeeks === 0) {
    return activeMessageSetting;
  }

  const segments: string[] = [];
  if (promoSummary.openWeeks > 0) {
    segments.push(`${promoSummary.openWeeks} week${promoSummary.openWeeks === 1 ? '' : 's'} open`);
  }
  if (promoSummary.limitedWeeks > 0) {
    segments.push(
      `${promoSummary.limitedWeeks} week${promoSummary.limitedWeeks === 1 ? '' : 's'} limited`
    );
  }
  if (promoSummary.waitlistWeeks > 0) {
    segments.push(
      `${promoSummary.waitlistWeeks} week${promoSummary.waitlistWeeks === 1 ? '' : 's'} waitlisted`
    );
  }
  if (segments.length === 0 && promoSummary.fullWeeks > 0) {
    segments.push(`${promoSummary.fullWeeks} week${promoSummary.fullWeeks === 1 ? '' : 's'} full`);
  }
  if (segments.length === 0 && promoSummary.closedWeeks > 0) {
    segments.push(
      `${promoSummary.closedWeeks} week${promoSummary.closedWeeks === 1 ? '' : 's'} currently closed`
    );
  }

  if (segments.length === 0) return activeMessageSetting;
  return `Current status: ${segments.join(' • ')}.`;
})();

const secondaryLine = showCampPage
  ? promoSummary?.nextOpenWeek
    ? `Next available week: ${promoSummary.nextOpenWeek.themeTitle} (${formatDate(promoSummary.nextOpenWeek.startDate)}).`
    : activeMessageSetting
  : openDateLabel
    ? `Expected update: ${openDateLabel}.`
    : 'We will share week-by-week details as soon as they are finalized.';

const nextWeekTheme =
  showCampPage && promoSummary?.nextOpenWeek ? promoSummary.nextOpenWeek.themeTitle : null;
const nextWeekDate =
  showCampPage && promoSummary?.nextOpenWeek
    ? formatDate(promoSummary.nextOpenWeek.startDate)
    : null;

const eyebrowLabel = (() => {
  if (placement === 'homepage') return 'Camp Spotlight';
  if (placement === 'programs') return 'Summer Add-On';
  return 'Seasonal Programs';
})();

const headingLabel = (() => {
  if (placement === 'homepage') return `${seasonLabel} At Spicebush`;
  if (placement === 'programs') return 'Continue the Montessori Journey This Summer';
  return `${seasonLabel} Questions?`;
})();

const shellClass = (() => {
  if (placement === 'homepage') {
    return 'border-forest-canopy/20 bg-gradient-to-br from-white to-moss-green/5';
  }
  if (placement === 'programs') {
    return 'border-sunlight-gold/40 bg-gradient-to-br from-white to-sunlight-gold/10';
  }
  return 'border-forest-canopy/20 bg-gradient-to-br from-white to-stone-beige';
})();

const primaryLabel = showCampPage ? 'View Camp Weeks' : 'View Camp Updates';
const stateBadge = showCampPage
  ? 'Camp Is Live'
  : campMode.prepMode
    ? 'Admin Preview Mode'
    : 'Camp Coming Soon';
const analyticsLabel = `${placement}-${showCampPage ? 'active' : 'inactive'}`;
const badgeClass = showCampPage
  ? 'border-green-200 bg-green-50 text-green-800'
  : campMode.prepMode
    ? 'border-purple-200 bg-purple-50 text-purple-800'
    : 'border-amber-200 bg-amber-50 text-amber-800';
---

{
  promoEnabled && showCampEntryPoints && (
    <section class="py-10">
      <div class="container mx-auto px-4">
        <div class={`relative overflow-hidden rounded-2xl border p-6 shadow-sm lg:p-8 ${shellClass}`}>
          <svg class="pointer-events-none absolute -right-8 -top-8 h-36 w-36 text-sunlight-gold/[0.06]" viewBox="0 0 120 120" fill="currentColor" aria-hidden="true">
            <circle cx="60" cy="60" r="40" />
            <circle cx="60" cy="60" r="56" stroke="currentColor" stroke-width="2" fill="none" opacity="0.5" />
          </svg>
          <div class="relative flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-3xl">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-earth-brown/70">
                {eyebrowLabel}
              </p>
              <h2 class="mt-2 text-2xl font-heading font-bold text-earth-brown lg:text-3xl">
                {headingLabel}
              </h2>
              <p class="mt-3 text-sm font-semibold text-earth-brown">
                {showCampPage ? activeStatusLine : inactiveMessageSetting}
              </p>
              {nextWeekTheme && nextWeekDate ? (
                <p class="mt-2 text-sm text-earth-brown/80">
                  Next up: <strong class="text-earth-brown">{nextWeekTheme}</strong>
                  <span class="ml-1.5 inline-flex items-center rounded-full bg-sunlight-gold/15 px-2 py-0.5 text-xs font-semibold text-earth-brown">
                    {nextWeekDate}
                  </span>
                </p>
              ) : (
                <p class="mt-2 text-sm text-earth-brown/80">{secondaryLine}</p>
              )}
            </div>

            <div class="flex w-full flex-col gap-3 sm:w-auto">
              <span class={`inline-flex w-fit items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold ${badgeClass}`}>
                {showCampPage ? (
                  <span class="relative flex h-2 w-2">
                    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75" />
                    <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500" />
                  </span>
                ) : (
                  <Calendar className="h-4 w-4" />
                )}
                {stateBadge}
              </span>
              <a
                href={campLink}
                class="inline-flex min-h-[44px] items-center justify-center rounded-lg bg-forest-canopy px-5 py-2 text-sm font-semibold text-white hover:bg-moss-green"
                data-analytics-event="camp_promo_click"
                data-analytics-label={analyticsLabel}
                data-analytics-location={`camp-promo-${placement}`}
              >
                {primaryLabel}
                <ArrowRight className="ml-2 h-4 w-4" />
              </a>
              <a
                href="/contact"
                class="inline-flex min-h-[44px] items-center justify-center rounded-lg border border-gray-300 px-5 py-2 text-sm font-semibold text-earth-brown hover:bg-gray-100"
              >
                Ask A Question
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
