<script is:inline>
  (() => {
    const EXTERNAL_LINK_ATTR = 'data-external-link-processed';

    const addSecurityRel = (anchor) => {
      const existing = (anchor.getAttribute('rel') || '')
        .split(/\s+/)
        .map((token) => token.trim())
        .filter(Boolean);
      const relValues = new Set(existing);
      relValues.add('noopener');
      relValues.add('noreferrer');
      anchor.setAttribute('rel', Array.from(relValues).join(' '));
    };

    const shouldOpenInNewTab = (anchor) => {
      const href = anchor.getAttribute('href');
      if (!href || href.startsWith('#')) {
        return false;
      }

      if (anchor.hasAttribute('download') || anchor.hasAttribute('data-open-same-tab')) {
        return false;
      }

      let parsed;
      try {
        parsed = new URL(href, window.location.href);
      } catch {
        return false;
      }

      if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') {
        return false;
      }

      return parsed.origin !== window.location.origin;
    };

    const processAnchor = (anchor) => {
      if (!(anchor instanceof HTMLAnchorElement)) return;
      if (anchor.getAttribute(EXTERNAL_LINK_ATTR) === 'true') return;

      if (shouldOpenInNewTab(anchor)) {
        anchor.setAttribute('target', '_blank');
        addSecurityRel(anchor);
      }

      anchor.setAttribute(EXTERNAL_LINK_ATTR, 'true');
    };

    const processRoot = (root) => {
      if (root instanceof HTMLAnchorElement) {
        processAnchor(root);
      }

      if (root instanceof Element) {
        root.querySelectorAll('a[href]').forEach((anchor) => processAnchor(anchor));
      }
    };

    const initialize = () => {
      processRoot(document.body);

      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (node instanceof Element) {
              processRoot(node);
            }
          });
        });
      });

      observer.observe(document.body, { childList: true, subtree: true });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initialize, { once: true });
    } else {
      initialize();
    }
  })();
</script>
