---
export interface Props {
  variant?: 'inline' | 'card' | 'footer';
  title?: string;
  description?: string;
  buttonText?: string;
  showName?: boolean;
  subscriptionType?: string;
  className?: string;
}

const { 
  variant = 'inline',
  title = 'Stay Connected',
  description = 'Get updates about our school, events, and Montessori education tips.',
  buttonText = 'Subscribe',
  showName = false,
  subscriptionType = 'general',
  className = ''
} = Astro.props;

// Generate a unique form ID for this instance
const formId = `newsletter-form-${Math.random().toString(36).substr(2, 9)}`;
---

<div class={`newsletter-signup newsletter-${variant} ${className}`}>
  {variant === 'footer' && (
    <div class="newsletter-footer">
      <h4 class="newsletter-title-footer">{title}</h4>
      <p class="newsletter-description-footer">{description}</p>
      <form id={formId} class="newsletter-form-footer">
        <div class="form-footer-wrapper">
          <label for={`${formId}-email`} class="sr-only">Email Address</label>
          <input 
            type="email" 
            id={`${formId}-email`}
            name="email" 
            placeholder="Your email"
            required
            class="form-input-footer"
          />
          <button type="submit" class="submit-button-footer">
            {buttonText}
          </button>
        </div>
        <input type="hidden" name="subscription_type" value={subscriptionType} />
        <input type="hidden" name="signup_source" value="website_footer" />
      </form>
      <div class="form-message-footer" id={`${formId}-message`}></div>
    </div>
  )}
</div>

<!-- Simplified script without define:vars -->
<script>
  // Newsletter form enhancement will be added when DOM loads
  // This simplified version avoids SSR issues with define:vars
</script>

<style>
  /* Newsletter Signup Styles */
  .newsletter-signup {
    @apply relative;
  }

  /* Footer variant styles */
  .newsletter-footer {
    @apply space-y-3;
  }

  .newsletter-title-footer {
    @apply text-lg font-semibold text-sunlight-gold;
  }

  .newsletter-description-footer {
    @apply text-sm text-light-stone/90;
  }

  .newsletter-form-footer {
    @apply relative;
  }

  .form-footer-wrapper {
    @apply flex gap-2;
  }

  .form-input-footer {
    @apply flex-1 px-3 py-2 bg-white/10 border border-white/20 rounded-md text-white placeholder-white/60 text-sm focus:outline-none focus:ring-2 focus:ring-sunlight-gold focus:border-transparent;
  }

  .submit-button-footer {
    @apply px-4 py-2 bg-sunlight-gold hover:bg-orange-600 text-white rounded-md font-medium text-sm transition-colors whitespace-nowrap;
  }

  .form-message-footer {
    @apply text-sm mt-2 opacity-0 transition-opacity duration-300;
  }

  .form-message-footer.show {
    @apply opacity-100;
  }

  .form-message-footer.success {
    @apply text-green-400;
  }

  .form-message-footer.error {
    @apply text-red-400;
  }
</style>