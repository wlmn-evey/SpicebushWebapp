---
interface Props {
  photoSlug: string;
  className?: string;
  style?: string;
  priority?: boolean;
  sizes?: string;
  objectFit?: 'cover' | 'contain' | 'fill' | 'scale-down' | 'none';
  objectPosition?: string;
  loading?: 'lazy' | 'eager';
  showFocalPoints?: boolean;
  alt?: string;
  slotId?: string;
  editable?: boolean;
  mediaCategory?: string;
}

import { getEntry as getContentEntry } from 'astro:content';
import { db } from '@lib/db';
import { logServerError } from '@lib/server-logger';
import { getPhotoFramingDefaults } from '@lib/photo-framing-defaults';

const {
  photoSlug,
  className = '',
  style = '',
  priority = false,
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  objectFit = 'cover',
  objectPosition,
  loading,
  showFocalPoints = false,
  alt,
  slotId,
  editable = true,
  mediaCategory
} = Astro.props;

const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));

const asRecord = (value: unknown): Record<string, unknown> => {
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    return value as Record<string, unknown>;
  }
  return {};
};

const stringFrom = (value: unknown, fallback = ''): string => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.length > 0) return trimmed;
  }
  return fallback;
};

const numberFrom = (value: unknown, fallback: number): number => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value === 'string') {
    const parsed = Number.parseFloat(value.trim());
    if (Number.isFinite(parsed)) return parsed;
  }
  return fallback;
};

const optionalNumberFrom = (value: unknown): number | null => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value === 'string') {
    const parsed = Number.parseFloat(value.trim());
    if (Number.isFinite(parsed)) return parsed;
  }
  return null;
};

const toSlotSlug = (value: string): string =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9-_]+/g, '-')
    .replace(/-{2,}/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 80);

const normalizeCrop = (
  xInput: unknown,
  yInput: unknown,
  widthInput: unknown,
  heightInput: unknown,
  defaults: { x: number; y: number; width: number; height: number }
) => {
  const width = clamp(numberFrom(widthInput, defaults.width), 10, 100);
  const height = clamp(numberFrom(heightInput, defaults.height), 10, 100);
  const x = clamp(numberFrom(xInput, defaults.x), 0, 100 - width);
  const y = clamp(numberFrom(yInput, defaults.y), 0, 100 - height);

  return {
    x: Math.round(x * 10) / 10,
    y: Math.round(y * 10) / 10,
    width: Math.round(width * 10) / 10,
    height: Math.round(height * 10) / 10
  };
};

const gallerySubcategories = new Set([
  'art',
  'classroom',
  'events',
  'group',
  'individual',
  'materials',
  'outdoor',
  'practical'
]);

const locals = Astro.locals as unknown as Record<string, unknown>;
const isAdmin = locals.isAdmin === true;

const routeScopedFallbackSlot = toSlotSlug(`${Astro.url.pathname}-${photoSlug}`);
const computedSlotId = toSlotSlug(stringFrom(slotId, routeScopedFallbackSlot));
const canInlineEdit = editable && isAdmin && computedSlotId.length > 0;

let slotAltOverride = '';
let requestedPhotoSlug = photoSlug;

if (computedSlotId.length > 0) {
  try {
    const slotEntry = await db.content.getEntry('media-slots', computedSlotId);
    const slotData = asRecord(slotEntry?.data);
    const assignedPhotoSlug = stringFrom(slotData.photoSlug, '');
    if (assignedPhotoSlug) {
      requestedPhotoSlug = assignedPhotoSlug;
    }
    slotAltOverride = stringFrom(slotData.altText, '');
  } catch (error) {
    logServerError('Media slot lookup failed', error, { component: 'OptimizedImage', computedSlotId });
  }
}

const resolvePhotoData = async (
  slugToLookup: string
): Promise<{ resolvedSlug: string; photoData: Record<string, unknown> } | null> => {
  try {
    const dbPhoto = await db.content.getEntry('photos', slugToLookup);
    if (dbPhoto?.data) {
      return {
        resolvedSlug: dbPhoto.slug,
        photoData: asRecord(dbPhoto.data)
      };
    }
  } catch (error) {
    logServerError('Database photo lookup failed', error, { component: 'OptimizedImage', photoSlug: slugToLookup });
  }

  try {
    const contentPhoto = await getContentEntry('photos', slugToLookup);
    if (contentPhoto?.data) {
      return {
        resolvedSlug: contentPhoto.slug,
        photoData: asRecord(contentPhoto.data)
      };
    }
  } catch (error) {
    logServerError('Photo content lookup failed', error, { component: 'OptimizedImage', photoSlug: slugToLookup });
  }

  return null;
};

let photoLookup = await resolvePhotoData(requestedPhotoSlug);
if (!photoLookup && requestedPhotoSlug !== photoSlug) {
  photoLookup = await resolvePhotoData(photoSlug);
}

if (!photoLookup) {
  return null;
}

const resolvedSlug = photoLookup.resolvedSlug;
const photoData = photoLookup.photoData;

const category = stringFrom(photoData.category, 'homepage');
const sourceUrl = stringFrom(photoData.sourceUrl, '');
const optimizedFilename = stringFrom(photoData.optimizedFilename, `${resolvedSlug}.webp`);

const originalWidth = Math.max(1, Math.round(numberFrom(photoData.originalWidth, 1280)));
const originalHeight = Math.max(1, Math.round(numberFrom(photoData.originalHeight, 800)));
const framingDefaults = getPhotoFramingDefaults({
  category,
  width: originalWidth,
  height: originalHeight,
  slug: resolvedSlug
});

const altText = stringFrom(photoData.altText, resolvedSlug);
const effectiveAlt = alt || slotAltOverride || altText;
const primaryFocalX = clamp(numberFrom(photoData.primaryFocalX, framingDefaults.primaryFocalX), 0, 100);
const primaryFocalY = clamp(numberFrom(photoData.primaryFocalY, framingDefaults.primaryFocalY), 0, 100);

const secondaryFocalX = optionalNumberFrom(photoData.secondaryFocalX);
const secondaryFocalY = optionalNumberFrom(photoData.secondaryFocalY);

const mobileCrop = normalizeCrop(
  photoData.mobileCropX,
  photoData.mobileCropY,
  photoData.mobileCropWidth,
  photoData.mobileCropHeight,
  {
    x: framingDefaults.mobileCropX,
    y: framingDefaults.mobileCropY,
    width: framingDefaults.mobileCropWidth,
    height: framingDefaults.mobileCropHeight
  }
);
const tabletCrop = normalizeCrop(
  photoData.tabletCropX,
  photoData.tabletCropY,
  photoData.tabletCropWidth,
  photoData.tabletCropHeight,
  {
    x: framingDefaults.tabletCropX,
    y: framingDefaults.tabletCropY,
    width: framingDefaults.tabletCropWidth,
    height: framingDefaults.tabletCropHeight
  }
);

const objectPositionDesktop = `${primaryFocalX}% ${primaryFocalY}%`;
const objectPositionTablet = `${tabletCrop.x + (tabletCrop.width / 2)}% ${tabletCrop.y + (tabletCrop.height / 2)}%`;
const objectPositionMobile = `${mobileCrop.x + (mobileCrop.width / 2)}% ${mobileCrop.y + (mobileCrop.height / 2)}%`;
const responsivePositionDesktop = objectPosition || objectPositionDesktop;
const responsivePositionTablet = objectPosition || objectPositionTablet;
const responsivePositionMobile = objectPosition || objectPositionMobile;

const basePath = sourceUrl
  ? ''
  : (gallerySubcategories.has(category)
    ? `/images/optimized/gallery/${category}`
    : `/images/optimized/${category}`);

const webpSrc = sourceUrl || `${basePath}/${optimizedFilename}`;
const jpgFallback = sourceUrl || `${basePath}/${resolvedSlug}-640w.jpg`;

const responsiveSources = sourceUrl
  ? [`${sourceUrl} ${originalWidth}w`]
  : [320, 640, 960, 1280]
    .filter((width) => width <= originalWidth)
    .map((width) => `${basePath}/${resolvedSlug}-${width}w.webp ${width}w`);

if (!sourceUrl && originalWidth > 1280) {
  responsiveSources.push(`${webpSrc} ${originalWidth}w`);
}

if (responsiveSources.length === 0) {
  responsiveSources.push(`${webpSrc} ${originalWidth}w`);
}

const srcSet = responsiveSources.join(', ');
const loadingStrategy = loading || (priority ? 'eager' : 'lazy');
const imageId = `img-${Math.random().toString(36).slice(2, 11)}`;

const uploadCategory = toSlotSlug(stringFrom(mediaCategory, category || 'gallery')) || 'gallery';
---

<div
  class="optimized-image"
  data-photo-slug={resolvedSlug}
  data-media-inline-slot={canInlineEdit ? computedSlotId : undefined}
>
  <picture>
    <source
      type="image/webp"
      srcset={srcSet}
      sizes={sizes}
    />

    <img
      src={jpgFallback}
      alt={effectiveAlt}
      width={originalWidth}
      height={originalHeight}
      loading={loadingStrategy}
      decoding={priority ? 'sync' : 'async'}
      class={`optimized-image-element ${className}`}
      data-image-id={imageId}
      style={`object-fit: ${objectFit}; --sb-pos-mobile: ${responsivePositionMobile}; --sb-pos-tablet: ${responsivePositionTablet}; --sb-pos-desktop: ${responsivePositionDesktop}; object-position: var(--sb-pos-mobile); ${style}`}
    />
  </picture>

  {canInlineEdit && (
    <button
      type="button"
      class="media-inline-trigger"
      data-media-inline-trigger
      data-slot-id={computedSlotId}
      data-photo-slug={resolvedSlug}
      data-media-category={uploadCategory}
      data-alt-text={effectiveAlt}
      aria-label="Edit this image"
      title="Edit this image"
    >
      Edit image
    </button>
  )}

  {showFocalPoints && (
    <div class="focal-points-debug">
      <div
        class="focal-point focal-point-primary"
        style={`left: ${primaryFocalX}%; top: ${primaryFocalY}%;`}
        title={`Primary: ${primaryFocalX}%, ${primaryFocalY}%`}
      ></div>

      {secondaryFocalX !== null && secondaryFocalY !== null && (
        <div
          class="focal-point focal-point-secondary"
          style={`left: ${secondaryFocalX}%; top: ${secondaryFocalY}%;`}
          title={`Secondary: ${secondaryFocalX}%, ${secondaryFocalY}%`}
        ></div>
      )}

      <div
        class="crop-zone crop-zone-mobile"
        style={`left: ${mobileCrop.x}%; top: ${mobileCrop.y}%; width: ${mobileCrop.width}%; height: ${mobileCrop.height}%;`}
        title="Mobile crop zone"
      ></div>

      <div
        class="crop-zone crop-zone-tablet"
        style={`left: ${tabletCrop.x}%; top: ${tabletCrop.y}%; width: ${tabletCrop.width}%; height: ${tabletCrop.height}%;`}
        title="Tablet crop zone"
      ></div>
    </div>
  )}
</div>

{canInlineEdit && (
  <script>
    (() => {
      if ((window as Window & { __sbInlineMediaEditorInit?: boolean }).__sbInlineMediaEditorInit) return;
      (window as Window & { __sbInlineMediaEditorInit?: boolean }).__sbInlineMediaEditorInit = true;

      type PhotoEntry = {
        slug: string;
        title: string;
        category: string;
        sourceUrl: string;
        updatedAt?: string;
      };

      const state: {
        photos: PhotoEntry[];
        loaded: boolean;
        activeSlotId: string;
        selectedSlug: string;
        selectedCategory: string;
      } = {
        photos: [],
        loaded: false,
        activeSlotId: '',
        selectedSlug: '',
        selectedCategory: 'gallery'
      };

      const styleId = 'sb-inline-media-editor-style';
      if (!document.getElementById(styleId)) {
        const styleTag = document.createElement('style');
        styleTag.id = styleId;
        styleTag.textContent = `
          .sb-inline-media-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.55);
            z-index: 12000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
          }

          .sb-inline-media-modal-backdrop[data-open='true'] {
            display: flex;
          }

          .sb-inline-media-modal {
            width: min(960px, 100%);
            max-height: min(88vh, 900px);
            overflow: hidden;
            border-radius: 16px;
            background: #ffffff;
            border: 1px solid #d6d3d1;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.28);
            display: grid;
            grid-template-rows: auto auto 1fr auto;
          }

          .sb-inline-media-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.9rem 1rem;
            border-bottom: 1px solid #e7e5e4;
          }

          .sb-inline-media-title {
            margin: 0;
            font-size: 1rem;
            line-height: 1.3;
            color: #1f2937;
          }

          .sb-inline-media-subtitle {
            margin: 0.25rem 0 0;
            font-size: 0.78rem;
            color: #57534e;
          }

          .sb-inline-media-close {
            border: 1px solid #d6d3d1;
            background: #fafaf9;
            color: #1f2937;
            border-radius: 8px;
            padding: 0.4rem 0.7rem;
            cursor: pointer;
            font-size: 0.85rem;
          }

          .sb-inline-media-toolbar {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.5rem;
            padding: 0.8rem 1rem;
            border-bottom: 1px solid #e7e5e4;
            background: #fafaf9;
          }

          .sb-inline-media-toolbar input,
          .sb-inline-media-toolbar select,
          .sb-inline-media-toolbar button,
          .sb-inline-media-toolbar a,
          .sb-inline-media-footer button {
            font: inherit;
          }

          .sb-inline-media-toolbar input,
          .sb-inline-media-toolbar select {
            width: 100%;
            border: 1px solid #d6d3d1;
            border-radius: 8px;
            padding: 0.55rem 0.65rem;
            font-size: 0.9rem;
            color: #1f2937;
            background: #fff;
          }

          .sb-inline-media-content {
            min-height: 220px;
            overflow: auto;
            padding: 0.9rem 1rem;
          }

          .sb-inline-media-list {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.45rem;
          }

          .sb-inline-media-item {
            border: 1px solid #d6d3d1;
            border-radius: 10px;
            background: #fff;
            padding: 0.6rem 0.7rem;
            text-align: left;
            cursor: pointer;
            display: grid;
            gap: 0.2rem;
            color: #1f2937;
          }

          .sb-inline-media-item[data-active='true'] {
            border-color: #2f5e44;
            box-shadow: inset 0 0 0 1px rgba(47, 94, 68, 0.25);
            background: #f2f7f4;
          }

          .sb-inline-media-item-title {
            font-size: 0.88rem;
            font-weight: 600;
          }

          .sb-inline-media-item-meta {
            font-size: 0.74rem;
            color: #57534e;
            overflow-wrap: anywhere;
          }

          .sb-inline-media-footer {
            padding: 0.8rem 1rem;
            border-top: 1px solid #e7e5e4;
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.55rem;
          }

          .sb-inline-media-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
          }

          .sb-inline-media-btn {
            border: 1px solid #2f5e44;
            background: #2f5e44;
            color: #fff;
            border-radius: 8px;
            padding: 0.5rem 0.72rem;
            cursor: pointer;
            font-size: 0.84rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
          }

          .sb-inline-media-btn.secondary {
            background: #fff;
            color: #2f5e44;
          }

          .sb-inline-media-upload-row {
            display: grid;
            gap: 0.5rem;
          }

          .sb-inline-media-status {
            min-height: 1.2rem;
            font-size: 0.8rem;
            color: #44403c;
          }

          .sb-inline-media-status[data-kind='error'] {
            color: #991b1b;
          }

          .sb-inline-media-status[data-kind='success'] {
            color: #14532d;
          }

          @media (max-width: 768px) {
            .sb-inline-media-modal-backdrop {
              align-items: flex-end;
              padding: 0;
            }

            .sb-inline-media-modal {
              width: 100%;
              max-height: 92vh;
              border-radius: 14px 14px 0 0;
            }

            .sb-inline-media-content {
              max-height: 40vh;
            }
          }
        `;
        document.head.appendChild(styleTag);
      }

      const backdrop = document.createElement('div');
      backdrop.className = 'sb-inline-media-modal-backdrop';
      backdrop.id = 'sb-inline-media-modal';
      backdrop.setAttribute('data-open', 'false');
      backdrop.innerHTML = `
        <div class="sb-inline-media-modal" role="dialog" aria-modal="true" aria-labelledby="sb-inline-media-title">
          <div class="sb-inline-media-header">
            <div>
              <h3 id="sb-inline-media-title" class="sb-inline-media-title">Edit Image</h3>
              <p id="sb-inline-media-subtitle" class="sb-inline-media-subtitle"></p>
            </div>
            <button type="button" class="sb-inline-media-close" data-close>Close</button>
          </div>

          <div class="sb-inline-media-toolbar">
            <input type="search" id="sb-inline-media-search" placeholder="Search media library" />
            <input type="text" id="sb-inline-media-alt" placeholder="Alt text (optional override)" />
          </div>

          <div class="sb-inline-media-content">
            <div id="sb-inline-media-list" class="sb-inline-media-list"></div>
          </div>

          <div class="sb-inline-media-footer">
            <div class="sb-inline-media-upload-row">
              <input id="sb-inline-media-file" type="file" accept="image/*" />
              <div class="sb-inline-media-actions">
                <button type="button" class="sb-inline-media-btn secondary" id="sb-inline-media-upload">Upload From Device</button>
                <a id="sb-inline-media-focal-link" class="sb-inline-media-btn secondary" href="/admin/media" target="_blank" rel="noreferrer">Open Focal/Crop Editor</a>
                <button type="button" class="sb-inline-media-btn" id="sb-inline-media-save">Save Selection</button>
              </div>
            </div>
            <p id="sb-inline-media-status" class="sb-inline-media-status"></p>
          </div>
        </div>
      `;
      document.body.appendChild(backdrop);

      const searchInput = backdrop.querySelector<HTMLInputElement>('#sb-inline-media-search');
      const altInput = backdrop.querySelector<HTMLInputElement>('#sb-inline-media-alt');
      const listNode = backdrop.querySelector<HTMLDivElement>('#sb-inline-media-list');
      const saveButton = backdrop.querySelector<HTMLButtonElement>('#sb-inline-media-save');
      const uploadButton = backdrop.querySelector<HTMLButtonElement>('#sb-inline-media-upload');
      const fileInput = backdrop.querySelector<HTMLInputElement>('#sb-inline-media-file');
      const focalLink = backdrop.querySelector<HTMLAnchorElement>('#sb-inline-media-focal-link');
      const statusNode = backdrop.querySelector<HTMLParagraphElement>('#sb-inline-media-status');
      const subtitleNode = backdrop.querySelector<HTMLParagraphElement>('#sb-inline-media-subtitle');

      if (
        !searchInput
        || !altInput
        || !listNode
        || !saveButton
        || !uploadButton
        || !fileInput
        || !focalLink
        || !statusNode
        || !subtitleNode
      ) {
        return;
      }

      const setStatus = (message: string, kind: 'default' | 'error' | 'success' = 'default') => {
        statusNode.textContent = message;
        if (kind === 'default') {
          statusNode.removeAttribute('data-kind');
        } else {
          statusNode.setAttribute('data-kind', kind);
        }
      };

      const closeModal = () => {
        backdrop.setAttribute('data-open', 'false');
        document.body.style.removeProperty('overflow');
        setStatus('');
      };

      const openModal = () => {
        backdrop.setAttribute('data-open', 'true');
        document.body.style.setProperty('overflow', 'hidden');
      };

      const normalizeSlug = (value: string): string =>
        value
          .toLowerCase()
          .replace(/[^a-z0-9-_]+/g, '-')
          .replace(/-{2,}/g, '-')
          .replace(/^-+|-+$/g, '')
          .slice(0, 80);

      const toEntry = (entry: Record<string, unknown>): PhotoEntry | null => {
        const slug = typeof entry.slug === 'string' ? entry.slug : '';
        const title = typeof entry.title === 'string' && entry.title.trim().length > 0 ? entry.title.trim() : slug;
        const data = entry.data && typeof entry.data === 'object' ? entry.data as Record<string, unknown> : {};
        const category = typeof data.category === 'string' ? data.category : 'gallery';
        const sourceUrl = typeof data.sourceUrl === 'string' ? data.sourceUrl : '';
        if (!slug) return null;
        return { slug, title, category, sourceUrl };
      };

      const fetchPhotoLibrary = async () => {
        if (state.loaded) return;
        const response = await fetch('/api/cms/entries?collection=photos', {
          method: 'GET',
          credentials: 'same-origin'
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(typeof payload.error === 'string' ? payload.error : 'Failed to load media library');
        }

        const entries = Array.isArray(payload.entries) ? payload.entries : [];
        state.photos = entries
          .map((entry) => (entry && typeof entry === 'object' ? toEntry(entry as Record<string, unknown>) : null))
          .filter((entry): entry is PhotoEntry => Boolean(entry));
        state.loaded = true;
      };

      const updateFocalLink = () => {
        const slug = state.selectedSlug;
        focalLink.href = slug ? `/admin/media?slug=${encodeURIComponent(slug)}` : '/admin/media';
      };

      const renderList = () => {
        const searchTerm = searchInput.value.trim().toLowerCase();
        const filtered = state.photos.filter((photo) => {
          if (!searchTerm) return true;
          return (
            photo.slug.toLowerCase().includes(searchTerm)
            || photo.title.toLowerCase().includes(searchTerm)
            || photo.category.toLowerCase().includes(searchTerm)
          );
        });

        listNode.innerHTML = '';

        if (!filtered.length) {
          const empty = document.createElement('p');
          empty.className = 'sb-inline-media-status';
          empty.textContent = 'No images match your search.';
          listNode.appendChild(empty);
          return;
        }

        filtered.forEach((photo) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'sb-inline-media-item';
          button.setAttribute('data-active', photo.slug === state.selectedSlug ? 'true' : 'false');
          button.innerHTML = `
            <span class="sb-inline-media-item-title">${photo.title}</span>
            <span class="sb-inline-media-item-meta">${photo.slug} | ${photo.category}${photo.sourceUrl ? ' | external source' : ''}</span>
          `;
          button.addEventListener('click', () => {
            state.selectedSlug = photo.slug;
            updateFocalLink();
            renderList();
          });
          listNode.appendChild(button);
        });
      };

      const saveSlot = async (slot: string, photoSlug: string, altText: string) => {
        const response = await fetch('/api/admin/content', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            collection: 'media-slots',
            slug: normalizeSlug(slot),
            title: `Media Slot: ${normalizeSlug(slot)}`,
            status: 'published',
            data: {
              slotId: normalizeSlug(slot),
              photoSlug,
              altText: altText.trim()
            }
          })
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(typeof payload.error === 'string' ? payload.error : 'Failed to save media slot');
        }
      };

      const uploadAndAssign = async () => {
        const selectedFile = fileInput.files?.[0];
        if (!selectedFile) {
          setStatus('Choose an image file to upload first.', 'error');
          return;
        }

        setStatus('Uploading image...');

        const formData = new FormData();
        formData.append('file', selectedFile);
        formData.append('createPhotoEntry', 'true');
        formData.append('category', state.selectedCategory || 'gallery');
        formData.append('title', selectedFile.name.replace(/\.[^.]+$/, '').replace(/[-_]+/g, ' '));

        const uploadResponse = await fetch('/api/media/upload', {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });

        const uploadPayload = await uploadResponse.json().catch(() => ({}));
        if (!uploadResponse.ok) {
          throw new Error(typeof uploadPayload.error === 'string' ? uploadPayload.error : 'Upload failed');
        }

        const newSlug = typeof uploadPayload.photoSlug === 'string' ? uploadPayload.photoSlug : '';
        if (!newSlug) {
          throw new Error('Upload did not return a photo slug');
        }

        state.selectedSlug = newSlug;
        state.loaded = false;
        await fetchPhotoLibrary();
        updateFocalLink();
        renderList();

        await saveSlot(state.activeSlotId, state.selectedSlug, altInput.value);
      };

      const openFromTrigger = async (trigger: HTMLElement) => {
        const slot = trigger.dataset.slotId || '';
        const photoSlug = trigger.dataset.photoSlug || '';
        const category = trigger.dataset.mediaCategory || 'gallery';
        const altText = trigger.dataset.altText || '';

        state.activeSlotId = slot;
        state.selectedSlug = photoSlug;
        state.selectedCategory = category;

        subtitleNode.textContent = `Slot: ${slot}`;
        altInput.value = altText;
        searchInput.value = '';
        updateFocalLink();
        setStatus('Loading media library...');
        openModal();

        try {
          await fetchPhotoLibrary();
          renderList();
          setStatus('Choose an existing image or upload a new one.');
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Failed to load media library';
          setStatus(message, 'error');
        }
      };

      document.addEventListener('click', (event) => {
        const target = event.target as HTMLElement | null;
        if (!target) return;

        if (target.matches('[data-close]') || target.closest('[data-close]')) {
          closeModal();
          return;
        }

        if (target === backdrop) {
          closeModal();
          return;
        }

        const trigger = target.closest<HTMLElement>('[data-media-inline-trigger]');
        if (trigger) {
          event.preventDefault();
          openFromTrigger(trigger).catch((error) => {
            const message = error instanceof Error ? error.message : 'Failed to open image editor';
            setStatus(message, 'error');
          });
          return;
        }

        const slotContainer = target.closest<HTMLElement>('[data-media-inline-slot]');
        if (
          slotContainer
          && !target.closest('a, button, input, select, textarea, label, summary')
        ) {
          const fallbackTrigger = slotContainer.querySelector<HTMLElement>('[data-media-inline-trigger]');
          if (fallbackTrigger) {
            event.preventDefault();
            openFromTrigger(fallbackTrigger).catch((error) => {
              const message = error instanceof Error ? error.message : 'Failed to open image editor';
              setStatus(message, 'error');
            });
          }
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && backdrop.getAttribute('data-open') === 'true') {
          closeModal();
        }
      });

      searchInput.addEventListener('input', () => {
        renderList();
      });

      saveButton.addEventListener('click', async () => {
        if (!state.activeSlotId) {
          setStatus('No slot selected.', 'error');
          return;
        }

        if (!state.selectedSlug) {
          setStatus('Choose an image from the library first.', 'error');
          return;
        }

        try {
          setStatus('Saving image selection...');
          await saveSlot(state.activeSlotId, state.selectedSlug, altInput.value);
          setStatus('Saved. Refreshing page...', 'success');
          window.location.reload();
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Failed to save image selection';
          setStatus(message, 'error');
        }
      });

      uploadButton.addEventListener('click', async () => {
        if (!state.activeSlotId) {
          setStatus('No slot selected.', 'error');
          return;
        }

        try {
          await uploadAndAssign();
          setStatus('Image uploaded and assigned. Refreshing page...', 'success');
          window.location.reload();
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Failed to upload and assign image';
          setStatus(message, 'error');
        }
      });
    })();
  </script>
)}

