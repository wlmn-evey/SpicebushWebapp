            }

            const rect = candidate.getBoundingClientRect();
            if (rect.width < 1 || rect.height < 1) return null;

            const overlapLeft = Math.max(imageRect.left, rect.left);
            const overlapTop = Math.max(imageRect.top, rect.top);
            const overlapRight = Math.min(imageRect.right, rect.right);
            const overlapBottom = Math.min(imageRect.bottom, rect.bottom);
            const overlapWidth = overlapRight - overlapLeft;
            const overlapHeight = overlapBottom - overlapTop;
            if (overlapWidth <= 0 || overlapHeight <= 0) return null;

            const overlapArea = overlapWidth * overlapHeight;
            const overlapRatio = overlapArea / imageArea;
            if (overlapRatio < 0.005 && text.length < 8) return null;

            return {
              text: text.slice(0, 120),
              x: toPercent(((overlapLeft - imageRect.left) / imageRect.width) * 100),
              y: toPercent(((overlapTop - imageRect.top) / imageRect.height) * 100),
              width: toPercent((overlapWidth / imageRect.width) * 100),
              height: toPercent((overlapHeight / imageRect.height) * 100),
              overlapRatio: toPercent(overlapRatio * 100)
            };
          })
          .filter((region): region is {
            text: string;
            x: number;
            y: number;
            width: number;
            height: number;
            overlapRatio: number;
          } => Boolean(region))
          .sort((a, b) => b.overlapRatio - a.overlapRatio)
          .slice(0, 12);

        return {
          pagePath: window.location.pathname,
          viewport,
          image: {
            naturalWidth: imageElement.naturalWidth || Number.parseInt(imageElement.getAttribute('width') || '0', 10),
            naturalHeight: imageElement.naturalHeight || Number.parseInt(imageElement.getAttribute('height') || '0', 10),
            renderedWidth: imageRect.width,
            renderedHeight: imageRect.height,
            className: imageElement.className
          },
          sectionSummary: (sectionRoot.textContent || '').replace(/\s+/g, ' ').trim().slice(0, 420),
          overlapRegions,
          imageDetailHint: computeImageDetailHint(imageElement)
        };
      };

      const runSmartAdjust = async () => {
        if (!state.activeSlotId) {
          setStatus('No slot selected.', 'error');
          return;
        }

        if (!state.selectedSlug) {
          setStatus('Choose an image from the library first.', 'error');
          return;
        }

        const { imageElement: activeImage } = getActiveImageElement();
        const usesServerCrop = activeImage?.dataset.sbServerCrop === 'true';
        const usesAiFill = activeImage?.dataset.sbAiFill === 'true';
        if (activeImage && !usesServerCrop && !usesAiFill && (activeImage.dataset.sbAutoFocus || 'true') !== 'true') {
          setStatus(
            'This image is using fixed template positioning, so Smart Adjust cannot move it yet.',
            'error'
          );
          return;
        }

        smartAdjustButton.setAttribute('disabled', 'disabled');
        saveButton.setAttribute('disabled', 'disabled');
        uploadButton.setAttribute('disabled', 'disabled');
        aiFillButton.setAttribute('disabled', 'disabled');

        try {
          setStatus('Smart Adjust is analyzing this page...');

          const response = await fetch('/api/admin/smart-adjust', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              slotId: state.activeSlotId,
              photoSlug: state.selectedSlug,
              pagePath: window.location.pathname,
              context: collectSmartAdjustContext()
            })
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            throw new Error(typeof payload.error === 'string' ? payload.error : 'Smart Adjust failed');
          }

          const suggestion = payload.suggestion && typeof payload.suggestion === 'object'
            ? payload.suggestion as Record<string, unknown>
            : null;
          if (!suggestion) {
            throw new Error('Smart Adjust returned no placement suggestion');
          }

          const toNumber = (value: unknown, fallback: number) => {
            const parsed = Number.parseFloat(String(value));
            return Number.isFinite(parsed) ? parsed : fallback;
          };
          const clampValue = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));
          const normalizeCropAxis = (value: number, size: number) => clampValue(value, 0, 100 - size);
          const normalizeCropSize = (value: number) => clampValue(value, 10, 100);
          const round = (value: number) => Math.round(value * 10) / 10;

          const mobileWidth = normalizeCropSize(toNumber(suggestion.mobileCropWidth, 100));
          const mobileHeight = normalizeCropSize(toNumber(suggestion.mobileCropHeight, 100));
          const tabletWidth = normalizeCropSize(toNumber(suggestion.tabletCropWidth, 100));
          const tabletHeight = normalizeCropSize(toNumber(suggestion.tabletCropHeight, 100));

          const placementOverrides = {
            desktopFocalX: round(clampValue(toNumber(suggestion.desktopFocalX, 50), 0, 100)),
            desktopFocalY: round(clampValue(toNumber(suggestion.desktopFocalY, 50), 0, 100)),
            mobileCropX: round(normalizeCropAxis(toNumber(suggestion.mobileCropX, 0), mobileWidth)),
            mobileCropY: round(normalizeCropAxis(toNumber(suggestion.mobileCropY, 0), mobileHeight)),
            mobileCropWidth: round(mobileWidth),
            mobileCropHeight: round(mobileHeight),
            tabletCropX: round(normalizeCropAxis(toNumber(suggestion.tabletCropX, 0), tabletWidth)),
            tabletCropY: round(normalizeCropAxis(toNumber(suggestion.tabletCropY, 0), tabletHeight)),
            tabletCropWidth: round(tabletWidth),
            tabletCropHeight: round(tabletHeight)
          };
          const layoutProfile = collectLayoutProfile();

          await saveSlot(state.activeSlotId, state.selectedSlug, altInput.value, placementOverrides, layoutProfile);

          const sourceLabel = typeof payload.source === 'string' ? payload.source : 'smart';
          const warningMessage = typeof payload.warning === 'string'
            ? payload.warning.trim().slice(0, 260)
            : '';
          const changed = payload.changed !== false;

          if (changed) {
            const statusMessage = warningMessage.length > 0
              ? `Smart Adjust applied (${sourceLabel}) at ${placementOverrides.desktopFocalX}%, ${placementOverrides.desktopFocalY}%. ${warningMessage} Refreshing page...`
              : `Smart Adjust applied (${sourceLabel}) at ${placementOverrides.desktopFocalX}%, ${placementOverrides.desktopFocalY}%. Refreshing page...`;
            setStatus(statusMessage, 'success');
            window.setTimeout(() => {
              window.location.reload();
            }, 500);
            return;
          }

          const noChangeMessage = warningMessage.length > 0
            ? `Smart Adjust ran (${sourceLabel}) but returned the same framing. ${warningMessage}`
            : `Smart Adjust ran (${sourceLabel}) but returned the same framing.`;
          setStatus(noChangeMessage, 'default');
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Smart Adjust failed';
          setStatus(message, 'error');
        } finally {
          smartAdjustButton.removeAttribute('disabled');
          saveButton.removeAttribute('disabled');
          uploadButton.removeAttribute('disabled');
          aiFillButton.removeAttribute('disabled');
        }
      };

      const runAiFill = async () => {
        if (!state.activeSlotId) {
          setStatus('No slot selected.', 'error');
          return;
        }

        if (!state.selectedSlug) {
          setStatus('Choose an image from the library first.', 'error');
          return;
        }

        const { imageElement } = getActiveImageElement();
        if (!imageElement) {
          setStatus('Could not find the active image on the page.', 'error');
          return;
        }

        const rect = imageElement.getBoundingClientRect();
        const targetWidth = Math.max(180, Math.round(rect.width || imageElement.clientWidth || 0));
        const targetHeight = Math.max(120, Math.round(rect.height || imageElement.clientHeight || 0));
        const breakpoint = getCurrentBreakpoint();

        aiFillButton.setAttribute('disabled', 'disabled');
        smartAdjustButton.setAttribute('disabled', 'disabled');
        saveButton.setAttribute('disabled', 'disabled');
        uploadButton.setAttribute('disabled', 'disabled');

        try {
          setStatus(`Generating AI Fill for ${breakpoint} layout...`);

          const response = await fetch('/api/admin/media/ai-fill', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              slotId: state.activeSlotId,
              photoSlug: state.selectedSlug,
              breakpoint,
              targetWidth,
              targetHeight
            })
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            throw new Error(typeof payload.error === 'string' ? payload.error : 'AI Fill failed');
          }

          const returnedBreakpoint = typeof payload.breakpoint === 'string' ? payload.breakpoint : breakpoint;
          setStatus(`AI Fill generated for ${returnedBreakpoint}. Refreshing page...`, 'success');
          window.setTimeout(() => {
            window.location.reload();
          }, 600);
        } catch (error) {
          const message = error instanceof Error ? error.message : 'AI Fill failed';
          setStatus(message, 'error');
        } finally {
          aiFillButton.removeAttribute('disabled');
          smartAdjustButton.removeAttribute('disabled');
          saveButton.removeAttribute('disabled');
          uploadButton.removeAttribute('disabled');
        }
      };

      const uploadAndAssign = async () => {
        const selectedFile = fileInput.files?.[0];
        if (!selectedFile) {
          setStatus('Choose an image file to upload first.', 'error');
          return;
        }

        setStatus('Uploading image...');

        const formData = new FormData();
        formData.append('file', selectedFile);
        formData.append('createPhotoEntry', 'true');
        formData.append('category', state.selectedCategory || 'gallery');
        formData.append('title', selectedFile.name.replace(/\.[^.]+$/, '').replace(/[-_]+/g, ' '));

        const uploadResponse = await fetch('/api/media/upload', {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });

        const uploadPayload = await uploadResponse.json().catch(() => ({}));
        if (!uploadResponse.ok) {
          throw new Error(typeof uploadPayload.error === 'string' ? uploadPayload.error : 'Upload failed');
        }

        const newSlug = typeof uploadPayload.photoSlug === 'string' ? uploadPayload.photoSlug : '';
        if (!newSlug) {
          throw new Error('Upload did not return a photo slug');
        }

        state.selectedSlug = newSlug;
        state.loaded = false;
        await fetchPhotoLibrary();
        updateFocalLink();
        renderList();

        await saveSlot(state.activeSlotId, state.selectedSlug, altInput.value, undefined, collectLayoutProfile());
      };

      const openFromTrigger = async (trigger: HTMLElement) => {
        const slot = trigger.dataset.slotId || '';
        const photoSlug = trigger.dataset.photoSlug || '';
        const category = trigger.dataset.mediaCategory || 'gallery';
        const altText = trigger.dataset.altText || '';

        state.activeTrigger = trigger;
        state.activeSlotId = slot;
        state.selectedSlug = photoSlug;
        state.selectedCategory = category;

        subtitleNode.textContent = `Slot: ${slot}`;
        altInput.value = altText;
        searchInput.value = '';
        updateFocalLink();
        setStatus('Loading media library...');
        openModal();

        try {
          await fetchPhotoLibrary();
          renderList();
          setStatus('Choose an existing image or upload a new one.');
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Failed to load media library';
          setStatus(message, 'error');
        }
      };

      document.addEventListener('click', (event) => {
        const target = event.target as HTMLElement | null;
        if (!target) return;

        if (target.matches('[data-close]') || target.closest('[data-close]')) {
          closeModal();
          return;
        }

        if (target === backdrop) {
          closeModal();
          return;
        }

        const trigger = target.closest<HTMLElement>('[data-media-inline-trigger]');
        if (trigger) {
          event.preventDefault();
          openFromTrigger(trigger).catch((error) => {
            const message = error instanceof Error ? error.message : 'Failed to open image editor';
            setStatus(message, 'error');
          });
          return;
        }

        const slotContainer = target.closest<HTMLElement>('[data-media-inline-slot]');
        if (
          slotContainer
          && !target.closest('a, button, input, select, textarea, label, summary')
        ) {
          const fallbackTrigger = slotContainer.querySelector<HTMLElement>('[data-media-inline-trigger]');
          if (fallbackTrigger) {
            event.preventDefault();
            openFromTrigger(fallbackTrigger).catch((error) => {
              const message = error instanceof Error ? error.message : 'Failed to open image editor';
              setStatus(message, 'error');
            });
          }
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && backdrop.getAttribute('data-open') === 'true') {
          closeModal();
        }
      });

      searchInput.addEventListener('input', () => {
        renderList();
      });

      saveButton.addEventListener('click', async () => {
        if (!state.activeSlotId) {
          setStatus('No slot selected.', 'error');
          return;
        }

        if (!state.selectedSlug) {
          setStatus('Choose an image from the library first.', 'error');
          return;
        }

        try {
          setStatus('Saving image selection...');
          await saveSlot(state.activeSlotId, state.selectedSlug, altInput.value, undefined, collectLayoutProfile());
          setStatus('Saved. Refreshing page...', 'success');
          window.location.reload();
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Failed to save image selection';
          setStatus(message, 'error');
        }
      });

      uploadButton.addEventListener('click', async () => {
        if (!state.activeSlotId) {
          setStatus('No slot selected.', 'error');
          return;
        }

        try {
          await uploadAndAssign();
          setStatus('Image uploaded and assigned. Refreshing page...', 'success');
          window.location.reload();
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Failed to upload and assign image';
          setStatus(message, 'error');
        }
      });

      smartAdjustButton.addEventListener('click', async () => {
        await runSmartAdjust();
      });

      aiFillButton.addEventListener('click', async () => {
        await runAiFill();
      });
    })();
  </script>
)}

