    transform: translateY(-2px);
    transition: opacity 0.16s ease, transform 0.16s ease;
  }

  .optimized-image:hover .media-inline-trigger,
  .optimized-image:focus-within .media-inline-trigger {
    opacity: 1;
    transform: translateY(0);
  }

  .optimized-image:hover .media-variant-debug,
  .optimized-image:focus-within .media-variant-debug {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .media-variant-debug,
    .media-inline-trigger {
      opacity: 1;
      transform: translateY(0);
