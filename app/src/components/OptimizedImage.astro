  .focal-point-primary {
    @apply bg-red-500;
  }

  .focal-point-secondary {
    @apply bg-blue-500 w-3 h-3 -translate-x-1.5 -translate-y-1.5;
  }

  .crop-zone {
    @apply absolute border-2;
  }

  .crop-zone-mobile {
    @apply border-green-400 bg-green-400/20;
  }

  @media (min-width: 768px) {
    .crop-zone-mobile {
      @apply hidden;
    }
  }

  .crop-zone-tablet {
    @apply border-orange-400 bg-orange-400/20 hidden;
  }

  @media (min-width: 768px) {
    .crop-zone-tablet {
      @apply block;
    }
  }

  @media (min-width: 1024px) {
    .crop-zone-tablet {
      @apply hidden;
    }
  }
</style>
