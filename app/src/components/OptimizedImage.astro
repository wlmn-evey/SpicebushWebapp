---
interface Props {
  photoSlug: string;
  className?: string;
  style?: string;
  priority?: boolean;
  sizes?: string;
  objectFit?: 'cover' | 'contain' | 'fill' | 'scale-down' | 'none';
  objectPosition?: string;
  loading?: 'lazy' | 'eager';
  showFocalPoints?: boolean;
  alt?: string;
  slotId?: string;
  editable?: boolean;
  mediaCategory?: string;
}

import { getEntry as getContentEntry } from 'astro:content';
import { db } from '@lib/db';
import { logServerError } from '@lib/server-logger';
import { getPhotoFramingDefaults } from '@lib/photo-framing-defaults';

const {
  photoSlug,
  className = 'w-full h-full',
  style = '',
  priority = false,
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  objectFit = 'cover',
  objectPosition,
  loading,
  showFocalPoints = false,
  alt,
  slotId,
  editable = true,
  mediaCategory
} = Astro.props;

const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));

const asRecord = (value: unknown): Record<string, unknown> => {
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    return value as Record<string, unknown>;
  }
  return {};
};

const stringFrom = (value: unknown, fallback = ''): string => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.length > 0) return trimmed;
  }
  return fallback;
};

const numberFrom = (value: unknown, fallback: number): number => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value === 'string') {
    const parsed = Number.parseFloat(value.trim());
    if (Number.isFinite(parsed)) return parsed;
  }
  return fallback;
};

const optionalNumberFrom = (value: unknown): number | null => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value === 'string') {
    const parsed = Number.parseFloat(value.trim());
    if (Number.isFinite(parsed)) return parsed;
  }
  return null;
};

const toSlotSlug = (value: string): string =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9-_]+/g, '-')
    .replace(/-{2,}/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 80);

const normalizeCrop = (
  xInput: unknown,
  yInput: unknown,
  widthInput: unknown,
  heightInput: unknown,
  defaults: { x: number; y: number; width: number; height: number }
) => {
  const width = clamp(numberFrom(widthInput, defaults.width), 10, 100);
  const height = clamp(numberFrom(heightInput, defaults.height), 10, 100);
  const x = clamp(numberFrom(xInput, defaults.x), 0, 100 - width);
  const y = clamp(numberFrom(yInput, defaults.y), 0, 100 - height);

  return {
    x: Math.round(x * 10) / 10,
    y: Math.round(y * 10) / 10,
    width: Math.round(width * 10) / 10,
    height: Math.round(height * 10) / 10
  };
};

const gallerySubcategories = new Set([
  'art',
  'classroom',
  'events',
  'group',
  'individual',
  'materials',
  'outdoor',
  'practical'
]);

const locals = Astro.locals as unknown as Record<string, unknown>;
const isAdmin = locals.isAdmin === true;

const routeScopedFallbackSlot = toSlotSlug(`${Astro.url.pathname}-${photoSlug}`);
const computedSlotId = toSlotSlug(stringFrom(slotId, routeScopedFallbackSlot));
const canInlineEdit = editable && isAdmin && computedSlotId.length > 0;

let slotAltOverride = '';
let requestedPhotoSlug = photoSlug;
let slotPlacementOverrides: Record<string, unknown> = {};

if (computedSlotId.length > 0) {
  try {
    const slotEntry = await db.content.getEntry('media-slots', computedSlotId);
    const slotData = asRecord(slotEntry?.data);
    const assignedPhotoSlug = stringFrom(slotData.photoSlug, '');
    if (assignedPhotoSlug) {
      requestedPhotoSlug = assignedPhotoSlug;
    }
    slotAltOverride = stringFrom(slotData.altText, '');
    slotPlacementOverrides = slotData;
  } catch (error) {
    logServerError('Media slot lookup failed', error, { component: 'OptimizedImage', computedSlotId });
  }
}

const resolvePhotoData = async (
  slugToLookup: string
): Promise<{ resolvedSlug: string; photoData: Record<string, unknown> } | null> => {
  try {
    const dbPhoto = await db.content.getEntry('photos', slugToLookup);
    if (dbPhoto?.data) {
      return {
        resolvedSlug: dbPhoto.slug,
        photoData: asRecord(dbPhoto.data)
      };
    }
  } catch (error) {
    logServerError('Database photo lookup failed', error, { component: 'OptimizedImage', photoSlug: slugToLookup });
  }

  try {
    const contentPhoto = await getContentEntry('photos', slugToLookup);
    if (contentPhoto?.data) {
      return {
        resolvedSlug: contentPhoto.slug,
        photoData: asRecord(contentPhoto.data)
      };
    }
  } catch (error) {
    logServerError('Photo content lookup failed', error, { component: 'OptimizedImage', photoSlug: slugToLookup });
  }

  return null;
};

let photoLookup = await resolvePhotoData(requestedPhotoSlug);
if (!photoLookup && requestedPhotoSlug !== photoSlug) {
  photoLookup = await resolvePhotoData(photoSlug);
}

if (!photoLookup) {
  return null;
}

const resolvedSlug = photoLookup.resolvedSlug;
const photoData = photoLookup.photoData;

const category = stringFrom(photoData.category, 'homepage');
const sourceUrl = stringFrom(photoData.sourceUrl, '');
const optimizedFilename = stringFrom(photoData.optimizedFilename, `${resolvedSlug}.webp`);

const originalWidth = Math.max(1, Math.round(numberFrom(photoData.originalWidth, 1280)));
const originalHeight = Math.max(1, Math.round(numberFrom(photoData.originalHeight, 800)));
const framingDefaults = getPhotoFramingDefaults({
  category,
  width: originalWidth,
  height: originalHeight,
  slug: resolvedSlug
});

const altText = stringFrom(photoData.altText, resolvedSlug);
const effectiveAlt = alt || slotAltOverride || altText;
const primaryFocalX = clamp(numberFrom(photoData.primaryFocalX, framingDefaults.primaryFocalX), 0, 100);
const primaryFocalY = clamp(numberFrom(photoData.primaryFocalY, framingDefaults.primaryFocalY), 0, 100);
const desktopFocalX = clamp(
  numberFrom(slotPlacementOverrides.desktopFocalX, numberFrom(photoData.desktopFocalX, primaryFocalX)),
  0,
  100
);
const desktopFocalY = clamp(
  numberFrom(slotPlacementOverrides.desktopFocalY, numberFrom(photoData.desktopFocalY, primaryFocalY)),
  0,
  100
);

const secondaryFocalX = optionalNumberFrom(photoData.secondaryFocalX);
const secondaryFocalY = optionalNumberFrom(photoData.secondaryFocalY);

const mobileCrop = normalizeCrop(
  slotPlacementOverrides.mobileCropX ?? photoData.mobileCropX,
  slotPlacementOverrides.mobileCropY ?? photoData.mobileCropY,
  slotPlacementOverrides.mobileCropWidth ?? photoData.mobileCropWidth,
  slotPlacementOverrides.mobileCropHeight ?? photoData.mobileCropHeight,
  {
    x: framingDefaults.mobileCropX,
    y: framingDefaults.mobileCropY,
    width: framingDefaults.mobileCropWidth,
    height: framingDefaults.mobileCropHeight
  }
);
const tabletCrop = normalizeCrop(
  slotPlacementOverrides.tabletCropX ?? photoData.tabletCropX,
  slotPlacementOverrides.tabletCropY ?? photoData.tabletCropY,
  slotPlacementOverrides.tabletCropWidth ?? photoData.tabletCropWidth,
  slotPlacementOverrides.tabletCropHeight ?? photoData.tabletCropHeight,
  {
    x: framingDefaults.tabletCropX,
    y: framingDefaults.tabletCropY,
    width: framingDefaults.tabletCropWidth,
    height: framingDefaults.tabletCropHeight
  }
);
const mobileFocusX = Math.round((mobileCrop.x + (mobileCrop.width / 2)) * 10) / 10;
const mobileFocusY = Math.round((mobileCrop.y + (mobileCrop.height / 2)) * 10) / 10;
const tabletFocusX = Math.round((tabletCrop.x + (tabletCrop.width / 2)) * 10) / 10;
const tabletFocusY = Math.round((tabletCrop.y + (tabletCrop.height / 2)) * 10) / 10;
const roundTenth = (value: number) => Math.round(value * 10) / 10;
const sourceAspect = originalWidth / originalHeight;

const resolveBreakpointSize = (
  widthKey: string,
  heightKey: string,
  fallbackWidth: number,
  fallbackHeight: number
) => {
  const width = Math.round(clamp(numberFrom(slotPlacementOverrides[widthKey], fallbackWidth), 180, 2200));
  const height = Math.round(clamp(numberFrom(slotPlacementOverrides[heightKey], fallbackHeight), 120, 2200));
  return { width, height };
};

const mobileTarget = resolveBreakpointSize('mobileTargetWidth', 'mobileTargetHeight', 640, 480);
const tabletTarget = resolveBreakpointSize('tabletTargetWidth', 'tabletTargetHeight', 960, 640);
const desktopTarget = resolveBreakpointSize('desktopTargetWidth', 'desktopTargetHeight', 1280, 853);

const deriveAspectAwareCrop = (
  focusX: number,
  focusY: number,
  targetWidth: number,
  targetHeight: number
) => {
  const targetAspect = targetHeight > 0 ? targetWidth / targetHeight : sourceAspect;
  if (!Number.isFinite(targetAspect) || targetAspect <= 0 || !Number.isFinite(sourceAspect) || sourceAspect <= 0) {
    return {
      x: 0,
      y: 0,
      width: 100,
      height: 100
    };
  }

  let cropWidth = 100;
  let cropHeight = 100;
  if (targetAspect > sourceAspect) {
    cropHeight = clamp((sourceAspect / targetAspect) * 100, 10, 100);
  } else if (targetAspect < sourceAspect) {
    cropWidth = clamp((targetAspect / sourceAspect) * 100, 10, 100);
  }

  const x = clamp(focusX - (cropWidth / 2), 0, 100 - cropWidth);
  const y = clamp(focusY - (cropHeight / 2), 0, 100 - cropHeight);

  return {
    x: roundTenth(x),
    y: roundTenth(y),
    width: roundTenth(cropWidth),
    height: roundTenth(cropHeight)
  };
};

const desktopCrop = deriveAspectAwareCrop(
  desktopFocalX,
  desktopFocalY,
  desktopTarget.width,
  desktopTarget.height
);

const objectPositionDesktop = `${desktopFocalX}% ${desktopFocalY}%`;
const objectPositionTablet = `${tabletFocusX}% ${tabletFocusY}%`;
const objectPositionMobile = `${mobileFocusX}% ${mobileFocusY}%`;
const responsivePositionDesktop = objectPosition || objectPositionDesktop;
const responsivePositionTablet = objectPosition || objectPositionTablet;
const responsivePositionMobile = objectPosition || objectPositionMobile;

const basePath = sourceUrl
  ? ''
  : (gallerySubcategories.has(category)
    ? `/images/optimized/gallery/${category}`
    : `/images/optimized/${category}`);

const webpSrc = sourceUrl || `${basePath}/${optimizedFilename}`;
const jpgFallback = sourceUrl || `${basePath}/${resolvedSlug}-640w.jpg`;

const responsiveSources = sourceUrl
  ? [`${sourceUrl} ${originalWidth}w`]
  : [320, 640, 960, 1280]
    .filter((width) => width <= originalWidth)
    .map((width) => `${basePath}/${resolvedSlug}-${width}w.webp ${width}w`);

if (!sourceUrl && originalWidth > 1280) {
  responsiveSources.push(`${webpSrc} ${originalWidth}w`);
}

if (responsiveSources.length === 0) {
  responsiveSources.push(`${webpSrc} ${originalWidth}w`);
}

const hasNumericOverride = (key: string): boolean => {
  const value = slotPlacementOverrides[key];
  if (typeof value === 'number') {
    return Number.isFinite(value);
  }
  if (typeof value === 'string') {
    const parsed = Number.parseFloat(value.trim());
    return Number.isFinite(parsed);
  }
  return false;
};

const hasCustomSlotFraming = [
  'desktopFocalX',
  'desktopFocalY',
  'mobileCropX',
  'mobileCropY',
  'mobileCropWidth',
  'mobileCropHeight',
  'tabletCropX',
  'tabletCropY',
  'tabletCropWidth',
  'tabletCropHeight'
].some((key) => hasNumericOverride(key));

const aiFillMobileUrl = stringFrom(slotPlacementOverrides.aiFillMobileUrl, '');
const aiFillTabletUrl = stringFrom(slotPlacementOverrides.aiFillTabletUrl, '');
const aiFillDesktopUrl = stringFrom(slotPlacementOverrides.aiFillDesktopUrl, '');
const hasAiFillVariant = Boolean(aiFillMobileUrl || aiFillTabletUrl || aiFillDesktopUrl);

const sourceForRenderer = sourceUrl || `${basePath}/${optimizedFilename}`;
const canUseServerCropSource = !objectPosition
  && hasCustomSlotFraming
  && (
    sourceForRenderer.startsWith('/')
    || sourceForRenderer.startsWith('https://spicebushmontessori.org')
    || sourceForRenderer.includes('.netlify.app')
  );
const canUseBreakpointSources = canUseServerCropSource || hasAiFillVariant;

const buildRenderedUrl = (
  crop: { x: number; y: number; width: number; height: number },
  outputSize: { width: number; height: number },
  format: 'webp' | 'jpg'
): string => {
  const params = new URLSearchParams();
  params.set('src', sourceForRenderer);
  params.set('x', `${crop.x}`);
  params.set('y', `${crop.y}`);
  params.set('w', `${crop.width}`);
  params.set('h', `${crop.height}`);
  params.set('ow', `${outputSize.width}`);
  params.set('oh', `${outputSize.height}`);
  params.set('fm', format);
  return `/api/media/render?${params.toString()}`;
};

const mobileCropSrcSet = canUseServerCropSource
  ? [360, 480, 640, 768]
    .map((width) => {
      const ratio = mobileTarget.width > 0 ? width / mobileTarget.width : 1;
      const height = Math.max(120, Math.round(mobileTarget.height * ratio));
      return `${buildRenderedUrl(mobileCrop, { width, height }, 'webp')} ${width}w`;
    })
    .join(', ')
  : '';
const tabletCropSrcSet = canUseServerCropSource
  ? [768, 960, 1200]
    .map((width) => {
      const ratio = tabletTarget.width > 0 ? width / tabletTarget.width : 1;
      const height = Math.max(120, Math.round(tabletTarget.height * ratio));
      return `${buildRenderedUrl(tabletCrop, { width, height }, 'webp')} ${width}w`;
    })
    .join(', ')
  : '';
const desktopCropSrcSet = canUseServerCropSource
  ? [1024, 1280, 1600]
    .map((width) => {
      const ratio = desktopTarget.width > 0 ? width / desktopTarget.width : 1;
      const height = Math.max(120, Math.round(desktopTarget.height * ratio));
      return `${buildRenderedUrl(desktopCrop, { width, height }, 'webp')} ${width}w`;
    })
    .join(', ')
  : '';

const mobileBreakpointSrcSet = aiFillMobileUrl
  ? `${aiFillMobileUrl} ${mobileTarget.width}w`
  : mobileCropSrcSet;
const tabletBreakpointSrcSet = aiFillTabletUrl
  ? `${aiFillTabletUrl} ${tabletTarget.width}w`
  : tabletCropSrcSet;
const desktopBreakpointSrcSet = aiFillDesktopUrl
  ? `${aiFillDesktopUrl} ${desktopTarget.width}w`
  : desktopCropSrcSet;

const renderedJpgFallback = aiFillDesktopUrl
  || aiFillTabletUrl
  || aiFillMobileUrl
  || (canUseServerCropSource ? buildRenderedUrl(desktopCrop, desktopTarget, 'jpg') : jpgFallback);

const mobileVariantMode = aiFillMobileUrl ? 'ai-fill' : (canUseServerCropSource ? 'crop' : 'focus');
const tabletVariantMode = aiFillTabletUrl ? 'ai-fill' : (canUseServerCropSource ? 'crop' : 'focus');
const desktopVariantMode = aiFillDesktopUrl ? 'ai-fill' : (canUseServerCropSource ? 'crop' : 'focus');
const variantDebugLabel = `M:${mobileVariantMode} T:${tabletVariantMode} D:${desktopVariantMode}`;
const variantDebugTitle = [
  `Mobile: ${mobileVariantMode} (${mobileTarget.width}x${mobileTarget.height})`,
  `Tablet: ${tabletVariantMode} (${tabletTarget.width}x${tabletTarget.height})`,
  `Desktop: ${desktopVariantMode} (${desktopTarget.width}x${desktopTarget.height})`
].join(' | ');

const srcSet = responsiveSources.join(', ');
const loadingStrategy = loading || (priority ? 'eager' : 'lazy');
const imageId = `img-${Math.random().toString(36).slice(2, 11)}`;

const uploadCategory = toSlotSlug(stringFrom(mediaCategory, category || 'gallery')) || 'gallery';
---

<div
  class="optimized-image"
  data-photo-slug={resolvedSlug}
  data-media-inline-slot={canInlineEdit ? computedSlotId : undefined}
>
  <picture>
    {canUseBreakpointSources ? (
      <>
        {mobileBreakpointSrcSet && (
          <source
            media="(max-width: 767px)"
            type="image/webp"
            srcset={mobileBreakpointSrcSet}
            sizes={sizes}
          />
        )}
        {tabletBreakpointSrcSet && (
          <source
            media="(min-width: 768px) and (max-width: 1023px)"
            type="image/webp"
            srcset={tabletBreakpointSrcSet}
            sizes={sizes}
          />
        )}
        {desktopBreakpointSrcSet && (
          <source
            media="(min-width: 1024px)"
            type="image/webp"
            srcset={desktopBreakpointSrcSet}
            sizes={sizes}
          />
        )}
        <source
          type="image/webp"
          srcset={srcSet}
          sizes={sizes}
        />
      </>
    ) : (
      <source
        type="image/webp"
        srcset={srcSet}
        sizes={sizes}
      />
    )}

    <img
      src={renderedJpgFallback}
      alt={effectiveAlt}
      width={originalWidth}
      height={originalHeight}
      loading={loadingStrategy}
      decoding={priority ? 'sync' : 'async'}
      class={`optimized-image-element ${className}`}
      data-image-id={imageId}
      data-sb-object-fit={objectFit}
      data-sb-auto-focus={objectPosition || canUseBreakpointSources ? 'false' : 'true'}
      data-sb-server-crop={canUseServerCropSource ? 'true' : 'false'}
      data-sb-ai-fill={hasAiFillVariant ? 'true' : 'false'}
      data-sb-variant-mobile={mobileVariantMode}
      data-sb-variant-tablet={tabletVariantMode}
      data-sb-variant-desktop={desktopVariantMode}
      data-sb-target-mobile={`${mobileTarget.width}x${mobileTarget.height}`}
      data-sb-target-tablet={`${tabletTarget.width}x${tabletTarget.height}`}
      data-sb-target-desktop={`${desktopTarget.width}x${desktopTarget.height}`}
      data-sb-focus-mobile-x={mobileFocusX}
      data-sb-focus-mobile-y={mobileFocusY}
      data-sb-focus-tablet-x={tabletFocusX}
      data-sb-focus-tablet-y={tabletFocusY}
      data-sb-focus-desktop-x={desktopFocalX}
      data-sb-focus-desktop-y={desktopFocalY}
      style={`object-fit: ${objectFit}; --sb-pos-mobile: ${responsivePositionMobile}; --sb-pos-tablet: ${responsivePositionTablet}; --sb-pos-desktop: ${responsivePositionDesktop}; object-position: var(--sb-pos-mobile); ${style}`}
    />
  </picture>

  {canInlineEdit && (
    <div
      class="media-variant-debug"
      title={variantDebugTitle}
      aria-label={variantDebugTitle}
    >
      {variantDebugLabel}
    </div>
  )}

  {canInlineEdit && (
    <button
      type="button"
      class="media-inline-trigger"
      data-media-inline-trigger
      data-slot-id={computedSlotId}
      data-photo-slug={resolvedSlug}
      data-media-category={uploadCategory}
      data-alt-text={effectiveAlt}
      aria-label="Edit this image"
      title="Edit this image"
    >
      Edit image
    </button>
  )}

  {showFocalPoints && (
    <div class="focal-points-debug">
      <div
        class="focal-point focal-point-primary"
        style={`left: ${desktopFocalX}%; top: ${desktopFocalY}%;`}
        title={`Desktop: ${desktopFocalX}%, ${desktopFocalY}%`}
      ></div>

      {secondaryFocalX !== null && secondaryFocalY !== null && (
        <div
          class="focal-point focal-point-secondary"
          style={`left: ${secondaryFocalX}%; top: ${secondaryFocalY}%;`}
          title={`Secondary: ${secondaryFocalX}%, ${secondaryFocalY}%`}
        ></div>
      )}

      <div
        class="crop-zone crop-zone-mobile"
        style={`left: ${mobileCrop.x}%; top: ${mobileCrop.y}%; width: ${mobileCrop.width}%; height: ${mobileCrop.height}%;`}
        title="Mobile crop zone"
      ></div>

      <div
        class="crop-zone crop-zone-tablet"
        style={`left: ${tabletCrop.x}%; top: ${tabletCrop.y}%; width: ${tabletCrop.width}%; height: ${tabletCrop.height}%;`}
        title="Tablet crop zone"
      ></div>
    </div>
  )}
</div>

<script is:inline>
  (() => {
    const runtimeWindow = window;
    if (runtimeWindow.__sbFocalRuntimeInit) {
      if (typeof runtimeWindow.__sbFocalRuntimeApply === 'function') {
        runtimeWindow.__sbFocalRuntimeApply();
      }
      return;
    }

    runtimeWindow.__sbFocalRuntimeInit = true;

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const parseNumber = (value, fallback) => {
      if (typeof value !== 'string') return fallback;
      const parsed = Number.parseFloat(value);
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const getBreakpoint = () => {
      if (window.matchMedia('(min-width: 1024px)').matches) return 'desktop';
      if (window.matchMedia('(min-width: 768px)').matches) return 'tablet';
      return 'mobile';
    };

    const getTargetPoint = (img) => {
      const desktopX = parseNumber(img.dataset.sbFocusDesktopX, 50);
      const desktopY = parseNumber(img.dataset.sbFocusDesktopY, 50);
      const breakpoint = getBreakpoint();

      if (breakpoint === 'mobile') {
        return {
          x: parseNumber(img.dataset.sbFocusMobileX, desktopX),
          y: parseNumber(img.dataset.sbFocusMobileY, desktopY)
        };
      }

      if (breakpoint === 'tablet') {
        return {
          x: parseNumber(img.dataset.sbFocusTabletX, desktopX),
          y: parseNumber(img.dataset.sbFocusTabletY, desktopY)
        };
      }

      return { x: desktopX, y: desktopY };
    };

    const computeAxisPosition = (containerSize, renderedSize, targetPercent) => {
      const overflow = renderedSize - containerSize;
      if (!Number.isFinite(overflow) || overflow <= 0) {
        return 50;
      }

      const targetPoint = (clamp(targetPercent, 0, 100) / 100) * renderedSize;
      const preferredOffset = (containerSize / 2) - targetPoint;
      const minOffset = containerSize - renderedSize;
      const maxOffset = 0;
      const clampedOffset = clamp(preferredOffset, minOffset, maxOffset);
      const denominator = containerSize - renderedSize;

      if (!Number.isFinite(denominator) || Math.abs(denominator) < 0.0001) {
        return 50;
      }

      return clamp((clampedOffset / denominator) * 100, 0, 100);
    };

    const applyImagePosition = (img) => {
      if (!img.isConnected) return;
      if ((img.dataset.sbAutoFocus || 'true') !== 'true') return;
      if ((img.dataset.sbObjectFit || 'cover') !== 'cover') return;

      const intrinsicWidth = parseNumber(img.getAttribute('width') || `${img.naturalWidth}`, img.naturalWidth || 0);
      const intrinsicHeight = parseNumber(img.getAttribute('height') || `${img.naturalHeight}`, img.naturalHeight || 0);

      if (intrinsicWidth <= 0 || intrinsicHeight <= 0) return;

      const rect = img.getBoundingClientRect();
      const containerWidth = rect.width;
      const containerHeight = rect.height;

      if (containerWidth <= 0 || containerHeight <= 0) return;

      const scale = Math.max(containerWidth / intrinsicWidth, containerHeight / intrinsicHeight);
      if (!Number.isFinite(scale) || scale <= 0) return;

      const renderedWidth = intrinsicWidth * scale;
      const renderedHeight = intrinsicHeight * scale;
      const target = getTargetPoint(img);

      const objectX = computeAxisPosition(containerWidth, renderedWidth, target.x);
      const objectY = computeAxisPosition(containerHeight, renderedHeight, target.y);

      img.style.objectPosition = `${objectX.toFixed(2)}% ${objectY.toFixed(2)}%`;
    };

    const getOptimizedImages = () => {
      const nodes = Array.from(document.querySelectorAll('.optimized-image-element[data-sb-focus-desktop-x]'));
      return nodes.filter((node) => node instanceof HTMLImageElement);
    };

    const observedImages = new WeakSet();
    const resizeObserver = typeof ResizeObserver !== 'undefined'
      ? new ResizeObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.target instanceof HTMLImageElement) {
            applyImagePosition(entry.target);
          }
        });
      })
      : null;

    const observeImage = (img) => {
      if (observedImages.has(img)) return;
      observedImages.add(img);
      if (resizeObserver) {
        resizeObserver.observe(img);
      }
      img.addEventListener('load', () => applyImagePosition(img), { passive: true });
    };

    const applyAll = () => {
      getOptimizedImages().forEach((img) => {
        observeImage(img);
        applyImagePosition(img);
      });
    };

    runtimeWindow.__sbFocalRuntimeApply = applyAll;
    applyAll();

