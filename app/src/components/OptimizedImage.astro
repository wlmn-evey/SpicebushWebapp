  }

  @media (min-width: 768px) {
    .optimized-image-element {
      object-position: var(--sb-pos-tablet, var(--sb-pos-mobile, 50% 50%));
    }
  }

  @media (min-width: 1024px) {
    .optimized-image-element {
      object-position: var(--sb-pos-desktop, var(--sb-pos-tablet, var(--sb-pos-mobile, 50% 50%)));
