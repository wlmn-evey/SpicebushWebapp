    z-index: 20;
    border-radius: 999px;
    border: 1px solid rgba(31, 41, 55, 0.2);
    background: rgba(255, 255, 255, 0.92);
    color: #1f2937;
    font-size: 0.63rem;
    font-weight: 700;
    padding: 0.22rem 0.5rem;
    letter-spacing: 0.01em;
    line-height: 1.2;
