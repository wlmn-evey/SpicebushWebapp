---
import { getSetting } from '@lib/content-db';
import { Phone, Mail, MapPin } from 'lucide-astro';

interface Props {
  showIcons?: boolean;
  showLabels?: boolean;
  inline?: boolean;
  className?: string;
}

const { showIcons = true, showLabels = false, inline = false, className = '' } = Astro.props;

// Get school info from database settings with error handling
let phone = '(484) 202-0712';
let email = 'information@spicebushmontessori.org';
let addressStreet = '827 Concord Road';
let addressCity = 'Glen Mills';
let addressState = 'PA';
let addressZip = '19342';

try {
  // Try to get all settings in parallel for better performance
  const [dbPhone, dbEmail, dbStreet, dbCity, dbState, dbZip] = await Promise.all([
    getSetting('school_phone').catch(() => null),
    getSetting('school_email').catch(() => null),
    getSetting('school_address_street').catch(() => null),
    getSetting('school_address_city').catch(() => null),
    getSetting('school_address_state').catch(() => null),
    getSetting('school_address_zip').catch(() => null)
  ]);
  
  // Use database values if available, otherwise keep defaults
  phone = dbPhone || phone;
  email = dbEmail || email;
  addressStreet = dbStreet || addressStreet;
  addressCity = dbCity || addressCity;
  addressState = dbState || addressState;
  addressZip = dbZip || addressZip;
} catch (error) {
  console.error('Error loading contact info from database:', error);
  // Use default values defined above
}

const address = {
  street: addressStreet,
  city: addressCity,
  state: addressState,
  zip: addressZip
};

const containerClass = inline ? 'flex flex-wrap gap-4' : 'space-y-2';
---

<div class={`${containerClass} ${className}`}>
  <div class="flex items-center gap-2">
    {showIcons && <Phone className="w-4 h-4 text-forest-canopy" />}
    {showLabels && <span class="text-earth-brown/80">Phone:</span>}
    <a 
      href={`tel:${phone.replace(/[^0-9]/g, '')}`}
      class="text-earth-brown hover:text-forest-canopy transition-colors"
    >
      {phone}
    </a>
  </div>
  
  <div class="flex items-center gap-2">
    {showIcons && <Mail className="w-4 h-4 text-forest-canopy" />}
    {showLabels && <span class="text-earth-brown/80">Email:</span>}
    <a 
      href={`mailto:${email}`}
      class="text-earth-brown hover:text-forest-canopy transition-colors break-all sm:break-normal"
    >
      {email}
    </a>
  </div>
  
  <div class="flex items-start gap-2">
    {showIcons && <MapPin className="w-4 h-4 text-forest-canopy mt-0.5" />}
    {showLabels && <span class="text-earth-brown/80">Address:</span>}
    <address class="not-italic text-earth-brown">
      {address.street}<br />
      {address.city}, {address.state} {address.zip}
    </address>
  </div>
</div>