---
import { Mail } from 'lucide-astro';
import { db, type ContentEntry } from '@lib/db';
import OptimizedImage from '@components/OptimizedImage.astro';
import { buildPhotoSlugResolver, toPhotoLookupEntry } from '@lib/photo-slug-resolver';

type StaffContentEntry = ContentEntry<Record<string, unknown>>;
type PhotoContentEntry = ContentEntry<Record<string, unknown>>;

interface StaffViewModel {
  id: string;
  name: string;
  role?: string;
  photo?: string;
  photoSlug?: string;
  email?: string;
  certificationBadge?: string;
  credentials: string[];
  languages: string[];
  startYearLabel?: string;
  order: number;
  bio?: string;
  initials: string;
}

const normalizeString = (value: unknown): string | undefined => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    return trimmed.length > 0 ? trimmed : undefined;
  }
  return undefined;
};

const normalizeStringArray = (value: unknown): string[] => {
  if (Array.isArray(value)) {
    return value
      .map((item) => (typeof item === 'string' ? item.trim() : ''))
      .filter((item) => item.length > 0);
  }
  return [];
};

const normalizeOrder = (value: unknown): number => {
  if (typeof value === 'number' && Number.isFinite(value)) {
    return value;
  }
  if (typeof value === 'string') {
    const parsed = Number.parseInt(value, 10);
    if (!Number.isNaN(parsed)) {
      return parsed;
    }
  }
  return 999;
};

const asRecord = (value: unknown): Record<string, unknown> => {
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    return value as Record<string, unknown>;
  }
  return {};
};

const photoEntries = (await db.content.getCollection('photos')) as PhotoContentEntry[];
const resolvePhotoSlug = buildPhotoSlugResolver(
  photoEntries.map((entry) => toPhotoLookupEntry(entry.slug, asRecord(entry.data)))
);

const toViewModel = (entry: StaffContentEntry): StaffViewModel | null => {
  const data = asRecord(entry.data);
  const name = normalizeString(data.name);
  if (!name) {
    return null;
  }

  const role = normalizeString(data.role);
  const email = normalizeString(data.email);
  const photo = normalizeString(data.photo);
  const photoSlug = resolvePhotoSlug(photo) ?? undefined;
  const certificationBadge = normalizeString(data.certificationBadge);
  const credentials = normalizeStringArray(data.credentials);
  const languages = normalizeStringArray(data.languages);
  const startYearRaw = data.startYear;
  const startYearValue = typeof startYearRaw === 'number'
    ? String(startYearRaw)
    : normalizeString(startYearRaw);
  const order = normalizeOrder(data.order);

  const bodyText = typeof entry.body === 'string' ? entry.body.trim() : '';
  const bio = bodyText.length > 0 ? bodyText : undefined;

  const initials = name
    .split(' ')
    .filter(Boolean)
    .map((segment) => segment.charAt(0).toUpperCase())
    .join('')
    .slice(0, 3) || name.charAt(0).toUpperCase();

  return {
    id: entry.id,
    name,
    role,
    photo,
    photoSlug,
    email,
    certificationBadge,
    credentials,
    languages,
    startYearLabel: startYearValue ? `Since ${startYearValue}` : undefined,
    order,
    bio,
    initials
  };
};

const staffEntries = await db.content.getCollection('staff');
const sortedStaff = staffEntries
  .map(toViewModel)
  .filter((staffMember): staffMember is StaffViewModel => staffMember !== null)
  .sort((a, b) => a.order - b.order);
---

<!-- Teachers Section for About Page -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-4 tracking-tight">
        Meet Our Teaching Team
      </h2>
      <p class="text-lg text-earth-brown max-w-3xl mx-auto leading-relaxed-plus font-light">
        Our dedicated teachers bring passion, expertise, and deep care to every interaction with children and families.
      </p>
    </div>
    
    <div id="teachers-container" class="space-y-12">
      {sortedStaff.length === 0 ? (
        <p class="text-center text-gray-500">No teachers available at this time.</p>
      ) : (
        sortedStaff.map((teacher, index) => {
          const isEven = index % 2 === 0;
          const layoutClass = isEven ? 'lg:flex-row' : 'lg:flex-row-reverse';

          return (
            <div 
              class="teacher-card bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100 hover:shadow-xl transition-all duration-500"
              style={`animation-delay: ${index * 200}ms;`}
            >
              <div class={`flex flex-col ${layoutClass} lg:min-h-[400px]`}>
                <div class="w-full lg:w-2/5 relative">
                  {teacher.photoSlug ? (
                    <div class="aspect-square lg:aspect-auto lg:h-full overflow-hidden">
                      <OptimizedImage
                        photoSlug={teacher.photoSlug}
                        alt={`${teacher.name}${teacher.role ? `, ${teacher.role}` : ''} at Spicebush Montessori School`}
                        className="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
                        slotId={`about-teachers-${teacher.id}`}
                        mediaCategory="teachers"
                      />
                    </div>
                  ) : teacher.photo ? (
                    <div class="aspect-square lg:aspect-auto lg:h-full overflow-hidden">
                      <img 
                        src={teacher.photo}
                        alt={`${teacher.name}${teacher.role ? `, ${teacher.role}` : ''} at Spicebush Montessori School`}
                        class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="aspect-square lg:aspect-auto lg:h-full bg-gradient-to-br from-forest-canopy to-moss-green flex items-center justify-center">
                      <span class="text-white text-6xl font-bold">{teacher.initials}</span>
                    </div>
                  )}
                  
                  <div class={`absolute top-4 ${isEven ? 'right-4' : 'left-4'} w-12 h-12 bg-sunlight-gold rounded-full opacity-20`}></div>
                </div>
                <div class="w-full lg:w-3/5 p-8 lg:p-12 flex flex-col justify-center">
                  <div class="mb-6">
                    <h3 class="text-2xl lg:text-3xl font-heading font-bold text-earth-brown mb-3 tracking-tight">
                      {teacher.name}
                    </h3>
                    {teacher.role && (
                      <div class="text-forest-canopy font-semibold text-lg mb-3">
                        {teacher.role}
                      </div>
                    )}
                    {teacher.startYearLabel && (
                      <div class="text-sm text-earth-brown/70 mb-3">
                        {teacher.startYearLabel}
                      </div>
                    )}
                    <div class="flex items-center gap-3 mb-4">
                      {teacher.certificationBadge && (
                        <span class="inline-block px-3 py-1 bg-sunlight-gold text-white rounded-full text-sm font-bold">
                          {teacher.certificationBadge} Certified
                        </span>
                      )}
                      {teacher.credentials.length > 0 && (
                        <div class="flex flex-wrap gap-2">
                          {teacher.credentials.map((credential) => (
                            <span class="inline-block px-3 py-1 bg-forest-canopy/10 text-forest-canopy rounded-full text-sm font-medium">
                              {credential}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                  
                  {teacher.bio && (
                    <div class="text-earth-brown leading-relaxed text-base lg:text-lg mb-8 max-w-none">
                      {teacher.bio}
                    </div>
                  )}
                  
                  {teacher.email && (
                    <div class="flex items-center text-moss-green">
                      <Mail className="w-5 h-5 mr-2" />
                      <a href={`mailto:${teacher.email}`} class="hover:text-forest-canopy transition-colors">
                        {teacher.email}
                      </a>
                    </div>
                  )}
                </div>
              </div>
            </div>
          );
        })
      )}
    </div>
  </div>
</section>

<script is:inline>
  // Trigger animation on page load
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.teacher-card');
    cards.forEach((card, index) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(30px)';
      setTimeout(() => {
        card.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
      }, index * 200);
    });
  });
</script>

<style>
  .teacher-card {
    opacity: 0;
    transform: translateY(30px);
  }
  
  .teacher-card img {
    transition: transform 0.3s ease;
  }
  
  .teacher-card:hover img {
    transform: scale(1.05);
  }
  
  /* Ensure text doesn't get too constrained */
  .teacher-card .text-earth-brown {
    max-width: none;
    line-height: 1.8;
  }
  
  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .teacher-card .flex {
      flex-direction: column !important;
    }
  }
</style>
