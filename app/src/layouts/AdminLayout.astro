---
import '../styles/global.css';
import AdminNav from '@components/AdminNav.astro';
import ExternalLinkTargetBehavior from '@components/ExternalLinkTargetBehavior.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const locals = Astro.locals as unknown as Record<string, unknown>;
const userEmail = typeof locals.userEmail === 'string' ? locals.userEmail : 'Administrator';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-stone-beige min-h-screen text-earth-brown">
    <AdminNav />

    <main class="lg:ml-64 min-h-screen">
      <header class="border-b border-gray-200 bg-white/80 backdrop-blur px-6 py-5 pl-16 lg:pl-6 sticky top-0 z-20">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h1 class="text-2xl font-heading font-bold tracking-tight">{title}</h1>
          <div class="text-sm text-earth-brown/80">
            Signed in as <span class="font-semibold">{userEmail}</span>
          </div>
        </div>
      </header>
      <section class="p-6">
        <slot />
      </section>
    </main>
    <ExternalLinkTargetBehavior />
  </body>
</html>
