---
/**
 * AdminLayout
 * 
 * The base layout for all admin pages. Provides consistent navigation,
 * authentication checks, and UI structure for the admin interface.
 */
import Layout from './Layout.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect(`/auth/login?redirect=${  Astro.url.pathname}`);
}

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// Get current path for navigation highlighting
const currentPath = Astro.url.pathname;

// Navigation items
const navItems = [
  { href: '/admin', label: 'Dashboard', icon: 'home' },
  { href: '/admin/blog', label: 'Blog Posts', icon: 'document-text' },
  { href: '/admin/staff', label: 'Staff', icon: 'users' },
  { href: '/admin/hours', label: 'Hours', icon: 'clock' },
  { href: '/admin/tuition', label: 'Tuition', icon: 'currency-dollar' },
  { href: '/admin/announcements', label: 'Announcements', icon: 'speakerphone' },
  { href: '/admin/photos', label: 'Photos', icon: 'photograph' },
  { href: '/admin/communications', label: 'Communications', icon: 'mail' },
  { href: '/admin/newsletter', label: 'Newsletter', icon: 'mail-open' },
  { href: '/admin/settings', label: 'Settings', icon: 'cog' }
];

// Check for flash messages
const successMessage = Astro.url.searchParams.get('success');
const errorMessage = Astro.url.searchParams.get('error');
---

<Layout title={`${title} - Admin`}>
  <div class="admin-layout">
    <!-- Sidebar Navigation -->
    <aside class="admin-sidebar">
      <div class="admin-logo">
        <a href="/admin" class="flex items-center space-x-2">
          <img src="/SpicebushLogo-03.png" alt="Spicebush Montessori School" class="h-8 w-8" />
          <span class="font-semibold text-lg">Admin</span>
        </a>
      </div>
      
      <nav class="admin-nav">
        <ul class="space-y-1">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class={`nav-item ${currentPath === item.href ? 'nav-item--active' : ''}`}
              >
                <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {item.icon === 'home' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                  )}
                  {item.icon === 'document-text' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  )}
                  {item.icon === 'users' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  )}
                  {item.icon === 'clock' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  )}
                  {item.icon === 'currency-dollar' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  )}
                  {item.icon === 'speakerphone' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                  )}
                  {item.icon === 'photograph' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  )}
                  {item.icon === 'mail' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  )}
                  {item.icon === 'mail-open' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 19v-8.93a2 2 0 01.89-1.664l7-4.666a2 2 0 012.22 0l7 4.666A2 2 0 0121 10.07V19M3 19a2 2 0 002 2h14a2 2 0 002-2M3 19l6.75-4.5M21 19l-6.75-4.5M3 10l6.75 4.5M21 10l-6.75 4.5m0 0l-1.14.76a2 2 0 01-2.22 0l-1.14-.76" />
                  )}
                  {item.icon === 'cog' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  )}
                </svg>
                <span>{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
      
      <div class="admin-user">
        <a href="/" class="text-sm text-gray-600 hover:text-gray-900">
          ← Back to Site
        </a>
        <a href="/auth/logout" class="text-sm text-red-600 hover:text-red-700">
          Sign Out
        </a>
      </div>
    </aside>
    
    <!-- Main Content Area -->
    <main class="admin-main">
      <!-- Header -->
      <header class="admin-header">
        <h1 class="admin-title">{title}</h1>
        {description && (
          <p class="admin-description">{description}</p>
        )}
      </header>
      
      <!-- Flash Messages -->
      {(successMessage || errorMessage) && (
        <div class="admin-messages">
          {successMessage && (
            <div class="message message--success" role="alert">
              <svg class="message-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{successMessage}</span>
            </div>
          )}
          {errorMessage && (
            <div class="message message--error" role="alert">
              <svg class="message-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{errorMessage}</span>
            </div>
          )}
        </div>
      )}
      
      <!-- Page Content -->
      <div class="admin-content">
        <slot />
      </div>
    </main>
  </div>
</Layout>

<style>
  .admin-layout {
    @apply flex h-screen bg-gray-100;
  }
  
  /* Sidebar */
  .admin-sidebar {
    @apply w-64 bg-white shadow-lg flex flex-col;
  }
  
  .admin-logo {
    @apply p-6 border-b border-gray-200;
  }
  
  .admin-nav {
    @apply flex-1 px-4 py-6 overflow-y-auto;
  }
  
  .nav-item {
    @apply flex items-center px-3 py-2 text-sm font-medium rounded-md;
    @apply text-gray-700 hover:text-gray-900 hover:bg-gray-100;
    @apply transition-colors duration-150;
  }
  
  .nav-item--active {
    @apply text-blue-700 bg-blue-50;
  }
  
  .nav-icon {
    @apply w-5 h-5 mr-3 flex-shrink-0;
  }
  
  .admin-user {
    @apply p-4 border-t border-gray-200 space-y-2 flex flex-col;
  }
  
  /* Main Content */
  .admin-main {
    @apply flex-1 flex flex-col overflow-hidden;
  }
  
  .admin-header {
    @apply bg-white shadow-sm px-8 py-6 border-b border-gray-200;
  }
  
  .admin-title {
    @apply text-2xl font-bold text-gray-900;
  }
  
  .admin-description {
    @apply mt-1 text-sm text-gray-600;
  }
  
  .admin-messages {
    @apply px-8 py-4;
  }
  
  .message {
    @apply flex items-center p-4 rounded-md;
  }
  
  .message--success {
    @apply bg-green-50 text-green-800;
  }
  
  .message--error {
    @apply bg-red-50 text-red-800;
  }
  
  .message-icon {
    @apply w-5 h-5 mr-2 flex-shrink-0;
  }
  
  .admin-content {
    @apply flex-1 overflow-y-auto px-8 py-6;
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .admin-sidebar {
      @apply hidden;
    }
    
    .admin-main {
      @apply w-full;
    }
  }
</style>

<script>
  // Auto-hide flash messages after 5 seconds
  const messages = document.querySelectorAll('.message');
  messages.forEach(message => {
    setTimeout(() => {
      message.style.transition = 'opacity 0.5s';
      message.style.opacity = '0';
      setTimeout(() => message.remove(), 500);
    }, 5000);
  });
</script>