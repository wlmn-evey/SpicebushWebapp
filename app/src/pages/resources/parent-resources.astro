---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Book, Download, Calendar, Users, ExternalLink } from 'lucide-astro';
---

<Layout 
  title="Caregiver Resources - Spicebush Montessori School"
  description="Resources and support materials for Montessori caregivers, including educational tips and information about supporting learning at home."
  keywords="Montessori caregiver resources, home learning support, educational materials, caregiver guides"
>
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-stone-beige to-light-stone py-16 lg:py-24">
      <div class="container mx-auto px-4">
        <div class="text-center">
          <h1 class="text-4xl lg:text-5xl font-bold text-earth-brown mb-6">
            Caregiver Resources
          </h1>
          <p class="text-lg text-earth-brown max-w-3xl mx-auto">
            Content coming soon...
          </p>
        </div>
      </div>
    </section>
    
    <!-- Resources Content -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Resource Categories -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Educational Resources -->
            <div class="bg-white rounded-lg shadow-md p-8">
              <div class="flex items-center mb-4">
                <div class="bg-moss-green/10 rounded-lg p-3 mr-4">
                  <Book className="w-6 h-6 text-moss-green" />
                </div>
                <h3 class="text-xl font-semibold text-earth-brown">Educational Resources</h3>
              </div>
              <p class="text-gray-600 mb-4">
                Guides and materials to support your child's Montessori learning at home.
              </p>
              <p class="text-sm text-gray-500 italic">Coming soon...</p>
            </div>

            <!-- Downloads -->
            <div class="bg-white rounded-lg shadow-md p-8">
              <div class="flex items-center mb-4">
                <div class="bg-sky-blue/10 rounded-lg p-3 mr-4">
                  <Download className="w-6 h-6 text-sky-blue" />
                </div>
                <h3 class="text-xl font-semibold text-earth-brown">Forms & Downloads</h3>
              </div>
              <p class="text-gray-600 mb-4">
                Important forms, calendars, and documents for families.
              </p>
              <p class="text-sm text-gray-500 italic">Coming soon...</p>
            </div>

            <!-- Community -->
            <div class="bg-white rounded-lg shadow-md p-8">
              <div class="flex items-center mb-4">
                <div class="bg-sunlight-gold/10 rounded-lg p-3 mr-4">
                  <Users className="w-6 h-6 text-orange-600" />
                </div>
                <h3 class="text-xl font-semibold text-earth-brown">Community Connection</h3>
              </div>
              <p class="text-gray-600 mb-4">
                Ways to get involved and connect with other Spicebush families.
              </p>
              <p class="text-sm text-gray-500 italic">Coming soon...</p>
            </div>

            <!-- Events -->
            <div class="bg-white rounded-lg shadow-md p-8">
              <div class="flex items-center mb-4">
                <div class="bg-purple-500/10 rounded-lg p-3 mr-4">
                  <Calendar className="w-6 h-6 text-purple-500" />
                </div>
                <h3 class="text-xl font-semibold text-earth-brown">Upcoming Events</h3>
              </div>
              <p class="text-gray-600 mb-4">
                School events, workshops, and community gatherings.
              </p>
              <p class="text-sm text-gray-500 italic">Coming soon...</p>
            </div>
          </div>

          <!-- External Resources -->
          <div class="mt-12 bg-forest-canopy/5 rounded-lg p-8">
            <h3 class="text-xl font-semibold text-earth-brown mb-4 flex items-center">
              <ExternalLink className="w-5 h-5 mr-2" />
              Helpful External Resources
            </h3>
            <p class="text-gray-600 mb-4">
              We'll be sharing links to trusted Montessori resources, educational websites, and community organizations.
            </p>
            <p class="text-sm text-gray-500 italic">Coming soon...</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
