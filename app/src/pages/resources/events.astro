---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout 
  title="Community Events - Spicebush Montessori School"
  description="Join us for community events, caregiver workshops, and special programs designed to support families in our Montessori community."
  keywords="Montessori events, caregiver workshops, community activities, school calendar"
>
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-stone-beige to-light-stone py-16 lg:py-24">
      <div class="container mx-auto px-4">
        <div class="text-center">
          <h1 class="text-4xl lg:text-5xl font-bold text-earth-brown mb-6">
            Community Events
          </h1>
          <p class="text-lg text-earth-brown max-w-3xl mx-auto">
            Content coming soon...
          </p>
        </div>
      </div>
    </section>
    
    <!-- Additional sections to be built -->
    <div class="py-16 text-center text-earth-brown">
      <p>Page sections will be built here...</p>
    </div>
  </main>
  
  <Footer />
</Layout>