---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { CheckCircle, ArrowLeft, Calendar, Mail } from 'lucide-astro';

// Get enrollment ID from URL params
const url = new URL(Astro.request.url);
const enrollmentId = url.searchParams.get('id');
---

<Layout 
  title="Enrollment Complete - Spicebush Montessori School"
  description="Thank you for enrolling your child at Spicebush Montessori School. We're excited to welcome your family!"
>
  <Header />
  
  <main id="main-content">
    <section class="min-h-[60vh] bg-gradient-to-br from-forest-canopy to-moss-green py-16 lg:py-20 flex items-center">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <div class="flex justify-center mb-6">
            <div class="w-20 h-20 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center border-2 border-white/30">
              <CheckCircle className="w-10 h-10 text-white" />
            </div>
          </div>
          
          <h1 class="text-4xl lg:text-5xl font-heading font-bold text-white mb-6 tracking-tight">
            Enrollment Complete!
          </h1>
          
          <p class="text-lg lg:text-xl text-green-100 mb-8 leading-relaxed-plus">
            Your child's spot at Spicebush Montessori School has been secured. We're thrilled to welcome your family to our community!
          </p>
          
          {enrollmentId && (
            <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 mb-6">
              <p class="text-sm text-green-100">
                Enrollment Reference: <span class="font-mono text-white">{enrollmentId}</span>
              </p>
            </div>
          )}
          
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 mb-8 text-left">
            <h2 class="text-xl font-semibold text-white mb-3">What happens next?</h2>
            <ul class="space-y-3 text-green-100">
              <li class="flex items-start">
                <Mail className="w-5 h-5 text-sunlight-gold mr-3 mt-0.5 flex-shrink-0" />
                <span>You'll receive an enrollment confirmation email within 24 hours</span>
              </li>
              <li class="flex items-start">
                <Calendar className="w-5 h-5 text-sunlight-gold mr-3 mt-0.5 flex-shrink-0" />
                <span>Our admissions team will contact you to schedule orientation</span>
              </li>
              <li class="flex items-start">
                <CheckCircle className="w-5 h-5 text-sunlight-gold mr-3 mt-0.5 flex-shrink-0" />
                <span>You'll receive a welcome packet with important information</span>
              </li>
              <li class="flex items-start">
                <span class="text-sunlight-gold mr-2">•</span>
                <span>We'll send you forms to complete before your child's first day</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-sunlight-gold/20 backdrop-blur-sm rounded-xl p-6 mb-8">
            <h3 class="text-lg font-semibold text-white mb-2">Important Dates</h3>
            <p class="text-sm text-green-100 mb-3">
              Please mark your calendar for these upcoming events:
            </p>
            <ul class="text-sm text-green-100 space-y-1 text-left">
              <li>• Parent Orientation: Date to be scheduled</li>
              <li>• First Day of School: Based on your selected start date</li>
              <li>• First Parent-Teacher Conference: Within 30 days of enrollment</li>
            </ul>
          </div>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="/" 
              class="inline-flex items-center justify-center bg-white text-forest-canopy px-6 py-3 rounded-lg font-semibold hover:bg-stone-beige transition-all duration-300"
            >
              <ArrowLeft className="w-5 h-5 mr-2" />
              Back to Home
            </a>
            
            <a 
              href="/programs" 
              class="inline-flex items-center justify-center bg-transparent text-white border-2 border-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-all duration-300"
            >
              Learn About Our Programs
            </a>
          </div>
          
          <div class="mt-12 p-6 bg-white/5 backdrop-blur-sm rounded-xl">
            <p class="text-sm text-green-100 italic">
              "The greatest sign of success for a teacher is to be able to say, 'The children are now working as if I did not exist.'"
            </p>
            <p class="text-xs text-green-200 mt-2">— Maria Montessori</p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Preparation Tips Section -->
    <section class="py-16 bg-stone-beige">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-heading font-bold text-earth-brown mb-6 text-center">
            Preparing for Your Child's First Day
          </h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl p-6 shadow-soft">
              <h3 class="font-semibold text-earth-brown mb-3">What to Bring</h3>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>• Indoor shoes or slippers</li>
                <li>• Change of clothes in a labeled bag</li>
                <li>• Water bottle with your child's name</li>
                <li>• Any comfort items for rest time</li>
              </ul>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-soft">
              <h3 class="font-semibold text-earth-brown mb-3">Tips for Success</h3>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>• Establish a consistent morning routine</li>
                <li>• Talk positively about school</li>
                <li>• Practice independence skills at home</li>
                <li>• Read books about starting school</li>
              </ul>
            </div>
          </div>
          
          <div class="mt-8 bg-forest-canopy/5 border border-forest-canopy/20 rounded-xl p-6">
            <h3 class="font-semibold text-earth-brown mb-3">Questions?</h3>
            <p class="text-gray-700 mb-4">
              Our team is here to support you through this transition. Don't hesitate to reach out with any questions or concerns.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a 
                href="tel:484-368-3745"
                class="inline-flex items-center justify-center text-forest-canopy font-semibold hover:underline"
              >
                Call: (484) 368-3745
              </a>
              <span class="hidden sm:inline text-gray-400">|</span>
              <a 
                href="mailto:hello@spicebushmontessori.org"
                class="inline-flex items-center justify-center text-forest-canopy font-semibold hover:underline"
              >
                Email: hello@spicebushmontessori.org
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>