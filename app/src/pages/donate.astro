---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SimplifiedDonationForm from '../components/SimplifiedDonationForm';
import { getEntry } from 'astro:content';

const schoolInfo = await getEntry('school-info', 'general');
---

<Layout 
  title="Donate - Support Spicebush Montessori School"
  description="Support accessible Montessori education for all children. Your donation helps us maintain our sliding-scale tuition and provide quality education regardless of family income."
  keywords="donate to Montessori school, support inclusive education, non-profit school donation"
>
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative">
      <div class="relative h-[50vh] lg:h-[60vh] overflow-hidden">
        <img 
          src="/images/gallery/collaborative-building.png" 
          alt="Children working together on a building project" 
          class="w-full h-full object-cover object-center"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-forest-canopy/20 via-forest-canopy/30 to-forest-canopy/50"></div>
      </div>
      <div class="container mx-auto px-4">
        <div class="text-center relative -mt-24 bg-white rounded-lg shadow-xl p-10 max-w-3xl mx-auto">
          <h1 class="text-4xl lg:text-5xl font-heading font-bold text-earth-brown mb-6 relative z-10 tracking-tight">
            Support Our Mission
          </h1>
          <p class="text-lg text-earth-brown relative z-10 leading-relaxed-plus font-medium">
            Your generosity helps us provide accessible Montessori education to all families, regardless of their financial circumstances.
          </p>
          <!-- Decorative element -->
          <div class="absolute top-0 right-0 w-20 h-20 bg-sunlight-gold/20 rounded-full -mr-10 -mt-10 z-0"></div>
        </div>
      </div>
    </section>

    <!-- Why Donate Section -->
    <section class="py-16 lg:py-24">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-8 text-center">
            Why Your Support Matters
          </h2>
          
          <div class="prose prose-lg max-w-none mb-12">
            <p class="text-gray-700 leading-relaxed">
              Spicebush Montessori operates as a non-profit school with a mission to make authentic Montessori education accessible to all families. Through our innovative Family Individualized Tuition (FIT) model, we ensure that no child is turned away due to financial constraints.
            </p>
            <p class="text-gray-700 leading-relaxed">
              Your donation directly supports:
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-forest-canopy/5 p-6 rounded-lg">
              <h3 class="text-xl font-semibold text-earth-brown mb-3">Sliding Scale Tuition</h3>
              <p class="text-gray-700">
                Enables families to pay tuition based on their income, making quality education accessible to diverse economic backgrounds.
              </p>
            </div>
            <div class="bg-forest-canopy/5 p-6 rounded-lg">
              <h3 class="text-xl font-semibold text-earth-brown mb-3">Learning Materials</h3>
              <p class="text-gray-700">
                Funds authentic Montessori materials and resources that support hands-on, self-directed learning.
              </p>
            </div>
            <div class="bg-forest-canopy/5 p-6 rounded-lg">
              <h3 class="text-xl font-semibold text-earth-brown mb-3">Teacher Development</h3>
              <p class="text-gray-700">
                Supports ongoing professional development for our dedicated Montessori-trained teachers.
              </p>
            </div>
            <div class="bg-forest-canopy/5 p-6 rounded-lg">
              <h3 class="text-xl font-semibold text-earth-brown mb-3">Inclusive Programs</h3>
              <p class="text-gray-700">
                Ensures we can welcome and support children of all abilities and learning styles.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Donation Form Section -->
    <section class="py-16 lg:py-24 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto">
          <!-- Simplified Donation Form -->
          <SimplifiedDonationForm client:visible />

          <!-- Tax Information -->
          <div class="mt-8 p-6 bg-sunlight-gold/10 rounded-lg">
            <h3 class="font-semibold text-earth-brown mb-2">Donation Information</h3>
            <p class="text-sm text-gray-700">
              Spicebush Montessori is committed to accessibility and transparency. Please contact us about the tax implications of your donation.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Ways to Give -->
    <section class="py-16 lg:py-24">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-8">
            Other Ways to Support
          </h2>
          
          <div class="grid md:grid-cols-3 gap-8">
            <div class="text-center">
              <div class="w-16 h-16 bg-forest-canopy/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-forest-canopy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-earth-brown mb-3">Monthly Giving</h3>
              <p class="text-gray-700">
                Join our Seedling Society with a recurring monthly gift that provides steady support for our programs.
              </p>
            </div>
            
            <div class="text-center">
              <div class="w-16 h-16 bg-forest-canopy/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-forest-canopy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-earth-brown mb-3">Corporate Matching</h3>
              <p class="text-gray-700">
                Many employers will match your donation. Check with your HR department to double your impact.
              </p>
            </div>
            
            <div class="text-center">
              <div class="w-16 h-16 bg-forest-canopy/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-forest-canopy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-earth-brown mb-3">Volunteer</h3>
              <p class="text-gray-700">
                Share your time and talents with our community. Contact us to learn about volunteer opportunities.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <h2 class="text-2xl font-heading font-bold text-earth-brown mb-4">
            Questions About Giving?
          </h2>
          <p class="text-gray-700 mb-6">
            We're happy to discuss donation options, planned giving, or answer any questions you may have.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="mailto:donate@spicebushmontessori.org" class="inline-flex items-center justify-center px-6 py-3 bg-forest-canopy text-white rounded-lg hover:bg-forest-canopy/90 transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              Email Us
            </a>
            <a href="tel:+16105058807" class="inline-flex items-center justify-center px-6 py-3 bg-white text-forest-canopy border-2 border-forest-canopy rounded-lg hover:bg-forest-canopy/5 transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              Call Us
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>