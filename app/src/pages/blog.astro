---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Calendar, Clock, ArrowRight } from 'lucide-astro';
import { getCollection } from '../lib/content-db';

let posts = [];
let categories = [];
let error = null;

try {
  // Fetch blog posts from Supabase
  const blogCollection = await getCollection('blog');

  // Filter out drafts and sort posts by date (newest first)
  posts = blogCollection
    .filter(post => post.data.draft !== true)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

  // Extract unique categories from posts
  const allCategories = posts.flatMap(post => post.data.categories || []);
  categories = [...new Set(allCategories)].map((category, index) => ({
    id: index + 1,
    name: category,
    slug: category.toLowerCase().replace(/\s+/g, '-')
  }));

} catch (e) {
  console.error('Error fetching blog data from Supabase:', e);
  error = 'Unable to load blog posts. Please try again later.';
}
---

<Layout title="Blog - Spicebush Montessori School">
  <Header />
  
  <main class="blog-page">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-stone-beige to-light-stone py-16 lg:py-24">
      <div class="container mx-auto px-4">
        <div class="text-center">
          <h1 class="text-4xl lg:text-5xl font-heading font-bold text-earth-brown mb-6 tracking-tight">
            Our Blog
          </h1>
          <p class="text-lg text-earth-brown max-w-3xl mx-auto leading-relaxed">
            Insights, updates, and stories from our Montessori community. 
            Discover resources for families and learn about our approach to inclusive education.
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Content -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        {error ? (
          <div class="text-center bg-red-50 border border-red-200 text-red-700 py-8 px-4 rounded-lg max-w-2xl mx-auto">
            {error}
          </div>
        ) : posts.length === 0 ? (
          <div class="text-center bg-moss-green/5 border border-moss-green/20 text-earth-brown py-12 px-4 rounded-lg max-w-2xl mx-auto">
            <p class="text-lg mb-4">No blog posts available yet.</p>
            <p class="text-gray-600">Check back soon for updates from our community!</p>
          </div>
        ) : (
          <>
            <!-- Categories Filter -->
            {categories.length > 0 && (
              <div class="flex justify-center gap-3 mb-12 flex-wrap">
                <button 
                  class="px-6 py-2 rounded-full border-2 border-moss-green/30 hover:border-moss-green bg-white text-earth-brown font-medium transition-all hover:shadow-md category-filter active"
                  data-category="all"
                >
                  All Posts
                </button>
                {categories.map(category => (
                  <button 
                    class="px-6 py-2 rounded-full border-2 border-moss-green/30 hover:border-moss-green bg-white text-earth-brown font-medium transition-all hover:shadow-md category-filter"
                    data-category={category.slug}
                  >
                    {category.name}
                  </button>
                ))}
              </div>
            )}

            <!-- Blog Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
              {posts.map(post => {
                const { title, excerpt, image, imageAlt, date, categories: postCategories, author } = post.data;
                const slug = post.slug;
                const categoryList = postCategories?.map(cat => cat.toLowerCase().replace(/\s+/g, '-')).join(',') || '';
                
                return (
                  <article 
                    class="blog-card bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all hover:-translate-y-1 border border-gray-100"
                    data-categories={categoryList}
                  >
                    {image && (
                      <div class="aspect-video overflow-hidden bg-gray-100">
                        <img 
                          src={image}
                          alt={imageAlt || title}
                          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                          loading="lazy"
                        />
                      </div>
                    )}
                    <div class="p-6">
                      {postCategories?.length > 0 && (
                        <div class="flex gap-2 mb-3 flex-wrap">
                          {postCategories.slice(0, 2).map(category => (
                            <span class="text-xs font-medium text-moss-green bg-moss-green/10 px-3 py-1 rounded-full">
                              {category}
                            </span>
                          ))}
                        </div>
                      )}
                      <h2 class="text-xl font-semibold mb-3 line-clamp-2">
                        <a href={`/blog/${slug}`} class="text-earth-brown hover:text-forest-canopy transition-colors">
                          {title}
                        </a>
                      </h2>
                      {excerpt && (
                        <p class="text-gray-600 mb-4 line-clamp-3 leading-relaxed">{excerpt}</p>
                      )}
                      <div class="flex justify-between items-center pt-4 border-t border-gray-100">
                        <div class="flex items-center text-sm text-gray-500">
                          <Calendar className="w-4 h-4 mr-1" />
                          <time datetime={date.toISOString()}>
                            {date.toLocaleDateString('en-US', {
                              month: 'short',
                              day: 'numeric',
                              year: 'numeric'
                            })}
                          </time>
                        </div>
                        <a href={`/blog/${slug}`} class="text-moss-green hover:text-forest-canopy font-medium text-sm flex items-center group">
                          Read More
                          <ArrowRight className="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" />
                        </a>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .category-filter.active {
    @apply bg-moss-green text-white border-moss-green;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Category filtering
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.category-filter');
    const blogCards = document.querySelectorAll('.blog-card');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Update active state
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        const selectedCategory = button.getAttribute('data-category');

        // Filter posts
        blogCards.forEach(card => {
          if (selectedCategory === 'all') {
            card.style.display = 'block';
          } else {
            const cardCategories = card.getAttribute('data-categories').split(',');
            if (cardCategories.includes(selectedCategory)) {
              card.style.display = 'block';
            } else {
              card.style.display = 'none';
            }
          }
        });
      });
    });
  });
</script>