---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Calendar, Clock, Users, CheckCircle } from 'lucide-astro';

/**
 * Schedule Tour Page
 * 
 * Free form for parents to schedule a tour of Spicebush Montessori School.
 * No payment required - this is just for scheduling.
 */
---

<Layout 
  title="Schedule a Tour - Spicebush Montessori School"
  description="Schedule a free tour of Spicebush Montessori School and see our nurturing environment firsthand."
>
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-forest-canopy to-moss-green py-16 lg:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl lg:text-5xl font-heading font-bold text-white mb-6 tracking-tight">
            Schedule Your Visit
          </h1>
          <p class="text-lg lg:text-xl text-green-100 leading-relaxed-plus max-w-2xl mx-auto">
            Come see our beautiful school and learn how we nurture each child's natural love of learning.
          </p>
        </div>
      </div>
    </section>

    <!-- Tour Information -->
    <section class="py-16 bg-stone-beige">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-heading font-bold text-earth-brown mb-8 text-center">
            What to Expect During Your Tour
          </h2>
          
          <div class="grid md:grid-cols-3 gap-6 mb-12">
            <div class="bg-white rounded-xl p-6 shadow-soft">
              <div class="w-12 h-12 bg-forest-canopy/10 rounded-full flex items-center justify-center mb-4">
                <Clock className="w-6 h-6 text-forest-canopy" />
              </div>
              <h3 class="font-semibold text-earth-brown mb-2">45-Minute Tour</h3>
              <p class="text-sm text-gray-600">
                Tour our classrooms, outdoor spaces, and meet our wonderful teachers.
              </p>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-soft">
              <div class="w-12 h-12 bg-spicebush-red/10 rounded-full flex items-center justify-center mb-4">
                <Users className="w-6 h-6 text-spicebush-red" />
              </div>
              <h3 class="font-semibold text-earth-brown mb-2">Meet Our Community</h3>
              <p class="text-sm text-gray-600">
                Learn about our philosophy and meet other families in our community.
              </p>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-soft">
              <div class="w-12 h-12 bg-moss-green/10 rounded-full flex items-center justify-center mb-4">
                <CheckCircle className="w-6 h-6 text-moss-green" />
              </div>
              <h3 class="font-semibold text-earth-brown mb-2">No Obligation</h3>
              <p class="text-sm text-gray-600">
                This is a free tour with no commitment required. Take your time to decide.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Scheduling Form Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto">
          <div class="bg-stone-beige/30 rounded-2xl p-8 lg:p-10">
            <h2 class="text-2xl font-heading font-bold text-earth-brown mb-6 text-center">
              Schedule Your Free Tour
            </h2>
            
            <form id="tour-form" class="space-y-6">
              <!-- Parent Information -->
              <div class="space-y-4">
                <h3 class="font-semibold text-earth-brown">Parent Information</h3>
                
                <div>
                  <label for="parent-name" class="block text-sm font-medium text-gray-700 mb-1">
                    Your Name <span class="text-spicebush-red">*</span>
                  </label>
                  <input
                    type="text"
                    id="parent-name"
                    name="parentName"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                  />
                </div>
                
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                    Email Address <span class="text-spicebush-red">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                  />
                </div>
                
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
                    Phone Number <span class="text-spicebush-red">*</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                  />
                </div>
              </div>
              
              <!-- Child Information -->
              <div class="space-y-4">
                <h3 class="font-semibold text-earth-brown">Child Information</h3>
                
                <div>
                  <label for="child-name" class="block text-sm font-medium text-gray-700 mb-1">
                    Child's Name <span class="text-spicebush-red">*</span>
                  </label>
                  <input
                    type="text"
                    id="child-name"
                    name="childName"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                  />
                </div>
                
                <div>
                  <label for="child-age" class="block text-sm font-medium text-gray-700 mb-1">
                    Child's Age <span class="text-spicebush-red">*</span>
                  </label>
                  <select
                    id="child-age"
                    name="childAge"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                  >
                    <option value="">Select age</option>
                    <option value="3">3 years old</option>
                    <option value="4">4 years old</option>
                    <option value="5">5 years old</option>
                    <option value="6">6 years old</option>
                  </select>
                </div>
              </div>
              
              <!-- Tour Preferences -->
              <div class="space-y-4">
                <h3 class="font-semibold text-earth-brown">Tour Preferences</h3>
                
                <div>
                  <label for="preferred-date" class="block text-sm font-medium text-gray-700 mb-1">
                    Preferred Date <span class="text-spicebush-red">*</span>
                  </label>
                  <input
                    type="date"
                    id="preferred-date"
                    name="preferredDate"
                    required
                    min={new Date().toISOString().split('T')[0]}
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                  />
                </div>
                
                <div>
                  <label for="preferred-time" class="block text-sm font-medium text-gray-700 mb-1">
                    Preferred Time
                  </label>
                  <select
                    id="preferred-time"
                    name="preferredTime"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                  >
                    <option value="morning">Morning (9:00 AM - 12:00 PM)</option>
                    <option value="afternoon">Afternoon (1:00 PM - 4:00 PM)</option>
                    <option value="flexible">I'm flexible</option>
                  </select>
                </div>
                
                <div>
                  <label for="questions" class="block text-sm font-medium text-gray-700 mb-1">
                    Questions or Special Requests (Optional)
                  </label>
                  <textarea
                    id="questions"
                    name="questions"
                    rows="3"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                  ></textarea>
                </div>
              </div>
              
              <!-- Submit Button -->
              <button
                type="submit"
                class="w-full bg-forest-canopy text-white font-semibold py-3 px-6 rounded-lg hover:bg-forest-canopy/90 transition duration-200"
              >
                Schedule My Free Tour
              </button>
              
              <!-- Success Message (hidden by default) -->
              <div id="success-message" class="hidden bg-green-50 border border-green-200 rounded-lg p-4 text-center">
                <p class="text-green-800 font-semibold">
                  Thank you! We'll contact you within 24 hours to confirm your tour.
                </p>
              </div>
              
              <!-- Error Message (hidden by default) -->
              <div id="error-message" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 text-center">
                <p class="text-red-800">
                  Something went wrong. Please try again or call us at (336) 766-1214.
                </p>
              </div>
            </form>
          </div>
          
          <!-- Contact Alternative -->
          <div class="mt-8 text-center">
            <p class="text-gray-600">
              Prefer to call? Reach us at 
              <a href="tel:336-766-1214" class="text-forest-canopy font-semibold hover:underline">
                (336) 766-1214
              </a>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />

  <script>
    // Simple form submission handler
    document.getElementById('tour-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      
      try {
        const response = await fetch('/api/schedule-tour', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });
        
        if (response.ok) {
          // Show success message
          document.getElementById('success-message')?.classList.remove('hidden');
          document.getElementById('error-message')?.classList.add('hidden');
          form.reset();
          
          // Scroll to success message
          document.getElementById('success-message')?.scrollIntoView({ behavior: 'smooth' });
        } else {
          throw new Error('Failed to submit');
        }
      } catch (error) {
        // Show error message
        document.getElementById('error-message')?.classList.remove('hidden');
        document.getElementById('success-message')?.classList.add('hidden');
      }
    });
  </script>
</Layout>