---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Heart, ArrowLeft, Download } from 'lucide-astro';

// Get donation ID from URL params
const url = new URL(Astro.request.url);
const donationId = url.searchParams.get('id');
---

<Layout 
  title="Thank You for Your Donation - Spicebush Montessori School"
  description="Thank you for supporting Spicebush Montessori School. Your generosity makes a difference."
>
  <Header />
  
  <main id="main-content">
    <section class="min-h-[60vh] bg-gradient-to-br from-forest-canopy to-moss-green py-16 lg:py-20 flex items-center">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <div class="flex justify-center mb-6">
            <div class="w-20 h-20 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center border-2 border-white/30">
              <Heart className="w-10 h-10 text-white" />
            </div>
          </div>
          
          <h1 class="text-4xl lg:text-5xl font-heading font-bold text-white mb-6 tracking-tight">
            Thank You for Your Generosity!
          </h1>
          
          <p class="text-lg lg:text-xl text-green-100 mb-8 leading-relaxed-plus">
            Your donation has been processed successfully. You're making a meaningful difference in the lives of our students.
          </p>
          
          {donationId && (
            <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 mb-6">
              <p class="text-sm text-green-100">
                Donation Reference: <span class="font-mono text-white">{donationId}</span>
              </p>
            </div>
          )}
          
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 mb-8 text-left">
            <h2 class="text-xl font-semibold text-white mb-3">What happens next?</h2>
            <ul class="space-y-2 text-green-100">
              <li class="flex items-start">
                <span class="text-sunlight-gold mr-2">•</span>
                <span>You'll receive an email receipt shortly</span>
              </li>
              <li class="flex items-start">
                <span class="text-sunlight-gold mr-2">•</span>
                <span>Your donation is tax-deductible (EIN: 82-2865329)</span>
              </li>
              <li class="flex items-start">
                <span class="text-sunlight-gold mr-2">•</span>
                <span>We'll send updates on how your gift makes an impact</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-blue-50/10 backdrop-blur-sm border border-blue-200/30 rounded-xl p-6 mb-8">
            <h3 class="text-lg font-semibold text-white mb-2">Double Your Impact</h3>
            <p class="text-sm text-green-100">
              Many employers will match your donation. Check with your HR department about corporate matching gift programs.
            </p>
          </div>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="/" 
              class="inline-flex items-center justify-center bg-white text-forest-canopy px-6 py-3 rounded-lg font-semibold hover:bg-stone-beige transition-all duration-300"
            >
              <ArrowLeft className="w-5 h-5 mr-2" />
              Back to Home
            </a>
            
            <a 
              href="/donate" 
              class="inline-flex items-center justify-center bg-transparent text-white border-2 border-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-all duration-300"
            >
              <Heart className="w-5 h-5 mr-2" />
              Make Another Donation
            </a>
          </div>
          
          <div class="mt-12 p-6 bg-white/5 backdrop-blur-sm rounded-xl">
            <p class="text-sm text-green-100 italic">
              "The child is both a hope and a promise for mankind."
            </p>
            <p class="text-xs text-green-200 mt-2">— Maria Montessori</p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Share Section -->
    <section class="py-16 bg-stone-beige">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <h2 class="text-2xl font-heading font-bold text-earth-brown mb-4">
            Help Us Spread the Word
          </h2>
          <p class="text-gray-700 mb-6">
            Your support means the world to us. Consider sharing our mission with friends and family who might also want to support quality Montessori education.
          </p>
          <div class="flex gap-4 justify-center">
            <a 
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://spicebushmontessori.org/donate')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
            >
              Share on Facebook
            </a>
            <a 
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent('I just supported Spicebush Montessori School! Join me in nurturing young minds: https://spicebushmontessori.org/donate')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-4 py-2 bg-sky-500 text-white rounded-lg hover:bg-sky-600 transition-colors"
            >
              Share on Twitter
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>