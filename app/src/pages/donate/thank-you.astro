---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout 
  title="Thank You - Spicebush Montessori School"
  description="Thank you for your generous donation to Spicebush Montessori School."
  keywords="donation thank you, Montessori school support"
>
  <Header />
  
  <main id="main-content">
    <section class="py-16 lg:py-24">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <!-- Success Icon -->
          <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          
          <h1 class="text-4xl lg:text-5xl font-heading font-bold text-earth-brown mb-6">
            Thank You!
          </h1>
          
          <p class="text-lg text-gray-700 mb-8 leading-relaxed">
            Your generous donation has been received and will directly support our mission to provide accessible Montessori education to all families. You should receive an email receipt shortly.
          </p>
          
          <div class="bg-sunlight-gold/10 rounded-lg p-6 mb-8">
            <h2 class="text-xl font-semibold text-earth-brown mb-3">Your Impact</h2>
            <p class="text-gray-700">
              Every donation helps us maintain our sliding-scale tuition model, provide quality learning materials, and support our dedicated teachers. Thank you for believing in our vision of inclusive education.
            </p>
          </div>
          
          <div class="space-y-4">
            <a 
              href="/" 
              class="inline-block bg-forest-canopy text-white px-8 py-3 rounded-lg font-semibold hover:bg-forest-canopy/90 transition-colors"
            >
              Return to Home
            </a>
            
            <p class="text-sm text-gray-600">
              Questions about your donation? Contact us at 
              <a href="mailto:donate@spicebushmontessori.org" class="text-forest-canopy hover:underline">
                donate@spicebushmontessori.org
              </a>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>