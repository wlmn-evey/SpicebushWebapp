---
// Test page to verify environment variables
const env = {
  PUBLIC_SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL,
  PUBLIC_SUPABASE_ANON_KEY: import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  PUBLIC_SITE_URL: import.meta.env.PUBLIC_SITE_URL,
  MODE: import.meta.env.MODE,
  PROD: import.meta.env.PROD,
  hasUrl: !!import.meta.env.PUBLIC_SUPABASE_URL,
  hasKey: !!import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
};
---

<html>
  <head>
    <title>Environment Test</title>
  </head>
  <body>
    <h1>Environment Variables Test</h1>
    <pre>{JSON.stringify(env, null, 2)}</pre>
    
    <h2>Supabase Status</h2>
    <p>URL configured: {env.hasUrl ? '✅ Yes' : '❌ No'}</p>
    <p>Key configured: {env.hasKey ? '✅ Yes' : '❌ No'}</p>
    
    <script>
      // Client-side check
      console.log('Client-side env check:', {
        url: import.meta.env.PUBLIC_SUPABASE_URL,
        key: import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      });
    </script>
  </body>
</html>