---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ImageGrid from '../components/ImageGrid.astro';
import PhotoFeature from '../components/PhotoFeature.astro';
import NonDiscriminationPolicy from '../components/NonDiscriminationPolicy.astro';
import ValuePropositions from '../components/ValuePropositions.astro';
import ProgramsOverview from '../components/ProgramsOverview.astro';
import InclusionCommitment from '../components/InclusionCommitment.astro';
import CallToAction from '../components/CallToAction.astro';
import TrustIndicators from '../components/TrustIndicators.astro';
import { CheckCircle, ArrowRight } from 'lucide-astro';
import { getHomepageData } from '@lib/content-db';
import { compareDates, formatBlogDate, getISOString } from '@lib/date-utils';

// Batch load all homepage data in a single operation
let pageData = { blog: [], staff: [], testimonials: [] };
let error = null;

try {
  pageData = await getHomepageData();
} catch (e) {
  console.error('Error loading homepage data:', e);
  error = true;
}

// Process blog posts
const blogPosts = pageData.blog
  .filter(post => !post.data.draft)
  .sort((a, b) => compareDates(a.data.date, b.data.date, true))
  .slice(0, 3);

// Process featured staff
const featuredStaff = pageData.staff
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
  .slice(0, 3);

// Process testimonials
const testimonials = pageData.testimonials.slice(0, 3);
---

<Layout 
  title="Spicebush Montessori School - Inclusive Montessori Education for Ages 3-6"
  description="Discover individualized, inclusive Montessori education at Spicebush. We welcome all learners with accessible tuition, neurodiversity support, and authentic Montessori methods."
  keywords="Montessori school, inclusive preschool, neurodiversity education, accessible tuition, early childhood education, autism friendly school, ADHD support"
  preloadImages={true}
>
  <Header />
  
  <main id="main-content">
    <!-- New Hero Section with full-width image -->
    <HeroSection />
    
    <!-- Trust Indicators -->
    <TrustIndicators />
    
    <!-- Content Section with Photo Feature -->
    <section class="py-16 bg-moss-green text-light-stone">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl lg:text-4xl font-heading font-bold mb-8 tracking-tight">
            Where Children Flourish as Themselves
          </h2>
          <p class="text-lg lg:text-xl leading-relaxed-plus font-light max-w-3xl mx-auto tracking-wide">
            We believe each child is already whole and wonderful. Our job is simply to create a space where their natural curiosity can unfold, where they feel deeply seen and loved, and where learning feels as natural as breathing.
          </p>
        </div>
      </div>
    </section>
    
    <!-- Authentic Montessori Section with Photo Feature -->
    <PhotoFeature 
      title="Learning the Montessori Way" 
      content="Dr. Montessori discovered something beautiful: when children are free to follow their interests in a thoughtfully prepared environment, they naturally develop concentration, independence, and a deep love of learning. We stay true to these discoveries while making sure every child—regardless of how they learn—can experience this magic."
      photoSlug="individual-montessori-concentration-img-7291-1770x1931"
      ctaLink="/our-principles"
      ctaText="Learn About Our Approach"
      imagePosition="right"
    />
    
    <!-- Component Sections -->
    <ValuePropositions />
    
    <!-- Optimized Testimonials Section -->
    {!error && testimonials.length > 0 && (
      <section class="py-16 bg-sunlight-gold/5">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-4 tracking-tight">
              What Families Say
            </h2>
            <p class="text-lg text-earth-brown max-w-3xl mx-auto leading-relaxed-plus font-light">
              Hear from parents who have experienced the Spicebush difference
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {testimonials.map((testimonial) => (
              <div class="bg-white p-6 rounded-xl shadow-sm border border-stone-beige/50">
                <div class="flex items-center mb-4">
                  {[...Array(5)].map((_, i) => (
                    <CheckCircle className="w-5 h-5 text-sunlight-gold" />
                  ))}
                </div>
                <blockquote class="text-earth-brown italic mb-4 leading-relaxed">
                  "{testimonial.body}"
                </blockquote>
                <cite class="text-forest-canopy font-semibold not-italic">
                  {testimonial.data.name}
                </cite>
                <p class="text-earth-brown/70 text-sm">
                  {testimonial.data.relationship}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}
    
    <!-- Photo Gallery Grid -->
    <ImageGrid 
      title="Life at Spicebush Montessori"
      subtitle="Explore our vibrant community and see our Montessori philosophy in action"
      columns={3}
      images={[
        {
          photoSlug: 'individual-montessori-concentration-img-7293-1732x2057',
          caption: 'Deep concentration and self-directed learning'
        },
        {
          photoSlug: 'materials-montessori-montessori-materials-img-6678-1499x1814',
          caption: 'Hands-on exploration with Montessori materials'
        },
        {
          photoSlug: 'individual-montessori-concentration-img-6989-1423x1897',
          caption: 'Independent discovery and joyful learning'
        },
        {
          photoSlug: 'gallery-montessori-watercolor-painting-artistic-expression',
          caption: 'Creative expression through art'
        },
        {
          photoSlug: 'group-montessori-collaboration-img-6543-1933x1450',
          caption: 'Our diverse classroom community working together'
        },
        {
          photoSlug: 'outdoor-montessori-outdoor-education-img-9428-1310x1746',
          caption: 'Exploring and learning in nature'
        }
      ]}
    />
    
    <ProgramsOverview />
    
    <!-- Optimized Featured Teachers Section -->
    {!error && featuredStaff.length > 0 && (
      <section class="py-16 bg-white">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-4 tracking-tight">
              Meet Our Teachers
            </h2>
            <p class="text-lg text-earth-brown max-w-3xl mx-auto leading-relaxed-plus font-light">
              Experienced Montessori guides who see the unique light in every child
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
            {featuredStaff.map((teacher) => (
              <div class="text-center">
                <div class="mb-6 relative inline-block">
                  {teacher.data.photo ? (
                    <img 
                      src={teacher.data.photo}
                      alt={`${teacher.data.name}, ${teacher.data.role} at Spicebush Montessori School`}
                      class="w-48 h-48 rounded-full object-cover mx-auto shadow-lg"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-48 h-48 rounded-full bg-gradient-to-br from-forest-canopy to-moss-green flex items-center justify-center mx-auto shadow-lg">
                      <span class="text-white text-4xl font-bold">
                        {teacher.data.name.split(' ').map(n => n[0]).join('')}
                      </span>
                    </div>
                  )}
                  {teacher.data.credentials && teacher.data.credentials.length > 0 && (
                    <div class="absolute -bottom-2 -right-2 bg-sunlight-gold text-white rounded-full w-12 h-12 flex items-center justify-center text-xs font-bold shadow-md">
                    AMI
                    </div>
                  )}
                </div>
              
                <h3 class="text-xl font-semibold text-earth-brown mb-1">
                  {teacher.data.name}
                </h3>
                <p class="text-forest-canopy font-medium mb-2">
                  {teacher.data.role}
                </p>
                <p class="text-sm text-earth-brown/80 mb-3">
                  {teacher.data.startYear && `Since ${teacher.data.startYear}`}
                </p>
              
                {teacher.body && (
                  <div class="text-earth-brown leading-relaxed text-sm max-w-sm mx-auto" set:html={`${teacher.body.split('.')[0]}.`} />
                )}
              </div>
            ))}
          </div>
          
          <div class="text-center">
            <a 
              href="/about#teachers" 
              class="inline-flex items-center text-forest-canopy hover:text-moss-green transition-colors font-semibold text-lg"
            >
              Meet Our Full Team
              <ArrowRight className="w-5 h-5 ml-2" />
            </a>
          </div>
        </div>
      </section>
    )}
    
    <InclusionCommitment />
    
    <!-- Non-Discrimination Policy Section -->
    <NonDiscriminationPolicy />
    
    <!-- Optimized Recent Blog Posts -->
    {!error && blogPosts.length > 0 && (
      <section class="py-16 bg-stone-beige">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-heading font-bold text-earth-brown mb-4">
              Latest from Our Blog
            </h2>
            <p class="text-lg text-gray-700 max-w-2xl mx-auto">
              Stay connected with our community through updates, insights, and stories from Spicebush Montessori.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
            {blogPosts.map(post => {
              const { title, excerpt, image, imageAlt, date, categories } = post.data;
              const slug = post.slug;
              
              return (
                <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow">
                  {image && (
                    <div class="aspect-video overflow-hidden">
                      <img 
                        src={image}
                        alt={imageAlt || title}
                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-6">
                    {categories?.length > 0 && (
                      <div class="flex gap-2 mb-3">
                        {categories.slice(0, 2).map(category => (
                          <span class="text-xs font-medium text-moss-green bg-green-50 px-2 py-1 rounded">
                            {category}
                          </span>
                        ))}
                      </div>
                    )}
                    <h3 class="text-xl font-semibold text-earth-brown mb-2 line-clamp-2">
                      <a href={`/blog/${slug}`} class="hover:text-forest-canopy transition-colors">
                        {title}
                      </a>
                    </h3>
                    {excerpt && (
                      <p class="text-gray-600 mb-4 line-clamp-3 text-sm leading-relaxed">
                        {excerpt}
                      </p>
                    )}
                    <div class="flex justify-between items-center">
                      <time class="text-sm text-gray-500" datetime={getISOString(date)}>
                        {formatBlogDate(date)}
                      </time>
                      <a 
                        href={`/blog/${slug}`} 
                        class="text-moss-green hover:text-forest-canopy font-medium text-sm flex items-center gap-1 group"
                      >
                        Read More 
                        <ArrowRight className="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                      </a>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>

          <div class="text-center mt-12">
            <a 
              href="/blog" 
              class="inline-flex items-center gap-2 bg-forest-canopy hover:bg-moss-green text-white px-6 py-3 rounded-lg font-semibold transition-colors"
            >
              View All Posts
              <ArrowRight className="w-5 h-5" />
            </a>
          </div>
        </div>
      </section>
    )}
    
    <!-- Call to Action Section -->
    <CallToAction />
  </main>
  
  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>