---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ImageGrid from '../components/ImageGrid.astro';
import PhotoFeature from '../components/PhotoFeature.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import NonDiscriminationPolicy from '../components/NonDiscriminationPolicy.astro';
import ValuePropositions from '../components/ValuePropositions.astro';
import ProgramsOverview from '../components/ProgramsOverview.astro';
import InclusionCommitment from '../components/InclusionCommitment.astro';
import CallToAction from '../components/CallToAction.astro';
import TrustIndicators from '../components/TrustIndicators.astro';
import CampPromoModule from '../components/CampPromoModule.astro';
import { CheckCircle, ArrowRight } from 'lucide-astro';
import { db, type ContentEntry } from '@lib/db';
import { logServerError } from '@lib/server-logger';
import { getTestimonialsForPlacement, type ManagedTestimonial } from '@lib/testimonials-content';
import { buildPhotoSlugResolver, toPhotoLookupEntry } from '@lib/photo-slug-resolver';

// Batch load homepage data needed for active sections.
type StaffEntryData = {
  order?: number;
  photo?: string;
  name?: string;
  role?: string;
  startYear?: string | number;
  certificationBadge?: string;
};

type HomepageData = {
  staff: ContentEntry<StaffEntryData>[];
  testimonials: ManagedTestimonial[];
};

type FeaturedStaffViewModel = {
  id: string;
  name: string;
  role?: string;
  photo?: string;
  photoSlug?: string;
  startYearLabel?: string;
  certificationBadge?: string;
  bioSnippet?: string;
  initials: string;
  order: number;
};

const normalizeString = (value: unknown): string => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.length > 0) return trimmed;
  }
  return '';
};

const asRecord = (value: unknown): Record<string, unknown> => {
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    return value as Record<string, unknown>;
  }
  return {};
};

let pageData: HomepageData = { staff: [], testimonials: [] };
let error = null;

try {
  const [staffEntries, homepageTestimonials] = await Promise.all([
    db.content.getCollection('staff'),
    getTestimonialsForPlacement('homepage')
  ]);

  pageData = {
    staff: (staffEntries ?? []) as ContentEntry<StaffEntryData>[],
    testimonials: homepageTestimonials
  };
} catch (e) {
  logServerError('Failed to load homepage data', e, { page: '/' });
  error = true;
}

let resolvePhotoSlug = (_value: string | undefined): string | null => null;

try {
  const photoEntries = await db.content.getCollection('photos');
  resolvePhotoSlug = buildPhotoSlugResolver(
    photoEntries.map(entry => toPhotoLookupEntry(entry.slug, asRecord(entry.data)))
  );
} catch (e) {
  logServerError('Failed to load photo slug resolver on homepage', e, { page: '/' });
}

const featuredStaff = pageData.staff
  .map((entry): FeaturedStaffViewModel | null => {
    const data = entry.data ?? {};
    const name = normalizeString(data.name) || 'Spicebush Teacher';
    const role = normalizeString(data.role) || undefined;
    const photo = normalizeString(data.photo) || undefined;
    const photoSlug = resolvePhotoSlug(photo) ?? undefined;
    const certificationBadge = normalizeString(data.certificationBadge) || undefined;
    const startYearRaw = data.startYear;
    const startYear =
      typeof startYearRaw === 'number' ? String(startYearRaw) : normalizeString(startYearRaw);
    const startYearLabel = startYear ? `Since ${startYear}` : undefined;
    const order = typeof data.order === 'number' ? data.order : 999;

    const bodyText = typeof entry.body === 'string' ? entry.body : '';
    const firstSentence = bodyText
      .split('.')
      .map(sentence => sentence.trim())
      .filter(Boolean)[0];
    const bioSnippet = firstSentence ? `${firstSentence}.` : undefined;

    const initials = name
      .split(' ')
      .filter(Boolean)
      .map(segment => segment.charAt(0).toUpperCase())
      .join('')
      .slice(0, 3);

    return {
      id: entry.id,
      name,
      role,
      photo,
      photoSlug,
      startYearLabel,
      certificationBadge,
      bioSnippet,
      initials: initials || 'S',
      order
    };
  })
  .filter((entry): entry is FeaturedStaffViewModel => entry !== null)
  .sort((a, b) => a.order - b.order)
  .slice(0, 3);

// Process testimonials
const testimonials = pageData.testimonials;
---

<Layout
  title="Spicebush Montessori School - Inclusive Montessori Education for Ages 3-6"
  description="Discover individualized, inclusive Montessori education at Spicebush. We welcome all learners with accessible tuition, neurodiversity support, and authentic Montessori methods."
  keywords="Montessori school, inclusive preschool, neurodiversity education, accessible tuition, early childhood education, autism friendly school, ADHD support"
  preloadImages={true}
>
  <Header />

  <main id="main-content">
    <!-- New Hero Section with full-width image -->
    <HeroSection />

    <!-- Trust Indicators -->
    <TrustIndicators />

    <CampPromoModule placement="homepage" />

    <!-- Content Section with Photo Feature -->
    <section class="py-16 bg-moss-green text-light-stone">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl lg:text-4xl font-heading font-bold mb-8 tracking-tight">
            Where Children Flourish as Themselves
          </h2>
          <p
            class="text-lg lg:text-xl leading-relaxed-plus font-light max-w-3xl mx-auto tracking-wide"
          >
            We believe each child is already whole and wonderful. Our job is simply to create a
            space where their natural curiosity can unfold, where they feel deeply seen and loved,
            and where learning feels as natural as breathing.
          </p>
        </div>
      </div>
    </section>

    <!-- Authentic Montessori Section with Photo Feature -->
    <PhotoFeature
      title="Learning the Montessori Way"
      content="Dr. Montessori discovered something beautiful: when children are free to follow their interests in a thoughtfully prepared environment, they naturally develop concentration, independence, and a deep love of learning. We stay true to these discoveries while making sure every child—regardless of how they learn—can experience this magic."
      photoSlug="individual-montessori-concentration-img-7291-1770x1931"
      slotId="home-photo-feature-learning"
      mediaCategory="homepage"
      ctaLink="/our-principles"
      ctaText="Learn About Our Approach"
      imagePosition="right"
    />

    <!-- Component Sections -->
    <ValuePropositions />

    <!-- Optimized Testimonials Section -->
    {
      !error && testimonials.length > 0 && (
        <section class="py-16 bg-sunlight-gold/5">
          <div class="container mx-auto px-4">
            <div class="text-center mb-12">
              <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-4 tracking-tight">
                What Families Say
              </h2>
              <p class="text-lg text-earth-brown max-w-3xl mx-auto leading-relaxed-plus font-light">
                Hear from parents who have experienced the Spicebush difference
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              {testimonials.map(testimonial => (
                <div class="bg-white p-6 rounded-xl shadow-sm border border-stone-beige/50">
                  <div class="flex items-center mb-4">
                    {Array.from({ length: testimonial.rating }).map(() => (
                      <CheckCircle className="w-5 h-5 text-sunlight-gold" />
                    ))}
                  </div>
                  <blockquote class="text-earth-brown italic mb-4 leading-relaxed">
                    "{testimonial.body}"
                  </blockquote>
                  <cite class="text-forest-canopy font-semibold not-italic">
                    {testimonial.author}
                  </cite>
                  <p class="text-earth-brown/70 text-sm">{testimonial.relationship}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Photo Gallery Grid -->
    <ImageGrid
      title="Life at Spicebush Montessori"
      subtitle="Explore our vibrant community and see our Montessori philosophy in action"
      columns={3}
      slotIdPrefix="home-gallery"
      images={[
        {
          photoSlug: 'individual-montessori-concentration-img-7293-1732x2057',
          caption: 'Deep concentration and self-directed learning'
        },
        {
          photoSlug: 'materials-montessori-montessori-materials-img-6678-1499x1814',
          caption: 'Hands-on exploration with Montessori materials'
        },
        {
          photoSlug: 'individual-montessori-concentration-img-6989-1423x1897',
          caption: 'Independent discovery and joyful learning'
        },
        {
          photoSlug: 'gallery-montessori-watercolor-painting-artistic-expression',
          caption: 'Creative expression through art'
        },
        {
          photoSlug: 'group-montessori-collaboration-img-6543-1933x1450',
          caption: 'Our diverse classroom community working together'
        },
        {
          photoSlug: 'outdoor-montessori-outdoor-education-img-9428-1310x1746',
          caption: 'Exploring and learning in nature'
        }
      ]}
    />

    <ProgramsOverview />

    <!-- Optimized Featured Teachers Section -->
    {
      !error && featuredStaff.length > 0 && (
        <section class="py-16 bg-white">
          <div class="container mx-auto px-4">
            <div class="text-center mb-12">
              <h2 class="text-3xl lg:text-4xl font-heading font-bold text-earth-brown mb-4 tracking-tight">
                Meet Our Teachers
              </h2>
              <p class="text-lg text-earth-brown max-w-3xl mx-auto leading-relaxed-plus font-light">
                Experienced Montessori guides who see the unique light in every child
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
              {featuredStaff.map(teacher => (
                <div class="text-center">
                  <div class="mb-6 relative inline-block">
                    {teacher.photoSlug ? (
                      <OptimizedImage
                        photoSlug={teacher.photoSlug}
                        alt={`${teacher.name}${teacher.role ? `, ${teacher.role}` : ''} at Spicebush Montessori School`}
                        className="w-48 h-48 rounded-full object-cover mx-auto shadow-lg"
                        slotId={`home-featured-teacher-${teacher.id}`}
                        mediaCategory="teachers"
                      />
                    ) : teacher.photo ? (
                      <img
                        src={teacher.photo}
                        alt={`${teacher.name}${teacher.role ? `, ${teacher.role}` : ''} at Spicebush Montessori School`}
                        class="w-48 h-48 rounded-full object-cover mx-auto shadow-lg"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-48 h-48 rounded-full bg-gradient-to-br from-forest-canopy to-moss-green flex items-center justify-center mx-auto shadow-lg">
                        <span class="text-white text-4xl font-bold">{teacher.initials}</span>
                      </div>
                    )}
                    {teacher.certificationBadge && (
                      <div class="absolute -bottom-2 -right-2 bg-sunlight-gold text-white rounded-full w-12 h-12 flex items-center justify-center text-xs font-bold shadow-md">
                        {teacher.certificationBadge}
                      </div>
                    )}
                  </div>

                  <h3 class="text-xl font-semibold text-earth-brown mb-1">{teacher.name}</h3>
                  {teacher.role && (
                    <p class="text-forest-canopy font-medium mb-2">{teacher.role}</p>
                  )}
                  {teacher.startYearLabel && (
                    <p class="text-sm text-earth-brown/80 mb-3">{teacher.startYearLabel}</p>
                  )}

                  {teacher.bioSnippet && (
                    <div class="text-earth-brown leading-relaxed text-sm max-w-sm mx-auto">
                      {teacher.bioSnippet}
                    </div>
                  )}
                </div>
              ))}
            </div>

            <div class="text-center">
              <a
                href="/about#teachers"
                class="inline-flex items-center text-forest-canopy hover:text-moss-green transition-colors font-semibold text-lg"
              >
                Meet Our Full Team
                <ArrowRight className="w-5 h-5 ml-2" />
              </a>
            </div>
          </div>
        </section>
      )
    }

    <InclusionCommitment />

    <!-- Non-Discrimination Policy Section -->
    <NonDiscriminationPolicy />

    <!-- Call to Action Section -->
    <CallToAction />
  </main>

  <Footer />
</Layout>
