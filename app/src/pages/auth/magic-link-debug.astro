---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Magic Link Debugger - Spicebush Montessori"
  description="Debug magic link authentication flow"
>
  <div class="min-h-screen bg-gradient-to-br from-stone-beige to-light-stone flex items-center justify-center py-12 px-4">
    <div class="max-w-2xl w-full bg-white rounded-xl shadow-lg p-8">
      <h1 class="text-2xl font-bold text-earth-brown mb-6">Magic Link Diagnostic Tool</h1>
      
      <div id="status" class="space-y-4">
        <!-- Status updates will appear here -->
      </div>
      
      <div class="mt-6 space-y-4">
        <button id="test-simple" class="w-full px-4 py-2 bg-moss-green text-white rounded hover:bg-forest-canopy">
          Test Simple Magic Link
        </button>
        
        <button id="check-session" class="w-full px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
          Check Current Session
        </button>
        
        <button id="test-callback" class="w-full px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700">
          Test Callback URL Parsing
        </button>
      </div>
      
      <div class="mt-8 p-4 bg-gray-100 rounded">
        <h2 class="font-bold mb-2">Instructions to Fix:</h2>
        <ol class="list-decimal list-inside space-y-2 text-sm">
          <li>Log into Supabase Dashboard</li>
          <li>Go to Authentication → Hooks</li>
          <li>If "Enable Email Hook" is ON, toggle it OFF</li>
          <li>Save and test magic link again</li>
          <li>If it works with default email, leave it off</li>
        </ol>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '@lib/supabase';
    
    const statusDiv = document.getElementById('status') as HTMLDivElement;
    
    function addStatus(message: string, isError: boolean = false) {
      const div = document.createElement('div');
      div.className = `p-3 rounded ${isError ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800'}`;
      div.textContent = message;
      statusDiv.appendChild(div);
    }
    
    // Test simple magic link
    document.getElementById('test-simple')?.addEventListener('click', async () => {
      statusDiv.innerHTML = '';
      addStatus('Testing magic link with test@spicebushmontessori.org...');
      
      try {
        const { data, error } = await supabase.auth.signInWithOtp({
          email: 'test@spicebushmontessori.org',
          options: {
            emailRedirectTo: `${window.location.origin}/auth/callback`
          }
        });
        
        if (error) {
          addStatus(`Error: ${error.message}`, true);
          addStatus(`Error code: ${error.code || 'none'}`, true);
          addStatus(`Error status: ${error.status || 'none'}`, true);
        } else {
          addStatus('Success! Check email for magic link');
          addStatus(`Redirect URL: ${window.location.origin}/auth/callback`);
        }
      } catch (err: any) {
        addStatus(`Exception: ${err.message}`, true);
      }
    });
    
    // Check current session
    document.getElementById('check-session')?.addEventListener('click', async () => {
      statusDiv.innerHTML = '';
      addStatus('Checking current session...');
      
      try {
        const { data: { session }, error } = await supabase.auth.getSession();
        
        if (error) {
          addStatus(`Session error: ${error.message}`, true);
        } else if (session) {
          addStatus(`Logged in as: ${session.user.email}`);
          addStatus(`Session expires: ${new Date(session.expires_at * 1000).toLocaleString()}`);
        } else {
          addStatus('No active session');
        }
      } catch (err: any) {
        addStatus(`Exception: ${err.message}`, true);
      }
    });
    
    // Test callback URL parsing
    document.getElementById('test-callback')?.addEventListener('click', () => {
      statusDiv.innerHTML = '';
      addStatus('Current URL info:');
      
      const hashParams = new URLSearchParams(window.location.hash.substring(1));
      const queryParams = new URLSearchParams(window.location.search);
      
      addStatus(`Hash params: ${Array.from(hashParams.entries()).map(([k,v]) => `${k}=${v}`).join(', ') || 'none'}`);
      addStatus(`Query params: ${Array.from(queryParams.entries()).map(([k,v]) => `${k}=${v}`).join(', ') || 'none'}`);
      
      // Check what Supabase expects
      const token = hashParams.get('access_token') || queryParams.get('access_token');
      const type = hashParams.get('type') || queryParams.get('type');
      const error = hashParams.get('error_description') || queryParams.get('error_description');
      
      if (error) {
        addStatus(`Error in URL: ${error}`, true);
      } else if (token) {
        addStatus(`Found token: ${token.substring(0, 20)}...`);
        addStatus(`Type: ${type || 'not specified'}`);
      } else {
        addStatus('No auth tokens in URL');
      }
    });
    
    // Also check Supabase configuration
    addStatus('Supabase URL: ' + import.meta.env.PUBLIC_SUPABASE_URL);
    addStatus('Anon key present: ' + (import.meta.env.PUBLIC_SUPABASE_ANON_KEY ? 'Yes' : 'No'));
  </script>
</Layout>