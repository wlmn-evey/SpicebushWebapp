---
import NetlifyAuthLayout from '../../layouts/NetlifyAuthLayout.astro';
import { Mail, ArrowRight, Shield } from 'lucide-astro';
---

<NetlifyAuthLayout 
  title="Sign In - Spicebush Montessori School"
  description="Access your Spicebush Montessori School admin account."
  keywords="login, sign in, admin access"
>
  <div class="min-h-screen bg-gradient-to-br from-stone-beige to-light-stone flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <!-- Header -->
      <div class="text-center">
        <a href="/" class="inline-block mb-6">
          <img 
            src="/images/optimized/homepage/homepage-spicebush-logo-brand-identity-800x800.webp" 
            alt="Spicebush Montessori School" 
            class="h-20 w-auto mx-auto"
          />
        </a>
        <h2 class="text-3xl font-heading font-bold text-earth-brown tracking-tight">Welcome Back</h2>
        <p class="mt-2 text-sm text-earth-brown font-medium">
          Sign in to access the admin dashboard
        </p>
        <p class="mt-1 text-xs text-gray-600">
          Admin access for @eveywinters.com and @spicebushmontessori.org emails only
        </p>
      </div>

      <!-- Login Container -->
      <div class="bg-white rounded-xl shadow-lg p-8 border border-gray-200">
        <!-- Security Notice -->
        <div class="mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
          <div class="flex items-center">
            <Shield className="h-5 w-5 text-blue-600 mr-2" />
            <p class="text-sm text-blue-800 font-medium">Secure Authentication</p>
          </div>
          <p class="text-xs text-blue-700 mt-1">
            This site uses Netlify Identity for secure authentication
          </p>
        </div>

        <!-- Netlify Identity Button -->
        <div class="space-y-4">
          <button
            data-netlify-identity-button
            class="w-full flex items-center justify-center px-4 py-3 border border-transparent rounded-lg shadow-sm text-base font-medium text-white bg-moss-green hover:bg-forest-canopy focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-moss-green transition-all duration-200"
          >
            <Mail className="mr-2 h-5 w-5" />
            Sign In with Email
          </button>
        </div>

        <!-- Info Message -->
        <div class="mt-6 text-center">
          <p class="text-xs text-gray-500">
            If you're a new admin, you'll need to be invited first.
            <br />
            Contact the school director for access.
          </p>
        </div>
      </div>

      <!-- Alternative Options -->
      <div class="text-center">
        <a href="/" class="text-sm text-moss-green hover:text-forest-canopy font-medium">
          <ArrowRight className="inline-block h-4 w-4 mr-1 rotate-180" />
          Back to Homepage
        </a>
      </div>
    </div>
  </div>

  <script>
    // Handle login redirect
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('login', () => {
        // Redirect to admin dashboard after successful login
        const redirect = new URLSearchParams(window.location.search).get('redirect');
        document.location.href = redirect || '/admin/';
      });
      
      window.netlifyIdentity.on('logout', () => {
        // Redirect to homepage after logout
        document.location.href = '/';
      });
      
      window.netlifyIdentity.on('error', err => {
        console.error('Netlify Identity error:', err);
      });
      
      // Check if user is already logged in
      window.netlifyIdentity.on('init', user => {
        if (user) {
          // User is already logged in, redirect to admin
          const redirect = new URLSearchParams(window.location.search).get('redirect');
          document.location.href = redirect || '/admin/';
        }
      });
    }
  </script>
</NetlifyAuthLayout>