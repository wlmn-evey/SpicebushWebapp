---
import Layout from '../../layouts/Layout.astro';
import { authAdapter } from '../../lib/auth';

// Check if user is already authenticated
if (Astro.request.method === 'GET') {
  const isAuthenticated = await authAdapter.isAuthenticated();
  if (isAuthenticated) {
    return Astro.redirect('/admin/dashboard');
  }
}

// Handle form submission
let error = '';
let success = false;
let emailSent = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email') as string;
  
  try {
    const result = await authAdapter.sendMagicLink(email);
    if (result.success) {
      success = true;
      emailSent = email;
    } else {
      error = result.error || 'Failed to send magic link';
    }
  } catch (err) {
    error = 'An unexpected error occurred. Please try again.';
  }
}
---

<Layout title="Sign In - Spicebush Montessori">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <!-- Header -->
      <div>
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
          Sign in to your account
        </h2>
        <p class="mt-2 text-center text-sm text-gray-600">
          We'll send you a magic link to sign in
        </p>
      </div>

      <!-- Form -->
      {!success ? (
        <form class="mt-8 space-y-6" method="POST">
          <div class="rounded-md shadow-sm -space-y-px">
            <div>
              <label for="email-address" class="sr-only">
                Email address
              </label>
              <input
                id="email-address"
                name="email"
                type="email"
                autocomplete="email"
                required
                class="appearance-none rounded-md relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-primary-500 focus:border-primary-500 focus:z-10 sm:text-sm"
                placeholder="Email address"
              />
            </div>
          </div>

          {error && (
            <div class="rounded-md bg-red-50 p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <p class="text-sm text-red-800">
                    {error}
                  </p>
                </div>
              </div>
            </div>
          )}

          <div>
            <button
              type="submit"
              class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500"
            >
              Send magic link
            </button>
          </div>

          <div class="flex items-center justify-center">
            <div class="text-sm">
              <a href="/" class="font-medium text-primary-600 hover:text-primary-500">
                Back to home
              </a>
            </div>
          </div>
        </form>
      ) : (
        <!-- Success message -->
        <div class="rounded-md bg-green-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-green-800">
                Magic link sent!
              </h3>
              <div class="mt-2 text-sm text-green-700">
                <p>
                  We've sent a magic link to <strong>{emailSent}</strong>.
                </p>
                <p class="mt-2">
                  Click the link in your email to sign in. The link will expire in 10 minutes.
                </p>
              </div>
              <div class="mt-4">
                <a
                  href="/"
                  class="text-sm font-medium text-green-800 hover:text-green-700"
                >
                  Return to home →
                </a>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Auth provider indicator -->
      <div class="mt-4 text-center text-xs text-gray-500">
        Using {authAdapter.getProvider()} authentication
      </div>
    </div>
  </div>
</Layout>