---
import Layout from '../../layouts/Layout.astro';
import { Mail, ArrowRight, Sparkles } from 'lucide-astro';
---

<Layout 
  title="Sign In - Spicebush Montessori School"
  description="Access your Spicebush Montessori School admin account with a secure magic link."
  keywords="login, sign in, admin access, magic link"
>
  <div class="min-h-screen bg-gradient-to-br from-stone-beige to-light-stone flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <!-- Header -->
      <div class="text-center">
        <a href="/" class="inline-block mb-6">
          <img 
            src="/images/optimized/homepage/homepage-spicebush-logo-brand-identity-800x800.webp" 
            alt="Spicebush Montessori School" 
            class="h-20 w-auto mx-auto"
          />
        </a>
        <h2 class="text-3xl font-heading font-bold text-earth-brown tracking-tight">Welcome Back</h2>
        <p class="mt-2 text-sm text-earth-brown font-medium">
          Sign in with a secure magic link - no password needed!
        </p>
        <p class="mt-1 text-xs text-gray-600">
          Admin access for @eveywinters.com and @spicebushmontessori.org emails only
        </p>
      </div>

      <!-- Form Container -->
      <div class="bg-white rounded-xl shadow-lg p-8 border border-gray-200">
        <!-- Alert Messages -->
        <div id="auth-alert" class="hidden mb-4 p-4 rounded-lg" role="alert" aria-live="polite">
          <p id="auth-alert-message" class="text-sm font-medium"></p>
        </div>

        <!-- Magic Link Form -->
        <form id="magic-link-form" class="space-y-6">
          <div>
            <label for="email" class="block text-sm font-medium text-earth-brown mb-2">
              Email Address
            </label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <Mail className="h-5 w-5 text-gray-400" />
              </div>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent font-medium"
                placeholder="Enter your email"
              />
            </div>
          </div>

          <button
            type="submit"
            id="submit-button"
            class="w-full flex items-center justify-center px-4 py-3 border border-transparent rounded-lg shadow-sm text-base font-medium text-white bg-moss-green hover:bg-forest-canopy focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-moss-green transition-all duration-200"
          >
            <span id="button-text" class="flex items-center">
              Send Magic Link
              <Sparkles className="ml-2 h-5 w-5" />
            </span>
            <span id="loading-spinner" class="hidden">
              <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </span>
          </button>
        </form>

        <!-- Alternative Options -->
        <div class="mt-6 relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">Or</span>
          </div>
        </div>

        <div class="mt-6 text-center">
          <a href="/auth/login" class="text-sm text-moss-green hover:text-forest-canopy font-medium">
            Use password instead <ArrowRight className="inline-block h-4 w-4 ml-1" />
          </a>
        </div>
      </div>

      <!-- Success Message (Initially Hidden) -->
      <div id="success-message" class="hidden bg-green-50 border border-green-200 rounded-xl p-6 text-center">
        <div class="flex justify-center mb-4">
          <div class="h-12 w-12 bg-green-100 rounded-full flex items-center justify-center">
            <Mail className="h-6 w-6 text-green-600" />
          </div>
        </div>
        <h3 class="text-lg font-semibold text-green-900 mb-2">Check Your Email!</h3>
        <p class="text-sm text-green-700">
          We've sent your access link to <span id="sent-email" class="font-medium"></span>
        </p>
        <p class="text-xs text-green-600 mt-2">
          Look for an email from Spicebush Montessori School. Your link will arrive within 30 seconds and expires in 1 hour.
        </p>
        <button 
          id="resend-button"
          class="mt-4 text-sm text-green-700 hover:text-green-800 font-medium"
        >
          Didn't receive it? Send again
        </button>
      </div>
    </div>
  </div>

  <script>
    import { auth } from '../../lib/supabase';
    import { supabase } from "../../lib/supabase";
    console.log("Auth module loaded:", typeof auth);
    console.log("Supabase client loaded:", typeof supabase);    
    const form = document.getElementById('magic-link-form') as HTMLFormElement;
    const alert = document.getElementById('auth-alert') as HTMLDivElement;
    const alertMessage = document.getElementById('auth-alert-message') as HTMLParagraphElement;
    const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
    const buttonText = document.getElementById('button-text') as HTMLSpanElement;
    const loadingSpinner = document.getElementById('loading-spinner') as HTMLSpanElement;
    const successMessage = document.getElementById('success-message') as HTMLDivElement;
    const sentEmail = document.getElementById('sent-email') as HTMLSpanElement;
    const resendButton = document.getElementById('resend-button') as HTMLButtonElement;
    const formContainer = form.parentElement as HTMLDivElement;
    
    let userEmail = '';
    
    function showAlert(message: string, isError: boolean = false) {
      alert.classList.remove('hidden', 'bg-green-50', 'bg-red-50', 'text-green-800', 'text-red-800');
      alert.classList.add(isError ? 'bg-red-50' : 'bg-green-50');
      alertMessage.classList.add(isError ? 'text-red-800' : 'text-green-800');
      alertMessage.textContent = message;
    }
    
    function setLoading(loading: boolean) {
      submitButton.disabled = loading;
      buttonText.classList.toggle('hidden', loading);
      loadingSpinner.classList.toggle('hidden', !loading);
    }
    
    // Check if email is from allowed domains
    function isAllowedEmail(email: string): boolean {
      const normalizedEmail = email.toLowerCase().trim();
      const allowedDomains = ['@eveywinters.com', '@spicebushmontessori.org'];
      return allowedDomains.some(domain => normalizedEmail.endsWith(domain));
    }
    
    async function sendMagicLink(email: string) {
      setLoading(true);
      console.log('sendMagicLink called with email:', email);
      
      // Check if email is allowed before sending
      if (!isAllowedEmail(email)) {
        showAlert('Only administrators with @eveywinters.com or @spicebushmontessori.org email addresses can access the admin panel. Please contact the school director if you need access.', true);
        setLoading(false);
        return;
      }
      
      try {
        // Try auth helper first, fallback to direct client if not available
        let error;
        if (typeof auth !== 'undefined' && auth.signInWithMagicLink) {
          console.log('Using auth helper for magic link');
          const result = await auth.signInWithMagicLink(email);
          error = result.error;
        } else {
          console.warn('Auth helper not available, using direct Supabase client');
          const result = await supabase.auth.signInWithOtp({
            email: email,
            options: {
              emailRedirectTo: `${window.location.origin}/auth/callback`
            }
          });
          error = result.error;
        }
        
        if (error) throw error;
        
        // Show success message
        userEmail = email;
        sentEmail.textContent = email;
        formContainer.classList.add('hidden');
        successMessage.classList.remove('hidden');
        
      } catch (error: any) {
        console.error('Magic link error:', error);
        const friendlyMessage = error.message.includes('not authorized') 
          ? 'This email isn\'t authorized for admin access. Please contact the school director if you need access.'
          : 'Unable to send your access link. Please try again or contact the school if the problem continues.';
        showAlert(friendlyMessage, true);
      } finally {
        setLoading(false);
      }
    }
    
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      await sendMagicLink(email);
    });
    
    resendButton.addEventListener('click', async () => {
      if (userEmail) {
        await sendMagicLink(userEmail);
        showAlert('Magic link resent! Check your email.');
      }
    });
  </script>
</Layout>