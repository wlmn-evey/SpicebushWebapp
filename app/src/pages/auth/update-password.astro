---
// Simple redirect for magic links to callback handler
const type = Astro.url.searchParams.get('type');
if (type === 'magiclink') {
  return Astro.redirect('/auth/callback' + Astro.url.search);
}

import Layout from '../../layouts/Layout.astro';
import AuthForm from '../../components/AuthForm.astro';
---

<Layout 
  title="Update Password - Spicebush Montessori School"
  description="Set a new password for your Spicebush Montessori School family account."
  keywords="update password, new password, change password"
>
  <AuthForm 
    type="update-password" 
    title="Set New Password" 
    subtitle="Enter your new password below"
  />
</Layout>