---
import Layout from '../../layouts/Layout.astro';
import { authAdapter } from '../../lib/auth';
import { AuthenticationError } from '../../lib/auth/errors';

// Handle magic link verification
let error = '';
let success = false;

const token = Astro.url.searchParams.get('token');
const type = Astro.url.searchParams.get('type') || 'magic_link';

if (token) {
  try {
    const result = await authAdapter.verifyMagicLink(token);
    if (result.success && result.user) {
      // Set session cookie or handle auth state
      // For now, redirect to admin dashboard
      return Astro.redirect('/admin/dashboard');
    } else {
      error = result.error || 'Invalid or expired link';
    }
  } catch (err) {
    const authError = AuthenticationError.fromUnknown(err);
    error = authError.toUserMessage();
  }
} else {
  error = 'No verification token provided';
}
---

<Layout title="Verifying - Spicebush Montessori">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <div>
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
          Verifying your sign in
        </h2>
      </div>

      {error ? (
        <!-- Error message -->
        <div class="rounded-md bg-red-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">
                Verification failed
              </h3>
              <div class="mt-2 text-sm text-red-700">
                <p>{error}</p>
              </div>
              <div class="mt-4">
                <a
                  href="/auth/clerk-sign-in"
                  class="text-sm font-medium text-red-800 hover:text-red-700"
                >
                  Try signing in again →
                </a>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <!-- Loading state -->
        <div class="text-center">
          <div class="inline-flex items-center px-4 py-2 font-semibold leading-6 text-sm shadow rounded-md text-white bg-primary-600 transition ease-in-out duration-150">
            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Verifying...
          </div>
          <p class="mt-4 text-sm text-gray-600">
            Please wait while we verify your sign in.
          </p>
        </div>
      )}

      <!-- Auth provider indicator -->
      <div class="mt-4 text-center text-xs text-gray-500">
        Using {authAdapter.getProvider()} authentication
      </div>
    </div>
  </div>
</Layout>