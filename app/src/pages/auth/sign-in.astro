---
import Layout from '../../layouts/Layout.astro';

const DEFAULT_AFTER_LOGIN_PATH = '/admin';
const parseNextPath = (value: string | null): string => {
  if (!value) return DEFAULT_AFTER_LOGIN_PATH;
  if (!value.startsWith('/')) return DEFAULT_AFTER_LOGIN_PATH;
  if (value.startsWith('//')) return DEFAULT_AFTER_LOGIN_PATH;
  return value;
};

const notice = Astro.url.searchParams.get('notice');
const error = Astro.url.searchParams.get('error');
const nextPath = parseNextPath(Astro.url.searchParams.get('next'));
const redirectToValue = `/auth/sign-in?next=${encodeURIComponent(nextPath)}`;

const noticeMessageMap: Record<string, string> = {
  'check-email': 'Check your inbox for a secure admin sign-in link.',
  'signed-out': 'You have been signed out.'
};

const errorMessageMap: Record<string, string> = {
  'invalid-link': 'That sign-in link is invalid or expired. Request a new one.',
  'invalid-domain': 'Please use a @spicebushmontessori.org or @eveywinters.com email address.',
  'request-failed': 'Unable to send a sign-in link right now. Please try again.'
};

const noticeMessage = notice ? noticeMessageMap[notice] : undefined;
const errorMessage = error ? errorMessageMap[error] : undefined;
---

<Layout 
  title="Admin Sign In - Spicebush Montessori"
  description="Securely access the Spicebush Montessori admin dashboard."
  keywords="Spicebush Montessori admin login"
>
  <div class="min-h-screen bg-gradient-to-br from-stone-beige to-light-stone flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-5">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-heading font-bold text-earth-brown">Administrator Login</h1>
        <p class="mt-2 text-gray-600">Enter your admin email to receive a one-time sign-in link.</p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        {noticeMessage && (
          <p class="mb-4 rounded-md border border-moss-green/30 bg-moss-green/10 px-3 py-2 text-sm text-forest-canopy">
            {noticeMessage}
          </p>
        )}

        {errorMessage && (
          <p class="mb-4 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-700">
            {errorMessage}
          </p>
        )}

        <form method="POST" action="/api/auth/request-link" class="space-y-4">
          <input type="hidden" name="redirectTo" value={redirectToValue} />
          <input type="hidden" name="next" value={nextPath} />

          <label for="email" class="block text-sm font-semibold text-earth-brown">Admin Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-earth-brown focus:border-moss-green focus:outline-none focus:ring-2 focus:ring-moss-green/40"
            placeholder="you@spicebushmontessori.org"
          />

          <button
            type="submit"
            class="w-full rounded-lg bg-moss-green px-4 py-2 text-white font-semibold transition-colors hover:bg-forest-canopy"
          >
            Send Secure Sign-In Link
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
