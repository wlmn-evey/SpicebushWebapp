---
import Layout from '../../layouts/Layout.astro';
import { CheckCircle, Loader2 } from 'lucide-astro';
---

<Layout 
  title="Signing In - Spicebush Montessori School"
  description="Processing your magic link sign in."
  keywords="login callback, authentication"
>
  <div class="min-h-screen bg-gradient-to-br from-stone-beige to-light-stone flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">
      <!-- Processing State -->
      <div id="processing" class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-white rounded-full shadow-lg mb-4">
          <Loader2 className="h-8 w-8 text-moss-green animate-spin" />
        </div>
        <h2 class="text-2xl font-heading font-bold text-earth-brown mb-2">Signing you in...</h2>
        <p class="text-gray-600">Please wait while we verify your magic link.</p>
      </div>

      <!-- Success State (Initially Hidden) -->
      <div id="success" class="hidden text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
          <CheckCircle className="h-8 w-8 text-green-600" />
        </div>
        <h2 class="text-2xl font-heading font-bold text-earth-brown mb-2">Success!</h2>
        <p class="text-gray-600">You're now signed in. Redirecting to admin dashboard...</p>
      </div>

      <!-- Error State (Initially Hidden) -->
      <div id="error" class="hidden">
        <div class="bg-red-50 border border-red-200 rounded-xl p-6 text-center">
          <h2 class="text-xl font-heading font-bold text-red-900 mb-2">Something went wrong</h2>
          <p id="error-message" class="text-red-700 mb-4">Your access link has expired. Would you like us to send a fresh one?</p>
          <a 
            href="/auth/magic-login" 
            class="inline-block px-4 py-2 bg-moss-green text-white rounded-lg hover:bg-forest-canopy transition-colors"
          >
            Request new link
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '@lib/supabase';
    import { isAdminEmail } from '@lib/admin-config';
    
    const processing = document.getElementById('processing') as HTMLDivElement;
    const success = document.getElementById('success') as HTMLDivElement;
    const error = document.getElementById('error') as HTMLDivElement;
    const errorMessage = document.getElementById('error-message') as HTMLParagraphElement;
    
    async function handleCallback() {
      try {
        // Get the current URL hash/params
        const hashParams = new URLSearchParams(window.location.hash.substring(1));
        const queryParams = new URLSearchParams(window.location.search);
        
        // Check for error first
        const errorDesc = hashParams.get('error_description') || queryParams.get('error_description');
        if (errorDesc) {
          throw new Error(errorDesc);
        }
        
        // Let Supabase handle the magic link automatically
        // It will detect access_token and refresh_token in the URL
        const { data: { session }, error: sessionError } = await supabase.auth.getSession();
        
        if (!session) {
          // No existing session, try to exchange the code/token in the URL
          // This handles both magic links and OAuth flows
          console.log('No existing session, attempting to exchange URL tokens...');
          const { data, error: exchangeError } = await supabase.auth.exchangeCodeForSession(window.location.href);
          if (exchangeError) {
            console.error('Exchange error:', exchangeError);
            throw exchangeError;
          }
          // Get the session after exchange
          const { data: { session: newSession } } = await supabase.auth.getSession();
          if (!newSession) {
            throw new Error('Failed to establish session after token exchange');
          }
        }
        
        // Get the user
        const { data: { user } } = await supabase.auth.getUser();
        
        if (!user) {
          throw new Error('No user found');
        }
        
        // Check if user is admin
        const isAdmin = isAdminEmail(user.email);
        
        if (!isAdmin) {
          // Sign out non-admin users
          await supabase.auth.signOut();
          throw new Error('Access denied. Only administrators can sign in.');
        }
        
        // Show success
        processing.classList.add('hidden');
        success.classList.remove('hidden');
        
        // Set admin cookie for middleware
        document.cookie = 'sbms-admin-auth=true; path=/; max-age=604800'; // 7 days
        
        // Log for debugging
        console.log('✅ Authentication successful!');
        console.log('✅ Admin cookie set');
        console.log('✅ Redirecting to /admin in 1.5 seconds...');
        
        // Redirect to admin dashboard
        setTimeout(() => {
          console.log('🚀 Redirecting to /admin now');
          window.location.href = '/admin';
        }, 1500);
        
      } catch (err: any) {
        console.error('Callback error:', err);
        processing.classList.add('hidden');
        error.classList.remove('hidden');
        const friendlyMessage = err.message.includes('Access denied') 
          ? 'This email isn\'t authorized for admin access. Please contact the school director if you need access.'
          : 'Your access link has expired. Would you like us to send a fresh one?';
        errorMessage.textContent = friendlyMessage;
      }
    }
    
    // Handle the callback on page load
    handleCallback();
  </script>
</Layout>