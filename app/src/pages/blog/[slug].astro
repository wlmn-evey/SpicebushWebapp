---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { ArrowLeft, Calendar, User, Clock, Share2 } from 'lucide-astro';
import { getEntry } from '../../lib/content-db';
import { marked } from 'marked';
import DOMPurify from 'isomorphic-dompurify';

// Get the slug from the URL
const { slug } = Astro.params;

// Fetch the blog post from Supabase
const entry = await getEntry('blog', slug);

if (!entry || entry.data.draft === true) {
  console.log(`Blog post not found or is draft: ${slug}`);
  return Astro.redirect('/404');
}

const { 
  title, 
  author, 
  date: publishedAt, 
  categories,
  seoTitle,
  seoDescription,
  excerpt,
  image: imageUrl,
  imageAlt
} = entry.data;

// Render and sanitize markdown content
const rawHtml = marked(entry.body || '');
const contentHtml = DOMPurify.sanitize(rawHtml, {
  ALLOWED_TAGS: ['p', 'br', 'strong', 'em', 'u', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 
                 'blockquote', 'ul', 'ol', 'li', 'a', 'img', 'code', 'pre', 'span', 'div'],
  ALLOWED_ATTR: ['href', 'src', 'alt', 'title', 'class', 'id']
});

// Estimate reading time (assuming 200 words per minute)
const wordCount = (entry.body || '').split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);

// Set cache headers for better performance
Astro.response.headers.set('Cache-Control', 'public, max-age=3600'); // 1 hour cache
---

<Layout title={`${seoTitle || title} - Spicebush Montessori School`}>
  <meta slot="head" name="description" content={seoDescription || excerpt || 'Read our latest blog post'} />
  <meta slot="head" property="og:title" content={title} />
  <meta slot="head" property="og:description" content={excerpt || seoDescription} />
  {imageUrl && <meta slot="head" property="og:image" content={imageUrl.startsWith('http') ? imageUrl : `/images/${imageUrl}`} />}
  <meta slot="head" property="og:type" content="article" />

  <Header />
  
  <main class="blog-post">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-stone-beige to-light-stone py-12 lg:py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <!-- Back link -->
          <a href="/blog" class="inline-flex items-center text-earth-brown hover:text-forest-canopy mb-8 transition-colors group">
            <ArrowLeft className="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" />
            <span class="font-medium">Back to Blog</span>
          </a>

          <!-- Post Header -->
          <header>
            {categories?.length > 0 && (
              <div class="flex gap-2 mb-4">
                {categories.map(cat => (
                  <span class="text-sm font-medium text-moss-green bg-moss-green/10 px-4 py-2 rounded-full">
                    {cat}
                  </span>
                ))}
              </div>
            )}
            
            <h1 class="text-4xl md:text-5xl font-heading font-bold text-earth-brown mb-6 tracking-tight leading-tight">
              {title}
            </h1>
            
            <div class="flex flex-wrap items-center gap-6 text-gray-600">
              {author && (
                <div class="flex items-center">
                  <User className="w-5 h-5 mr-2 text-moss-green" />
                  <span>By <span class="font-medium text-earth-brown">{author}</span></span>
                </div>
              )}
              <div class="flex items-center">
                <Calendar className="w-5 h-5 mr-2 text-moss-green" />
                <time datetime={publishedAt}>
                  {new Date(publishedAt).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </time>
              </div>
              <div class="flex items-center">
                <Clock className="w-5 h-5 mr-2 text-moss-green" />
                <span>{readingTime} min read</span>
              </div>
            </div>
          </header>
        </div>
      </div>
    </section>

    <!-- Article Content -->
    <article class="py-12 lg:py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <!-- Featured Image -->
          {imageUrl && (
            <div class="mb-12 rounded-xl overflow-hidden shadow-lg">
              <img 
                src={imageUrl.startsWith('http') ? imageUrl : `/images/${imageUrl}`}
                alt={imageAlt || title}
                class="w-full h-auto"
              />
            </div>
          )}

          <!-- Post Content -->
          <div class="prose prose-lg max-w-none 
            prose-headings:font-heading prose-headings:text-earth-brown 
            prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 
            prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
            prose-p:text-gray-700 prose-p:leading-relaxed prose-p:mb-6
            prose-a:text-moss-green prose-a:underline prose-a:decoration-moss-green/30 hover:prose-a:decoration-moss-green
            prose-strong:text-earth-brown prose-strong:font-semibold
            prose-blockquote:border-l-4 prose-blockquote:border-moss-green prose-blockquote:pl-6 prose-blockquote:italic prose-blockquote:text-gray-600
            prose-ul:list-disc prose-ul:pl-6 prose-ul:space-y-2
            prose-ol:list-decimal prose-ol:pl-6 prose-ol:space-y-2
            prose-li:text-gray-700
            prose-code:bg-gray-100 prose-code:px-2 prose-code:py-1 prose-code:rounded prose-code:text-earth-brown prose-code:font-mono prose-code:text-sm
            prose-pre:bg-gray-900 prose-pre:text-gray-100 prose-pre:rounded-lg prose-pre:shadow-lg
            prose-img:rounded-lg prose-img:shadow-md">
            <div set:html={contentHtml} />
          </div>

          <!-- Share Section -->
          <div class="mt-16 pt-8 border-t-2 border-gray-200">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-semibold text-earth-brown flex items-center">
                <Share2 className="w-5 h-5 mr-2 text-moss-green" />
                Share this post
              </h3>
              <div class="flex gap-3">
                <a 
                  href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 bg-sky-400 hover:bg-sky-500 text-white rounded-lg font-medium transition-colors flex items-center gap-2"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                  Share on X
                </a>
                <a 
                  href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors flex items-center gap-2"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                  Share on Facebook
                </a>
              </div>
            </div>
          </div>

          <!-- Call to Action -->
          <div class="mt-16 bg-moss-green/5 rounded-xl p-8 text-center">
            <h3 class="text-2xl font-semibold text-earth-brown mb-4">
              Ready to Join Our Community?
            </h3>
            <p class="text-gray-700 mb-6 max-w-2xl mx-auto">
              Experience the Spicebush difference. Schedule a tour to see how we nurture each child's unique potential.
            </p>
            <a 
              href="/admissions/schedule-tour" 
              class="inline-block bg-sunlight-gold hover:bg-orange-600 text-white px-8 py-3 rounded-lg font-semibold transition-colors"
            >
              Schedule a Tour
            </a>
          </div>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

