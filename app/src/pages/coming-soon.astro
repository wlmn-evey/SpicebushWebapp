---
export const prerender = false;

import { getEntry, getCollection, getEntries, getSchoolInfo, getSetting } from '@lib/content-db';
import { Fragment } from 'astro/jsx-runtime';

// Get all the data we need
const schoolInfo = await getSchoolInfo();
const hoursCollection = await getCollection('hours');
const tuitionPrograms = await getEntries('tuition', (entry) => entry.data.type === 'program');
const tuitionRates = await getEntries('tuition', (entry) => entry.data.type === 'rate');
const testimonials = await getEntries('testimonials', (entry) => entry.data.featured);

// Get coming soon settings
const launchDateSetting = await getSetting('coming_soon_launch_date');
const messageSetting = await getSetting('coming_soon_message');
const newsletterSetting = await getSetting('coming_soon_newsletter');

// Extract values with fallbacks
const launchDate = launchDateSetting || 'Fall 2025';
const updateMessage = messageSetting || "We're updating our website to enhance your experience. Thank you for your patience!";
const showNewsletter = newsletterSetting !== false; // Default to true if not set


// Sort hours by order
const sortedHours = hoursCollection.sort((a, b) => a.data.order - b.data.order);

// Generate hours display functions
function generateHoursDisplay() {
  // Get weekdays (Monday-Friday)
  const weekdays = sortedHours.filter(hour => 
    !hour.data.is_closed && 
    !['Saturday', 'Sunday'].includes(hour.data.day)
  );
  
  if (weekdays.length === 0) {
    return 'Monday - Friday: 8:30 AM - 3:00 PM (pickup 2:45-3:00)';
  }
  
  // Check if all weekdays have the same schedule
  const regularHours = '8:30 AM - 3:00 PM';
  const hasConsistentRegularHours = weekdays.every(day => 
    day.data.open_time === '8:30 AM'
  );
  
  if (hasConsistentRegularHours) {
    return `Monday - Friday: ${regularHours} (pickup 2:45-3:00)`;
  }
  
  // If hours vary, show individual days
  return weekdays.map(day => 
    `${day.data.day}: ${day.data.open_time} - ${day.data.close_time}`
  ).join(', ');
}

function generateExtendedCareInfo() {
  // Get days with extended care (close after 3:00 PM)
  const extendedCareDays = sortedHours.filter(hour => 
    !hour.data.is_closed && 
    hour.data.close_time !== '3:00 PM' &&
    !['Saturday', 'Sunday'].includes(hour.data.day)
  );
  
  if (extendedCareDays.length === 0) {
    return 'Extended care not available';
  }
  
  // Check if it's Mon-Thu
  const isMonThu = extendedCareDays.length === 4 && 
    extendedCareDays.every(day => ['Monday', 'Tuesday', 'Wednesday', 'Thursday'].includes(day.data.day));
  
  if (isMonThu && extendedCareDays.every(day => day.data.close_time === '5:30 PM')) {
    return 'Until 5:30 PM • Additional cost varies by income';
  }
  
  // Show specific days and times
  const dayRange = extendedCareDays.length === 4 ? 'Mon-Thu' : 
    extendedCareDays.map(day => day.data.day.substring(0, 3)).join(', ');
  const latestTime = extendedCareDays[0]?.data.close_time || '5:30 PM';
  
  return `${dayRange} until ${latestTime} • Additional cost varies by income`;
}

// Calculate tuition ranges for each program type
function getTuitionRange(programId: string) {
  const rates = tuitionRates.filter(rate => 
    rate.data.program_id === programId && rate.data.active
  );
  
  if (rates.length === 0) return { min: 0, max: 0 };
  
  const prices = rates.map(r => r.data.tuition_price);
  const min = Math.min(...prices);
  const max = Math.max(...prices);
  
  // Convert annual to monthly
  return {
    min: Math.round(min / 12),
    max: Math.round(max / 12)
  };
}

// Constants
const applicationLink = 'https://www.transparentclassroom.com/s/4693/online_applications/new';
