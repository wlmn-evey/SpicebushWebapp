<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Spicebush Montessori School - Enrolling Now for Fall 2025</title>
    <meta name="description" content="Spicebush Montessori School in Glen Mills, PA. Inclusive Montessori education for ages 3-6 with income-based tuition. Schedule a tour today!">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --moss-green: #5A8065;
      --forest-canopy: #3E6D51;
      --sunlight-gold: #F89406;
      --stone-beige: #F7F2DC;
      --earth-brown: #8B5A2B;
      --warm-white: #FDFBF7;
      --text-primary: #2C2C2C;
      --text-secondary: #5A5A5A;
      --border-color: #E8E4D9;
    }

    /* Accessibility: Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    body {
      font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: var(--text-primary);
      background: var(--warm-white);
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: 'Poppins', sans-serif;
      font-weight: 600;
      line-height: 1.3;
    }

    /* Skip to content link */
    .skip-to-content {
      position: absolute;
      left: -9999px;
      top: 0;
      z-index: 999;
      padding: 1rem 2rem;
      background: var(--forest-canopy);
      color: white;
      text-decoration: none;
      border-radius: 0 0 8px 0;
    }

    .skip-to-content:focus {
      left: 0;
    }

    /* Focus styles */
    a:focus-visible,
    button:focus-visible,
    input:focus-visible,
    textarea:focus-visible,
    select:focus-visible {
      outline: 3px solid var(--moss-green);
      outline-offset: 2px;
    }

    /* Header Section */
    .header {
      background: linear-gradient(135deg, #E8F3E8 0%, #D4E7D4 100%);
      padding: 3rem 1rem 4rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .header::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(90, 128, 101, 0.05) 0%, transparent 70%);
      animation: rotate 40s linear infinite;
    }

    @keyframes rotate {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .logo {
      width: 150px;
      height: 150px;
      margin: 0 auto 1.5rem;
      display: block;
      position: relative;
      z-index: 1;
      animation: logoFloat 4s ease-in-out infinite;
    }

    @keyframes logoFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    h1 {
      font-size: 2.75rem;
      color: var(--forest-canopy);
      margin-bottom: 0.5rem;
      position: relative;
      z-index: 1;
      font-weight: 700;
    }

    .tagline {
      font-size: 1.25rem;
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
      position: relative;
      z-index: 1;
    }

    .enrollment-notice {
      display: inline-block;
      background: var(--sunlight-gold);
      color: white;
      padding: 0.75rem 2rem;
      border-radius: 30px;
      font-weight: 600;
      position: relative;
      z-index: 1;
      font-size: 1.1rem;
      box-shadow: 0 4px 15px rgba(248, 148, 6, 0.3);
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.02); }
    }

    /* Update Notice */
    .update-notice {
      background: linear-gradient(135deg, var(--moss-green) 0%, var(--forest-canopy) 100%);
      color: white;
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 1.15rem;
      font-weight: 600;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      position: relative;
      overflow: hidden;
    }

    .update-notice::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
      animation: shimmer 3s infinite;
    }

    @keyframes shimmer {
      to { left: 100%; }
    }

    .update-notice p {
      position: relative;
      z-index: 1;
      margin: 0;
      max-width: 800px;
      margin: 0 auto;
    }

    /* Quick Info Cards */
    .quick-info {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      max-width: 1200px;
      margin: 2rem auto 4rem;
      padding: 0 1rem;
      position: relative;
      z-index: 2;
    }

    .info-card {
      background: white;
      padding: 2rem;
      border-radius: 15px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border: 1px solid var(--border-color);
    }

    .info-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    }

    .info-card-icon {
      width: 60px;
      height: 60px;
