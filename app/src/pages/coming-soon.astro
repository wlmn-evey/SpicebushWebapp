      text-decoration: none;
      font-weight: 600;
      word-break: break-word;
      overflow-wrap: break-word;
      display: inline-block;
      max-width: 100%;
    }

    .info-card a:hover {
      text-decoration: underline;
    }

    /* CTA Buttons */
    .primary-button {
      display: inline-block;
      background: var(--moss-green);
      color: white !important;
      padding: 1rem 2.5rem;
      border-radius: 30px;
      text-decoration: none;
      font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-weight: 600;
      font-size: 1.1rem;
      line-height: 1.4;
      margin-top: 0.5rem;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(90, 128, 101, 0.3);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .primary-button:hover {
      background: var(--forest-canopy);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(90, 128, 101, 0.4);
    }

    .secondary-button {
      display: inline-block;
      background: transparent;
      color: var(--moss-green);
      border: 2px solid var(--moss-green);
      padding: 0.9rem 2rem;
      border-radius: 30px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .secondary-button:hover {
      background: var(--moss-green);
      color: white;
    }

    /* Content Sections */
    .section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 1rem;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .section-header h2 {
      font-size: 2.25rem;
      color: var(--forest-canopy);
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    .section-header p {
      color: var(--text-secondary);
      font-size: 1.15rem;
    }

    /* About Section */
    .about-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .about-text h3 {
      color: var(--forest-canopy);
      margin-bottom: 1rem;
      font-size: 1.75rem;
    }

    .about-text p {
      color: var(--text-secondary);
      margin-bottom: 1.25rem;
      font-size: 1.05rem;
    }

    .values-list {
      list-style: none;
      margin-top: 1.5rem;
    }

    .values-list li {
      padding: 0.75rem 0;
      padding-left: 2.5rem;
      position: relative;
      color: var(--text-secondary);
      font-size: 1.05rem;
    }

    .values-list li::before {
      content: '';
