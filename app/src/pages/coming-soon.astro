---
export const prerender = false;

import { getCollection, getEntries, getAllSettings, type ContentEntry } from '@lib/content-db';
import { getTestimonialsForPlacement, type ManagedTestimonial } from '@lib/testimonials-content';
import ExternalLinkTargetBehavior from '@components/ExternalLinkTargetBehavior.astro';
import OptimizedImage from '@components/OptimizedImage.astro';
import { resolveSeoMetadata } from '@lib/seo-config';

const DEFAULT_APPLICATION_SCHOOL_YEAR = '2026-2027 School Year';
const DEFAULT_UPDATE_MESSAGE = 'Enrollment is open for the 2026-2027 school year while we work on bringing you an improved website experience.';
const DEFAULT_PHONE = '(484) 202-0712';
const DEFAULT_EMAIL = 'information@spicebushmontessori.org';
const DEFAULT_ADDRESS = {
  street: '827 Concord Road',
  city: 'Glen Mills',
  state: 'PA',
  zip: '19342'
};

let settings: Record<string, unknown> = {};
type GenericEntryData = Record<string, unknown>;
type GenericContentEntry = ContentEntry<GenericEntryData>;

let hoursCollection: GenericContentEntry[] = [];
let tuitionRates: GenericContentEntry[] = [];
let testimonials: ManagedTestimonial[] = [];

try {
  settings = await getAllSettings();
  hoursCollection = await getCollection('hours');
  tuitionRates = await getEntries('tuition', (entry) => {
    const data = (entry.data ?? {}) as GenericEntryData;
    return data.type === 'rate';
  });
  testimonials = await getTestimonialsForPlacement('coming-soon', settings as Record<string, unknown>);
} catch (e) {
  settings = {};
  hoursCollection = [];
  tuitionRates = [];
  testimonials = [];
}

const settingsRecord = settings as Record<string, unknown>;

const coerceString = (value: unknown, fallback = ''): string => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    return trimmed.length > 0 ? trimmed : fallback;
  }
  if (typeof value === 'number') {
    return value.toString();
  }
  return fallback;
};

const coerceBoolean = (value: unknown, fallback: boolean): boolean => {
  if (typeof value === 'boolean') {
    return value;
  }
  return fallback;
};

const coerceNumber = (value: unknown, fallback: number): number => {
  if (typeof value === 'number') {
    return Number.isFinite(value) ? value : fallback;
  }
  if (typeof value === 'string') {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? numeric : fallback;
  }
  return fallback;
};

const getSettingString = (key: string, fallback: string): string =>
  coerceString(settingsRecord[key], fallback);

const getSettingBoolean = (key: string, fallback: boolean): boolean =>
  coerceBoolean(settingsRecord[key], fallback);

const getEnvValue = (key: string): string => {
  const runtimeEnv = typeof process !== 'undefined' ? process.env : undefined;
  const runtimeValue = runtimeEnv?.[key];
  if (typeof runtimeValue === 'string' && runtimeValue.trim().length > 0) {
    return runtimeValue.trim();
  }

  const importEnv = import.meta.env as Record<string, string | undefined>;
  const importValue = importEnv[key];
  if (typeof importValue === 'string' && importValue.trim().length > 0) {
    return importValue.trim();
  }

  return '';
};

const siteName = getSettingString('site_name', 'Spicebush Montessori School');
const gaMeasurementId = getSettingString('ga4_measurement_id', '')
  || getEnvValue('PUBLIC_GA4_MEASUREMENT_ID')
  || getEnvValue('GA4_MEASUREMENT_ID');
const analyticsEnabled = getSettingBoolean('ga4_enabled', false)
  || getSettingString('ga4_enabled', '').toLowerCase() === 'true'
  || getEnvValue('PUBLIC_GA4_ENABLED').toLowerCase() === 'true'
  || gaMeasurementId.length > 0;
const shouldLoadGaScript = analyticsEnabled && gaMeasurementId.length > 0;
const mainPhone = getSettingString('school_phone', getSettingString('contact_phone', DEFAULT_PHONE));
const mainEmail = getSettingString('school_email', getSettingString('contact_email', DEFAULT_EMAIL));

const addressStreet = getSettingString('school_address_street', DEFAULT_ADDRESS.street);
const addressCity = getSettingString('school_address_city', DEFAULT_ADDRESS.city);
const addressState = getSettingString('school_address_state', DEFAULT_ADDRESS.state);
const addressZip = getSettingString('school_address_zip', DEFAULT_ADDRESS.zip);
const streetLine = coerceString(addressStreet);

const tagline = `Nurturing Young Minds in ${addressCity}, ${addressState}`;
const agesServed = getSettingString('school_ages_served', '3-6 years old');
const agesServedShort = agesServed.replace(/\byears old\b/i, 'years');
const applicationSchoolYear = getSettingString('application_school_year', DEFAULT_APPLICATION_SCHOOL_YEAR);
const tourExternalLink = '/admissions';

const tourSchedulingEnabled = getSettingBoolean('tour_scheduling_enabled', true);

const updateMessage = getSettingString('coming_soon_message', DEFAULT_UPDATE_MESSAGE);
const copyrightYear = new Date().getFullYear();

const normalizePhoneHref = (value: string) => value.replace(/[^0-9+]/g, '');
const phoneHrefValue = normalizePhoneHref(mainPhone);
const hasPhone = phoneHrefValue.length > 0;
const hasEmail = mainEmail.length > 0;
const addressLineTwoParts = [addressCity, addressState].filter((part) => coerceString(part).length > 0).join(', ');
const addressLineTwo = [addressLineTwoParts, coerceString(addressZip)].filter((part) => part.length > 0).join(' ').trim();
const addressAvailable = streetLine.length > 0 || addressLineTwo.length > 0;

const DAY_ORDER: Record<string, number> = {
  monday: 1,
  tuesday: 2,
  wednesday: 3,
  thursday: 4,
  friday: 5,
  saturday: 6,
  sunday: 7
};

const rawHoursEntries = Array.isArray(hoursCollection) ? hoursCollection : [];

type NormalizedHoursEntry = {
  day: string;
  dayKey: string;
  order: number;
  openTime: string;
  closeTime: string;
  beforeCareStart: string;
  afterCareEnd: string;
  beforeCareOffset: number;
  afterCareOffset: number;
  regular: string;
  extended: string;
  note: string;
  morning: string;
};

const normalizedHours: NormalizedHoursEntry[] = rawHoursEntries
  .map((entry) => {
    const data = (entry?.data ?? {}) as Record<string, unknown>;
    const rawDay = coerceString(data.day ?? data.dayOfWeek ?? entry?.slug ?? '', '');
    const dayKey = rawDay.toLowerCase();
    const day = rawDay ? rawDay.replace(/\b\w/g, (char) => char.toUpperCase()) : '';
    const order = coerceNumber(data.order, DAY_ORDER[dayKey] ?? 99);
    const openTime = coerceString(data.open_time ?? data.start_time ?? '', '');
    const closeTime = coerceString(data.close_time ?? data.end_time ?? '', '');
    const beforeCareStart = coerceString(data.before_care_start ?? data.beforeCareStart ?? '', '');
    const afterCareEnd = coerceString(data.after_care_end ?? data.afterCareEnd ?? '', '');
    const beforeCareOffset = coerceNumber(data.before_care_offset ?? data.beforeCareOffset, 0);
    const afterCareOffset = coerceNumber(data.after_care_offset ?? data.afterCareOffset, 0);
    const regularFallback = (() => {
      const open = coerceString(openTime, '');
      const close = coerceString(closeTime, '');
      return open && close ? `${open} - ${close}` : '';
    })();
    const regular = coerceString(data.regularDay ?? data.regular_hours, regularFallback);
    const extended = coerceString(data.extendedDay ?? data.extended_hours ?? data.close_time_extended, '');
    const note = coerceString(data.note ?? '', '');
    const morning = coerceString(data.morningCare ?? data.morning_hours, '');
    return {
      day,
      dayKey,
      order,
      openTime,
      closeTime,
      beforeCareStart,
      afterCareEnd,
      beforeCareOffset,
      afterCareOffset,
      regular,
      extended,
      note,
      morning
    };
  })
  .filter((entry) => entry.dayKey)
  .sort((a, b) => a.order - b.order);

// Generate hours display functions
function generateHoursDisplay() {
  const weekdays = normalizedHours.filter((entry) => entry.order >= 1 && entry.order <= 5);

  if (weekdays.length === 0) {
    return 'Monday - Friday: 8:30 AM - 3:00 PM';
  }

  const regularByDay = weekdays.map((entry) => ({
    day: entry.day,
    regular: entry.regular || '8:30 AM - 3:00 PM'
  }));

  if (regularByDay.length === 0) {
    return 'Monday - Friday: 8:30 AM - 3:00 PM';
  }

  const uniqueRegularSchedules = Array.from(new Set(regularByDay.map((entry) => entry.regular)));
  if (uniqueRegularSchedules.length === 1 && uniqueRegularSchedules[0]) {
    return `Monday - Friday: ${uniqueRegularSchedules[0]}`;
  }

  if (regularByDay.length === 5 && regularByDay.slice(0, 4).every((entry) => entry.regular === regularByDay[0].regular)) {
    return `Mon-Thu: ${regularByDay[0].regular} • Fri: ${regularByDay[4].regular}`;
  }

  return regularByDay
    .map((entry) => `${entry.day}: ${entry.regular}`)
    .join(' • ');
}

function generateContactHoursSummary() {
  const weekdays = normalizedHours.filter((entry) => entry.order >= 1 && entry.order <= 5);

  if (weekdays.length === 0) {
    return 'Monday - Friday: 8:30 AM - 3:00 PM';
  }

  const regularByDay = weekdays.map((entry) => ({
    day: entry.day,
    regular: entry.regular || '8:30 AM - 3:00 PM'
  }));
  const uniqueRegular = Array.from(new Set(regularByDay.map((entry) => entry.regular)));

  if (uniqueRegular.length === 1) {
    return `Monday - Friday: ${uniqueRegular[0]}`;
  }

  if (
    regularByDay.length === 5 &&
    regularByDay.slice(0, 4).every((entry) => entry.regular === regularByDay[0].regular)
  ) {
    return `Mon-Thu: ${regularByDay[0].regular} • Fri: ${regularByDay[4].regular}`;
  }

  return regularByDay.map((entry) => `${entry.day}: ${entry.regular}`).join(' • ');
}

function generateHoursDisplayForDayKeys(dayKeys: string[], fallback: string) {
  const selected = normalizedHours
    .filter((entry) => dayKeys.includes(entry.dayKey))
    .sort((a, b) => a.order - b.order);

  if (selected.length === 0) {
    return fallback;
  }

  const regularByDay = selected
    .map((entry) => ({
      day: entry.day,
      dayKey: entry.dayKey,
      order: entry.order,
      regular: entry.regular || ''
    }))
    .filter((entry) => entry.regular);

  if (regularByDay.length === 0) {
    return fallback;
  }

  const uniqueRegular = Array.from(new Set(regularByDay.map((entry) => entry.regular)));
  const label = formatDayLabelFromHoursEntries(regularByDay);

  if (uniqueRegular.length === 1) {
    return `${label}: ${uniqueRegular[0]}`;
  }

  return regularByDay.map((entry) => `${entry.day}: ${entry.regular}`).join(' • ');
}

const EXTENDED_UNAVAILABLE_NOTE = /(no|not)\s+extended\s+care|extended\s+care\s+not\s+available/i;
const EXTENDED_AVAILABLE_NOTE = /extended\s+care\s+available/i;
const EXTENDED_UNTIL_PATTERN = /until\s+([0-9]{1,2}(?::[0-9]{2})?\s*[ap]m)/i;
const EXTENDED_RANGE_PATTERN = /([0-9]{1,2}(?::[0-9]{2})?\s*[ap]m)\s*[-–]\s*([0-9]{1,2}(?::[0-9]{2})?\s*[ap]m)/i;

const normalizeTimeLabel = (value: string): string =>
  value
    .trim()
    .replace(/\s+/g, ' ')
    .toUpperCase();

function inferExtendedScheduleFromNote(note: string): string {
  if (!note) return '';
  if (EXTENDED_UNAVAILABLE_NOTE.test(note)) return '';
  if (!EXTENDED_AVAILABLE_NOTE.test(note)) return '';

  const untilMatch = note.match(EXTENDED_UNTIL_PATTERN);
  if (untilMatch?.[1]) {
    return `until ${normalizeTimeLabel(untilMatch[1])}`;
  }

  const rangeMatch = note.match(EXTENDED_RANGE_PATTERN);
  if (rangeMatch?.[1] && rangeMatch?.[2]) {
    return `${normalizeTimeLabel(rangeMatch[1])} - ${normalizeTimeLabel(rangeMatch[2])}`;
  }

  return note;
}

const formatDayLabelFromHoursEntries = (
  entries: { dayKey: string; day: string; order?: number }[]
): string => {
  const unique = new Map<string, { day: string; order: number }>();
  for (const entry of entries) {
    if (entry.dayKey) {
      unique.set(entry.dayKey, {
        day: entry.day || entry.dayKey,
        order: typeof entry.order === 'number' ? entry.order : (DAY_ORDER[entry.dayKey] ?? 99)
      });
    }
  }

  const ordered = Array.from(unique.entries())
    .map(([dayKey, meta]) => ({ dayKey, day: meta.day, order: meta.order }))
    .sort((a, b) => a.order - b.order);

  const contiguous = ordered.every((entry, index) => index === 0 || entry.order === ordered[index - 1].order + 1);
  if (contiguous && ordered.length >= 2) {
    return `${ordered[0].day} - ${ordered[ordered.length - 1].day}`;
  }

  return ordered.map((entry) => entry.day).join(', ');
};

type HoursScheduleInfo = {
  available: boolean;
  label: string;
  description: string;
};

const parseTimeToDecimal = (value: string): number | null => {
  const trimmed = value.trim();
  if (!trimmed) return null;

  const match = trimmed.match(/^(\d{1,2})(?::(\d{1,2}))?\s*(AM|PM)?$/i);
  if (!match) return null;

  let hours = Number.parseInt(match[1] ?? '0', 10);
  const minutes = Number.parseInt(match[2] ?? '0', 10);
  const period = match[3]?.toUpperCase();

  if (period === 'PM' && hours !== 12) {
    hours += 12;
  } else if (period === 'AM' && hours === 12) {
    hours = 0;
  }

  if (!Number.isFinite(hours) || !Number.isFinite(minutes)) return null;
  return hours + minutes / 60;
};

const formatDecimalTime = (value: number): string => {
  const hours24 = ((Math.floor(value) % 24) + 24) % 24;
  const minutesRaw = Math.round((value - Math.floor(value)) * 60);
  const minutes = minutesRaw === 60 ? 0 : minutesRaw;
  const adjustedHours24 = minutesRaw === 60 ? (hours24 + 1) % 24 : hours24;
  const period = adjustedHours24 >= 12 ? 'PM' : 'AM';
  const displayHour = adjustedHours24 % 12 === 0 ? 12 : adjustedHours24 % 12;
  return `${displayHour}:${minutes.toString().padStart(2, '0')} ${period}`;
};

const normalizeScheduleRange = (start: string, end: string): string => {
  const normalizedStart = normalizeTimeLabel(start);
  const normalizedEnd = normalizeTimeLabel(end);
  if (!normalizedStart || !normalizedEnd || normalizedStart === normalizedEnd) return '';
  return `${normalizedStart} - ${normalizedEnd}`;
};

const deriveAfterCareSchedule = (entry: NormalizedHoursEntry): string => {
  if (entry.extended) return entry.extended;

  if (entry.afterCareEnd && entry.closeTime) {
    const explicitRange = normalizeScheduleRange(entry.closeTime, entry.afterCareEnd);
    if (explicitRange) return explicitRange;
  }

  if (entry.afterCareOffset > 0 && entry.closeTime) {
    const closeDecimal = parseTimeToDecimal(entry.closeTime);
    if (closeDecimal !== null) {
      const computedEnd = formatDecimalTime(closeDecimal + entry.afterCareOffset);
      const range = normalizeScheduleRange(entry.closeTime, computedEnd);
      if (range) return range;
    }
  }

  const inferred = inferExtendedScheduleFromNote(entry.note);
  if (!inferred) return '';

  if (entry.closeTime) {
    const regularEnd = normalizeTimeLabel(entry.closeTime);
    const untilMatch = inferred.match(/^until\s+(.+)$/i);
    if (untilMatch?.[1]) {
      const untilTime = normalizeTimeLabel(untilMatch[1]);
      const range = normalizeScheduleRange(regularEnd, untilTime);
      if (range) return range;
    }
  }

  return inferred;
};

const deriveBeforeCareSchedule = (entry: NormalizedHoursEntry): string => {
  if (entry.beforeCareStart && entry.openTime) {
    const explicitRange = normalizeScheduleRange(entry.beforeCareStart, entry.openTime);
    if (explicitRange) return explicitRange;
  }

  if (entry.beforeCareOffset > 0 && entry.openTime) {
    const openDecimal = parseTimeToDecimal(entry.openTime);
    if (openDecimal !== null) {
      const computedStart = formatDecimalTime(openDecimal - entry.beforeCareOffset);
      const range = normalizeScheduleRange(computedStart, entry.openTime);
      if (range) return range;
    }
  }

  if (entry.openTime) {
    const openDecimal = parseTimeToDecimal(entry.openTime);
    if (openDecimal !== null) {
      const computedStart = formatDecimalTime(openDecimal - 1);
      const range = normalizeScheduleRange(computedStart, entry.openTime);
      if (range) return range;
    }
  }

  return '';
};

function generateExtendedCareInfo() {
  const weekdayEntries = normalizedHours.filter((entry) => entry.order >= 1 && entry.order <= 5);
  const scheduleBaseEntries = weekdayEntries.length > 0 ? weekdayEntries : normalizedHours;

  const scheduleEntries = scheduleBaseEntries
    .map((entry) => ({
      day: entry.day,
      dayKey: entry.dayKey,
      order: entry.order,
      schedule: deriveAfterCareSchedule(entry)
    }))
    .filter((entry) => entry.schedule);

  if (scheduleEntries.length === 0) {
    return {
      available: false,
      label: '',
      description: 'Extended care not currently available.'
    } satisfies HoursScheduleInfo;
  }

  const scheduleSet = new Set(scheduleEntries.map((entry) => entry.schedule));
  const dayLabel = formatDayLabelFromHoursEntries(scheduleEntries);
  const description = scheduleSet.size === 1
    ? scheduleEntries[0].schedule
    : scheduleEntries.map((entry) => `${entry.day}: ${entry.schedule}`).join(' • ');

  return {
    available: true,
    label: dayLabel,
    description
  } satisfies HoursScheduleInfo;
}

const extendedCareInfo = generateExtendedCareInfo();

function generateBeforeCareInfo() {
  const weekdayEntries = normalizedHours.filter((entry) => entry.order >= 1 && entry.order <= 5);
  const scheduleBaseEntries = weekdayEntries.length > 0 ? weekdayEntries : normalizedHours;

  const scheduleEntries = scheduleBaseEntries
    .map((entry) => ({
      day: entry.day,
      dayKey: entry.dayKey,
      order: entry.order,
      schedule: deriveBeforeCareSchedule(entry)
    }))
    .filter((entry) => entry.schedule);

  if (scheduleEntries.length === 0) {
    return {
      available: false,
      label: '',
      description: 'Before care not currently available.'
    } satisfies HoursScheduleInfo;
  }

  const scheduleSet = new Set(scheduleEntries.map((entry) => entry.schedule));
  const dayLabel = formatDayLabelFromHoursEntries(scheduleEntries);
  const description = scheduleSet.size === 1
    ? scheduleEntries[0].schedule
    : scheduleEntries.map((entry) => `${entry.day}: ${entry.schedule}`).join(' • ');

  return {
    available: true,
    label: dayLabel,
    description
  } satisfies HoursScheduleInfo;
}

const beforeCareInfo = generateBeforeCareInfo();

// Calculate tuition ranges for each program type
function getTuitionRange(programId: string) {
  const rates = tuitionRates.filter((rate) => {
    const data = (rate.data ?? {}) as GenericEntryData;
    return coerceString(data.program_id, '') === programId && data.active === true;
  });
  
  if (rates.length === 0) return { min: 0, max: 0 };
  
  const prices = rates
    .map((rate) => {
      const data = (rate.data ?? {}) as GenericEntryData;
      const price = Number(data.tuition_price);
      return Number.isFinite(price) ? price : 0;
    })
    .filter((price) => price > 0);

  if (prices.length === 0) return { min: 0, max: 0 };
  const min = Math.min(...prices);
  const max = Math.max(...prices);
  
  // Convert annual to monthly
  return {
    min: Math.round(min / 12),
    max: Math.round(max / 12)
  };
}

const formatCurrency = (value: number) => value.toLocaleString('en-US');

const formatMonthlyTuition = (range: { min: number; max: number }): string | null => {
  if (!range || range.min <= 0 || range.max <= 0) return null;
  if (range.min === range.max) return `$${formatCurrency(range.min)}/month`;
  return `$${formatCurrency(range.min)} - $${formatCurrency(range.max)}/month`;
};

// Constants
const applicationLink = '/admissions';
const adminPreviewPath = '/api/admin/preview-mode?mode=site&redirect=/';
const adminSignInPath = `/auth/sign-in?next=${encodeURIComponent(adminPreviewPath)}`;
const comingSoonDescription = `Spicebush Montessori School in Glen Mills, PA has enrollment open for the ${applicationSchoolYear}. Inclusive Montessori education for ${agesServed.toLowerCase()} with income-based tuition.`;
const seoMetadata = await resolveSeoMetadata({
  pathname: Astro.url.pathname,
  title: `${siteName} - Enrollment Open for ${applicationSchoolYear}`,
  description: comingSoonDescription,
  keywords:
    'montessori school enrollment, kindergarten enrollment, glen mills montessori, inclusive early childhood education',
  site: Astro.site
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{seoMetadata.title}</title>
    <meta name="description" content={seoMetadata.description}>
    <meta name="keywords" content={seoMetadata.keywords}>
    <link rel="canonical" href={seoMetadata.canonicalUrl}>
    <meta name="robots" content={seoMetadata.robotsContent}>
    {seoMetadata.noIndex && <meta name="googlebot" content="noindex, nofollow" />}
    <meta property="og:type" content="website">
    <meta property="og:url" content={seoMetadata.canonicalUrl}>
    <meta property="og:title" content={seoMetadata.title}>
    <meta property="og:description" content={seoMetadata.description}>
    <meta property="og:image" content={seoMetadata.ogImageUrl}>
    <meta property="twitter:card" content={seoMetadata.twitterCard}>
    <meta property="twitter:url" content={seoMetadata.canonicalUrl}>
    <meta property="twitter:title" content={seoMetadata.title}>
    <meta property="twitter:description" content={seoMetadata.description}>
    <meta property="twitter:image" content={seoMetadata.ogImageUrl}>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    {shouldLoadGaScript && (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(gaMeasurementId)}`}></script>
    )}
    {analyticsEnabled && (
      <script is:inline define:vars={{ gaMeasurementId, shouldLoadGaScript }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        window.gtag = gtag;
        if (shouldLoadGaScript && gaMeasurementId) {
          gtag('js', new Date());
          gtag('config', gaMeasurementId, {
            anonymize_ip: true,
            send_page_view: true
          });
        }
        window.sbAnalyticsConfig = {
          enabled: true,
          measurementId: gaMeasurementId || ''
        };
      </script>
    )}
    {analyticsEnabled && <script is:inline src="/js/analytics-tracker.js" defer></script>}
    <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --moss-green: #5A8065;
      --forest-canopy: #3E6D51;
      --deep-forest: #2F5640;
      --sunlight-gold: #F89406;
      --evergreen: #1F2A24;
      --stone-beige: #F7F2DC;
      --earth-brown: #8B5A2B;
      --warm-white: #FDFBF7;
      --text-primary: #2C2C2C;
      --text-secondary: #5A5A5A;
      --border-color: #E8E4D9;
      --soft-shadow: rgba(62, 109, 81, 0.18);
    }

    /* Accessibility: Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    body {
      font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: var(--text-primary);
      background: var(--warm-white);
    }

    h1, h2, h3, h4 {
      font-family: 'Poppins', sans-serif;
      font-weight: 600;
      line-height: 1.3;
    }

    /* Skip to content link */
    .skip-to-content {
      position: absolute;
      left: -9999px;
      top: 0;
      z-index: 999;
      padding: 1rem 2rem;
      background: var(--forest-canopy);
      color: white;
      text-decoration: none;
      border-radius: 0 0 8px 0;
    }

    .skip-to-content:focus {
      left: 0;
    }

    /* Focus styles */
    a:focus-visible,
    button:focus-visible,
    input:focus-visible,
    textarea:focus-visible,
    select:focus-visible {
      outline: 3px solid var(--moss-green);
      outline-offset: 2px;
    }

    /* Header Section */
    .header {
      background: linear-gradient(135deg, #E8F3E8 0%, #D4E7D4 100%);
      padding: 3rem 1rem 4rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .header::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(90, 128, 101, 0.05) 0%, transparent 70%);
      animation: rotate 40s linear infinite;
    }

    @keyframes rotate {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .header :global(.logo) {
      width: 170px;
      height: 170px;
      margin: 0 auto 1.5rem;
      display: block;
      position: relative;
      z-index: 1;
      animation: logoFloat 4s ease-in-out infinite;
    }

    @keyframes logoFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    h1 {
      font-size: 2.75rem;
      color: var(--evergreen);
      margin-bottom: 0.5rem;
      position: relative;
      z-index: 1;
      font-weight: 700;
    }

    .tagline {
      font-size: 1.25rem;
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
      position: relative;
      z-index: 1;
    }

    .enrollment-notice {
      display: inline-block;
      background: var(--sunlight-gold);
      color: var(--forest-canopy);
      padding: 0.75rem 2rem;
      border-radius: 30px;
      font-weight: 700;
      position: relative;
      z-index: 1;
      font-size: 1.1rem;
      box-shadow: 0 4px 15px rgba(248, 148, 6, 0.3);
      animation: pulse 2s ease-in-out infinite;
      letter-spacing: 0.01em;
    }

    .footer-admin-access {
      margin-top: 1.5rem;
    }

    .footer-admin-access p {
      color: rgba(255, 255, 255, 0.9);
      font-size: 0.95rem;
      margin-bottom: 0.5rem;
    }

    .footer-admin-access-link {
      display: inline-block;
      text-decoration: none;
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.6);
      background: rgba(255, 255, 255, 0.12);
      border-radius: 999px;
      padding: 0.45rem 1rem;
      font-weight: 700;
      font-size: 0.92rem;
      transition: all 0.2s ease;
    }

    .footer .footer-admin-access-link:hover,
    .footer .footer-admin-access-link:focus {
      background: rgba(255, 255, 255, 0.24);
      border-color: white;
      color: white;
      text-decoration: none;
      transform: translateY(-1px);
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.02); }
    }

    /* Update Notice */
    .update-notice {
      background: linear-gradient(135deg, var(--forest-canopy) 0%, var(--deep-forest) 100%);
      color: white;
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 1.15rem;
      font-weight: 600;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      position: relative;
      overflow: hidden;
    }

    .update-notice::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
      animation: shimmer 3s infinite;
    }

    @keyframes shimmer {
      to { left: 100%; }
    }

    .update-notice p {
      position: relative;
      z-index: 1;
      margin: 0;
      max-width: 800px;
      margin: 0 auto;
    }

    /* Quick Info Cards */
    .quick-info {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      max-width: 1200px;
      margin: 2rem auto 4rem;
      padding: 0 1rem;
      position: relative;
      z-index: 2;
    }

    .info-card {
      background: white;
      padding: 2rem;
      border-radius: 15px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border: 1px solid var(--border-color);
    }

    .info-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    }

    .info-card-icon {
      width: 60px;
      height: 60px;
      margin: 0 auto 1rem;
      background: var(--stone-beige);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .info-card-icon svg {
      width: 30px;
      height: 30px;
      color: var(--forest-canopy);
    }

    .info-card h3 {
      color: var(--forest-canopy);
      margin-bottom: 0.5rem;
      font-size: 1.35rem;
    }

    .info-card p {
      color: var(--text-secondary);
      font-size: 1rem;
      margin-bottom: 0.5rem;
      word-break: break-word;
      overflow-wrap: break-word;
    }

    .hours-info {
      margin-top: 0.5rem;
    }

    .hours-section {
      margin-bottom: 1rem !important;
      line-height: 1.5;
    }

    .hours-section:last-child {
      margin-bottom: 0 !important;
    }

    .hours-section strong {
      color: var(--forest-canopy);
      font-size: 0.95rem;
    }

    .info-card a {
      color: var(--forest-canopy);
      text-decoration: none;
      font-weight: 600;
      word-break: break-word;
      overflow-wrap: break-word;
      display: inline-block;
      max-width: 100%;
    }

    .info-card a:hover {
      text-decoration: underline;
      color: var(--deep-forest);
    }

    /* CTA Buttons */
    .primary-button {
      display: inline-block;
      background: var(--forest-canopy);
      color: white !important;
      padding: 1rem 2.5rem;
      border-radius: 30px;
      text-decoration: none;
      font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-weight: 600;
      font-size: 1.1rem;
      line-height: 1.4;
      margin-top: 0.5rem;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px var(--soft-shadow);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .primary-button:hover,
    .primary-button:focus {
      background: var(--deep-forest);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(47, 86, 64, 0.45);
    }

    .secondary-button {
      display: inline-block;
      background: transparent;
      color: var(--forest-canopy);
      border: 2px solid var(--forest-canopy);
      padding: 0.9rem 2rem;
      border-radius: 30px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .secondary-button:hover,
    .secondary-button:focus {
      background: rgba(62, 109, 81, 0.12);
      color: var(--deep-forest);
    }

    /* Content Sections */
    .section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 1rem;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .section-header h2 {
      font-size: 2.25rem;
      color: var(--forest-canopy);
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    .section-header p {
      color: var(--text-secondary);
      font-size: 1.15rem;
    }

    /* About Section */
    .about-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .about-text h3 {
      color: var(--forest-canopy);
      margin-bottom: 1rem;
      font-size: 1.75rem;
    }

    .about-text p {
      color: var(--text-secondary);
      margin-bottom: 1.25rem;
      font-size: 1.05rem;
    }

    .values-list {
      list-style: none;
      margin-top: 1.5rem;
    }

    .values-list li {
      padding: 0.75rem 0;
      padding-left: 2.5rem;
      position: relative;
      color: var(--text-secondary);
      font-size: 1.05rem;
    }

    .values-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.9rem;
      width: 20px;
      height: 20px;
      background: var(--sunlight-gold);
      border-radius: 50%;
      opacity: 0.3;
    }

    .values-list li strong {
      color: var(--forest-canopy);
    }

    .about-images {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      align-items: start;
    }

    .about-images :global(.optimized-image) {
      aspect-ratio: 4 / 3;
      border-radius: 15px;
      overflow: hidden;
      background: var(--stone-beige);
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
    }

    .about-images :global(.optimized-image picture) {
      display: block;
      width: 100%;
      height: 100%;
    }

    .about-images :global(.optimized-image-element) {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 0;
      box-shadow: none;
    }

    /* Testimonials Section */
    .testimonials-section {
      background: var(--stone-beige);
      padding: 4rem 1rem;
      margin: 4rem 0;
    }

    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .testimonial-card {
      background: white;
      padding: 2rem;
      border-radius: 15px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
      position: relative;
    }

    .testimonial-quote {
      font-style: italic;
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .testimonial-quote::before {
      content: '"';
      font-size: 3rem;
      color: var(--sunlight-gold);
      position: absolute;
      top: 1rem;
      left: 1rem;
      opacity: 0.5;
    }

    .testimonial-author {
      font-weight: 600;
      color: var(--forest-canopy);
      margin-bottom: 0.25rem;
    }

    .testimonial-role {
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    .testimonial-rating {
      margin-bottom: 1rem;
    }

    .star {
      color: var(--sunlight-gold);
      font-size: 1.2rem;
    }

    /* Programs Section */
    .programs-section {
      background: linear-gradient(to bottom, var(--warm-white) 0%, var(--stone-beige) 100%);
      padding: 4rem 1rem;
    }

    .programs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .program-card {
      background: white;
      border-radius: 20px;
      padding: 2.5rem;
      box-shadow: 0 5px 25px rgba(0, 0, 0, 0.08);
      transition: transform 0.3s ease;
      border: 1px solid var(--border-color);
      position: relative;
      overflow: hidden;
    }

    .program-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 5px;
      background: linear-gradient(90deg, var(--moss-green), var(--sunlight-gold));
    }

    .program-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 35px rgba(0, 0, 0, 0.12);
    }

    .program-card h3 {
      color: var(--forest-canopy);
      margin-bottom: 1rem;
      font-size: 1.75rem;
    }

    .program-details {
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
    }

    .program-details p {
      margin-bottom: 0.5rem;
      font-size: 1.05rem;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .program-details strong {
      color: var(--forest-canopy);
    }

    .tuition-range {
      background: var(--stone-beige);
      padding: 1.25rem;
      border-radius: 12px;
      margin-top: 1.5rem;
    }

    .tuition-range h4 {
      color: var(--forest-canopy);
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
    }

    .tuition-range p {
      color: var(--text-secondary);
      font-size: 0.95rem;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .tuition-range .price {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--moss-green);
      margin: 0.5rem 0;
    }

    .tuition-note {
      margin-top: 0.75rem;
      color: var(--text-secondary);
      font-size: 1rem;
      font-weight: 600;
      line-height: 1.5;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .tuition-note a {
      color: var(--deep-forest);
      font-weight: 700;
      text-decoration: underline;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .tuition-note a:hover {
      color: var(--forest-canopy);
    }

    /* Contact Section */
    .contact-section {
      background: white;
      border-radius: 25px;
      padding: 3rem;
      margin-top: 4rem;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
      border: 1px solid var(--border-color);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }

    /* Prevent grid items from forcing horizontal overflow on very narrow viewports. */
    .contact-grid > * {
      min-width: 0;
    }

    .contact-info h3 {
      color: var(--forest-canopy);
      margin-bottom: 1.5rem;
      font-size: 1.75rem;
    }

    .contact-item {
      margin-bottom: 1.5rem;
      display: flex;
      align-items: start;
      gap: 1rem;
    }

    .contact-item-icon {
      width: 45px;
      height: 45px;
      background: var(--stone-beige);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .contact-item-icon svg {
      width: 24px;
      height: 24px;
      color: var(--forest-canopy);
    }

    .contact-item-content h4 {
      color: var(--forest-canopy);
      margin-bottom: 0.25rem;
      font-size: 1.1rem;
    }

    .contact-item-content {
      min-width: 0;
    }

    .contact-item-content p {
      color: var(--text-secondary);
      font-size: 1rem;
      word-break: break-word;
      overflow-wrap: break-word;
    }

    .contact-item-content a {
      color: var(--moss-green);
      text-decoration: none;
      font-weight: 600;
      word-break: break-word;
      overflow-wrap: break-word;
    }

    .contact-item-content a:hover {
      text-decoration: underline;
    }

    /* Contact Form */
    .contact-form {
      background: var(--stone-beige);
      padding: 2.5rem;
      border-radius: 20px;
    }

    .contact-form h3 {
      color: var(--forest-canopy);
      margin-bottom: 1.5rem;
      font-size: 1.75rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group.full-width {
      grid-column: 1 / -1;
    }

    .form-group label {
      display: block;
      color: var(--forest-canopy);
      margin-bottom: 0.5rem;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 0.875rem 1rem;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      font-family: inherit;
      font-size: 1rem;
      transition: all 0.3s ease;
      background: white;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: var(--moss-green);
      box-shadow: 0 0 0 3px rgba(90, 128, 101, 0.1);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }

    .form-group small {
      display: block;
      color: var(--text-secondary);
      font-size: 0.85rem;
      margin-top: 0.25rem;
    }

    .submit-button {
      background: var(--forest-canopy);
      color: white;
      border: none;
      padding: 1rem 2.5rem;
      border-radius: 8px;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      width: 100%;
      box-shadow: 0 4px 15px var(--soft-shadow);
    }

    .submit-button:hover,
    .submit-button:focus {
      background: var(--deep-forest);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(47, 86, 64, 0.45);
    }

    /* Footer */
    .footer {
      background: var(--forest-canopy);
      color: white;
      text-align: center;
      padding: 3rem 1rem;
    }

    .footer p {
      margin-bottom: 0.5rem;
      opacity: 0.95;
    }

    .footer a {
      color: var(--stone-beige);
      text-decoration: none;
      font-weight: 600;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    .footer-links {
      margin-top: 1rem;
    }

    .footer-links a {
      margin: 0 1rem;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      h1 {
        font-size: 2.25rem;
      }

      h2 {
        font-size: 1.875rem;
      }

      .about-content,
      .contact-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .about-images {
        grid-template-columns: 1fr;
      }

      .quick-info {
        margin-top: -2rem;
      }

      .section {
        padding: 3rem 1rem;
      }

      .contact-section {
        padding: 2rem 1rem;
      }

      .form-row {
        grid-template-columns: 1fr;
      }

      .testimonials-grid {
        grid-template-columns: 1fr;
      }

      .programs-grid {
        grid-template-columns: 1fr;
      }

      .enrollment-notice {
        font-size: 1rem;
        padding: 0.65rem 1.5rem;
      }
    }

    @media (max-width: 420px) {
      .program-card {
        padding: 1.5rem;
      }

      .program-card h3 {
        font-size: 1.45rem;
      }

      .tuition-range .price {
        font-size: 1.1rem;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .enrollment-notice,
      .update-notice p {
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .primary-button,
      .secondary-button {
        width: 100%;
        max-width: 100%;
        padding-left: 1rem;
        padding-right: 1rem;
      }

      .contact-section {
        padding: 1.5rem 0.85rem;
      }

      .contact-info h3,
      .contact-form h3 {
        font-size: 1.45rem;
        overflow-wrap: anywhere;
        word-break: break-word;
      }
    }

    /* Loading state */
    .loading {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 3px solid rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      border-top-color: white;
      animation: spin 1s ease-in-out infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

      /* Success message */
      .success-message {
        background: var(--forest-canopy);
        color: white;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1rem;
        display: none;
      }

      /* Error message */
      .error-message {
        background: #7a1f1f;
        color: white;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1rem;
        display: none;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .error-message a {
        color: white;
        font-weight: 700;
        text-decoration: underline;
      }

    </style>
  </head>
  <body>
    <a href="#main" class="skip-to-content">Skip to content</a>

  <!-- Header Section -->
  <header class="header">
    <OptimizedImage
      photoSlug="homepage-spicebush-logo-brand-identity"
      className="logo"
      objectFit="contain"
      slotId="coming-soon-header-logo"
      mediaCategory="homepage"
      sizes="220px"
      alt={siteName}
    />
    <h1>{siteName}</h1>
    <p class="tagline">{tagline}</p>
    <div class="enrollment-notice" role="alert">🌟 Enrollment Open for {applicationSchoolYear} - Limited Spots Available!</div>
  </header>

  <!-- Update Notice -->
  <div class="update-notice" role="status" aria-live="polite">
    <p>🔧 {updateMessage}</p>
  </div>

  <!-- Quick Info Cards -->
  <main id="main">
    <section class="quick-info" aria-label="Quick Information">
      <div class="info-card">
        <div class="info-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </div>
        <h3>Ages Served</h3>
        <p><strong>{agesServed}</strong></p>
        <p>Preschool & Kindergarten Programs</p>
      </div>

      <div class="info-card">
        <div class="info-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3>School Hours</h3>
        <div class="hours-info">
          <p class="hours-section">
            <strong>Regular Program Hours</strong><br/>
            {generateHoursDisplay()}
          </p>
            
          <p class="hours-section">
            <strong>
                Before Care
              {beforeCareInfo.available && beforeCareInfo.label ? ` (${beforeCareInfo.label})` : ''}
            </strong><br/>
            {beforeCareInfo.description}
          </p>
            
          <p class="hours-section">
            <strong>
                Extended Care Option
              {extendedCareInfo.available && extendedCareInfo.label ? ` (${extendedCareInfo.label})` : ''}
            </strong><br/>
            {extendedCareInfo.description}
          </p>
        </div>
      </div>

      <div class="info-card">
        <div class="info-card-icon">
