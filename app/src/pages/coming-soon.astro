    }

    .values-list li strong {
      color: var(--forest-canopy);
    }

    .about-images {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .about-images img {
      width: 100%;
      border-radius: 15px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
    }

    /* Testimonials Section */
    .testimonials-section {
