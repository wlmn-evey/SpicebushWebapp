                            data-analytics-event="camp_contact_click"
                            data-analytics-label={`question-${week.slug}`}
                            data-analytics-location="camp-week-card"
                          >
                            Ask Admissions
                          </a>
                        </div>

                        <div class="mt-4 rounded-xl border border-gray-200 bg-white p-3 text-xs text-earth-brown/80">
                          <p class="font-semibold text-earth-brown">Enrollment partner</p>
                          <p class="mt-1">Registration links open in Transparent Classroom.</p>
