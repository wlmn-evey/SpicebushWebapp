          class="inline-flex min-h-[50px] w-full items-center justify-center rounded-xl bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          data-analytics-event={primaryAction.eventName}
          data-analytics-label={`sticky-${primaryAction.eventLabel}`}
          data-analytics-location="camp-mobile-sticky-cta"
        >
          {primaryAction.label}
        </a>
      </div>
    )
  }

  <script>
    function initCampAnimations() {
      const nodes = Array.from(document.querySelectorAll('[data-camp-animate]'));
      if (nodes.length === 0) return;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion || typeof IntersectionObserver === 'undefined') {
        nodes.forEach(node => node.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            // Add a small delay to ensure CSS transitions are ready
            requestAnimationFrame(() => {
              entry.target.classList.add('is-visible');
            });
            observer.unobserve(entry.target);
          });
        },
        {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        }
      );

      nodes.forEach(node => {
        // Reset visibility if it was already set (useful for SPA navigation)
        node.classList.remove('is-visible');
        observer.observe(node);
      });
    }

    // Run on initial load and after Astro View Transitions
    document.addEventListener('astro:page-load', initCampAnimations);
  </script>

  <style>
    .camp-reveal {
      opacity: 0;
      transform: translate3d(0, 18px, 0) scale(0.992);
      transition-property: opacity, transform;
      transition-duration: 560ms;
      transition-timing-function: cubic-bezier(0.2, 0.74, 0.25, 1);
      transition-delay: var(--camp-delay, 0ms);
      will-change: opacity, transform;
    }

    .camp-reveal.is-visible {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }

    .camp-card {
      transition:
        transform 260ms cubic-bezier(0.2, 0.74, 0.25, 1),
        box-shadow 260ms ease,
        border-color 260ms ease;
    }

    .camp-stat-card {
      transition:
        transform 260ms ease,
        background-color 260ms ease;
    }

    .camp-status-chip {
      animation: campStatusPulse 2.8s ease-in-out infinite;
    }

    @media (hover: hover) and (pointer: fine) {
      .camp-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 30px rgba(17, 24, 39, 0.14);
        border-color: rgba(62, 109, 81, 0.28);
      }

      .camp-stat-card:hover {
        transform: translateY(-2px);
      }
    }

    @keyframes campStatusPulse {
      0%,
      100% {
        transform: scale(1);
      }

      50% {
        transform: scale(1.03);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .camp-reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }

      .camp-card,
      .camp-stat-card,
      .camp-status-chip {
        transition: none;
        animation: none;
      }
    }
  </style>

  <Footer />
</Layout>
