---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import {
  Calendar,
  Clock,
  Users,
  Leaf,
  ArrowRight,
  CheckCircle,
  Mail,
  Phone,
  CircleHelp,
  Megaphone,
  Sparkles
} from 'lucide-astro';
import { db } from '@lib/db';
import type { CampWeekView } from '@lib/db/camp';

interface WeekAction {
  href: string;
  label: string;
  eventName: 'camp_enroll_click' | 'camp_waitlist_click' | 'camp_contact_click';
  eventLabel: string;
  external: boolean;
}

const settings = await db.content.getAllSettings();
const campData = await db.camp.getCampAdminData();

const asString = (value: unknown, fallback = ''): string => {
  if (typeof value !== 'string') return fallback;
  const trimmed = value.trim();
  return trimmed.length > 0 ? trimmed : fallback;
};

const formatDate = (value: string): string => {
  const parsed = Date.parse(`${value}T00:00:00`);
  if (!Number.isFinite(parsed)) return value;
  return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(
    new Date(parsed)
  );
};

const formatDateWithYear = (value: string): string => {
  const parsed = Date.parse(`${value}T00:00:00`);
  if (!Number.isFinite(parsed)) return value;
  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  }).format(new Date(parsed));
};

const formatDateTime = (value: string): string => {
  const parsed = Date.parse(value);
  if (!Number.isFinite(parsed)) return value;
  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit'
  }).format(new Date(parsed));
};

const statusLabel = (status: CampWeekView['status']): string => {
  if (status === 'draft') return 'Draft';
  if (status === 'open') return 'Open';
  if (status === 'limited') return 'Limited';
  if (status === 'full') return 'Full';
  if (status === 'waitlist') return 'Waitlist';
  return 'Closed';
};

const statusClass = (status: CampWeekView['status']): string => {
  if (status === 'open') return 'bg-green-100 text-green-800 border-green-200';
  if (status === 'limited') return 'bg-amber-100 text-amber-900 border-amber-200';
  if (status === 'full') return 'bg-red-100 text-red-800 border-red-200';
  if (status === 'waitlist') return 'bg-blue-100 text-blue-800 border-blue-200';
  if (status === 'draft') return 'bg-purple-100 text-purple-800 border-purple-200';
  return 'bg-gray-200 text-gray-800 border-gray-300';
};

const availabilityText = (week: CampWeekView, isAdmin: boolean): string => {
  if (week.status === 'draft') {
    return isAdmin ? 'Draft week (admin preview only).' : 'Not yet available.';
  }
  if (week.status === 'closed') return 'Registration is currently closed.';
  if (week.status === 'waitlist' || week.status === 'full') return 'No open seats right now.';
  return `${week.availableSeats} seat${week.availableSeats === 1 ? '' : 's'} remaining`;
};

const sanitizeExternalUrl = (value: string | null | undefined): string | null => {
  if (!value) return null;
  try {
    const parsed = new URL(value);
    if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') return null;
    return parsed.toString();
  } catch {
    return null;
  }
};

const getWeekAction = (week: CampWeekView): WeekAction => {
  const enrollmentUrl = sanitizeExternalUrl(week.enrollmentUrl);
  const waitlistUrl = sanitizeExternalUrl(week.waitlistUrl);

  if ((week.status === 'open' || week.status === 'limited') && enrollmentUrl) {
    return {
      href: enrollmentUrl,
      label: 'Reserve This Week',
      eventName: 'camp_enroll_click',
      eventLabel: week.slug,
      external: true
    };
  }

  if ((week.status === 'waitlist' || week.status === 'full') && waitlistUrl) {
    return {
      href: waitlistUrl,
      label: 'Join Waitlist',
      eventName: 'camp_waitlist_click',
      eventLabel: week.slug,
      external: true
    };
  }

  if (waitlistUrl) {
    return {
      href: waitlistUrl,
      label: 'Join Waitlist',
      eventName: 'camp_waitlist_click',
      eventLabel: week.slug,
      external: true
    };
  }

  if (enrollmentUrl) {
    return {
      href: enrollmentUrl,
      label: 'View Enrollment',
      eventName: 'camp_enroll_click',
      eventLabel: week.slug,
      external: true
    };
  }

  return {
    href: '/contact',
    label: 'Contact Admissions',
    eventName: 'camp_contact_click',
    eventLabel: week.slug,
    external: false
  };
};

const uniq = (values: string[]): string[] => {
  const seen = new Set<string>();
  const output: string[] = [];
  for (const value of values) {
    const trimmed = value.trim();
    if (!trimmed || seen.has(trimmed)) continue;
    seen.add(trimmed);
    output.push(trimmed);
  }
  return output;
};

const summarizeValues = (values: string[], max: number, fallback: string): string => {
  const cleaned = uniq(values.filter(value => value.trim().length > 0));
  if (cleaned.length === 0) return fallback;
  if (cleaned.length <= max) return cleaned.join(' • ');
  return `${cleaned.slice(0, max).join(' • ')} +${cleaned.length - max} more`;
};

const extractHighlights = (text: string): string[] =>
  text
    .split('\n')
    .map(line => line.trim())
    .filter(line => line.startsWith('-'))
    .map(line => line.replace(/^-+/, '').trim())
    .filter(Boolean)
    .slice(0, 4);

const extractLead = (text: string): string => {
  const lines = text
    .split('\n')
    .map(line => line.trim())
    .filter(Boolean);
  return lines.find(line => !line.startsWith('-') && !line.endsWith(':')) ?? '';
};

const locals = Astro.locals as Record<string, unknown>;
const isAdmin = locals.isAdmin === true;
const showPrepBanner = isAdmin && locals.campModePrep === true;
const campModeReason =
  typeof locals.campModeReason === 'string' && locals.campModeReason.length > 0
    ? locals.campModeReason
    : 'unknown';

const allWeeks = [...campData.weeks].sort((a, b) => {
  if (a.startDate === b.startDate) return a.displayOrder - b.displayOrder;
  return a.startDate.localeCompare(b.startDate);
});
const publicWeeks = allWeeks.filter(week => week.isPublished);
const visibleWeeks = isAdmin ? allWeeks : publicWeeks;

const seasonLabel = asString(
  settings.camp_current_season_label,
  campData.seasons.find(season => season.isActive)?.name ?? 'Summer Camp'
);

const openCount = visibleWeeks.filter(week => week.status === 'open').length;
const limitedCount = visibleWeeks.filter(week => week.status === 'limited').length;
const waitlistCount = visibleWeeks.filter(week => week.status === 'waitlist').length;
const fullCount = visibleWeeks.filter(week => week.status === 'full').length;
const totalAvailableSeats = visibleWeeks.reduce((sum, week) => sum + week.availableSeats, 0);

const latestUpdateTimestamp = visibleWeeks
  .map(week => Date.parse(week.updatedAt))
  .filter(value => Number.isFinite(value))
  .sort((a, b) => b - a)[0];
const latestUpdate =
  typeof latestUpdateTimestamp === 'number'
    ? formatDateTime(new Date(latestUpdateTimestamp).toISOString())
    : null;

const firstWeek = visibleWeeks[0] ?? null;
const lastWeek = visibleWeeks.length > 0 ? visibleWeeks[visibleWeeks.length - 1] : null;
const seasonDateRange =
  firstWeek && lastWeek
    ? `${formatDateWithYear(firstWeek.startDate)} - ${formatDateWithYear(lastWeek.endDate)}`
    : 'Schedule updates coming soon';

const ageRangeSummary = summarizeValues(
  visibleWeeks.map(week => week.ageRangeLabel),
  2,
  'Ages vary by week'
);
const hoursSummary = summarizeValues(
  visibleWeeks.map(week => week.hoursLabel),
  2,
  'Hours vary by week'
);
const priceSummary = summarizeValues(
  visibleWeeks.map(week => week.priceLabel),
  2,
  'Pricing varies by week'
);

const contactEmail = asString(settings.main_email, 'information@spicebushmontessori.org');
const contactPhone = asString(settings.main_phone, '(484) 202-0712');
const contactPhoneHref = `tel:${contactPhone.replace(/[^+\d]/g, '')}`;

const nextAvailableWeek =
  visibleWeeks.find(week => week.status === 'open' || week.status === 'limited') ?? null;
const heroWeek = nextAvailableWeek ?? visibleWeeks[0] ?? null;
const heroAction = heroWeek ? getWeekAction(heroWeek) : null;

const primaryWeek =
  visibleWeeks.find(
    week => week.status === 'open' || week.status === 'limited' || week.status === 'waitlist'
  ) ??
  visibleWeeks[0] ??
  null;
const primaryAction = primaryWeek ? getWeekAction(primaryWeek) : null;

const spotlightWeeks = visibleWeeks.filter(week => Boolean(week.heroMediaSlug)).slice(0, 3);

const enrollmentReadinessMessage = nextAvailableWeek
  ? `${nextAvailableWeek.availableSeats} seats currently open in ${nextAvailableWeek.themeTitle}.`
  : waitlistCount + fullCount > 0
    ? `${waitlistCount + fullCount} week${waitlistCount + fullCount === 1 ? '' : 's'} are full or on waitlist right now.`
    : 'New openings are posted here first.';

const faqEntries: Array<{ question: string; answer: string }> = [
  {
    question: 'Can we enroll in more than one week?',
    answer:
      'Yes. Many families combine multiple weeks. Use each week card to reserve that specific session through Transparent Classroom.'
  },
  {
    question: 'What if our preferred week is full?',
    answer:
      'Use the waitlist link when available. We monitor seat movement and contact families quickly if an opening appears.'
  },
  {
    question: 'How quickly are seat updates reflected?',
    answer:
      'Seat counts are managed from our admin system and updates are published to this page as soon as staff records changes.'
  },
  {
    question: 'Do you help families choose the right week?',
    answer:
      'Absolutely. Admissions can help match themes, age fit, and summer schedules so you can pick confidently.'
  }
];
---

<Layout
  title={`${seasonLabel} | Spicebush Montessori School`}
  description="Explore Spicebush Montessori camp themes, live seat availability, and quick enrollment links by week."
  keywords="montessori camp, glen mills camp, spicebush camp, camp enrollment"
>
  <Header />

  <main id="main-content" class="bg-[#f4f3ef] pb-28 md:pb-0">
    {
      showPrepBanner && (
        <div class="border-b border-amber-200 bg-amber-50">
          <div class="container mx-auto px-4 py-2 text-sm font-semibold text-amber-800">
            Camp is in Prep mode. You are previewing the private camp page before public launch.
            <span class="ml-2 font-normal text-amber-700">(reason: {campModeReason})</span>
          </div>
        </div>
      )
    }

    <section
      class="relative overflow-hidden bg-gradient-to-br from-forest-canopy via-moss-green to-[#274934] py-14 text-white lg:py-20"
    >
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-20 top-6 h-56 w-56 rounded-full bg-sunlight-gold/20 blur-3xl">
        </div>
        <div class="absolute -right-10 bottom-0 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
        <div class="absolute right-1/3 top-1/3 h-52 w-52 rounded-full bg-[#9cc8a8]/20 blur-3xl">
        </div>
      </div>

      <div class="container relative z-10 mx-auto px-4">
        <div class="grid gap-8 xl:grid-cols-[1.2fr_0.9fr] xl:items-center">
          <div data-camp-animate class="camp-reveal">
            <p class="text-xs uppercase tracking-[0.24em] text-white/80">
              Spicebush Montessori Summer Camp
            </p>
            <h1
              class="mt-3 max-w-3xl text-3xl font-heading font-bold leading-tight md:text-4xl lg:text-5xl"
            >
              {seasonLabel}
            </h1>
            <p class="mt-4 max-w-2xl text-base text-white/90 md:text-lg">
              A summer of outdoor play, hands-on discovery, and Montessori-led exploration. Explore our weekly themes and reserve your child's spot in minutes.
            </p>

            <div class="mt-5 flex flex-wrap gap-2 text-xs font-semibold">
              <span
                class="rounded-full border border-white/30 bg-white/10 px-3 py-1.5 text-white/95"
              >
                {seasonDateRange}
              </span>
              <span
                class="rounded-full border border-white/30 bg-white/10 px-3 py-1.5 text-white/95"
              >
                {ageRangeSummary}
              </span>
              <span
                class="rounded-full border border-white/30 bg-white/10 px-3 py-1.5 text-white/95"
              >
                {hoursSummary}
              </span>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
              {
                primaryAction ? (
                  <a
                    href={primaryAction.href}
                    target={primaryAction.external ? '_blank' : undefined}
                    rel={primaryAction.external ? 'noopener noreferrer' : undefined}
                    class="inline-flex min-h-[48px] items-center justify-center rounded-xl bg-sunlight-gold px-5 py-2 text-sm font-semibold text-earth-brown transition hover:bg-orange-300"
                    data-analytics-event={primaryAction.eventName}
                    data-analytics-label={`hero-${primaryAction.eventLabel}`}
                    data-analytics-location="camp-hero"
                  >
                    {primaryAction.label}
                    <ArrowRight className="ml-2 h-4 w-4" />
                  </a>
                ) : (
                  <a
                    href="/contact"
                    class="inline-flex min-h-[48px] items-center justify-center rounded-xl bg-sunlight-gold px-5 py-2 text-sm font-semibold text-earth-brown transition hover:bg-orange-300"
                    data-analytics-event="camp_contact_click"
                    data-analytics-label="hero-contact"
                    data-analytics-location="camp-hero"
                  >
                    Contact Admissions
                    <ArrowRight className="ml-2 h-4 w-4" />
                  </a>
                )
              }
              <a
                href="#camp-weeks"
                class="inline-flex min-h-[48px] items-center justify-center rounded-xl border border-white/35 px-5 py-2 text-sm font-semibold text-white transition hover:bg-white/10"
              >
                See All Themes
              </a>
            </div>

            <div class="mt-6 grid gap-3 sm:grid-cols-3">
              <div
                class="camp-stat-card rounded-xl border border-white/20 bg-white/10 p-3 backdrop-blur"
              >
                <p class="text-xs uppercase tracking-wide text-white/70">Open Seats</p>
                <p class="mt-1 text-2xl font-bold">{totalAvailableSeats}</p>
              </div>
              <div
                class="camp-stat-card rounded-xl border border-white/20 bg-white/10 p-3 backdrop-blur"
              >
                <p class="text-xs uppercase tracking-wide text-white/70">Open Weeks</p>
                <p class="mt-1 text-2xl font-bold">{openCount + limitedCount}</p>
              </div>
              <div
                class="camp-stat-card rounded-xl border border-white/20 bg-white/10 p-3 backdrop-blur"
              >
                <p class="text-xs uppercase tracking-wide text-white/70">Waitlist / Full</p>
                <p class="mt-1 text-2xl font-bold">{waitlistCount + fullCount}</p>
              </div>
            </div>
          </div>

          <aside
            data-camp-animate
            style="--camp-delay: 90ms;"
            class="camp-card camp-reveal overflow-hidden rounded-3xl border border-white/20 bg-white/10 shadow-xl backdrop-blur"
          >
            {
              heroWeek?.heroMediaSlug ? (
                <div class="aspect-[4/3] w-full md:aspect-[3/2]">
                  <OptimizedImage
                    photoSlug={heroWeek.heroMediaSlug}
                    alt={`${heroWeek.themeTitle} camp image`}
                    className="h-full w-full object-cover"
                    slotId={`camp-hero-${heroWeek.slug}`}
                    mediaCategory="events"
                  />
                </div>
              ) : (
                <div class="flex aspect-[4/3] items-center justify-center bg-white/10 px-6 text-center md:aspect-[3/2]">
                  <p class="text-xl font-semibold">Discover our weekly camp themes</p>
                </div>
              )
            }
            <div class="p-5">
              <p class="text-xs uppercase tracking-[0.2em] text-white/75">Featured Week</p>
              <h2 class="mt-1 text-2xl font-heading font-bold">
                {heroWeek?.themeTitle ?? 'Camp Overview'}
              </h2>
              {
                heroWeek && (
                  <p class="mt-1 text-sm text-white/85">
                    {formatDate(heroWeek.startDate)} - {formatDate(heroWeek.endDate)}
                  </p>
                )
              }
              <p class="mt-3 text-sm font-semibold text-white">{enrollmentReadinessMessage}</p>
              <p class="mt-2 text-sm text-white/90">
                {heroWeek?.summary || extractLead(heroWeek?.description ?? '')}
              </p>

              {
                heroAction && (
                  <a
                    href={heroAction.href}
                    target={heroAction.external ? '_blank' : undefined}
                    rel={heroAction.external ? 'noopener noreferrer' : undefined}
                    class="mt-4 inline-flex min-h-[46px] w-full items-center justify-center rounded-xl bg-white px-4 py-2 text-sm font-semibold text-forest-canopy transition hover:bg-stone-beige"
                    data-analytics-event={heroAction.eventName}
                    data-analytics-label={`hero-side-${heroAction.eventLabel}`}
                    data-analytics-location="camp-hero-side"
                  >
                    {heroAction.label}
                    <ArrowRight className="ml-2 h-4 w-4" />
                  </a>
                )
              }

              {
                latestUpdate && (
                  <p class="mt-3 text-xs text-white/75">Last updated {latestUpdate}</p>
                )
              }
            </div>
          </aside>
        </div>
      </div>
    </section>

    {
      spotlightWeeks.length > 0 && (
        <section class="-mt-7 pb-6">
          <div class="container mx-auto px-4">
            <div class="grid gap-3 md:grid-cols-3">
              {spotlightWeeks.map((week, index) => (
                <article
                  data-camp-animate
                  style={`--camp-delay: ${index * 75}ms;`}
                  class="camp-card camp-reveal overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm"
                >
                  <div class="aspect-[4/3] w-full">
                    {week.heroMediaSlug && (
                      <OptimizedImage
                        photoSlug={week.heroMediaSlug}
                        alt={`${week.themeTitle} spotlight image`}
                        className="h-full w-full object-cover"
                        slotId={`camp-spotlight-${week.slug}`}
                        mediaCategory="events"
                      />
                    )}
                  </div>
                  <div class="p-3">
                    <p class="text-xs uppercase tracking-wide text-earth-brown/70">
                      {formatDate(week.startDate)} - {formatDate(week.endDate)}
                    </p>
                    <p class="mt-1 text-sm font-semibold text-earth-brown">{week.themeTitle}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section data-camp-animate class="camp-reveal py-8">
      <div class="container mx-auto px-4">
        {
          !campData.available && (
            <div class="mb-5 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
              {campData.errorMessage ??
                'Camp data is not available yet. Apply the latest migration to enable camp management.'}
            </div>
          )
        }

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          <article class="camp-card rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-center gap-2 text-forest-canopy">
              <Users className="h-4 w-4" />
              <p class="text-xs uppercase tracking-wide text-earth-brown/70">Age Range</p>
            </div>
            <p class="mt-2 text-base font-semibold text-earth-brown">{ageRangeSummary}</p>
          </article>

          <article class="camp-card rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-center gap-2 text-forest-canopy">
              <Clock className="h-4 w-4" />
              <p class="text-xs uppercase tracking-wide text-earth-brown/70">Hours</p>
            </div>
            <p class="mt-2 text-base font-semibold text-earth-brown">{hoursSummary}</p>
          </article>

          <article class="camp-card rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-center gap-2 text-forest-canopy">
              <Calendar className="h-4 w-4" />
              <p class="text-xs uppercase tracking-wide text-earth-brown/70">Weekly Tuition</p>
            </div>
            <p class="mt-2 text-base font-semibold text-earth-brown">{priceSummary}</p>
          </article>

          <article class="camp-card rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-center gap-2 text-forest-canopy">
              <Leaf className="h-4 w-4" />
              <p class="text-xs uppercase tracking-wide text-earth-brown/70">Program Style</p>
            </div>
            <p class="mt-2 text-base font-semibold text-earth-brown">
              Montessori-led exploration, outdoor play, and weekly themes
            </p>
          </article>
        </div>
      </div>
    </section>

    <section data-camp-animate class="camp-reveal py-6" style="--camp-delay: 60ms;">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
          <div class="camp-card rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-earth-brown/70">
              Simple Enrollment Steps
            </p>
            <h2 class="mt-2 text-3xl font-heading font-bold text-earth-brown">
              Easy for Busy Parents
            </h2>
            <p class="mt-2 max-w-2xl text-sm text-earth-brown/80">
              Review the details quickly, choose the right week, and enroll with clear next steps.
            </p>

            <div class="mt-5 grid gap-3 md:grid-cols-3">
              <article class="camp-card rounded-2xl border border-gray-200 bg-stone-beige/30 p-4">
                <p class="text-xs uppercase tracking-wide text-earth-brown/70">Step 1</p>
                <h3 class="mt-1 text-base font-semibold text-earth-brown">Compare Weeks</h3>
                <p class="mt-1 text-sm text-earth-brown/85">
                  Review themes, dates, and seat status to find your best-fit sessions.
                </p>
              </article>

              <article class="camp-card rounded-2xl border border-gray-200 bg-stone-beige/30 p-4">
                <p class="text-xs uppercase tracking-wide text-earth-brown/70">Step 2</p>
                <h3 class="mt-1 text-base font-semibold text-earth-brown">Reserve Directly</h3>
                <p class="mt-1 text-sm text-earth-brown/85">
                  Click 'Reserve This Week' on any opening to secure your spot directly through Transparent Classroom.
                </p>
              </article>

              <article class="camp-card rounded-2xl border border-gray-200 bg-stone-beige/30 p-4">
                <p class="text-xs uppercase tracking-wide text-earth-brown/70">Step 3</p>
                <h3 class="mt-1 text-base font-semibold text-earth-brown">Get Follow-Up</h3>
                <p class="mt-1 text-sm text-earth-brown/85">
                  Admissions confirms details and supports any questions right away.
                </p>
              </article>
            </div>
          </div>

          <aside
            class="camp-card rounded-3xl border border-gray-200 bg-gradient-to-br from-[#ecf4ee] via-white to-[#f7f3df] p-6 shadow-sm"
          >
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-forest-canopy">
              Helpful Highlights
            </p>
            <h3 class="mt-2 text-2xl font-heading font-bold text-earth-brown">
              Booking made simple
            </h3>
            <ul class="mt-4 space-y-3 text-sm text-earth-brown/90">
              <li class="flex items-start gap-2">
                <CheckCircle className="mt-0.5 h-4 w-4 shrink-0 text-forest-canopy" />
                <span>Live seat updates help you plan with confidence.</span>
              </li>
              <li class="flex items-start gap-2">
                <CheckCircle className="mt-0.5 h-4 w-4 shrink-0 text-forest-canopy" />
                <span>One-tap enrollment links make registration simple.</span>
              </li>
              <li class="flex items-start gap-2">
                <CheckCircle className="mt-0.5 h-4 w-4 shrink-0 text-forest-canopy" />
                <span>Fast contact options are available if you need help.</span>
              </li>
            </ul>
            <a
              href="#camp-weeks"
