    </section>

    <section data-camp-animate class="camp-reveal pb-12 pt-4" style="--camp-delay: 100ms;">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 lg:grid-cols-[1.15fr_0.85fr]">
          <div class="camp-card rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-2 text-forest-canopy">
              <CircleHelp className="h-5 w-5" />
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-earth-brown/70">
