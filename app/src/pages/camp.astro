  <script is:inline>
    function initCampAnimations() {
      if (typeof window === 'undefined') return;
      document.documentElement.classList.add('camp-motion-ready');
      const nodes = Array.from(document.querySelectorAll('[data-camp-animate]'));
      if (nodes.length === 0) return;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion || typeof IntersectionObserver === 'undefined') {
        nodes.forEach(node => node.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            // Add a small delay to ensure CSS transitions are ready
            requestAnimationFrame(() => {
              entry.target.classList.add('is-visible');
            });
            observer.unobserve(entry.target);
          });
        },
        {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        }
      );

      nodes.forEach(node => {
        // Reset visibility if it was already set (useful for SPA navigation)
        node.classList.remove('is-visible');
        observer.observe(node);
      });
    }

    function initCampPageInteractions() {
      initCampAnimations();
    }

    // Run on both initial load and after Astro View Transitions navigate
    initCampPageInteractions();
    document.addEventListener('astro:page-load', initCampPageInteractions);
  </script>

