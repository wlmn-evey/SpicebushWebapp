---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Clock, Users, Calendar, Leaf } from 'lucide-astro';
import { getTourLink } from '@lib/tour-settings';

const tourLink = await getTourLink();
---

<Layout 
  title="Our Programs - Spicebush Montessori School"
  description="Learn about our Montessori programs for ages 3-6, including our full-day schedule, enrichment activities, and inclusive approach to education."
  keywords="Montessori programs, preschool curriculum, ages 3-6, school schedule, enrichment activities"
>
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-stone-beige to-light-stone py-16 lg:py-24">
      <div class="container mx-auto px-4">
        <div class="text-center">
          <h1 class="text-4xl lg:text-5xl font-bold text-earth-brown mb-6">
            Our Programs
          </h1>
          <p class="text-lg lg:text-xl text-earth-brown max-w-3xl mx-auto">
            A carefully prepared environment where children ages 3-6 learn, grow, and thrive together through authentic Montessori education.
          </p>
        </div>
      </div>
    </section>
    
    <!-- Preschool & Kindergarten Program Overview -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-earth-brown mb-4">Preschool & Kindergarten Program (Ages 3-6)</h2>
            <p class="text-lg text-earth-brown/80 max-w-3xl mx-auto">
              Our mixed-age classroom brings together children from 3 to 6 years old, creating a vibrant community where younger children learn from older peers and older children develop leadership and mentoring skills.
            </p>
          </div>
          
          <!-- Program Features Grid -->
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
            <div class="bg-stone-beige rounded-lg p-6 text-center">
              <div class="w-12 h-12 bg-sunlight-gold/20 rounded-full flex items-center justify-center mx-auto mb-4">
                <Clock className="w-6 h-6 text-sunlight-gold" />
              </div>
              <h3 class="font-semibold text-earth-brown mb-2">Full Day Program</h3>
              <p class="text-sm text-earth-brown/80">8:30 AM - 3:00 PM<br/>Optional before care and extended care available</p>
            </div>
            
            <div class="bg-stone-beige rounded-lg p-6 text-center">
              <div class="w-12 h-12 bg-sunlight-gold/20 rounded-full flex items-center justify-center mx-auto mb-4">
                <Users className="w-6 h-6 text-sunlight-gold" />
              </div>
              <h3 class="font-semibold text-earth-brown mb-2">Small Class Size</h3>
              <p class="text-sm text-earth-brown/80">24 students<br/>4 trained guides</p>
            </div>
            
            <div class="bg-stone-beige rounded-lg p-6 text-center">
              <div class="w-12 h-12 bg-sunlight-gold/20 rounded-full flex items-center justify-center mx-auto mb-4">
                <Calendar className="w-6 h-6 text-sunlight-gold" />
              </div>
              <h3 class="font-semibold text-earth-brown mb-2">School Year</h3>
              <p class="text-sm text-earth-brown/80">September - June<br/>Optional summer program</p>
            </div>
            
            <div class="bg-stone-beige rounded-lg p-6 text-center">
              <div class="w-12 h-12 bg-sunlight-gold/20 rounded-full flex items-center justify-center mx-auto mb-4">
                <Leaf className="w-6 h-6 text-sunlight-gold" />
              </div>
              <h3 class="font-semibold text-earth-brown mb-2">Outdoor Time</h3>
              <p class="text-sm text-earth-brown/80">Daily nature exploration<br/>Garden & outdoor classroom</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Daily Schedule -->
    <section class="py-16 bg-moss-green/10">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-earth-brown mb-8 text-center">A Day at Spicebush</h2>
          
          <div class="bg-white rounded-lg shadow-lg p-8">
            <div class="space-y-4">
              <div class="flex items-start space-x-4">
                <span class="font-semibold text-forest-canopy whitespace-nowrap">8:00 - 8:30 AM</span>
                <div>
                  <p class="font-semibold text-earth-brown">Optional Before Care & Arrival</p>
                  <p class="text-sm text-earth-brown/80">Families needing early drop-off can use before care while children settle in for the school day</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-4">
                <span class="font-semibold text-forest-canopy whitespace-nowrap">8:30 - 11:30 AM</span>
                <div>
                  <p class="font-semibold text-earth-brown">Morning Work Cycle</p>
                  <p class="text-sm text-earth-brown/80">Uninterrupted time for individual and small group lessons across all curriculum areas</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-4">
                <span class="font-semibold text-forest-canopy whitespace-nowrap">11:30 AM - 12:00 PM</span>
                <div>
                  <p class="font-semibold text-earth-brown">Lunch</p>
                  <p class="text-sm text-earth-brown/80">Children set tables, serve themselves, and clean up together</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-4">
                <span class="font-semibold text-forest-canopy whitespace-nowrap">12:00 - 1:00 PM</span>
                <div>
                  <p class="font-semibold text-earth-brown">Outdoor Play</p>
                  <p class="text-sm text-earth-brown/80">Free play, nature exploration, and gardening</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-4">
                <span class="font-semibold text-forest-canopy whitespace-nowrap">1:00 - 2:30 PM</span>
                <div>
                  <p class="font-semibold text-earth-brown">Afternoon Work/Rest</p>
                  <p class="text-sm text-earth-brown/80">Continued work time or rest for younger children</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-4">
                <span class="font-semibold text-forest-canopy whitespace-nowrap">2:30 - 3:00 PM</span>
                <div>
                  <p class="font-semibold text-earth-brown">Snack & Circle Time</p>
                  <p class="text-sm text-earth-brown/80">Community gathering with stories, songs, and sharing</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-4">
                <span class="font-semibold text-forest-canopy whitespace-nowrap">3:00 - 5:30 PM</span>
                <div>
                  <p class="font-semibold text-earth-brown">Extended Care (Optional)</p>
                  <p class="text-sm text-earth-brown/80">Quiet activities, outdoor play, and snack</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Curriculum Areas -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-earth-brown mb-12 text-center">Montessori Curriculum Areas</h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="text-center">
              <div class="bg-stone-beige rounded-lg p-6 mb-4">
                <h3 class="font-semibold text-earth-brown mb-2">Practical Life</h3>
                <p class="text-sm text-earth-brown/80">Real-world activities that develop coordination, concentration, independence, and care for self and environment</p>
              </div>
            </div>
            
            <div class="text-center">
              <div class="bg-stone-beige rounded-lg p-6 mb-4">
                <h3 class="font-semibold text-earth-brown mb-2">Sensorial</h3>
                <p class="text-sm text-earth-brown/80">Materials that refine the senses and help children classify and understand the world around them</p>
              </div>
            </div>
            
            <div class="text-center">
              <div class="bg-stone-beige rounded-lg p-6 mb-4">
                <h3 class="font-semibold text-earth-brown mb-2">Language</h3>
                <p class="text-sm text-earth-brown/80">Rich oral language, phonics, writing, and reading experiences that follow each child's readiness</p>
              </div>
            </div>
            
            <div class="text-center">
              <div class="bg-stone-beige rounded-lg p-6 mb-4">
                <h3 class="font-semibold text-earth-brown mb-2">Mathematics</h3>
                <p class="text-sm text-earth-brown/80">Concrete materials that make abstract concepts tangible, from counting to complex operations</p>
              </div>
            </div>
            
            <div class="text-center">
              <div class="bg-stone-beige rounded-lg p-6 mb-4">
                <h3 class="font-semibold text-earth-brown mb-2">Cultural Studies</h3>
                <p class="text-sm text-earth-brown/80">Geography, history, science, art, and music that connect children to the wider world</p>
              </div>
            </div>
            
            <div class="text-center">
              <div class="bg-stone-beige rounded-lg p-6 mb-4">
                <h3 class="font-semibold text-earth-brown mb-2">Peace Education</h3>
                <p class="text-sm text-earth-brown/80">Conflict resolution, grace and courtesy, and building a caring classroom community</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Enrichment Programs -->
    <section class="py-16 bg-stone-beige">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-earth-brown mb-8">Enrichment & Special Activities</h2>
          
          <div class="grid md:grid-cols-2 gap-6 text-left">
            <div class="bg-white rounded-lg p-6">
              <h3 class="font-semibold text-earth-brown mb-3">Garden & Nature Program</h3>
              <p class="text-earth-brown/80">Children tend our organic garden, learning about plants, seasons, and where food comes from. Daily outdoor exploration connects children with nature.</p>
            </div>
            
            <div class="bg-white rounded-lg p-6">
              <h3 class="font-semibold text-earth-brown mb-3">Art & Creative Expression</h3>
              <p class="text-earth-brown/80">Weekly art experiences with various media, plus daily access to art materials for self-expression and creativity.</p>
            </div>
            
            <div class="bg-white rounded-lg p-6">
              <h3 class="font-semibold text-earth-brown mb-3">Music & Movement</h3>
              <p class="text-earth-brown/80">Songs, instruments, and movement activities integrated throughout the day, plus special music circles.</p>
            </div>
            
            <div class="bg-white rounded-lg p-6">
              <h3 class="font-semibold text-earth-brown mb-3">Community Connections</h3>
              <p class="text-earth-brown/80">Walking field trips in our neighborhood, visits from community helpers, and celebrations of diverse cultures.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Call to Action -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-earth-brown mb-6">Ready to Learn More?</h2>
          <p class="text-lg text-earth-brown/80 mb-8">
            The best way to understand our program is to see it in action. Schedule a tour to observe our classroom and meet our teachers.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={tourLink} class="bg-sunlight-gold hover:bg-orange-600 text-white px-8 py-3 rounded-lg font-semibold transition-colors">
              Schedule a Tour
            </a>
            <a href="/admissions/tuition-calculator" class="bg-white hover:bg-gray-50 text-earth-brown border-2 border-earth-brown px-8 py-3 rounded-lg font-semibold transition-colors">
              Calculate Tuition
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
