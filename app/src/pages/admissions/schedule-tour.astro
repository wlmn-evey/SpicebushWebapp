---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Calendar, Clock, MapPin, Phone, Mail, CheckCircle } from 'lucide-astro';
import { getEntry } from 'astro:content';

// Get school info for contact details
const schoolInfo = await getEntry('school-info', 'general');
const { phone, email, address } = schoolInfo.data;
---

<Layout 
  title="Schedule a Tour - Spicebush Montessori School"
  description="Schedule a personal tour of our Montessori classrooms and meet our teachers. See our inclusive education environment in action."
  keywords="schedule Montessori tour, visit school, classroom observation, meet teachers"
>
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-stone-beige to-light-stone py-16 lg:py-24">
      <div class="container mx-auto px-4">
        <div class="text-center">
          <h1 class="text-4xl lg:text-5xl font-bold text-earth-brown mb-6">
            Visit Our School
          </h1>
          <p class="text-lg lg:text-xl text-earth-brown max-w-3xl mx-auto">
            Come see our beautiful classrooms, meet our teachers, and experience the warmth of our community. We'd love to show you around!
          </p>
        </div>
      </div>
    </section>
    
    <!-- Tour Information -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <div class="grid lg:grid-cols-2 gap-12 items-start">
            <!-- Tour Details -->
            <div>
              <h2 class="text-3xl font-bold text-earth-brown mb-8">What to Expect During Your Visit</h2>
              
              <div class="space-y-6 mb-8">
                <div class="flex items-start space-x-4">
                  <div class="flex-shrink-0 w-10 h-10 bg-sunlight-gold/20 rounded-full flex items-center justify-center">
                    <Clock className="w-5 h-5 text-sunlight-gold" />
                  </div>
                  <div>
                    <h3 class="font-semibold text-earth-brown mb-1">45-60 Minutes</h3>
                    <p class="text-earth-brown/80">Tours typically last about an hour, giving you time to see everything and ask questions</p>
                  </div>
                </div>
                
                <div class="flex items-start space-x-4">
                  <div class="flex-shrink-0 w-10 h-10 bg-sunlight-gold/20 rounded-full flex items-center justify-center">
                    <CheckCircle className="w-5 h-5 text-sunlight-gold" />
                  </div>
                  <div>
                    <h3 class="font-semibold text-earth-brown mb-1">Classroom Observation</h3>
                    <p class="text-earth-brown/80">See our Montessori environment in action and observe children engaged in their work</p>
                  </div>
                </div>
                
                <div class="flex items-start space-x-4">
                  <div class="flex-shrink-0 w-10 h-10 bg-sunlight-gold/20 rounded-full flex items-center justify-center">
                    <CheckCircle className="w-5 h-5 text-sunlight-gold" />
                  </div>
                  <div>
                    <h3 class="font-semibold text-earth-brown mb-1">Meet Our Teachers</h3>
                    <p class="text-earth-brown/80">Chat with our experienced Montessori guides about their approach and philosophy</p>
                  </div>
                </div>
                
                <div class="flex items-start space-x-4">
                  <div class="flex-shrink-0 w-10 h-10 bg-sunlight-gold/20 rounded-full flex items-center justify-center">
                    <CheckCircle className="w-5 h-5 text-sunlight-gold" />
                  </div>
                  <div>
                    <h3 class="font-semibold text-earth-brown mb-1">Q&A Time</h3>
                    <p class="text-earth-brown/80">Discuss tuition options, daily schedules, and any specific needs your child may have</p>
                  </div>
                </div>
              </div>
              
              <!-- When to Visit -->
              <div class="bg-moss-green/10 rounded-lg p-6">
                <h3 class="font-semibold text-earth-brown mb-3">Best Times to Visit</h3>
                <p class="text-earth-brown/80 mb-3">
                  We offer tours during school hours so you can see our classrooms in action:
                </p>
                <ul class="space-y-2 text-earth-brown/80">
                  <li class="flex items-center space-x-2">
                    <Calendar className="w-4 h-4 text-moss-green" />
                    <span>Tuesday & Thursday mornings (9:00 AM - 11:00 AM)</span>
                  </li>
                  <li class="flex items-center space-x-2">
                    <Calendar className="w-4 h-4 text-moss-green" />
                    <span>Wednesday afternoons (1:00 PM - 3:00 PM)</span>
                  </li>
                </ul>
              </div>
            </div>
            
            <!-- Contact Form -->
            <div class="bg-white rounded-lg shadow-lg p-8">
              <h2 class="text-2xl font-bold text-earth-brown mb-6">Schedule Your Visit</h2>
              
              <form id="tour-form" class="space-y-6">
                <!-- Parent Name -->
                <div>
                  <label for="parent-name" class="block text-sm font-medium text-earth-brown mb-2">
                    Parent/Guardian Name <span class="text-red-500">*</span>
                  </label>
                  <input 
                    type="text" 
                    id="parent-name" 
                    name="parent-name" 
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                    placeholder="Your full name"
                  />
                </div>
                
                <!-- Email -->
                <div>
                  <label for="email" class="block text-sm font-medium text-earth-brown mb-2">
                    Email Address <span class="text-red-500">*</span>
                  </label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                    placeholder="your@email.com"
                  />
                </div>
                
                <!-- Phone -->
                <div>
                  <label for="phone" class="block text-sm font-medium text-earth-brown mb-2">
                    Phone Number <span class="text-red-500">*</span>
                  </label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone" 
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                    placeholder="(xxx) xxx-xxxx"
                  />
                </div>
                
                <!-- Child Info -->
                <div>
                  <label for="child-age" class="block text-sm font-medium text-earth-brown mb-2">
                    Child's Age <span class="text-red-500">*</span>
                  </label>
                  <select 
                    id="child-age" 
                    name="child-age" 
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                  >
                    <option value="">Select age</option>
                    <option value="2.5-3">2.5 - 3 years</option>
                    <option value="3">3 years</option>
                    <option value="4">4 years</option>
                    <option value="5">5 years</option>
                    <option value="6">6 years</option>
                  </select>
                </div>
                
                <!-- Preferred Times -->
                <div>
                  <label for="preferred-times" class="block text-sm font-medium text-earth-brown mb-2">
                    Preferred Tour Times
                  </label>
                  <textarea 
                    id="preferred-times" 
                    name="preferred-times" 
                    rows="3"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                    placeholder="Please let us know what days/times work best for you"
                  ></textarea>
                </div>
                
                <!-- Questions -->
                <div>
                  <label for="questions" class="block text-sm font-medium text-earth-brown mb-2">
                    Questions or Special Considerations
                  </label>
                  <textarea 
                    id="questions" 
                    name="questions" 
                    rows="3"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                    placeholder="Any specific questions or needs we should know about?"
                  ></textarea>
                </div>
                
                <!-- Submit Button -->
                <button 
                  type="submit"
                  class="w-full bg-sunlight-gold hover:bg-orange-600 text-white px-6 py-4 rounded-lg font-semibold text-lg transition-colors focus:ring-2 focus:ring-orange-300 focus:ring-offset-2"
                >
                  Request Tour
                </button>
              </form>

              <!-- Success Message (hidden by default) -->
              <div id="success-message" class="hidden mt-6 p-4 bg-moss-green/20 border border-moss-green rounded-lg">
                <p class="text-moss-green font-semibold">Thank you for your interest!</p>
                <p class="text-earth-brown/80 mt-1">We've received your tour request and will contact you within 1-2 business days to schedule your visit.</p>
              </div>

              <!-- Error Message (hidden by default) -->
              <div id="error-message" class="hidden mt-6 p-4 bg-red-100 border border-red-300 rounded-lg">
                <p class="text-red-700 font-semibold">Something went wrong</p>
                <p class="text-red-600 mt-1">Please try again or contact us directly at <a href={`tel:${phone.replace(/[^0-9]/g, '')}`} class="underline">{phone}</a>.</p>
              </div>
              
              <!-- Alternative Contact -->
              <div class="mt-8 pt-8 border-t border-gray-200">
                <p class="text-sm text-earth-brown/80 text-center mb-4">
                  Prefer to schedule by phone? Call us directly:
                </p>
                <div class="flex flex-col sm:flex-row items-center justify-center space-y-2 sm:space-y-0 sm:space-x-6">
                  <a href={`tel:${phone.replace(/[^0-9]/g, '')}`} class="flex items-center space-x-2 text-forest-canopy hover:text-moss-green transition-colors">
                    <Phone className="w-5 h-5" />
                    <span class="font-semibold">{phone}</span>
                  </a>
                  <a href={`mailto:${email}`} class="flex items-center space-x-2 text-forest-canopy hover:text-moss-green transition-colors">
                    <Mail className="w-5 h-5" />
                    <span class="font-semibold">Email Us</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Location Info -->
    <section class="py-16 bg-stone-beige">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-earth-brown mb-8">Find Us</h2>
          <div class="bg-white rounded-lg shadow-lg p-8">
            <div class="flex items-start space-x-4">
              <MapPin className="w-6 h-6 text-forest-canopy flex-shrink-0 mt-1" />
              <div class="text-left">
                <h3 class="font-semibold text-earth-brown mb-2">Spicebush Montessori School</h3>
                <p class="text-earth-brown/80">
                  {address.street}<br>
                  {address.city}, {address.state} {address.zip}
                </p>
                <p class="text-sm text-earth-brown/60 mt-2">
                  Free street parking available. The school entrance is on the side of the building.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script define:vars={{ schoolEmail: email, schoolPhone: phone }}>
  // Form submission handler
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('tour-form');
    const successMessage = document.getElementById('success-message');
    const errorMessage = document.getElementById('error-message');
    
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Hide any existing messages
        successMessage.classList.add('hidden');
        errorMessage.classList.add('hidden');
        
        // Get form data
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        try {
          // Send form data to API endpoint
          const response = await fetch('/api/schedule-tour', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              parentName: data['parent-name'],
              email: data.email,
              phone: data.phone,
              childAge: data['child-age'],
              preferredTimes: data['preferred-times'] || '',
              questions: data.questions || '',
              schoolEmail
            })
          });

          if (response.ok) {
            // Show success message
            successMessage.classList.remove('hidden');
            form.reset();
            
            // Scroll to success message
            successMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          } else {
            throw new Error('Failed to submit form');
          }
        } catch (error) {
          console.error('Form submission error:', error);
          
          // Show error message
          errorMessage.classList.remove('hidden');
          
          // Scroll to error message
          errorMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    }
  });
</script>