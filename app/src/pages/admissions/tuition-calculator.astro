---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TuitionCalculatorComponent from '../../components/TuitionCalculator.tsx';
import { db } from '@lib/db';
import { logServerError } from '@lib/server-logger';

interface ProgramRecord {
  id: string;
  slug: string;
  name: string;
  description: string;
  programType?: string;
  daysPerWeek?: number;
  dailyHours?: number;
  displayOrder: number;
}

interface RateRecord {
  id: string;
  programId: string;
  label: string;
  tuitionPrice: number;
  extendedCarePrice: number | null;
  extendedCareAvailable: boolean;
  isConstantRate: boolean;
  incomeThresholdType: string | null;
  thresholds: Record<string, number | null>;
  displayOrder: number;
  schoolYear?: string;
}

interface CalculatorSettings {
  upfrontDiscountRate: number;
  siblingDiscountRate: number;
  currentSchoolYear: string;
}

const numberFrom = (value: unknown, fallback = 0): number => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (!trimmed) return fallback;
    const parsed = Number.parseFloat(trimmed.replace(/[^0-9.-]/g, ''));
    return Number.isFinite(parsed) ? parsed : fallback;
  }
  return fallback;
};

const stringFrom = (value: unknown, fallback = ''): string => {
  return typeof value === 'string' && value.trim().length > 0 ? value.trim() : fallback;
};

const optionalNumberFrom = (value: unknown): number | null => {
  if (value === undefined || value === null) return null;
  if (typeof value === 'string' && value.trim().length === 0) return null;
  const parsed = numberFrom(value, Number.NaN);
  return Number.isFinite(parsed) ? parsed : null;
};

let programs: ProgramRecord[] = [];
let rates: RateRecord[] = [];
let calculatorSettings: CalculatorSettings = {
  upfrontDiscountRate: 0.05,
  siblingDiscountRate: 0.1,
  currentSchoolYear: '2025-2026'
};
let loadError: string | null = null;

try {
  const [tuitionEntries, settingsMap] = await Promise.all([
    db.content.getCollection('tuition'),
    db.content.getAllSettings()
  ]);

  programs = tuitionEntries
    .filter((entry) => {
      const data = entry.data as Record<string, unknown>;
      return stringFrom(data.type) === 'program' && data.active !== false;
    })
    .map((entry) => {
      const data = entry.data as Record<string, unknown>;
      return {
        id: stringFrom(data.program_id, entry.slug),
        slug: entry.slug,
        name: stringFrom(data.name ?? data.title, entry.slug),
        description: stringFrom(data.description, ''),
        programType: stringFrom(data.program_type),
        daysPerWeek: Number.isFinite(Number(data.days_per_week)) ? Number(data.days_per_week) : undefined,
        dailyHours: Number.isFinite(Number(data.daily_hours)) ? Number(data.daily_hours) : undefined,
        displayOrder: numberFrom(data.display_order, 999)
      } satisfies ProgramRecord;
    })
    .sort((a, b) => a.displayOrder - b.displayOrder || a.name.localeCompare(b.name));

  rates = tuitionEntries
    .filter((entry) => {
      const data = entry.data as Record<string, unknown>;
      return stringFrom(data.type) === 'rate' && data.active !== false;
    })
    .map((entry) => {
      const data = entry.data as Record<string, unknown>;
      const thresholds: RateRecord['thresholds'] = {};
      ['2', '3', '4', '5', '6', '7', '8_plus'].forEach((sizeKey) => {
        const fieldName = sizeKey === '8_plus' ? 'income_threshold_family_8_plus' : `income_threshold_family_${sizeKey}`;
        thresholds[sizeKey] = optionalNumberFrom(data[fieldName]);
      });

      return {
        id: entry.slug,
        programId: stringFrom(data.program_id, entry.slug),
        label: stringFrom(data.rate_label, entry.slug.replace(/-/g, ' ')),
        tuitionPrice: numberFrom(data.tuition_price),
        extendedCarePrice: optionalNumberFrom(data.extended_care_price),
        extendedCareAvailable: data.extended_care_available !== false,
        isConstantRate: data.is_constant_rate === true,
        incomeThresholdType: data.income_threshold_type ? stringFrom(data.income_threshold_type) : null,
        thresholds,
        displayOrder: numberFrom(data.display_order, 999),
        schoolYear: stringFrom(data.school_year, '')
      } satisfies RateRecord;
    })
    .sort((a, b) => a.displayOrder - b.displayOrder || a.label.localeCompare(b.label));

  if (settingsMap) {
    const upfront = settingsMap['upfront_discount_rate'];
    const sibling = settingsMap['sibling_discount_rate'];
    const schoolYear = settingsMap['current_school_year'];

    calculatorSettings = {
      upfrontDiscountRate: numberFrom(upfront, calculatorSettings.upfrontDiscountRate),
      siblingDiscountRate: numberFrom(sibling, calculatorSettings.siblingDiscountRate),
      currentSchoolYear: stringFrom(schoolYear, calculatorSettings.currentSchoolYear)
    };
  }
} catch (error) {
  logServerError('Failed to load tuition calculator data', error, {
    page: '/admissions/tuition-calculator'
  });
  loadError = 'We are updating our tuition calculator. Please contact admissions for personalized tuition guidance.';
}
---

<Layout
  title="Tuition Calculator – Spicebush Montessori"
  description="Estimate your family’s tuition rate using our sliding-scale calculator and learn about payment options at Spicebush Montessori."
>
  <Header />
  <main class="bg-stone-beige/20 py-16">
    <section class="container mx-auto px-4 max-w-6xl">
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-heading font-bold text-earth-brown tracking-tight mb-4">
          Tuition & Sliding Scale Calculator
        </h1>
        <p class="text-lg text-earth-brown/80 leading-relaxed max-w-3xl mx-auto">
          Enter your family size and household income to view tuition options for each program. Our calculator applies the current sliding-scale tiers and highlights tuition assistance programs automatically.
        </p>
      </div>

      {loadError ? (
        <div class="bg-white border border-orange-200 text-orange-800 rounded-2xl p-8 shadow-sm text-center">
          <h2 class="text-2xl font-semibold mb-3">Calculator Unavailable</h2>
          <p class="mb-4 text-lg">
            {loadError}
          </p>
          <p class="text-sm text-earth-brown/70">
            Call <a class="underline font-medium" href="tel:14842020712">(484) 202-0712</a> or email
            <a class="underline font-medium ml-1" href="mailto:hello@spicebushmontessori.org">hello@spicebushmontessori.org</a>
            for immediate assistance.
          </p>
        </div>
      ) : (
        <TuitionCalculatorComponent
          client:load
          programs={programs}
          rates={rates}
          settings={calculatorSettings}
        />
      )}
    </section>
  </main>
  <Footer />
</Layout>
