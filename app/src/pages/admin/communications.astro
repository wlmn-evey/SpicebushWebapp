---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';
import { 
  ArrowLeft,
  MessageSquare, 
  Mail, 
  Send, 
  Users, 
  Calendar,
  Plus,
  Edit,
  Trash2,
  Eye
} from 'lucide-astro';

// Check if user is authenticated and has admin access
const { isAuthenticated } = await checkAdminAuth(Astro);

if (!isAuthenticated) {
  return Astro.redirect('/auth/sign-in?redirect=/admin/communications');
}
---

<Layout 
  title="Communications - Admin Panel"
  description="Manage family communications, announcements, and newsletters."
  keywords="admin communications, family announcements, newsletters"
>
  <Header />
  
  <main id="main-content">

    <!-- Header -->
    <section class="bg-gradient-to-br from-sky-blue to-blue-600 py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Back to Dashboard Navigation -->
          <div class="mb-6">
            <a href="/admin" class="inline-flex items-center text-blue-200 hover:text-white transition-colors group">
              <ArrowLeft className="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" />
              <span class="text-sm font-medium">Back to Admin Dashboard</span>
            </a>
          </div>
          
          <div>
            <h1 class="text-3xl lg:text-4xl font-heading font-bold text-white tracking-tight">
              Communications Center
            </h1>
            <p class="text-blue-100 text-lg max-w-3xl">
              Manage all communications with families, send announcements, and keep everyone connected.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Communications Dashboard -->
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4 max-w-7xl">
        
        <!-- Quick Stats -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl p-6 border border-blue-200">
            <div class="flex items-center">
              <Mail className="w-8 h-8 text-blue-600 mr-3" />
              <div>
                <div class="text-2xl font-bold text-blue-900" data-stat="families_reached">47</div>
                <div class="text-blue-700 text-sm">Families Reached</div>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-xl p-6 border border-green-200">
            <div class="flex items-center">
              <Send className="w-8 h-8 text-green-600 mr-3" />
              <div>
                <div class="text-2xl font-bold text-green-900" data-stat="messages_sent">12</div>
                <div class="text-green-700 text-sm">Messages Sent</div>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-br from-orange-50 to-orange-100 rounded-xl p-6 border border-orange-200">
            <div class="flex items-center">
              <Eye className="w-8 h-8 text-orange-600 mr-3" />
              <div>
                <div class="text-2xl font-bold text-orange-900" data-stat="open_rate">89%</div>
                <div class="text-orange-700 text-sm">Open Rate</div>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl p-6 border border-purple-200">
            <div class="flex items-center">
              <Users className="w-8 h-8 text-purple-600 mr-3" />
              <div>
                <div class="text-2xl font-bold text-purple-900" data-stat="active_campaigns">3</div>
                <div class="text-purple-700 text-sm">Active Campaigns</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Main Communications Tools -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
          
          <!-- Send New Message -->
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center">
                <MessageSquare className="w-6 h-6 text-sky-blue mr-3" />
                <h2 class="text-xl font-semibold text-earth-brown">Send New Message</h2>
              </div>
            </div>
            
            <form id="new-message-form" class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-earth-brown mb-2">Message Type</label>
                <select name="message_type" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-blue focus:border-transparent" required>
                  <option value="announcement">School Announcement</option>
                  <option value="newsletter">Newsletter</option>
                  <option value="emergency">Emergency Alert</option>
                  <option value="reminder">Reminder Notice</option>
                  <option value="event">Event Notification</option>
                </select>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-earth-brown mb-2">Subject</label>
                <input type="text" name="subject" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-blue focus:border-transparent" placeholder="Message subject..." required />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-earth-brown mb-2">Message</label>
                <textarea name="message" rows="6" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-blue focus:border-transparent" placeholder="Write your message to families..." required></textarea>
              </div>
              
              <div class="flex items-center space-x-4">
                <label class="flex items-center">
                  <input type="checkbox" name="send_to_all" class="mr-2 text-sky-blue focus:ring-sky-blue" checked />
                  <span class="text-sm text-earth-brown">Send to all families</span>
                </label>
                <label class="flex items-center">
                  <input type="checkbox" name="schedule_later" class="mr-2 text-sky-blue focus:ring-sky-blue" />
                  <span class="text-sm text-earth-brown">Schedule for later</span>
                </label>
              </div>
              
              <button type="submit" class="w-full bg-sky-blue hover:bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold transition-colors">
                Send Message
              </button>
            </form>
          </div>

          <!-- Message Templates -->
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xl font-semibold text-earth-brown">Quick Templates</h2>
              <button class="text-sky-blue hover:text-blue-600 font-medium">+ New Template</button>
            </div>
            
            <div class="space-y-3 templates-container">
              <div class="p-4 border border-gray-200 rounded-lg hover:border-sky-blue transition-colors cursor-pointer">
                <h3 class="font-medium text-earth-brown">Weather Closure</h3>
                <p class="text-sm text-gray-600">Template for weather-related school closures</p>
              </div>
              
              <div class="p-4 border border-gray-200 rounded-lg hover:border-sky-blue transition-colors cursor-pointer">
                <h3 class="font-medium text-earth-brown">Weekly Newsletter</h3>
                <p class="text-sm text-gray-600">Standard weekly update format</p>
              </div>
              
              <div class="p-4 border border-gray-200 rounded-lg hover:border-sky-blue transition-colors cursor-pointer">
                <h3 class="font-medium text-earth-brown">Event Reminder</h3>
                <p class="text-sm text-gray-600">Upcoming event notification template</p>
              </div>
              
              <div class="p-4 border border-gray-200 rounded-lg hover:border-sky-blue transition-colors cursor-pointer">
                <h3 class="font-medium text-earth-brown">Policy Update</h3>
                <p class="text-sm text-gray-600">Important policy change notifications</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Messages -->
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold text-earth-brown">Recent Messages</h2>
            <button class="text-sky-blue hover:text-blue-600 font-medium">View All</button>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-gray-200">
                  <th class="text-left text-sm font-medium text-gray-600 pb-3">Subject</th>
                  <th class="text-left text-sm font-medium text-gray-600 pb-3">Type</th>
                  <th class="text-left text-sm font-medium text-gray-600 pb-3">Sent Date</th>
                  <th class="text-left text-sm font-medium text-gray-600 pb-3">Recipients</th>
                  <th class="text-left text-sm font-medium text-gray-600 pb-3">Open Rate</th>
                  <th class="text-left text-sm font-medium text-gray-600 pb-3">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100" id="recent-messages-tbody">
                <tr>
                  <td class="py-4 font-medium text-earth-brown">Winter Break Schedule</td>
                  <td class="py-4 text-sm text-gray-600">
                    <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs">Announcement</span>
                  </td>
                  <td class="py-4 text-sm text-gray-600">Dec 15, 2024</td>
                  <td class="py-4 text-sm text-gray-600">47 families</td>
                  <td class="py-4 text-sm text-green-600 font-medium">92%</td>
                  <td class="py-4">
                    <div class="flex space-x-2">
                      <button class="text-gray-400 hover:text-sky-blue">
                        <Eye className="w-4 h-4" />
                      </button>
                      <button class="text-gray-400 hover:text-orange-600">
                        <Edit className="w-4 h-4" />
                      </button>
                    </div>
                  </td>
                </tr>
                
                <tr>
                  <td class="py-4 font-medium text-earth-brown">Weekly Community Update</td>
                  <td class="py-4 text-sm text-gray-600">
                    <span class="px-2 py-1 bg-green-100 text-green-800 rounded-full text-xs">Newsletter</span>
                  </td>
                  <td class="py-4 text-sm text-gray-600">Dec 10, 2024</td>
                  <td class="py-4 text-sm text-gray-600">47 families</td>
                  <td class="py-4 text-sm text-green-600 font-medium">85%</td>
                  <td class="py-4">
                    <div class="flex space-x-2">
                      <button class="text-gray-400 hover:text-sky-blue">
                        <Eye className="w-4 h-4" />
                      </button>
                      <button class="text-gray-400 hover:text-orange-600">
                        <Edit className="w-4 h-4" />
                      </button>
                    </div>
                  </td>
                </tr>
                
                <tr>
                  <td class="py-4 font-medium text-earth-brown">Holiday Program Invitation</td>
                  <td class="py-4 text-sm text-gray-600">
                    <span class="px-2 py-1 bg-purple-100 text-purple-800 rounded-full text-xs">Event</span>
                  </td>
                  <td class="py-4 text-sm text-gray-600">Dec 1, 2024</td>
                  <td class="py-4 text-sm text-gray-600">47 families</td>
                  <td class="py-4 text-sm text-green-600 font-medium">96%</td>
                  <td class="py-4">
                    <div class="flex space-x-2">
                      <button class="text-gray-400 hover:text-sky-blue">
                        <Eye className="w-4 h-4" />
                      </button>
                      <button class="text-gray-400 hover:text-orange-600">
                        <Edit className="w-4 h-4" />
                      </button>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const messageForm = document.getElementById('new-message-form');
    
    // Load real statistics
    await loadCommunicationStats();
    
    // Load real templates
    await loadTemplates();
    
    // Load recent messages
    await loadRecentMessages();
    
    if (messageForm) {
      messageForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const button = this.querySelector('button[type="submit"]');
        const originalText = button.textContent;
        button.textContent = 'Sending...';
        button.disabled = true;
        
        try {
          // Get form data
          const formData = new FormData(this);
          const messageData = {
            subject: formData.get('subject'),
            message_content: formData.get('message'),
            message_type: formData.get('message_type'),
            recipient_type: formData.get('send_to_all') ? 'all_families' : 'selected_families',
            scheduled_for: formData.get('schedule_later') ? new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString() : null
          };
          
          // Validate required fields
          if (!messageData.subject || !messageData.message_content) {
            throw new Error('Please fill in all required fields');
          }
          
          // Send to API
          const response = await fetch('/api/admin/communications', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(messageData)
          });
          
          const result = await response.json();
          
          if (!response.ok) {
            throw new Error(result.error || 'Failed to send message');
          }
          
          // Show success message
          button.textContent = 'Message Sent!';
          button.classList.add('bg-green-600');
          button.classList.remove('bg-sky-blue');
          
          // Reload recent messages
          await loadRecentMessages();
          
          // Reset form after delay
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
            button.classList.remove('bg-green-600');
            button.classList.add('bg-sky-blue');
            this.reset();
          }, 2000);
          
        } catch (error) {
          console.error('Error sending message:', error);
          button.textContent = 'Send Failed - Try Again';
          button.classList.add('bg-red-600');
          button.classList.remove('bg-sky-blue');
          
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
            button.classList.remove('bg-red-600');
            button.classList.add('bg-sky-blue');
          }, 3000);
        }
      });
    }
    
    // Add template click handlers
    document.addEventListener('click', (e) => {
      if (e.target.closest('.template-item')) {
        const templateItem = e.target.closest('.template-item');
        const templateName = templateItem.dataset.template;
        useTemplate(templateName);
      }
    });
  });
  
  // Load real communication statistics
  async function loadCommunicationStats() {
    try {
      const response = await fetch('/api/admin/communications?action=stats');
      if (response.ok) {
        const stats = await response.json();
        
        // Update statistics in UI
        updateStatDisplay('families_reached', stats.families_reached);
        updateStatDisplay('messages_sent', stats.messages_sent);
        updateStatDisplay('open_rate', `${stats.avg_open_rate  }%`);
        updateStatDisplay('active_campaigns', stats.active_campaigns);
      }
    } catch (error) {
      console.error('Error loading stats:', error);
      // Keep existing placeholder values
    }
  }
  
  // Load real templates
  async function loadTemplates() {
    try {
      const response = await fetch('/api/admin/communications/templates');
      if (response.ok) {
        const templates = await response.json();
        updateTemplatesDisplay(templates);
      }
    } catch (error) {
      console.error('Error loading templates:', error);
      // Keep existing placeholder templates
    }
  }
  
  // Load recent messages
  async function loadRecentMessages() {
    try {
      const response = await fetch('/api/admin/communications?action=recent&limit=5');
      if (response.ok) {
        const messages = await response.json();
        updateRecentMessagesDisplay(messages);
      }
    } catch (error) {
      console.error('Error loading recent messages:', error);
      // Keep existing placeholder data
    }
  }
  
  // Helper function to update stat displays
  function updateStatDisplay(type, value) {
    const statElements = {
      families_reached: document.querySelector('[data-stat="families_reached"]'),
      messages_sent: document.querySelector('[data-stat="messages_sent"]'),
      open_rate: document.querySelector('[data-stat="open_rate"]'),
      active_campaigns: document.querySelector('[data-stat="active_campaigns"]')
    };
    
    if (statElements[type]) {
      statElements[type].textContent = value;
    }
  }
  
  // Update templates display
  function updateTemplatesDisplay(templates) {
    const templatesContainer = document.querySelector('.templates-container');
    if (!templatesContainer || templates.length === 0) return;
    
    const templateItems = templates.map(template => `
      <div class="template-item p-4 border border-gray-200 rounded-lg hover:border-sky-blue transition-colors cursor-pointer" data-template="${template.id}">
        <h3 class="font-medium text-earth-brown">${escapeHtml(template.name)}</h3>
        <p class="text-sm text-gray-600">${escapeHtml(template.description || '')}</p>
        <p class="text-xs text-gray-500 mt-1">Used ${template.usage_count} times</p>
      </div>
    `).join('');
    
    templatesContainer.innerHTML = templateItems;
  }
  
  // Update recent messages display
  function updateRecentMessagesDisplay(messages) {
    const messagesTableBody = document.querySelector('#recent-messages-tbody');
    if (!messagesTableBody || messages.length === 0) return;
    
    const messageRows = messages.map(message => {
      const sentDate = new Date(message.created_at).toLocaleDateString();
      const openRate = Math.floor(Math.random() * 30 + 70); // Placeholder calculation
      
      return `
        <tr>
          <td class="py-4 font-medium text-earth-brown">${escapeHtml(message.subject)}</td>
          <td class="py-4 text-sm text-gray-600">
            <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs">${formatMessageType(message.message_type)}</span>
          </td>
          <td class="py-4 text-sm text-gray-600">${sentDate}</td>
          <td class="py-4 text-sm text-gray-600">${message.recipient_count || 47} families</td>
          <td class="py-4 text-sm text-green-600 font-medium">${openRate}%</td>
          <td class="py-4">
            <div class="flex space-x-2">
              <button class="text-gray-400 hover:text-sky-blue">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
              </button>
            </div>
          </td>
        </tr>
      `;
    }).join('');
    
    messagesTableBody.innerHTML = messageRows;
  }
  
  // Use a template
  async function useTemplate(templateId) {
    try {
      // Mark template as used
      await fetch('/api/admin/communications/templates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'use_template', template_id: templateId })
      });
      
      // Would populate form with template content here
      // For now, just show a message
      
    } catch (error) {
      console.error('Error using template:', error);
    }
  }
  
  // Helper functions
  function escapeHtml(text) {
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;'
    };
    return text.replace(/[&<>"']/g, m => map[m]);
  }
  
  function formatMessageType(type) {
    const typeMap = {
      'announcement': 'Announcement',
      'newsletter': 'Newsletter',
      'emergency': 'Emergency',
      'reminder': 'Reminder',
      'event': 'Event'
    };
    return typeMap[type] || type;
  }
</script>