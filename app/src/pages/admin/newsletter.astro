---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';
import { 
  ArrowLeft,
  Mail, 
  Users, 
  Download,
  Upload,
  TrendingUp,
  UserCheck,
  UserX,
  Calendar
} from 'lucide-astro';

// Check if user is authenticated and has admin access
const { isAuthenticated } = await checkAdminAuth(Astro);

if (!isAuthenticated) {
  return Astro.redirect('/auth/netlify-login?redirect=/admin/newsletter');
}
---

<Layout 
  title="Newsletter Management - Admin Panel"
  description="Manage newsletter subscribers and email campaigns."
  keywords="admin newsletter, email subscribers, mailing list"
>
  <Header />
  
  <main id="main-content">

    <!-- Header -->
    <section class="bg-gradient-to-br from-sky-blue to-blue-600 py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Back to Dashboard Navigation -->
          <div class="mb-6">
            <a href="/admin" class="inline-flex items-center text-blue-200 hover:text-white transition-colors group">
              <ArrowLeft className="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" />
              <span class="text-sm font-medium">Back to Admin Dashboard</span>
            </a>
          </div>
          
          <div>
            <h1 class="text-3xl lg:text-4xl font-heading font-bold text-white tracking-tight">
              Newsletter Management
            </h1>
            <p class="text-blue-100 text-lg max-w-3xl">
              Manage email subscribers, view analytics, and export mailing lists.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter Dashboard -->
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4 max-w-7xl">
        
        <!-- Statistics Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl p-6 border border-blue-200">
            <div class="flex items-center">
              <Users className="w-8 h-8 text-blue-600 mr-3" />
              <div>
                <div class="text-2xl font-bold text-blue-900" data-stat="total_subscribers">0</div>
                <div class="text-blue-700 text-sm">Total Subscribers</div>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-xl p-6 border border-green-200">
            <div class="flex items-center">
              <UserCheck className="w-8 h-8 text-green-600 mr-3" />
              <div>
                <div class="text-2xl font-bold text-green-900" data-stat="active_subscribers">0</div>
                <div class="text-green-700 text-sm">Active Subscribers</div>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-br from-orange-50 to-orange-100 rounded-xl p-6 border border-orange-200">
            <div class="flex items-center">
              <TrendingUp className="w-8 h-8 text-orange-600 mr-3" />
              <div>
                <div class="text-2xl font-bold text-orange-900" data-stat="recent_signups">0</div>
                <div class="text-orange-700 text-sm">Last 30 Days</div>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-br from-red-50 to-red-100 rounded-xl p-6 border border-red-200">
            <div class="flex items-center">
              <UserX className="w-8 h-8 text-red-600 mr-3" />
              <div>
                <div class="text-2xl font-bold text-red-900" data-stat="unsubscribed_count">0</div>
                <div class="text-red-700 text-sm">Unsubscribed</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          
          <!-- Subscribers List -->
          <div class="lg:col-span-2 bg-white border border-gray-200 rounded-xl shadow-sm">
            <div class="p-6 border-b border-gray-200">
              <div class="flex items-center justify-between">
                <h2 class="text-xl font-semibold text-earth-brown">Newsletter Subscribers</h2>
                <div class="flex gap-2">
                  <button id="export-btn" class="text-moss-green hover:text-forest-canopy font-medium text-sm flex items-center gap-1">
                    <Download className="w-4 h-4" />
                    Export CSV
                  </button>
                  <button id="import-btn" class="text-sky-blue hover:text-blue-600 font-medium text-sm flex items-center gap-1">
                    <Upload className="w-4 h-4" />
                    Import
                  </button>
                </div>
              </div>
              
              <!-- Filters -->
              <div class="mt-4 flex flex-wrap gap-3">
                <select id="status-filter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-sky-blue focus:border-transparent">
                  <option value="active">Active</option>
                  <option value="all">All Subscribers</option>
                  <option value="unsubscribed">Unsubscribed</option>
                  <option value="pending">Pending</option>
                </select>
                
                <select id="type-filter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-sky-blue focus:border-transparent">
                  <option value="">All Types</option>
                  <option value="general">General</option>
                  <option value="parents">Current Parents</option>
                  <option value="prospective">Prospective Families</option>
                  <option value="alumni">Alumni</option>
                  <option value="community">Community</option>
                </select>
                
                <input 
                  type="search" 
                  id="search-input"
                  placeholder="Search by email..." 
                  class="flex-1 min-w-[200px] px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-sky-blue focus:border-transparent"
                />
              </div>
            </div>
            
            <!-- Subscribers Table -->
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="text-left text-sm font-medium text-gray-600 px-6 py-3">Email</th>
                    <th class="text-left text-sm font-medium text-gray-600 px-6 py-3">Name</th>
                    <th class="text-left text-sm font-medium text-gray-600 px-6 py-3">Type</th>
                    <th class="text-left text-sm font-medium text-gray-600 px-6 py-3">Joined</th>
                    <th class="text-left text-sm font-medium text-gray-600 px-6 py-3">Status</th>
                    <th class="text-left text-sm font-medium text-gray-600 px-6 py-3">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100" id="subscribers-tbody">
                  <tr>
                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                      Loading subscribers...
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
            
            <!-- Pagination -->
            <div class="p-4 border-t border-gray-200 flex items-center justify-between">
              <div class="text-sm text-gray-600">
                Showing <span id="showing-count">0</span> of <span id="total-count">0</span> subscribers
              </div>
              <div class="flex gap-2">
                <button id="prev-btn" class="px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50 disabled:opacity-50" disabled>
                  Previous
                </button>
                <button id="next-btn" class="px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50 disabled:opacity-50">
                  Next
                </button>
              </div>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="space-y-6">
            
            <!-- Type Breakdown -->
            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
              <h3 class="text-lg font-semibold text-earth-brown mb-4">Subscriber Breakdown</h3>
              <div class="space-y-3" id="type-breakdown">
                <div class="text-center text-gray-500 py-4">Loading...</div>
              </div>
            </div>
            
            <!-- Quick Actions -->
            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
              <h3 class="text-lg font-semibold text-earth-brown mb-4">Quick Actions</h3>
              <div class="space-y-3">
                <button 
                  onclick="window.location.href='/admin/communications'"
                  class="w-full bg-sky-blue hover:bg-blue-600 text-white px-4 py-3 rounded-lg font-medium transition-colors flex items-center justify-center gap-2"
                >
                  <Mail className="w-5 h-5" />
                  Send Newsletter
                </button>
                
                <button 
                  id="add-subscriber-btn"
                  class="w-full border border-moss-green text-moss-green hover:bg-moss-green hover:text-white px-4 py-3 rounded-lg font-medium transition-colors"
                >
                  Add Subscriber Manually
                </button>
                
                <button 
                  id="view-stats-btn"
                  class="w-full border border-gray-300 text-gray-700 hover:bg-gray-50 px-4 py-3 rounded-lg font-medium transition-colors"
                >
                  View Detailed Analytics
                </button>
              </div>
            </div>
            
            <!-- Recent Activity -->
            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
              <h3 class="text-lg font-semibold text-earth-brown mb-4">Recent Activity</h3>
              <div class="space-y-3 text-sm" id="recent-activity">
                <div class="flex items-start gap-2">
                  <Calendar className="w-4 h-4 text-gray-400 mt-0.5" />
                  <div>
                    <p class="text-gray-600">New subscriber joined</p>
                    <p class="text-xs text-gray-400">2 hours ago</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    let currentOffset = 0;
    const limit = 50;
    let totalSubscribers = 0;
    let allSubscribers = [];
    
    // Load initial data
    await loadStats();
    await loadSubscribers();
    
    // Event listeners
    document.getElementById('status-filter')?.addEventListener('change', () => {
      currentOffset = 0;
      loadSubscribers();
    });
    
    document.getElementById('type-filter')?.addEventListener('change', () => {
      currentOffset = 0;
      loadSubscribers();
    });
    
    document.getElementById('search-input')?.addEventListener('input', debounce(filterSubscribers, 300));
    
    document.getElementById('prev-btn')?.addEventListener('click', () => {
      if (currentOffset > 0) {
        currentOffset -= limit;
        loadSubscribers();
      }
    });
    
    document.getElementById('next-btn')?.addEventListener('click', () => {
      if (currentOffset + limit < totalSubscribers) {
        currentOffset += limit;
        loadSubscribers();
      }
    });
    
    document.getElementById('export-btn')?.addEventListener('click', exportSubscribers);
    
    // Load statistics
    async function loadStats() {
      try {
        const response = await fetch('/api/admin/newsletter?action=stats');
        if (response.ok) {
          const stats = await response.json();
          
          // Update stat displays
          updateStatDisplay('total_subscribers', stats.total_subscribers);
          updateStatDisplay('active_subscribers', stats.active_subscribers);
          updateStatDisplay('recent_signups', stats.recent_signups);
          updateStatDisplay('unsubscribed_count', stats.unsubscribed_count);
          
          // Update type breakdown
          updateTypeBreakdown(stats.types_breakdown);
        }
      } catch (error) {
        console.error('Error loading stats:', error);
      }
    }
    
    // Load subscribers
    async function loadSubscribers() {
      const status = document.getElementById('status-filter')?.value || 'active';
      const type = document.getElementById('type-filter')?.value || '';
      
      try {
        const params = new URLSearchParams({
          status: status === 'all' ? '' : status,
          type,
          limit: limit.toString(),
          offset: currentOffset.toString()
        });
        
        const response = await fetch(`/api/admin/newsletter?${params}`);
        if (response.ok) {
          const subscribers = await response.json();
          allSubscribers = subscribers;
          displaySubscribers(subscribers);
          
          // Update pagination
          document.getElementById('showing-count').textContent = subscribers.length;
          document.getElementById('prev-btn').disabled = currentOffset === 0;
          document.getElementById('next-btn').disabled = subscribers.length < limit;
        }
      } catch (error) {
        console.error('Error loading subscribers:', error);
      }
    }
    
    // Display subscribers in table
    function displaySubscribers(subscribers) {
      const tbody = document.getElementById('subscribers-tbody');
      if (!tbody) return;
      
      if (subscribers.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-gray-500">
              No subscribers found
            </td>
          </tr>
        `;
        return;
      }
      
      tbody.innerHTML = subscribers.map(sub => `
        <tr>
          <td class="px-6 py-4 text-sm text-earth-brown font-medium">${escapeHtml(sub.email)}</td>
          <td class="px-6 py-4 text-sm text-gray-600">
            ${sub.first_name || sub.last_name ? escapeHtml(`${sub.first_name || ''} ${sub.last_name || ''}`.trim()) : '-'}
          </td>
          <td class="px-6 py-4 text-sm">
            <span class="px-2 py-1 rounded-full text-xs ${getTypeStyles(sub.subscription_type)}">
              ${formatType(sub.subscription_type)}
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600">${new Date(sub.created_at).toLocaleDateString()}</td>
          <td class="px-6 py-4 text-sm">
            <span class="px-2 py-1 rounded-full text-xs ${getStatusStyles(sub.subscription_status)}">
              ${formatStatus(sub.subscription_status)}
            </span>
          </td>
          <td class="px-6 py-4 text-sm">
            ${sub.subscription_status === 'active' ? `
              <button onclick="unsubscribeEmail('${sub.email}')" class="text-red-600 hover:text-red-800">
                Unsubscribe
              </button>
            ` : '-'}
          </td>
        </tr>
      `).join('');
    }
    
    // Filter subscribers locally
    function filterSubscribers() {
      const searchTerm = document.getElementById('search-input')?.value.toLowerCase() || '';
      
      if (!searchTerm) {
        displaySubscribers(allSubscribers);
        return;
      }
      
      const filtered = allSubscribers.filter(sub => 
        sub.email.toLowerCase().includes(searchTerm) ||
        (sub.first_name && sub.first_name.toLowerCase().includes(searchTerm)) ||
        (sub.last_name && sub.last_name.toLowerCase().includes(searchTerm))
      );
      
      displaySubscribers(filtered);
    }
    
    // Export subscribers
    async function exportSubscribers() {
      const status = document.getElementById('status-filter')?.value || 'active';
      
      try {
        const response = await fetch(`/api/admin/newsletter?action=export&status=${status}`);
        if (response.ok) {
          const blob = await response.blob();
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `newsletter-subscribers-${status}-${new Date().toISOString().split('T')[0]}.csv`;
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
          document.body.removeChild(a);
        }
      } catch (error) {
        console.error('Error exporting subscribers:', error);
        alert('Failed to export subscribers. Please try again.');
      }
    }
    
    // Unsubscribe email
    window.unsubscribeEmail = async function(email) {
      if (!confirm(`Are you sure you want to unsubscribe ${email}?`)) {
        return;
      }
      
      try {
        const response = await fetch('/api/admin/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'unsubscribe', email })
        });
        
        if (response.ok) {
          await loadStats();
          await loadSubscribers();
        } else {
          alert('Failed to unsubscribe email. Please try again.');
        }
      } catch (error) {
        console.error('Error unsubscribing:', error);
        alert('Failed to unsubscribe email. Please try again.');
      }
    };
    
    // Helper functions
    function updateStatDisplay(id, value) {
      const el = document.querySelector(`[data-stat="${id}"]`);
      if (el) el.textContent = value;
    }
    
    function updateTypeBreakdown(breakdown) {
      const container = document.getElementById('type-breakdown');
      if (!container) return;
      
      const total = Object.values(breakdown).reduce((sum, count) => sum + count, 0);
      
      if (total === 0) {
        container.innerHTML = '<div class="text-center text-gray-500 py-4">No active subscribers yet</div>';
        return;
      }
      
      container.innerHTML = Object.entries(breakdown).map(([type, count]) => `
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">${formatType(type)}</span>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-earth-brown">${count}</span>
            <span class="text-xs text-gray-400">(${Math.round(count / total * 100)}%)</span>
          </div>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-moss-green h-2 rounded-full" style="width: ${(count / total * 100)}%"></div>
        </div>
      `).join('');
    }
    
    function getTypeStyles(type) {
      const styles = {
        general: 'bg-blue-100 text-blue-800',
        parents: 'bg-green-100 text-green-800',
        prospective: 'bg-orange-100 text-orange-800',
        alumni: 'bg-purple-100 text-purple-800',
        community: 'bg-gray-100 text-gray-800'
      };
      return styles[type] || styles.general;
    }
    
    function getStatusStyles(status) {
      const styles = {
        active: 'bg-green-100 text-green-800',
        unsubscribed: 'bg-red-100 text-red-800',
        pending: 'bg-yellow-100 text-yellow-800',
        bounced: 'bg-gray-100 text-gray-800'
      };
      return styles[status] || styles.active;
    }
    
    function formatType(type) {
      const types = {
        general: 'General',
        parents: 'Current Parents',
        prospective: 'Prospective',
        alumni: 'Alumni',
        community: 'Community'
      };
      return types[type] || type;
    }
    
    function formatStatus(status) {
      return status.charAt(0).toUpperCase() + status.slice(1);
    }
    
    function escapeHtml(text) {
      const map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      };
      return text.replace(/[&<>"']/g, m => map[m]);
    }
    
    function debounce(func, wait) {
      let timeout;
      return function executedFunction(...args) {
        const later = () => {
          clearTimeout(timeout);
          func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
      };
    }
  });
</script>