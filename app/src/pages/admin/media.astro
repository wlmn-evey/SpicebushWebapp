---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db, type ContentEntry } from '@lib/db';
import { getCollection } from 'astro:content';
import { getPhotoFramingDefaults } from '@lib/photo-framing-defaults';

type PhotoData = Record<string, unknown>;
type DbPhotoEntry = ContentEntry<PhotoData>;
type PhotoSource = 'database' | 'content';

type EditorPhoto = {
  slug: string;
  source: PhotoSource;
  title: string;
  category: string;
  sourceUrl: string;
  optimizedFilename: string;
  previewUrl: string;
  fallbackPreviewUrl: string;
  originalWidth: number;
  originalHeight: number;
  altText: string;
  primaryUse: string;
  usedOnCsv: string;
  seoKeywordsCsv: string;
  primaryFocalDescription: string;
  primaryFocalX: number;
  primaryFocalY: number;
  mobileCropX: number;
  mobileCropY: number;
  mobileCropWidth: number;
  mobileCropHeight: number;
  tabletCropX: number;
  tabletCropY: number;
  tabletCropWidth: number;
  tabletCropHeight: number;
  baseData: Record<string, unknown>;
};

const collection = 'photos';
const dbEntries = (await db.content.getCollection(collection, 0)) as DbPhotoEntry[];
const fileEntries = await getCollection('photos');

const PHOTO_CATEGORIES = [
  'homepage',
  'about',
  'programs',
  'admissions',
  'gallery',
  'teachers',
  'blog',
  'art',
  'classroom',
  'events',
  'group',
  'individual',
  'materials',
  'outdoor',
  'practical'
] as const;

const savedSlug = Astro.url.searchParams.get('saved');
const errorMessage = Astro.url.searchParams.get('error');

const GALLERY_SUBCATEGORIES = new Set([
  'art',
  'classroom',
  'events',
  'group',
  'individual',
  'materials',
  'outdoor',
  'practical'
]);

const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));

const asRecord = (value: unknown): Record<string, unknown> => {
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    return value as Record<string, unknown>;
  }
  return {};
};

const stringFrom = (value: unknown, fallback = ''): string => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.length > 0) return trimmed;
  }
  return fallback;
};

const numberFrom = (value: unknown, fallback: number): number => {
  if (typeof value === 'number' && Number.isFinite(value)) {
    return value;
  }

  if (typeof value === 'string') {
    const parsed = Number.parseFloat(value.trim());
    if (Number.isFinite(parsed)) {
      return parsed;
    }
  }

  return fallback;
};

const arrayFromCsv = (value: unknown): string[] => {
  if (Array.isArray(value)) {
    return value
      .map((item) => (typeof item === 'string' ? item.trim() : ''))
      .filter((item) => item.length > 0);
  }
  return [];
};

const filenameFromUrl = (value: string): string => {
  const withoutQuery = value.split('?')[0] ?? value;
  const segments = withoutQuery.split('/');
  return segments[segments.length - 1] ?? '';
};

const normalizeCrop = (
  xInput: unknown,
  yInput: unknown,
  widthInput: unknown,
  heightInput: unknown,
  defaults: { x: number; y: number; width: number; height: number } = {
    x: 0,
    y: 0,
    width: 100,
    height: 100
  }
) => {
  const width = clamp(numberFrom(widthInput, defaults.width), 10, 100);
  const height = clamp(numberFrom(heightInput, defaults.height), 10, 100);
  const x = clamp(numberFrom(xInput, defaults.x), 0, 100 - width);
  const y = clamp(numberFrom(yInput, defaults.y), 0, 100 - height);
  return {
    x: Math.round(x * 10) / 10,
    y: Math.round(y * 10) / 10,
    width: Math.round(width * 10) / 10,
    height: Math.round(height * 10) / 10
  };
};

const buildPhotoPreview = (slug: string, category: string, optimizedFilename: string, sourceUrl: string) => {
  if (sourceUrl) {
    return {
      previewUrl: sourceUrl,
      fallbackPreviewUrl: sourceUrl
    };
  }

  const basePath = GALLERY_SUBCATEGORIES.has(category)
    ? `/images/optimized/gallery/${category}`
    : `/images/optimized/${category}`;

  return {
    previewUrl: `${basePath}/${optimizedFilename}`,
    fallbackPreviewUrl: `${basePath}/${slug}-640w.jpg`
  };
};

const toEditorPhoto = (slug: string, source: PhotoSource, input: unknown): EditorPhoto => {
  const data = asRecord(input);

  const category = stringFrom(data.category, 'homepage');
  const title = stringFrom(data.title, slug);
  const sourceUrl = stringFrom(data.sourceUrl, stringFrom(data.url, ''));
  const optimizedFilename = stringFrom(data.optimizedFilename, filenameFromUrl(sourceUrl) || `${slug}.webp`);
  const altText = stringFrom(data.altText, title);
  const primaryUse = stringFrom(data.primaryUse, category);
  const usedOn = arrayFromCsv(data.usedOn);
  const seoKeywords = arrayFromCsv(data.seoKeywords);

  const originalWidth = Math.round(numberFrom(data.originalWidth, 1200));
  const originalHeight = Math.round(numberFrom(data.originalHeight, 800));
  const framingDefaults = getPhotoFramingDefaults({
    category,
    width: originalWidth,
    height: originalHeight,
    slug
  });
  const primaryFocalDescription = stringFrom(data.primaryFocalDescription, framingDefaults.primaryFocalDescription);
  const primaryFocalX = clamp(numberFrom(data.primaryFocalX, framingDefaults.primaryFocalX), 0, 100);
  const primaryFocalY = clamp(numberFrom(data.primaryFocalY, framingDefaults.primaryFocalY), 0, 100);

  const mobileCrop = normalizeCrop(
    data.mobileCropX,
    data.mobileCropY,
    data.mobileCropWidth,
    data.mobileCropHeight,
    {
      x: framingDefaults.mobileCropX,
      y: framingDefaults.mobileCropY,
      width: framingDefaults.mobileCropWidth,
      height: framingDefaults.mobileCropHeight
    }
  );
  const tabletCrop = normalizeCrop(
    data.tabletCropX,
    data.tabletCropY,
    data.tabletCropWidth,
    data.tabletCropHeight,
    {
      x: framingDefaults.tabletCropX,
      y: framingDefaults.tabletCropY,
      width: framingDefaults.tabletCropWidth,
      height: framingDefaults.tabletCropHeight
    }
  );

  const { previewUrl, fallbackPreviewUrl } = buildPhotoPreview(slug, category, optimizedFilename, sourceUrl);

  const baseData: Record<string, unknown> = {
    ...data,
    category,
    title,
    optimizedFilename,
    sourceUrl,
    altText,
    primaryUse,
    usedOn,
    seoKeywords,
    originalWidth,
    originalHeight,
    primaryFocalDescription,
    primaryFocalX,
    primaryFocalY,
    mobileCropX: mobileCrop.x,
    mobileCropY: mobileCrop.y,
    mobileCropWidth: mobileCrop.width,
    mobileCropHeight: mobileCrop.height,
    tabletCropX: tabletCrop.x,
    tabletCropY: tabletCrop.y,
    tabletCropWidth: tabletCrop.width,
    tabletCropHeight: tabletCrop.height
  };

  return {
    slug,
    source,
    title,
    category,
    sourceUrl,
    optimizedFilename,
    previewUrl,
    fallbackPreviewUrl,
    originalWidth,
    originalHeight,
    altText,
    primaryUse,
    usedOnCsv: usedOn.join(', '),
    seoKeywordsCsv: seoKeywords.join(', '),
    primaryFocalDescription,
    primaryFocalX,
    primaryFocalY,
    mobileCropX: mobileCrop.x,
    mobileCropY: mobileCrop.y,
    mobileCropWidth: mobileCrop.width,
    mobileCropHeight: mobileCrop.height,
    tabletCropX: tabletCrop.x,
    tabletCropY: tabletCrop.y,
    tabletCropWidth: tabletCrop.width,
    tabletCropHeight: tabletCrop.height,
    baseData
  };
};

const bySlug = new Map<string, EditorPhoto>();
for (const entry of fileEntries) {
  bySlug.set(entry.slug, toEditorPhoto(entry.slug, 'content', entry.data));
}

for (const entry of dbEntries) {
  bySlug.set(entry.slug, toEditorPhoto(entry.slug, 'database', entry.data));
}

const editableEntries = [...bySlug.values()].sort((a, b) => {
  if (a.category !== b.category) {
    return a.category.localeCompare(b.category);
  }
  return a.slug.localeCompare(b.slug);
});

const categories = [...new Set(editableEntries.map((entry) => entry.category))].sort();
const requestedSlug = Astro.url.searchParams.get('slug') ?? '';
const initialSlug = editableEntries.some((entry) => entry.slug === requestedSlug)
  ? requestedSlug
  : editableEntries.some((entry) => entry.slug === (savedSlug ?? ''))
    ? (savedSlug as string)
    : (editableEntries[0]?.slug ?? '');

const serializedEditorState = JSON.stringify({
  entries: editableEntries,
  initialSlug
}).replace(/</g, '\\u003c');
---

<AdminLayout title="Manage Media">
  {savedSlug && (
    <p class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
      Saved media settings: <strong>{savedSlug}</strong>
    </p>
  )}

  {errorMessage && (
    <p class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
      {errorMessage}
    </p>
  )}

  <div class="space-y-6">
    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Media Manager</h2>
      <p class="mb-4 text-sm text-earth-brown/80">
        Pick an image, click to set the focal point, drag the crop boxes for mobile and tablet, then save.
      </p>
      <div class="grid gap-3 md:grid-cols-3">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Photo Entries</p>
          <p class="text-2xl font-semibold text-earth-brown">{editableEntries.length}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Categories</p>
          <p class="text-2xl font-semibold text-earth-brown">{categories.length}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Editing Tip</p>
          <p class="text-sm text-earth-brown/80">Start with focal point, then tighten mobile crop first.</p>
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Upload New Image</h2>
      <p class="mb-4 text-sm text-earth-brown/80">
        Upload an image and it will be stored, indexed, and added to this editor automatically.
      </p>

      <form id="media-upload-form" class="space-y-4">
        <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
          <label class="block text-sm font-medium md:col-span-2 xl:col-span-1">
            Image File
            <input
              id="media-upload-file"
              type="file"
              name="file"
              accept="image/*"
              required
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
            />
          </label>

          <label class="block text-sm font-medium">
            Internal Title
            <input
              id="media-upload-title"
              type="text"
              name="title"
              placeholder="Autumn Classroom Circle Time"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>

          <label class="block text-sm font-medium">
            Slug (optional)
            <input
              id="media-upload-slug"
              type="text"
              name="slug"
              placeholder="autumn-classroom-circle-time"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>

          <label class="block text-sm font-medium">
            Category
            <select id="media-upload-category" name="category" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              {PHOTO_CATEGORIES.map((category) => (
                <option value={category} selected={category === 'gallery'}>{category}</option>
              ))}
            </select>
          </label>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <button
            id="media-upload-submit"
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Upload and Add to Media Library
          </button>
          <p class="text-xs text-earth-brown/70">Accepted formats: JPG, PNG, WebP, GIF, AVIF, SVG (max 10MB).</p>
        </div>
      </form>

      <p id="media-upload-status" class="mt-3 hidden rounded-lg border p-3 text-sm"></p>
    </section>

    {editableEntries.length === 0 ? (
      <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <p class="text-sm text-earth-brown/80">No photo entries are available yet.</p>
      </section>
    ) : (
      <section class="grid gap-6 xl:grid-cols-[340px_minmax(0,1fr)]">
        <aside class="space-y-4 rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
          <div class="space-y-3">
            <label class="block text-sm font-medium">
              Search photos
              <input
                id="media-search"
                type="text"
                placeholder="Search by slug, title, or category"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              />
            </label>
            <label class="block text-sm font-medium">
              Category
              <select id="media-category-filter" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                <option value="all">All categories</option>
                {categories.map((category) => (
                  <option value={category}>{category}</option>
                ))}
              </select>
            </label>
            <p id="media-filter-count" class="text-xs text-earth-brown/70"></p>
          </div>

          <p id="media-filter-empty" class="hidden rounded-lg border border-amber-200 bg-amber-50 p-3 text-xs text-amber-800">
            No photos match the current filters.
          </p>

          <div id="media-list" class="max-h-[68vh] space-y-2 overflow-y-auto pr-1">
            {editableEntries.map((entry) => (
              <button
                type="button"
                class="media-item-btn w-full rounded-lg border border-gray-200 bg-gray-50 p-2 text-left"
                data-media-item
                data-slug={entry.slug}
                data-category={entry.category}
                data-search={`${entry.slug} ${entry.title} ${entry.category}`.toLowerCase()}
                aria-pressed="false"
              >
                <div class="flex items-center gap-3">
                  <img
                    src={entry.previewUrl}
                    alt={entry.altText}
                    class="h-16 w-16 rounded-md border border-gray-200 object-cover"
                    loading="lazy"
                  />
                  <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-earth-brown">{entry.title}</p>
                    <p class="truncate text-xs text-earth-brown/70">{entry.slug}</p>
                    <p class="text-xs text-earth-brown/70">{entry.category} | {entry.source === 'database' ? 'DB override' : 'Content default'}</p>
                  </div>
                </div>
              </button>
            ))}
          </div>
        </aside>

        <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
          <form id="media-editor-form" method="post" action="/api/admin/content" class="space-y-6">
            <input type="hidden" name="collection" value={collection} />
            <input id="media-field-slug" type="hidden" name="slug" value="" />
            <input id="media-field-title" type="hidden" name="title" value="" />
            <input id="media-field-status" type="hidden" name="status" value="published" />
            <input id="media-field-redirect" type="hidden" name="redirectTo" value="/admin/media" />
            <input id="media-field-base" type="hidden" name="baseDataJson" value="{}" />

            <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_340px]">
              <div class="space-y-3">
                <div class="flex flex-wrap items-start justify-between gap-2">
                  <div>
                    <h3 id="media-selected-title" class="text-lg font-semibold text-earth-brown">Select an image</h3>
                    <p id="media-selected-meta" class="text-sm text-earth-brown/75"></p>
                  </div>
                  <p id="media-selected-source" class="rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs text-earth-brown/70"></p>
                </div>

                <div class="overflow-hidden rounded-xl border border-gray-200 bg-gray-100">
                  <div class="relative">
                    <img
                      id="media-preview-image"
                      src=""
                      alt=""
                      class="block w-full select-none"
                      draggable="false"
                    />
                    <button
                      id="media-preview-overlay"
                      type="button"
                      class="absolute inset-0 cursor-crosshair border-0 bg-transparent p-0"
                      aria-label="Image focal and crop editor"
                    >
                      <span
                        id="media-focal-marker"
                        class="media-focal-marker"
                        aria-hidden="true"
                      ></span>

                      <div id="media-mobile-crop" data-crop-box="mobile" class="media-crop-box media-crop-mobile">
                        <span class="media-crop-handle" data-crop-handle aria-hidden="true"></span>
                      </div>

                      <div id="media-tablet-crop" data-crop-box="tablet" class="media-crop-box media-crop-tablet">
                        <span class="media-crop-handle" data-crop-handle aria-hidden="true"></span>
                      </div>
                    </button>
                  </div>
                </div>

                <p class="text-xs text-earth-brown/70">
                  Click anywhere on the image to place the focal point. Drag a crop box to move it; drag its corner handle to resize.
                </p>
                <p id="media-coordinates" class="rounded-md border border-gray-200 bg-gray-50 p-2 text-xs text-earth-brown/80"></p>
              </div>

              <div class="space-y-4">
                <section class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                  <h4 class="mb-3 text-sm font-semibold text-earth-brown">Details</h4>
                  <div class="space-y-3">
                    <label class="block text-sm font-medium">
                      Source URL
                      <input id="media-source-url" type="text" readonly class="mt-1 w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-xs text-earth-brown/80" />
                    </label>
                    <label class="block text-sm font-medium">
                      Internal Label
                      <input id="media-title" type="text" name="data.title" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" />
                    </label>
                    <label class="block text-sm font-medium">
                      Alt Text
                      <input id="media-alt-text" type="text" name="data.altText" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" />
                    </label>
                    <label class="block text-sm font-medium">
                      Primary Use
                      <input id="media-primary-use" type="text" name="data.primaryUse" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" />
                    </label>
                    <label class="block text-sm font-medium">
                      Used On (comma-separated)
                      <input id="media-used-on" type="text" name="data.usedOn_csv" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" />
                    </label>
                    <label class="block text-sm font-medium">
                      SEO Keywords (comma-separated)
                      <input id="media-seo-keywords" type="text" name="data.seoKeywords_csv" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" />
                    </label>
                  </div>
                </section>

                <section class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                  <h4 class="mb-3 text-sm font-semibold text-earth-brown">Focal Point</h4>
                  <div class="grid grid-cols-2 gap-3">
                    <label class="block text-sm font-medium">
                      X (%)
                      <input id="media-focal-x" type="number" min="0" max="100" step="0.1" name="data.primaryFocalX" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" />
                    </label>
                    <label class="block text-sm font-medium">
                      Y (%)
                      <input id="media-focal-y" type="number" min="0" max="100" step="0.1" name="data.primaryFocalY" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" />
                    </label>
                    <label class="block text-sm font-medium col-span-2">
                      Focal Description
                      <input id="media-focal-description" type="text" name="data.primaryFocalDescription" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" />
                    </label>
                  </div>
                </section>

                <section class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                  <div class="mb-3 flex items-center justify-between">
                    <h4 class="text-sm font-semibold text-earth-brown">Crop Zones</h4>
                    <div class="inline-flex rounded-lg border border-gray-300 bg-white p-1 text-xs">
                      <button type="button" id="media-target-mobile" class="media-target-btn rounded-md px-2 py-1" data-target="mobile">Mobile</button>
                      <button type="button" id="media-target-tablet" class="media-target-btn rounded-md px-2 py-1" data-target="tablet">Tablet</button>
                    </div>
                  </div>
                  <div class="space-y-4">
                    <fieldset class="rounded-md border border-gray-200 bg-white p-2">
                      <legend class="px-1 text-xs font-semibold text-earth-brown/70">Mobile Crop</legend>
                      <div class="grid grid-cols-2 gap-2">
                        <label class="block text-xs font-medium">
                          X (%)
                          <input id="media-mobile-x" type="number" min="0" max="100" step="0.1" name="data.mobileCropX" class="mt-1 w-full rounded-md border border-gray-300 px-2 py-1" />
                        </label>
                        <label class="block text-xs font-medium">
                          Y (%)
                          <input id="media-mobile-y" type="number" min="0" max="100" step="0.1" name="data.mobileCropY" class="mt-1 w-full rounded-md border border-gray-300 px-2 py-1" />
                        </label>
                        <label class="block text-xs font-medium">
                          Width (%)
                          <input id="media-mobile-width" type="number" min="10" max="100" step="0.1" name="data.mobileCropWidth" class="mt-1 w-full rounded-md border border-gray-300 px-2 py-1" />
                        </label>
                        <label class="block text-xs font-medium">
                          Height (%)
                          <input id="media-mobile-height" type="number" min="10" max="100" step="0.1" name="data.mobileCropHeight" class="mt-1 w-full rounded-md border border-gray-300 px-2 py-1" />
                        </label>
                      </div>
                    </fieldset>

                    <fieldset class="rounded-md border border-gray-200 bg-white p-2">
                      <legend class="px-1 text-xs font-semibold text-earth-brown/70">Tablet Crop</legend>
                      <div class="grid grid-cols-2 gap-2">
                        <label class="block text-xs font-medium">
                          X (%)
                          <input id="media-tablet-x" type="number" min="0" max="100" step="0.1" name="data.tabletCropX" class="mt-1 w-full rounded-md border border-gray-300 px-2 py-1" />
                        </label>
                        <label class="block text-xs font-medium">
                          Y (%)
                          <input id="media-tablet-y" type="number" min="0" max="100" step="0.1" name="data.tabletCropY" class="mt-1 w-full rounded-md border border-gray-300 px-2 py-1" />
                        </label>
                        <label class="block text-xs font-medium">
                          Width (%)
                          <input id="media-tablet-width" type="number" min="10" max="100" step="0.1" name="data.tabletCropWidth" class="mt-1 w-full rounded-md border border-gray-300 px-2 py-1" />
                        </label>
                        <label class="block text-xs font-medium">
                          Height (%)
                          <input id="media-tablet-height" type="number" min="10" max="100" step="0.1" name="data.tabletCropHeight" class="mt-1 w-full rounded-md border border-gray-300 px-2 py-1" />
                        </label>
                      </div>
                    </fieldset>
                  </div>
                </section>
              </div>
            </div>

            <div class="flex flex-wrap items-center justify-between gap-3">
              <button
                id="media-reset"
                type="button"
                class="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-earth-brown hover:bg-gray-50"
              >
                Reset Unsaved Changes
              </button>
              <button
                type="submit"
                class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
              >
                Save Media Settings
              </button>
            </div>
          </form>
        </section>
      </section>
    )}
  </div>

  {editableEntries.length > 0 && (
    <>
      <script id="media-admin-data" type="application/json" is:inline set:html={serializedEditorState}></script>
      <script is:inline>
        (() => {
          const dataNode = document.getElementById('media-admin-data');
          if (!dataNode) return;

          let payload;
          try {
            payload = JSON.parse(dataNode.textContent || '{}');
          } catch {
            return;
          }

          const entries = Array.isArray(payload.entries) ? payload.entries : [];
          if (!entries.length) return;

          const clone = (value) => JSON.parse(JSON.stringify(value));
          const bySlug = new Map(entries.map((entry) => [entry.slug, clone(entry)]));

          const searchInput = document.getElementById('media-search');
          const categoryFilter = document.getElementById('media-category-filter');
          const filterCount = document.getElementById('media-filter-count');
          const filterEmpty = document.getElementById('media-filter-empty');
          const listButtons = Array.from(document.querySelectorAll('[data-media-item]'));

          const slugField = document.getElementById('media-field-slug');
          const titleField = document.getElementById('media-field-title');
          const statusField = document.getElementById('media-field-status');
          const redirectField = document.getElementById('media-field-redirect');
          const baseDataField = document.getElementById('media-field-base');

          const selectedTitle = document.getElementById('media-selected-title');
          const selectedMeta = document.getElementById('media-selected-meta');
          const selectedSource = document.getElementById('media-selected-source');
          const coordinates = document.getElementById('media-coordinates');

          const previewImage = document.getElementById('media-preview-image');
          const previewOverlay = document.getElementById('media-preview-overlay');
          const focalMarker = document.getElementById('media-focal-marker');
          const mobileCropBox = document.getElementById('media-mobile-crop');
          const tabletCropBox = document.getElementById('media-tablet-crop');

          const titleInput = document.getElementById('media-title');
          const altTextInput = document.getElementById('media-alt-text');
          const primaryUseInput = document.getElementById('media-primary-use');
          const usedOnInput = document.getElementById('media-used-on');
          const seoKeywordsInput = document.getElementById('media-seo-keywords');

          const focalXInput = document.getElementById('media-focal-x');
          const focalYInput = document.getElementById('media-focal-y');
          const focalDescriptionInput = document.getElementById('media-focal-description');

          const mobileXInput = document.getElementById('media-mobile-x');
          const mobileYInput = document.getElementById('media-mobile-y');
          const mobileWidthInput = document.getElementById('media-mobile-width');
          const mobileHeightInput = document.getElementById('media-mobile-height');

          const tabletXInput = document.getElementById('media-tablet-x');
          const tabletYInput = document.getElementById('media-tablet-y');
          const tabletWidthInput = document.getElementById('media-tablet-width');
          const tabletHeightInput = document.getElementById('media-tablet-height');

          const targetMobileButton = document.getElementById('media-target-mobile');
          const targetTabletButton = document.getElementById('media-target-tablet');

          const resetButton = document.getElementById('media-reset');
          const sourceUrlInput = document.getElementById('media-source-url');

          const requiredNodes = [
            searchInput,
            categoryFilter,
            filterCount,
            filterEmpty,
            slugField,
            titleField,
            statusField,
            redirectField,
            baseDataField,
            selectedTitle,
            selectedMeta,
            selectedSource,
            coordinates,
            previewImage,
            previewOverlay,
            focalMarker,
            mobileCropBox,
            tabletCropBox,
            titleInput,
            altTextInput,
            primaryUseInput,
            usedOnInput,
            seoKeywordsInput,
            focalXInput,
            focalYInput,
            focalDescriptionInput,
            mobileXInput,
            mobileYInput,
            mobileWidthInput,
            mobileHeightInput,
            tabletXInput,
            tabletYInput,
            tabletWidthInput,
            tabletHeightInput,
            targetMobileButton,
            targetTabletButton,
            resetButton,
            sourceUrlInput
          ];

          if (requiredNodes.some((node) => !node)) {
            return;
          }

          const numberOr = (value, fallback) => {
            const parsed = Number.parseFloat(String(value));
            return Number.isFinite(parsed) ? parsed : fallback;
          };

          const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
          const round = (value) => Math.round(value * 10) / 10;
          const format = (value) => {
            const rounded = round(value);
            return Number.isInteger(rounded) ? String(rounded) : String(rounded.toFixed(1));
          };

          const normalizeCrop = (crop) => {
            const width = clamp(numberOr(crop.width, 100), 10, 100);
            const height = clamp(numberOr(crop.height, 100), 10, 100);
            const x = clamp(numberOr(crop.x, 0), 0, 100 - width);
            const y = clamp(numberOr(crop.y, 0), 0, 100 - height);
            return { x: round(x), y: round(y), width: round(width), height: round(height) };
          };

          let selectedSlug = '';
          let baseEntry = null;
          let workingEntry = null;
          let activeCropTarget = 'mobile';
          let dragState = null;
          let suppressFocalSet = false;

          const getCrop = (target) => {
            if (!workingEntry) return { x: 0, y: 0, width: 100, height: 100 };

            if (target === 'mobile') {
              return normalizeCrop({
                x: workingEntry.mobileCropX,
                y: workingEntry.mobileCropY,
                width: workingEntry.mobileCropWidth,
                height: workingEntry.mobileCropHeight
              });
            }

            return normalizeCrop({
              x: workingEntry.tabletCropX,
              y: workingEntry.tabletCropY,
              width: workingEntry.tabletCropWidth,
              height: workingEntry.tabletCropHeight
            });
          };

          const setCrop = (target, crop) => {
            if (!workingEntry) return;
            if (target === 'mobile') {
              workingEntry.mobileCropX = crop.x;
              workingEntry.mobileCropY = crop.y;
              workingEntry.mobileCropWidth = crop.width;
              workingEntry.mobileCropHeight = crop.height;
            } else {
              workingEntry.tabletCropX = crop.x;
              workingEntry.tabletCropY = crop.y;
              workingEntry.tabletCropWidth = crop.width;
              workingEntry.tabletCropHeight = crop.height;
            }
          };

          const setActiveCropTarget = (target) => {
            activeCropTarget = target;
            targetMobileButton.dataset.active = target === 'mobile' ? 'true' : 'false';
            targetTabletButton.dataset.active = target === 'tablet' ? 'true' : 'false';

            mobileCropBox.dataset.active = target === 'mobile' ? 'true' : 'false';
            tabletCropBox.dataset.active = target === 'tablet' ? 'true' : 'false';
          };

          const applyFilters = () => {
            const searchTerm = searchInput.value.trim().toLowerCase();
            const category = categoryFilter.value;
            let visibleCount = 0;
            let firstVisibleSlug = '';

            listButtons.forEach((button) => {
              const buttonCategory = button.dataset.category || '';
              const searchText = button.dataset.search || '';
              const categoryMatch = category === 'all' || buttonCategory === category;
              const searchMatch = !searchTerm || searchText.includes(searchTerm);
              const visible = categoryMatch && searchMatch;
              button.hidden = !visible;

              if (visible) {
                visibleCount += 1;
                if (!firstVisibleSlug) {
                  firstVisibleSlug = button.dataset.slug || '';
                }
              }
            });

            filterCount.textContent = `${visibleCount} photo${visibleCount === 1 ? '' : 's'} shown`;
            filterEmpty.classList.toggle('hidden', visibleCount > 0);

            if (visibleCount > 0 && !listButtons.some((btn) => !btn.hidden && btn.dataset.slug === selectedSlug)) {
              selectEntry(firstVisibleSlug);
            }
          };

          const render = () => {
            if (!workingEntry || !baseEntry) return;

            slugField.value = workingEntry.slug;
            titleField.value = workingEntry.title;
            statusField.value = 'published';
            redirectField.value = `/admin/media?saved=${encodeURIComponent(workingEntry.slug)}`;
            baseDataField.value = JSON.stringify(baseEntry.baseData || {});

            selectedTitle.textContent = workingEntry.title;
            selectedMeta.textContent = `${workingEntry.slug} | ${workingEntry.category} | ${workingEntry.originalWidth}x${workingEntry.originalHeight}`;
            selectedSource.textContent = workingEntry.source === 'database' ? 'DB override active' : 'Using content default';

            previewImage.src = workingEntry.previewUrl;
            previewImage.alt = workingEntry.altText;
            previewImage.onerror = () => {
              previewImage.onerror = null;
              previewImage.src = workingEntry.fallbackPreviewUrl;
            };

            titleInput.value = workingEntry.title;
            sourceUrlInput.value = workingEntry.sourceUrl || '';
            altTextInput.value = workingEntry.altText;
            primaryUseInput.value = workingEntry.primaryUse;
            usedOnInput.value = workingEntry.usedOnCsv;
            seoKeywordsInput.value = workingEntry.seoKeywordsCsv;
            focalDescriptionInput.value = workingEntry.primaryFocalDescription;

            focalXInput.value = format(workingEntry.primaryFocalX);
            focalYInput.value = format(workingEntry.primaryFocalY);

            mobileXInput.value = format(workingEntry.mobileCropX);
            mobileYInput.value = format(workingEntry.mobileCropY);
            mobileWidthInput.value = format(workingEntry.mobileCropWidth);
            mobileHeightInput.value = format(workingEntry.mobileCropHeight);

            tabletXInput.value = format(workingEntry.tabletCropX);
            tabletYInput.value = format(workingEntry.tabletCropY);
            tabletWidthInput.value = format(workingEntry.tabletCropWidth);
            tabletHeightInput.value = format(workingEntry.tabletCropHeight);

            focalMarker.style.left = `${workingEntry.primaryFocalX}%`;
            focalMarker.style.top = `${workingEntry.primaryFocalY}%`;

            const mobileCrop = getCrop('mobile');
            mobileCropBox.style.left = `${mobileCrop.x}%`;
            mobileCropBox.style.top = `${mobileCrop.y}%`;
            mobileCropBox.style.width = `${mobileCrop.width}%`;
            mobileCropBox.style.height = `${mobileCrop.height}%`;

            const tabletCrop = getCrop('tablet');
            tabletCropBox.style.left = `${tabletCrop.x}%`;
            tabletCropBox.style.top = `${tabletCrop.y}%`;
            tabletCropBox.style.width = `${tabletCrop.width}%`;
            tabletCropBox.style.height = `${tabletCrop.height}%`;

            coordinates.textContent = `Focal ${format(workingEntry.primaryFocalX)}%, ${format(workingEntry.primaryFocalY)}% | Mobile crop ${format(mobileCrop.x)}%, ${format(mobileCrop.y)}%, ${format(mobileCrop.width)}%, ${format(mobileCrop.height)}% | Tablet crop ${format(tabletCrop.x)}%, ${format(tabletCrop.y)}%, ${format(tabletCrop.width)}%, ${format(tabletCrop.height)}%`;

            listButtons.forEach((button) => {
              button.setAttribute('aria-pressed', button.dataset.slug === workingEntry.slug ? 'true' : 'false');
            });

            setActiveCropTarget(activeCropTarget);
          };

          const selectEntry = (slug) => {
            if (!slug || !bySlug.has(slug)) return;
            selectedSlug = slug;
            const selected = bySlug.get(slug);
            if (!selected) return;
            baseEntry = clone(selected);
            workingEntry = clone(selected);
            activeCropTarget = 'mobile';
            render();
          };

          const updateFocalFromInputs = () => {
            if (!workingEntry) return;
            workingEntry.primaryFocalX = round(clamp(numberOr(focalXInput.value, workingEntry.primaryFocalX), 0, 100));
            workingEntry.primaryFocalY = round(clamp(numberOr(focalYInput.value, workingEntry.primaryFocalY), 0, 100));
            render();
          };

          const updateCropFromInputs = (target) => {
            if (!workingEntry) return;

            const crop = target === 'mobile'
              ? normalizeCrop({
                x: mobileXInput.value,
                y: mobileYInput.value,
                width: mobileWidthInput.value,
                height: mobileHeightInput.value
              })
              : normalizeCrop({
                x: tabletXInput.value,
                y: tabletYInput.value,
                width: tabletWidthInput.value,
                height: tabletHeightInput.value
              });

            setCrop(target, crop);
            render();
          };

          searchInput.addEventListener('input', applyFilters);
          categoryFilter.addEventListener('change', applyFilters);

          listButtons.forEach((button) => {
            button.addEventListener('click', () => {
              const slug = button.dataset.slug || '';
              selectEntry(slug);
            });
          });

          titleInput.addEventListener('input', () => {
            if (!workingEntry) return;
            workingEntry.title = titleInput.value.trim() || workingEntry.slug;
            render();
          });

          altTextInput.addEventListener('input', () => {
            if (!workingEntry) return;
            workingEntry.altText = altTextInput.value;
            render();
          });

          primaryUseInput.addEventListener('input', () => {
            if (!workingEntry) return;
            workingEntry.primaryUse = primaryUseInput.value;
          });

          usedOnInput.addEventListener('input', () => {
            if (!workingEntry) return;
            workingEntry.usedOnCsv = usedOnInput.value;
          });

          seoKeywordsInput.addEventListener('input', () => {
            if (!workingEntry) return;
            workingEntry.seoKeywordsCsv = seoKeywordsInput.value;
          });

          focalDescriptionInput.addEventListener('input', () => {
            if (!workingEntry) return;
            workingEntry.primaryFocalDescription = focalDescriptionInput.value;
          });

          focalXInput.addEventListener('input', updateFocalFromInputs);
          focalYInput.addEventListener('input', updateFocalFromInputs);

          mobileXInput.addEventListener('input', () => updateCropFromInputs('mobile'));
          mobileYInput.addEventListener('input', () => updateCropFromInputs('mobile'));
          mobileWidthInput.addEventListener('input', () => updateCropFromInputs('mobile'));
          mobileHeightInput.addEventListener('input', () => updateCropFromInputs('mobile'));

          tabletXInput.addEventListener('input', () => updateCropFromInputs('tablet'));
          tabletYInput.addEventListener('input', () => updateCropFromInputs('tablet'));
          tabletWidthInput.addEventListener('input', () => updateCropFromInputs('tablet'));
          tabletHeightInput.addEventListener('input', () => updateCropFromInputs('tablet'));

          targetMobileButton.addEventListener('click', () => {
            setActiveCropTarget('mobile');
          });

          targetTabletButton.addEventListener('click', () => {
            setActiveCropTarget('tablet');
          });

          resetButton.addEventListener('click', () => {
            if (!baseEntry) return;
            workingEntry = clone(baseEntry);
            activeCropTarget = 'mobile';
            render();
          });

          previewOverlay.addEventListener('pointerdown', (event) => {
            if (!workingEntry || suppressFocalSet) return;
            if (event.button !== 0) return;
            if (event.target.closest('[data-crop-box]')) return;

            const rect = previewOverlay.getBoundingClientRect();
            if (!rect.width || !rect.height) return;

            const x = ((event.clientX - rect.left) / rect.width) * 100;
            const y = ((event.clientY - rect.top) / rect.height) * 100;
            workingEntry.primaryFocalX = round(clamp(x, 0, 100));
            workingEntry.primaryFocalY = round(clamp(y, 0, 100));
            render();
          });

          const beginDrag = (event, target, mode) => {
            if (!workingEntry) return;
            if (event.button !== 0) return;

            const rect = previewOverlay.getBoundingClientRect();
            if (!rect.width || !rect.height) return;

            const currentCrop = getCrop(target);
            setActiveCropTarget(target);

            dragState = {
              target,
              mode,
              startClientX: event.clientX,
              startClientY: event.clientY,
              startCrop: currentCrop,
              rect
            };

            const handlePointerMove = (moveEvent) => {
              if (!dragState) return;
              const dx = ((moveEvent.clientX - dragState.startClientX) / dragState.rect.width) * 100;
              const dy = ((moveEvent.clientY - dragState.startClientY) / dragState.rect.height) * 100;

              let nextCrop;

              if (dragState.mode === 'resize') {
                nextCrop = normalizeCrop({
                  x: dragState.startCrop.x,
                  y: dragState.startCrop.y,
                  width: dragState.startCrop.width + dx,
                  height: dragState.startCrop.height + dy
                });
              } else {
                nextCrop = normalizeCrop({
                  x: dragState.startCrop.x + dx,
                  y: dragState.startCrop.y + dy,
                  width: dragState.startCrop.width,
                  height: dragState.startCrop.height
                });
              }

              setCrop(dragState.target, nextCrop);
              render();
            };

            const endDrag = () => {
              window.removeEventListener('pointermove', handlePointerMove);
              dragState = null;
              suppressFocalSet = true;
              window.setTimeout(() => {
                suppressFocalSet = false;
              }, 50);
            };

            window.addEventListener('pointermove', handlePointerMove);
            window.addEventListener('pointerup', endDrag, { once: true });
            event.preventDefault();
          };

          mobileCropBox.addEventListener('pointerdown', (event) => {
            const mode = event.target.closest('[data-crop-handle]') ? 'resize' : 'move';
            beginDrag(event, 'mobile', mode);
          });

          tabletCropBox.addEventListener('pointerdown', (event) => {
            const mode = event.target.closest('[data-crop-handle]') ? 'resize' : 'move';
            beginDrag(event, 'tablet', mode);
          });

          const preferredSlug = typeof payload.initialSlug === 'string' && bySlug.has(payload.initialSlug)
            ? payload.initialSlug
            : (entries[0]?.slug || '');

          selectEntry(preferredSlug);
          applyFilters();
        })();
      </script>

      <style>
        .media-item-btn {
          transition: border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
        }

        .media-item-btn[aria-pressed='true'] {
          border-color: rgb(74 124 89);
          background-color: rgb(248 250 248);
          box-shadow: inset 0 0 0 1px rgb(74 124 89 / 0.3);
        }

        .media-focal-marker {
          position: absolute;
          width: 16px;
          height: 16px;
          border-radius: 9999px;
          border: 2px solid white;
          background-color: rgb(239 68 68);
          transform: translate(-50%, -50%);
          pointer-events: none;
          box-shadow: 0 0 0 1px rgb(127 29 29 / 0.4);
        }

        .media-crop-box {
          position: absolute;
          border: 2px solid;
          background: rgb(0 0 0 / 0.08);
          transition: border-color 0.15s ease, box-shadow 0.15s ease;
        }

        .media-crop-mobile {
          border-color: rgb(22 163 74);
        }

        .media-crop-tablet {
          border-color: rgb(234 88 12);
        }

        .media-crop-box[data-active='true'] {
          box-shadow: 0 0 0 2px rgb(255 255 255 / 0.8);
        }

        .media-crop-handle {
          position: absolute;
          right: -7px;
          bottom: -7px;
          width: 14px;
          height: 14px;
          border-radius: 9999px;
          border: 1px solid white;
          background: currentColor;
          color: inherit;
          cursor: nwse-resize;
          padding: 0;
        }

        .media-crop-mobile .media-crop-handle {
          color: rgb(22 163 74);
        }

        .media-crop-tablet .media-crop-handle {
          color: rgb(234 88 12);
        }

        .media-target-btn {
          color: rgb(87 83 78);
          transition: background-color 0.15s ease, color 0.15s ease;
        }

        .media-target-btn[data-active='true'] {
          background-color: rgb(74 124 89);
          color: white;
        }
      </style>
    </>
  )}

  <script is:inline>
    (() => {
      const uploadForm = document.getElementById('media-upload-form');
      const uploadFileInput = document.getElementById('media-upload-file');
      const uploadTitleInput = document.getElementById('media-upload-title');
      const uploadSlugInput = document.getElementById('media-upload-slug');
      const uploadCategoryInput = document.getElementById('media-upload-category');
      const uploadSubmitButton = document.getElementById('media-upload-submit');
      const uploadStatus = document.getElementById('media-upload-status');

      if (
        !uploadForm
        || !uploadFileInput
        || !uploadTitleInput
        || !uploadSlugInput
        || !uploadCategoryInput
        || !uploadSubmitButton
        || !uploadStatus
      ) {
        return;
      }

      const setUploadStatus = (message, isError = false) => {
        uploadStatus.textContent = message;
        uploadStatus.classList.remove(
          'hidden',
          'border-red-200',
          'bg-red-50',
          'text-red-800',
          'border-green-200',
          'bg-green-50',
          'text-green-800'
        );

        if (isError) {
          uploadStatus.classList.add('border-red-200', 'bg-red-50', 'text-red-800');
        } else {
          uploadStatus.classList.add('border-green-200', 'bg-green-50', 'text-green-800');
        }
      };

      uploadForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const selectedFile = uploadFileInput.files && uploadFileInput.files[0];
        if (!selectedFile) {
          setUploadStatus('Please choose an image file to upload.', true);
          return;
        }

        const requestData = new FormData();
        requestData.append('file', selectedFile);
        requestData.append('createPhotoEntry', 'true');
        requestData.append('category', uploadCategoryInput.value || 'gallery');

        if (uploadTitleInput.value.trim()) {
          requestData.append('title', uploadTitleInput.value.trim());
        }

        if (uploadSlugInput.value.trim()) {
          requestData.append('slug', uploadSlugInput.value.trim());
        }

        uploadSubmitButton.setAttribute('disabled', 'disabled');
        uploadSubmitButton.classList.add('opacity-60', 'cursor-not-allowed');
        setUploadStatus('Uploading image and creating media entry...');

        try {
          const response = await fetch('/api/media/upload', {
            method: 'POST',
            body: requestData
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok || payload.success !== true) {
            const message = typeof payload.error === 'string' ? payload.error : 'Upload failed';
            setUploadStatus(message, true);
            return;
          }

          const newSlug = typeof payload.photoSlug === 'string' ? payload.photoSlug : '';
          if (newSlug) {
            window.location.assign(`/admin/media?saved=${encodeURIComponent(newSlug)}&slug=${encodeURIComponent(newSlug)}`);
            return;
          }

          setUploadStatus('Image uploaded successfully.');
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Unexpected upload error';
          setUploadStatus(message, true);
        } finally {
          uploadSubmitButton.removeAttribute('disabled');
          uploadSubmitButton.classList.remove('opacity-60', 'cursor-not-allowed');
        }
      });
    })();
  </script>
</AdminLayout>
