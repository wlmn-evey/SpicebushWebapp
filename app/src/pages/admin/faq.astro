---
import AdminLayout from '@layouts/AdminLayout.astro';
import { getManagedFaqItems, type FaqListStyle } from '@lib/faq-content';

const faqItems = await getManagedFaqItems();

const savedSlug = Astro.url.searchParams.get('saved');
const errorMessage = Astro.url.searchParams.get('error');

const stringFrom = (value: unknown, fallback = ''): string => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.length > 0) return trimmed;
  }
  return fallback;
};

const numberFrom = (value: unknown, fallback: number): number => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value === 'string') {
    const parsed = Number.parseFloat(value.trim());
    if (Number.isFinite(parsed)) return parsed;
  }
  return fallback;
};

const listStyles: Array<{ value: FaqListStyle; label: string }> = [
  { value: 'none', label: 'No bullet list' },
  { value: 'unordered', label: 'Bullet list' },
  { value: 'ordered', label: 'Numbered list' }
];

const sortedItems = [...faqItems].sort((a, b) => {
  if (a.sectionOrder !== b.sectionOrder) return a.sectionOrder - b.sectionOrder;
  if (a.sectionTitle !== b.sectionTitle) return a.sectionTitle.localeCompare(b.sectionTitle);
  if (a.itemOrder !== b.itemOrder) return a.itemOrder - b.itemOrder;
  return a.question.localeCompare(b.question);
});

const sectionStatsMap = new Map<string, { title: string; order: number; count: number; maxItemOrder: number }>();
for (const item of sortedItems) {
  const existing = sectionStatsMap.get(item.sectionTitle);
  if (existing) {
    existing.count += 1;
    if (item.itemOrder > existing.maxItemOrder) {
      existing.maxItemOrder = item.itemOrder;
    }
  } else {
    sectionStatsMap.set(item.sectionTitle, {
      title: item.sectionTitle,
      order: item.sectionOrder,
      count: 1,
      maxItemOrder: item.itemOrder
    });
  }
}

const sectionStats = [...sectionStatsMap.values()].sort((a, b) => {
  if (a.order !== b.order) return a.order - b.order;
  return a.title.localeCompare(b.title);
});

const sectionGroups = sectionStats.map((section) => ({
  ...section,
  items: sortedItems.filter((item) => item.sectionTitle === section.title)
}));

const sectionOptionsFor = (currentTitle: string) => {
  const options = sectionStats.map((section) => ({
    title: section.title,
    order: section.order,
    nextItemOrder: section.maxItemOrder + 1
  }));

  if (currentTitle && !options.some((option) => option.title === currentTitle)) {
    options.push({
      title: currentTitle,
      order: 99,
      nextItemOrder: 1
    });
  }

  return options.sort((a, b) => {
    if (a.order !== b.order) return a.order - b.order;
    return a.title.localeCompare(b.title);
  });
};

const defaultSectionTitle = sectionStats[0]?.title ?? 'General FAQs';
const defaultSectionOrder = sectionStats[0]?.order ?? 1;
const defaultItemOrder = (sectionStats[0]?.maxItemOrder ?? 0) + 1;
const defaultSlug = `faq-${Date.now().toString(36)}-${Math.floor(Math.random() * 9000 + 1000)}`;
---

<AdminLayout title="Manage FAQs">
  {savedSlug && (
    <p class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
      Saved entry: <strong>{savedSlug}</strong>
    </p>
  )}

  {errorMessage && (
    <p class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
      {errorMessage}
    </p>
  )}

  <div class="space-y-6">
    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">FAQ Manager</h2>
      <p class="mb-4 text-sm text-earth-brown/80">
        FAQ items are grouped by section below. Use the section dropdowns to keep content organized without editing raw JSON.
      </p>
      <div class="grid gap-3 md:grid-cols-3">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">FAQ Items</p>
          <p class="text-2xl font-semibold text-earth-brown">{sortedItems.length}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Sections</p>
          <p class="text-2xl font-semibold text-earth-brown">{sectionStats.length}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Quick Tip</p>
          <p class="text-sm text-earth-brown/80">Section order controls which section appears first on the public FAQ page.</p>
        </div>
      </div>

      {sectionStats.length > 0 && (
        <div class="mt-4 grid gap-2 md:grid-cols-2">
          {sectionStats.map((section) => (
            <div class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-earth-brown/85">
              <span class="font-semibold">{section.order}. {section.title}</span>
              <span class="ml-2 text-earth-brown/65">({section.count} items)</span>
            </div>
          ))}
        </div>
      )}
    </section>

    <section class="space-y-4">
      <details class="rounded-xl border border-gray-200 bg-white shadow-sm">
        <summary class="cursor-pointer px-5 py-4 text-base font-semibold text-earth-brown">Add FAQ Item</summary>
        <div class="space-y-4 border-t border-gray-200 p-5">
          <p class="text-sm text-earth-brown/80">Start with question and answer, then place the item in an existing section or create a new one.</p>

          <form method="post" action="/api/admin/content" class="space-y-4" data-faq-form data-new-faq-form>
            <input type="hidden" name="collection" value="faq" />
            <input type="hidden" name="redirectTo" value="/admin/faq?saved=new" />

            <div class="grid gap-3 md:grid-cols-2">
              <label class="block text-sm font-medium md:col-span-2">
                Question
                <input
                  type="text"
                  name="data.question"
                  required
                  placeholder="What ages do you serve?"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>

              <label class="block text-sm font-medium">
                Section Group
                <select
                  name="data.section_title"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  data-section-select
                >
                  {sectionStats.length > 0 ? (
                    sectionStats.map((section) => (
                      <option
                        value={section.title}
                        selected={section.title === defaultSectionTitle}
                        data-section-order={String(section.order)}
                        data-next-item-order={String(section.maxItemOrder + 1)}
                      >
                        {section.order}. {section.title}
                      </option>
                    ))
                  ) : (
                    <option value="General FAQs" data-section-order="1" data-next-item-order="1">1. General FAQs</option>
                  )}
                  <option value="__new__" data-section-order="99" data-next-item-order="1">+ Create a new section</option>
                </select>
              </label>

              <label class="block text-sm font-medium" data-new-section-fields hidden>
                New Section Name
                <input
                  type="text"
                  name="data.section_title_custom"
                  placeholder="Parent & Family Involvement"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  data-new-section-input
                />
              </label>

              <label class="block text-sm font-medium">
                Section Order
                <input
                  type="number"
                  name="data.section_order"
                  min="1"
                  step="1"
                  value={String(defaultSectionOrder)}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  data-section-order-input
                />
              </label>

              <label class="block text-sm font-medium">
                Item Order in Section
                <input
                  type="number"
                  name="data.item_order"
                  min="1"
                  step="1"
                  value={String(defaultItemOrder)}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  data-item-order-input
                />
              </label>

              <label class="block text-sm font-medium">
                List Style
                <select name="data.list_style" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                  {listStyles.map((style) => (
                    <option value={style.value}>{style.label}</option>
                  ))}
                </select>
              </label>

              <label class="block text-sm font-medium md:col-span-2">
                Answer
                <textarea
                  name="data.answer"
                  rows="4"
                  required
                  placeholder="Write the main answer paragraph here."
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                ></textarea>
              </label>

              <label class="block text-sm font-medium md:col-span-2">
                Bullet List (one line per bullet)
                <textarea
                  name="data.bullets_lines"
                  rows="4"
                  placeholder="Optional. Add one bullet point per line."
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                ></textarea>
              </label>

              <label class="block text-sm font-medium md:col-span-2">
                Follow-up Note (optional)
                <textarea
                  name="data.note"
                  rows="3"
                  placeholder="Optional short note shown under the answer."
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                ></textarea>
              </label>

              <label class="block text-sm font-medium">
                Button Label (optional)
                <input
                  type="text"
                  name="data.cta_label"
                  placeholder="Tuition Calculator"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>

              <label class="block text-sm font-medium">
                Button URL (optional)
                <input
                  type="text"
                  name="data.cta_url"
                  placeholder="/admissions/tuition-calculator"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
            </div>

            <details class="rounded-lg border border-gray-200 bg-gray-50 p-3">
              <summary class="cursor-pointer text-sm font-semibold text-earth-brown">Advanced Options</summary>
              <div class="mt-3 grid gap-3 md:grid-cols-2">
                <label class="block text-sm font-medium">
                  URL Slug
                  <input
                    type="text"
                    name="slug"
                    value={defaultSlug}
                    required
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>

                <label class="block text-sm font-medium">
                  Internal Title (optional)
                  <input
                    type="text"
                    name="title"
                    placeholder="Same as question"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>

                <label class="block text-sm font-medium">
                  Publish Status
                  <select name="status" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                    <option value="published">Published</option>
                    <option value="draft">Draft</option>
                  </select>
                </label>
              </div>
            </details>

            <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
              Add FAQ Item
            </button>
          </form>
        </div>
      </details>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Existing FAQ Items</h2>
      <p class="mb-4 text-sm text-earth-brown/80">Items are grouped by section so updates are easier to scan and maintain.</p>

      {sortedItems.length === 0 ? (
        <p class="rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-earth-brown/80">No FAQ entries found yet.</p>
      ) : (
        <div class="space-y-5">
          {sectionGroups.map((section) => (
            <div class="rounded-xl border border-gray-200 bg-gray-50/70 p-4">
              <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
                <div>
                  <h3 class="text-base font-semibold text-earth-brown">{section.order}. {section.title}</h3>
                  <p class="text-xs text-earth-brown/70">{section.count} item{section.count === 1 ? '' : 's'}</p>
                </div>
                <span class="rounded-full border border-gray-200 bg-white px-2 py-1 text-xs text-earth-brown/80">
                  next item order: {section.maxItemOrder + 1}
                </span>
              </div>

              <div class="space-y-3">
                {section.items.map((item) => (
                  <details class="rounded-lg border border-gray-200 bg-white">
                    <summary class="cursor-pointer px-4 py-3">
                      <div class="flex flex-wrap items-start justify-between gap-2">
                        <div>
                          <p class="font-semibold text-earth-brown">{item.question}</p>
                          <p class="text-xs text-earth-brown/70">{item.sectionTitle}</p>
                        </div>
                        <div class="flex flex-wrap gap-2 text-xs">
                          <span class="rounded-full border border-gray-200 bg-gray-50 px-2 py-1 text-earth-brown">section {item.sectionOrder}</span>
                          <span class="rounded-full border border-gray-200 bg-gray-50 px-2 py-1 text-earth-brown">item {item.itemOrder}</span>
                          <span class="rounded-full border border-gray-200 bg-gray-50 px-2 py-1 text-earth-brown">{item.listStyle}</span>
                        </div>
                      </div>
                    </summary>

                    <div class="border-t border-gray-200 bg-white p-4">
                      <form method="post" action="/api/admin/content" class="space-y-4" data-faq-form>
                        <input type="hidden" name="collection" value="faq" />
                        <input type="hidden" name="slug" value={item.slug} />
                        <input type="hidden" name="redirectTo" value={`/admin/faq?saved=${encodeURIComponent(item.slug)}`} />
                        <input
                          type="hidden"
                          name="baseDataJson"
                          value={JSON.stringify({
                            question: item.question,
                            answer: item.answer,
                            section_title: item.sectionTitle,
                            section_order: item.sectionOrder,
                            item_order: item.itemOrder,
                            list_style: item.listStyle,
                            bullets: item.bullets,
                            note: item.note,
                            cta_label: item.ctaLabel,
                            cta_url: item.ctaUrl,
                            status: item.status,
                            title: item.title
                          })}
                        />

                        <div class="grid gap-3 md:grid-cols-2">
                          <label class="block text-sm font-medium md:col-span-2">
                            Question
                            <input
                              type="text"
                              name="data.question"
                              required
                              value={item.question}
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                            />
                          </label>

                          <label class="block text-sm font-medium">
                            Section Group
                            <select name="data.section_title" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" data-section-select>
                              {sectionOptionsFor(item.sectionTitle).map((sectionOption) => (
                                <option
                                  value={sectionOption.title}
                                  selected={sectionOption.title === item.sectionTitle}
                                  data-section-order={String(sectionOption.order)}
                                  data-next-item-order={String(sectionOption.nextItemOrder)}
                                >
                                  {sectionOption.order}. {sectionOption.title}
                                </option>
                              ))}
                              <option value="__new__" data-section-order="99" data-next-item-order="1">+ Create a new section</option>
                            </select>
                          </label>

                          <label class="block text-sm font-medium" data-new-section-fields hidden>
                            New Section Name
                            <input
                              type="text"
                              name="data.section_title_custom"
                              placeholder="Parent & Family Involvement"
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                              data-new-section-input
                            />
                          </label>

                          <label class="block text-sm font-medium">
                            Section Order
                            <input
                              type="number"
                              name="data.section_order"
                              min="1"
                              step="1"
                              value={String(numberFrom(item.sectionOrder, 99))}
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                              data-section-order-input
                            />
                          </label>

                          <label class="block text-sm font-medium">
                            Item Order in Section
                            <input
                              type="number"
                              name="data.item_order"
                              min="1"
                              step="1"
                              value={String(numberFrom(item.itemOrder, 999))}
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                              data-item-order-input
                            />
                          </label>

                          <label class="block text-sm font-medium">
                            List Style
                            <select name="data.list_style" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                              {listStyles.map((style) => (
                                <option value={style.value} selected={style.value === item.listStyle}>{style.label}</option>
                              ))}
                            </select>
                          </label>

                          <label class="block text-sm font-medium md:col-span-2">
                            Answer
                            <textarea
                              name="data.answer"
                              rows="4"
                              required
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                            >{item.answer}</textarea>
                          </label>

                          <label class="block text-sm font-medium md:col-span-2">
                            Bullet List (one line per bullet)
                            <textarea
                              name="data.bullets_lines"
                              rows="4"
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                            >{item.bullets.join('\n')}</textarea>
                          </label>

                          <label class="block text-sm font-medium md:col-span-2">
                            Follow-up Note (optional)
                            <textarea
                              name="data.note"
                              rows="3"
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                            >{item.note}</textarea>
                          </label>

                          <label class="block text-sm font-medium">
                            Button Label (optional)
                            <input
                              type="text"
                              name="data.cta_label"
                              value={item.ctaLabel}
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                            />
                          </label>

                          <label class="block text-sm font-medium">
                            Button URL (optional)
                            <input
                              type="text"
                              name="data.cta_url"
                              value={item.ctaUrl}
                              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                            />
                          </label>
                        </div>

                        <details class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                          <summary class="cursor-pointer text-sm font-semibold text-earth-brown">Advanced Options</summary>
                          <div class="mt-3 grid gap-3 md:grid-cols-2">
                            <label class="block text-sm font-medium">
                              URL Slug
                              <input
                                type="text"
                                value={item.slug}
                                readonly
                                class="mt-1 w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-earth-brown/80"
                              />
                            </label>

                            <label class="block text-sm font-medium">
                              Internal Title (optional)
                              <input
                                type="text"
                                name="title"
                                value={stringFrom(item.title, item.question)}
                                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                              />
                            </label>

                            <label class="block text-sm font-medium">
                              Publish Status
                              <select name="status" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                                <option value="published" selected={item.status !== 'draft'}>Published</option>
                                <option value="draft" selected={item.status === 'draft'}>Draft</option>
                              </select>
                            </label>
                          </div>
                        </details>

                        <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
                          Save FAQ Item
                        </button>
                      </form>
                    </div>
                  </details>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </div>
</AdminLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const initSectionControls = (form: Element | null) => {
      if (!(form instanceof HTMLFormElement)) return;

      const sectionSelect = form.querySelector('[data-section-select]');
      if (!(sectionSelect instanceof HTMLSelectElement)) return;

      const newSectionFields = form.querySelector('[data-new-section-fields]');
      const newSectionInput = form.querySelector('[data-new-section-input]');
      const sectionOrderInput = form.querySelector('[data-section-order-input]');
      const itemOrderInput = form.querySelector('[data-item-order-input]');
      const isNewForm = form.hasAttribute('data-new-faq-form');
      let hasChangedSelection = false;

      const syncSectionState = () => {
        const selectedOption = sectionSelect.selectedOptions[0];
        const isNewSection = sectionSelect.value === '__new__';

        if (newSectionFields instanceof HTMLElement) {
          newSectionFields.hidden = !isNewSection;
        }

        if (newSectionInput instanceof HTMLInputElement) {
          newSectionInput.required = isNewSection;
          if (!isNewSection) {
            newSectionInput.value = '';
          }
        }

        if (
          (isNewForm || hasChangedSelection)
          && sectionOrderInput instanceof HTMLInputElement
          && sectionOrderInput.dataset.manual !== 'true'
        ) {
          const orderValue = selectedOption?.dataset.sectionOrder;
          if (orderValue) {
            sectionOrderInput.value = orderValue;
          }
        }

        if (
          (isNewForm || hasChangedSelection)
          && itemOrderInput instanceof HTMLInputElement
          && itemOrderInput.dataset.manual !== 'true'
        ) {
          const itemOrderValue = selectedOption?.dataset.nextItemOrder;
          if (itemOrderValue) {
            itemOrderInput.value = itemOrderValue;
          }
        }

        if (isNewSection && (isNewForm || hasChangedSelection)) {
          if (sectionOrderInput instanceof HTMLInputElement && sectionOrderInput.dataset.manual !== 'true' && !sectionOrderInput.value) {
            sectionOrderInput.value = '99';
          }

          if (itemOrderInput instanceof HTMLInputElement && itemOrderInput.dataset.manual !== 'true') {
            itemOrderInput.value = '1';
          }
        }
      };

      if (sectionOrderInput instanceof HTMLInputElement) {
        sectionOrderInput.addEventListener('input', () => {
          sectionOrderInput.dataset.manual = 'true';
        });
      }

      if (itemOrderInput instanceof HTMLInputElement) {
        itemOrderInput.addEventListener('input', () => {
          itemOrderInput.dataset.manual = 'true';
        });
      }

      sectionSelect.addEventListener('change', () => {
        hasChangedSelection = true;
        syncSectionState();
      });
      syncSectionState();
    };

    document.querySelectorAll('[data-faq-form]').forEach((form) => {
      initSectionControls(form);
    });

    const addForm = document.querySelector('[data-new-faq-form]');
    if (!(addForm instanceof HTMLFormElement)) return;

    const questionInput = addForm.querySelector('input[name="data.question"]');
    const slugInput = addForm.querySelector('input[name="slug"]');

    if (!(questionInput instanceof HTMLInputElement) || !(slugInput instanceof HTMLInputElement)) {
      return;
    }

    const slugify = (value: string): string =>
      String(value || '')
        .trim()
        .toLowerCase()
        .replace(/&/g, 'and')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '')
        .replace(/-{2,}/g, '-');

    questionInput.addEventListener('input', () => {
      if (slugInput.dataset.manual === 'true') return;

      const normalized = slugify(questionInput.value);
      if (normalized.length > 0) {
        slugInput.value = `faq-${normalized}`.slice(0, 80);
      }
    });

    slugInput.addEventListener('input', () => {
      slugInput.dataset.manual = 'true';
    });
  });
</script>
