---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db, type ContentEntry } from '@lib/db';
import { getCollection } from 'astro:content';
import { buildPhotoSlugResolver, toPhotoLookupEntry } from '@lib/photo-slug-resolver';

type StaffEntry = ContentEntry<Record<string, unknown>>;
type PhotoEntry = ContentEntry<Record<string, unknown>>;

const collection = 'staff';
const entries = (await db.content.getCollection(collection)) as StaffEntry[];
const dbPhotoEntries = (await db.content.getCollection('photos', 0)) as PhotoEntry[];
const filePhotoEntries = await getCollection('photos');
const sortedEntries = [...entries].sort((a, b) => {
  const aOrder = Number((a.data as Record<string, unknown>).order ?? 999);
  const bOrder = Number((b.data as Record<string, unknown>).order ?? 999);
  if (aOrder !== bOrder) return aOrder - bOrder;
  return a.slug.localeCompare(b.slug);
});

const savedSlug = Astro.url.searchParams.get('saved');
const errorMessage = Astro.url.searchParams.get('error');

const asRecord = (value: unknown): Record<string, unknown> => {
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    return value as Record<string, unknown>;
  }
  return {};
};

const photoLookupBySlug = new Map<string, ReturnType<typeof toPhotoLookupEntry>>();

for (const entry of filePhotoEntries) {
  photoLookupBySlug.set(entry.slug, toPhotoLookupEntry(entry.slug, asRecord(entry.data)));
}

for (const entry of dbPhotoEntries) {
  photoLookupBySlug.set(entry.slug, toPhotoLookupEntry(entry.slug, asRecord(entry.data)));
}

const resolvePhotoSlug = buildPhotoSlugResolver([...photoLookupBySlug.values()]);

const stringFrom = (value: unknown, fallback = ''): string => {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.length > 0) return trimmed;
  }
  return fallback;
};

const numberFrom = (value: unknown, fallback: number): number => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value === 'string') {
    const parsed = Number.parseFloat(value.trim());
    if (Number.isFinite(parsed)) return parsed;
  }
  return fallback;
};

const numberInputValue = (value: unknown): string => {
  if (typeof value === 'number' && Number.isFinite(value)) return String(value);
  if (typeof value === 'string' && value.trim().length > 0) return value.trim();
  return '';
};

const csvFrom = (value: unknown, fallback = ''): string => {
  if (Array.isArray(value)) {
    return value
      .map((item) => (typeof item === 'string' ? item.trim() : ''))
      .filter((item) => item.length > 0)
      .join(', ');
  }
  return fallback;
};

const editableEntries = sortedEntries.map((entry) => {
  const data = asRecord(entry.data);
  const photo = stringFrom(data.photo, '');
  return {
    entry,
    data,
    status: stringFrom(data.status, 'published'),
    title: stringFrom(data.title, entry.slug),
    name: stringFrom(data.name, stringFrom(data.title, entry.slug)),
    role: stringFrom(data.role, ''),
    email: stringFrom(data.email, ''),
    photo,
    photoEditorSlug: resolvePhotoSlug(photo),
    badge: stringFrom(data.certificationBadge, ''),
    credentials: csvFrom(data.credentials, ''),
    languages: csvFrom(data.languages, 'English'),
    startYear: numberInputValue(data.startYear),
    order: numberFrom(data.order, 99),
    bio: stringFrom(data.body, '')
  };
});
---

<AdminLayout title="Manage Staff">
  {savedSlug && (
    <p class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
      Saved entry: <strong>{savedSlug}</strong>
    </p>
  )}

  {errorMessage && (
    <p class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
      {errorMessage}
    </p>
  )}

  <div class="space-y-6">
    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Staff Manager</h2>
      <p class="mb-4 text-sm text-earth-brown/80">
        Keep this simple: update the essentials first, then use Advanced Options for ordering, badges, and profile details.
      </p>
      <div class="grid gap-3 md:grid-cols-3">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Staff Profiles</p>
          <p class="text-2xl font-semibold text-earth-brown">{editableEntries.length}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Quick Tip</p>
          <p class="text-sm text-earth-brown/80">Display order controls who appears first.</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Photo Tip</p>
          <p class="text-sm text-earth-brown/80">Upload directly in each profile, then refine with crop and focal controls.</p>
        </div>
      </div>
    </section>

    <section class="space-y-4">
      <details class="rounded-xl border border-gray-200 bg-white shadow-sm">
        <summary class="cursor-pointer px-5 py-4 text-base font-semibold text-earth-brown">Add Staff Member</summary>
        <div class="space-y-4 border-t border-gray-200 p-5">
          <p class="text-sm text-earth-brown/80">Start with name, role, and contact info. Open Advanced Options for everything else.</p>
          <form method="post" action="/api/admin/content" class="space-y-4">
            <input type="hidden" name="collection" value={collection} />
            <input type="hidden" name="redirectTo" value="/admin/staff?saved=new" />

            <div class="grid gap-3 md:grid-cols-2">
              <label class="block text-sm font-medium">
                Full Name
                <input
                  type="text"
                  name="data.name"
                  placeholder="Jane Doe"
                  required
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <label class="block text-sm font-medium">
                Role / Title
                <input
                  type="text"
                  name="data.role"
                  placeholder="Lead Teacher"
                  required
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <label class="block text-sm font-medium">
                Email (optional)
                <input
                  type="email"
                  name="data.email"
                  placeholder="jane@spicebushmontessori.org"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <label class="block text-sm font-medium">
                Photo URL (optional)
                <input
                  type="text"
                  name="data.photo"
                  placeholder="/images/teachers/jane-doe.jpg"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
            </div>
            <p class="text-xs text-earth-brown/70">
              Save first, then open that teacher from &quot;Existing Staff&quot; to launch the crop and focal editor for their image.
            </p>

            <details class="rounded-lg border border-gray-200 bg-gray-50 p-3">
              <summary class="cursor-pointer text-sm font-semibold text-earth-brown">Advanced Options</summary>
              <div class="mt-3 grid gap-3 md:grid-cols-2">
                <label class="block text-sm font-medium">
                  URL Slug
                  <input
                    type="text"
                    name="slug"
                    placeholder="jane-doe"
                    required
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Internal Title (optional)
                  <input
                    type="text"
                    name="title"
                    placeholder="Jane Doe"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Publish Status
                  <select name="status" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                    <option value="published">Published</option>
                    <option value="draft">Draft</option>
                  </select>
                </label>
                <label class="block text-sm font-medium">
                  Display Order
                  <input
                    type="number"
                    name="data.order"
                    min="1"
                    step="1"
                    value="99"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Certification Badge (optional)
                  <input
                    type="text"
                    name="data.certificationBadge"
                    placeholder="AMI"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Start Year (optional)
                  <input
                    type="number"
                    name="data.startYear"
                    min="1900"
                    max="2100"
                    step="1"
                    placeholder="2024"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium md:col-span-2">
                  Credentials (comma-separated)
                  <input
                    type="text"
                    name="data.credentials_csv"
                    placeholder="AMI, M.Ed., CPR"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium md:col-span-2">
                  Languages (comma-separated)
                  <input
                    type="text"
                    name="data.languages_csv"
                    placeholder="English, Spanish"
                    value="English"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium md:col-span-2">
                  Bio (optional)
                  <textarea
                    name="data.body"
                    rows="4"
                    placeholder="Short bio shown on staff sections."
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  ></textarea>
                </label>
              </div>
            </details>

            <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
              Add Staff Member
            </button>
          </form>
        </div>
      </details>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Existing Staff</h2>
      <p class="mb-4 text-sm text-earth-brown/80">Open any card to edit. Save to apply changes.</p>

      {editableEntries.length === 0 ? (
        <p class="rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-earth-brown/80">No staff entries found yet.</p>
      ) : (
        <div class="space-y-3">
          {editableEntries.map(({ entry, data, status, title, name, role, email, photo, photoEditorSlug, badge, credentials, languages, startYear, order, bio }) => (
            <details class="rounded-lg border border-gray-200 bg-gray-50">
              <summary class="cursor-pointer px-4 py-3">
                <div class="flex flex-wrap items-start justify-between gap-2">
                  <div>
                    <p class="font-semibold text-earth-brown">{name}</p>
                    <p class="text-xs text-earth-brown/70">{role || 'Role not set'}{email ? ` | ${email}` : ''}</p>
                  </div>
                  <div class="flex flex-wrap gap-2 text-xs">
                    <span class="rounded-full border border-gray-200 bg-white px-2 py-1 text-earth-brown">order: {order}</span>
                    <span class="rounded-full border border-gray-200 bg-white px-2 py-1 text-earth-brown">{status === 'draft' ? 'draft' : 'published'}</span>
                  </div>
                </div>
              </summary>

              <div class="border-t border-gray-200 bg-white p-4">
                <form method="post" action="/api/admin/content" class="space-y-4">
                  <input type="hidden" name="collection" value={collection} />
                  <input type="hidden" name="redirectTo" value={`/admin/staff?saved=${encodeURIComponent(entry.slug)}`} />
                  <input type="hidden" name="baseDataJson" value={JSON.stringify(data ?? {})} />

                  <div class="grid gap-3 md:grid-cols-2">
                    <label class="block text-sm font-medium">
                      Full Name
                      <input
                        type="text"
                        name="data.name"
                        value={name}
                        required
                        class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                      />
                    </label>
                    <label class="block text-sm font-medium">
                      Role / Title
                      <input
                        type="text"
                        name="data.role"
                        value={role}
                        required
                        class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                      />
                    </label>
                    <label class="block text-sm font-medium">
                      Email (optional)
                      <input
                        type="email"
                        name="data.email"
                        value={email}
                        class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                      />
                    </label>
                    <label class="block text-sm font-medium">
                      Photo URL (optional)
                      <input
                        type="text"
                        name="data.photo"
                        data-photo-url-input
                        value={photo}
                        class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                      />
                    </label>
                    <div
                      class="rounded-lg border border-gray-200 bg-gray-50 p-3 md:col-span-2"
                      data-staff-upload
                      data-entry-slug={entry.slug}
                    >
                      <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-earth-brown/70">Upload Teacher Photo</p>
                      <div class="flex flex-wrap items-center gap-2">
                        <input
                          type="file"
                          accept="image/*"
                          data-upload-file
                          class="max-w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-xs"
                        />
                        <button
                          type="button"
                          data-upload-button
                          class="rounded-lg bg-forest-canopy px-3 py-2 text-xs font-semibold text-white hover:bg-moss-green"
                        >
                          Upload and Attach
                        </button>
                        <a
                          href="/admin/media"
                          data-upload-crop-link
                          class="hidden rounded-lg border border-forest-canopy bg-white px-3 py-2 text-xs font-semibold text-forest-canopy hover:bg-forest-canopy hover:text-white"
                        >
                          Open Crop &amp; Focal Editor
                        </a>
                      </div>
                      <p data-upload-status class="mt-2 hidden rounded-md border px-2 py-1 text-xs"></p>
                    </div>
                    <div class="flex flex-wrap items-end gap-2 md:col-span-2">
                      {photoEditorSlug ? (
                        <a
                          href={`/admin/media?slug=${encodeURIComponent(photoEditorSlug)}`}
                          class="rounded-lg border border-forest-canopy bg-white px-3 py-2 text-xs font-semibold text-forest-canopy hover:bg-forest-canopy hover:text-white"
                        >
                          Edit Crop &amp; Focal Point
                        </a>
                      ) : (
                        <p class="text-xs text-earth-brown/70">
                          No linked media entry found yet. Save a valid photo URL, then this button will appear.
                        </p>
                      )}
                      <a
                        href="/admin/media"
                        class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-xs font-semibold text-earth-brown hover:bg-gray-50"
                      >
                        Open Media Manager
                      </a>
                    </div>
                  </div>

                  <details class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                    <summary class="cursor-pointer text-sm font-semibold text-earth-brown">Advanced Options</summary>
                    <div class="mt-3 grid gap-3 md:grid-cols-2">
                      <label class="block text-sm font-medium">
                        URL Slug
                        <input
                          type="text"
                          name="slug"
                          value={entry.slug}
                          required
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Internal Title (optional)
                        <input
                          type="text"
                          name="title"
                          value={title}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Publish Status
                        <select name="status" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                          <option value="published" selected={status !== 'draft'}>Published</option>
                          <option value="draft" selected={status === 'draft'}>Draft</option>
                        </select>
                      </label>
                      <label class="block text-sm font-medium">
                        Display Order
                        <input
                          type="number"
                          name="data.order"
                          min="1"
                          step="1"
                          value={String(order)}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Certification Badge (optional)
                        <input
                          type="text"
                          name="data.certificationBadge"
                          value={badge}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Start Year (optional)
                        <input
                          type="number"
                          name="data.startYear"
                          min="1900"
                          max="2100"
                          step="1"
                          value={startYear}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium md:col-span-2">
                        Credentials (comma-separated)
                        <input
                          type="text"
                          name="data.credentials_csv"
                          value={credentials}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium md:col-span-2">
                        Languages (comma-separated)
                        <input
                          type="text"
                          name="data.languages_csv"
                          value={languages}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium md:col-span-2">
                        Bio (optional)
                        <textarea
                          name="data.body"
                          rows="4"
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        >{bio}</textarea>
                      </label>
                    </div>
                  </details>

                  <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
                    Save Staff Member
                  </button>
                </form>
              </div>
            </details>
          ))}
        </div>
      )}
    </section>
  </div>

  <script is:inline>
    (() => {
      const uploadCards = Array.from(document.querySelectorAll('[data-staff-upload]'));
      if (!uploadCards.length) return;

      const slugify = (value) => String(value || '')
        .toLowerCase()
        .replace(/[^a-z0-9-_]+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 80);

      const setStatus = (node, message, isError = false) => {
        if (!node) return;
        node.textContent = message;
        node.classList.remove(
          'hidden',
          'border-red-200',
          'bg-red-50',
          'text-red-800',
          'border-green-200',
          'bg-green-50',
          'text-green-800'
        );

        if (isError) {
          node.classList.add('border-red-200', 'bg-red-50', 'text-red-800');
        } else {
          node.classList.add('border-green-200', 'bg-green-50', 'text-green-800');
        }
      };

      uploadCards.forEach((card) => {
        const form = card.closest('form');
        if (!form) return;

        const fileInput = card.querySelector('[data-upload-file]');
        const uploadButton = card.querySelector('[data-upload-button]');
        const statusNode = card.querySelector('[data-upload-status]');
        const cropLink = card.querySelector('[data-upload-crop-link]');

        const nameInput = form.querySelector('input[name="data.name"]');
        const slugInput = form.querySelector('input[name="slug"]');
        const photoInput = form.querySelector('[data-photo-url-input]');
        const entrySlug = card.getAttribute('data-entry-slug') || '';

        if (!fileInput || !uploadButton || !statusNode || !photoInput) {
          return;
        }

        uploadButton.addEventListener('click', async () => {
          const selectedFile = fileInput.files && fileInput.files[0];
          if (!selectedFile) {
            setStatus(statusNode, 'Please select an image file first.', true);
            return;
          }

          const nameValue = (nameInput && typeof nameInput.value === 'string')
            ? nameInput.value.trim()
            : '';
          const slugValue = (slugInput && typeof slugInput.value === 'string')
            ? slugInput.value.trim()
            : entrySlug;

          const teacherName = nameValue || slugValue || 'Teacher';
          const requestedSlug = slugify(`teachers-${slugValue || teacherName}`);

          const requestData = new FormData();
          requestData.append('file', selectedFile);
          requestData.append('createPhotoEntry', 'true');
          requestData.append('category', 'teachers');
          requestData.append('title', `${teacherName} Photo`);
          if (requestedSlug) {
            requestData.append('slug', requestedSlug);
          }

          uploadButton.setAttribute('disabled', 'disabled');
          uploadButton.classList.add('opacity-60', 'cursor-not-allowed');
          setStatus(statusNode, 'Uploading and attaching photo...');

          try {
            const response = await fetch('/api/media/upload', {
              method: 'POST',
              body: requestData
            });

            const payload = await response.json().catch(() => ({}));
            if (!response.ok || payload.success !== true) {
              const message = typeof payload.error === 'string' ? payload.error : 'Upload failed';
              setStatus(statusNode, message, true);
              return;
            }

            const uploadedUrl = typeof payload.url === 'string' ? payload.url : '';
            const photoSlug = typeof payload.photoSlug === 'string' ? payload.photoSlug : '';

            if (uploadedUrl) {
              photoInput.value = uploadedUrl;
            }

            if (cropLink && photoSlug) {
              cropLink.href = `/admin/media?slug=${encodeURIComponent(photoSlug)}`;
              cropLink.classList.remove('hidden');
            }

            setStatus(statusNode, 'Photo uploaded and attached. Save staff profile to keep this URL.');
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unexpected upload error';
            setStatus(statusNode, message, true);
          } finally {
            uploadButton.removeAttribute('disabled');
            uploadButton.classList.remove('opacity-60', 'cursor-not-allowed');
          }
        });
      });
    })();
  </script>
</AdminLayout>
