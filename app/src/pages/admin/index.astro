---
import AdminLayout from '@layouts/AdminLayout.astro';
---

<AdminLayout title="Admin Dashboard">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <a
      href="/admin/hours"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Hours</h2>
      <p class="text-sm text-earth-brown/80">
        Edit school hours displayed in widgets and public pages.
      </p>
    </a>

    <a
      href="/admin/staff"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Staff</h2>
      <p class="text-sm text-earth-brown/80">
        Manage teacher and staff bios shown across the site.
      </p>
    </a>

    <a
      href="/admin/tuition"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Tuition</h2>
      <p class="text-sm text-earth-brown/80">
        Update tuition programs and rate tiers for the calculator.
      </p>
    </a>

    <a
      href="/admin/testimonials"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Testimonials</h2>
      <p class="text-sm text-earth-brown/80">
        Control quotes, ratings, and page visibility rules for social proof sections.
      </p>
    </a>

    <a
      href="/admin/contact-submissions"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Contact Submissions</h2>
      <p class="text-sm text-earth-brown/80">
        Review inquiries sent from the website contact form.
      </p>
    </a>

    <a
      href="/admin/announcements"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Announcements</h2>
      <p class="text-sm text-earth-brown/80">
        Publish updates, reminders, and school closure notices for families.
      </p>
    </a>

    <a
      href="/admin/donations"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Donations</h2>
      <p class="text-sm text-earth-brown/80">
        Manage donor thank-you templates, schedule reminders, and monitor delivery status.
      </p>
    </a>

    <a
      href="/admin/seo"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">SEO & Analytics</h2>
      <p class="text-sm text-earth-brown/80">
        Monitor traffic, campaign attribution, and conversion performance.
      </p>
    </a>

    <a
      href="/admin/settings"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Settings</h2>
      <p class="text-sm text-earth-brown/80">
        Control coming-soon mode and site-level configuration values.
      </p>
    </a>

    <a
      href="/admin/media"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">Media</h2>
      <p class="text-sm text-earth-brown/80">
        Adjust image focal points and crop zones for better responsive placement.
      </p>
    </a>

    <a
      href="/admin/faq"
      class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow"
    >
      <h2 class="text-xl font-semibold mb-2">FAQs</h2>
      <p class="text-sm text-earth-brown/80">
        Manage question-and-answer sections shown on the FAQ page.
      </p>
    </a>
  </div>
</AdminLayout>
