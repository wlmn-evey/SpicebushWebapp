---
/**
 * Admin Dashboard
 * 
 * Main dashboard providing an overview of content, quick actions,
 * and system status for admin users.
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '../../lib/admin-auth-check';
import { getCollection, getAllSettings } from '../../lib/content-db';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect('/auth/login?redirect=' + Astro.url.pathname);
}

// Load dashboard data
const [
  blogPosts,
  staffMembers,
  photos,
  settings
] = await Promise.all([
  getCollection('blog'),
  getCollection('staff'),
  getCollection('photos'),
  getAllSettings()
]);

// Calculate stats
const stats = {
  blog: {
    total: blogPosts.length,
    published: blogPosts.filter(post => post.data.status === 'published').length,
    drafts: blogPosts.filter(post => post.data.status === 'draft').length
  },
  staff: {
    total: staffMembers.length,
    active: staffMembers.filter(member => member.data.active !== false).length
  },
  photos: {
    total: photos.length,
    featured: photos.filter(photo => photo.data.featured).length
  }
};

// Recent blog posts
const recentPosts = blogPosts
  .sort((a, b) => new Date(b.data.updated_at || b.data.created_at).getTime() - new Date(a.data.updated_at || a.data.created_at).getTime())
  .slice(0, 5);

// Quick actions
const quickActions = [
  {
    title: 'New Blog Post',
    description: 'Create a new blog post',
    href: '/admin/blog/edit',
    icon: 'document-add',
    color: 'blue'
  },
  {
    title: 'Add Staff Member',
    description: 'Add a new staff profile',
    href: '/admin/staff/edit',
    icon: 'user-add',
    color: 'green'
  },
  {
    title: 'Upload Photos',
    description: 'Add photos to gallery',
    href: '/admin/photos/upload',
    icon: 'photograph',
    color: 'purple'
  },
  {
    title: 'Update Hours',
    description: 'Modify school hours',
    href: '/admin/hours',
    icon: 'clock',
    color: 'orange'
  }
];

// System status
const systemStatus = {
  comingSoonMode: settings.coming_soon_enabled === 'true',
  storageProvider: settings.storage_provider || 'local',
  lastBackup: settings.last_backup_date || null
};

// Format date helper
function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}

// Format relative time
function formatRelativeTime(dateString: string): string {
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  
  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays} days ago`;
  if (diffDays < 30) return `${Math.floor(diffDays / 7)} weeks ago`;
  return formatDate(dateString);
}
---

<AdminLayout title="Dashboard" description="Overview of your site and content">
  <div class="dashboard">
    <!-- System Status Alert -->
    {systemStatus.comingSoonMode && (
      <div class="status-alert status-alert--warning">
        <svg class="status-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 15.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <div>
          <h3>Coming Soon Mode Active</h3>
          <p>Your site is in coming soon mode. Visitors will see a placeholder page.</p>
          <a href="/admin/settings" class="alert-action">Update Settings</a>
        </div>
      </div>
    )}
    
    <!-- Stats Overview -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-header">
          <h3>Blog Posts</h3>
          <svg class="stat-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="stat-numbers">
          <span class="stat-primary">{stats.blog.total}</span>
          <span class="stat-secondary">total</span>
        </div>
        <div class="stat-breakdown">
          <span class="stat-item">
            <span class="stat-badge stat-badge--green">{stats.blog.published}</span>
            published
          </span>
          <span class="stat-item">
            <span class="stat-badge stat-badge--yellow">{stats.blog.drafts}</span>
            drafts
          </span>
        </div>
        <a href="/admin/blog" class="stat-link">Manage Posts →</a>
      </div>
      
      <div class="stat-card">
        <div class="stat-header">
          <h3>Staff</h3>
          <svg class="stat-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </div>
        <div class="stat-numbers">
          <span class="stat-primary">{stats.staff.total}</span>
          <span class="stat-secondary">total</span>
        </div>
        <div class="stat-breakdown">
          <span class="stat-item">
            <span class="stat-badge stat-badge--green">{stats.staff.active}</span>
            active
          </span>
        </div>
        <a href="/admin/staff" class="stat-link">Manage Staff →</a>
      </div>
      
      <div class="stat-card">
        <div class="stat-header">
          <h3>Photos</h3>
          <svg class="stat-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="stat-numbers">
          <span class="stat-primary">{stats.photos.total}</span>
          <span class="stat-secondary">total</span>
        </div>
        <div class="stat-breakdown">
          <span class="stat-item">
            <span class="stat-badge stat-badge--purple">{stats.photos.featured}</span>
            featured
          </span>
        </div>
        <a href="/admin/photos" class="stat-link">Manage Photos →</a>
      </div>
      
      <div class="stat-card">
        <div class="stat-header">
          <h3>Storage</h3>
          <svg class="stat-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
          </svg>
        </div>
        <div class="stat-numbers">
          <span class="stat-primary">{systemStatus.storageProvider}</span>
          <span class="stat-secondary">provider</span>
        </div>
        <div class="stat-breakdown">
          {systemStatus.lastBackup && (
            <span class="stat-item">
              <span class="stat-badge stat-badge--blue">
                {formatRelativeTime(systemStatus.lastBackup)}
              </span>
              last backup
            </span>
          )}
        </div>
        <a href="/admin/settings" class="stat-link">Manage Settings →</a>
      </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="section">
      <h2 class="section-title">Quick Actions</h2>
      <div class="actions-grid">
        {quickActions.map(action => (
          <a href={action.href} class={`action-card action-card--${action.color}`}>
            <div class="action-icon">
              {action.icon === 'document-add' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              )}
              {action.icon === 'user-add' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                </svg>
              )}
              {action.icon === 'photograph' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              )}
              {action.icon === 'clock' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
            </div>
            <div class="action-content">
              <h3>{action.title}</h3>
              <p>{action.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
    
    <!-- Recent Activity -->
    <div class="section">
      <div class="section-header">
        <h2 class="section-title">Recent Blog Posts</h2>
        <a href="/admin/blog" class="section-action">View All</a>
      </div>
      
      {recentPosts.length > 0 ? (
        <div class="activity-list">
          {recentPosts.map(post => (
            <div class="activity-item">
              <div class="activity-content">
                <h4 class="activity-title">
                  <a href={`/admin/blog/edit?slug=${post.slug}`}>
                    {post.data.title}
                  </a>
                </h4>
                <p class="activity-meta">
                  {post.data.author} • 
                  <span class={`status-badge status-badge--${post.data.status}`}>
                    {post.data.status === 'published' ? 'Published' : 'Draft'}
                  </span> • 
                  {formatRelativeTime(post.data.updated_at || post.data.created_at)}
                </p>
                {post.data.excerpt && (
                  <p class="activity-excerpt">
                    {post.data.excerpt.length > 120 
                      ? post.data.excerpt.substring(0, 120) + '...' 
                      : post.data.excerpt
                    }
                  </p>
                )}
              </div>
              <div class="activity-actions">
                <a href={`/admin/blog/edit?slug=${post.slug}`} class="activity-action">
                  Edit
                </a>
                {post.data.status === 'published' && (
                  <a href={`/blog/${post.slug}`} target="_blank" class="activity-action">
                    View
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <svg class="empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3>No Blog Posts Yet</h3>
          <p>Start sharing your stories with the community.</p>
          <a href="/admin/blog/edit" class="btn btn--primary">Create First Post</a>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<style>
  .dashboard {
    @apply space-y-8;
  }
  
  /* Status Alert */
  .status-alert {
    @apply flex items-start space-x-3 p-4 rounded-lg border;
  }
  
  .status-alert--warning {
    @apply bg-yellow-50 border-yellow-200 text-yellow-800;
  }
  
  .status-icon {
    @apply w-6 h-6 flex-shrink-0;
  }
  
  .status-alert h3 {
    @apply font-semibold mb-1;
  }
  
  .status-alert p {
    @apply text-sm mb-2;
  }
  
  .alert-action {
    @apply text-sm font-medium underline hover:no-underline;
  }
  
  /* Stats Grid */
  .stats-grid {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6;
  }
  
  .stat-card {
    @apply bg-white rounded-lg shadow p-6;
  }
  
  .stat-header {
    @apply flex items-center justify-between mb-4;
  }
  
  .stat-header h3 {
    @apply text-sm font-medium text-gray-500 uppercase tracking-wide;
  }
  
  .stat-icon {
    @apply w-6 h-6 text-gray-400;
  }
  
  .stat-numbers {
    @apply mb-4;
  }
  
  .stat-primary {
    @apply text-3xl font-bold text-gray-900 mr-2;
  }
  
  .stat-secondary {
    @apply text-sm text-gray-500;
  }
  
  .stat-breakdown {
    @apply flex flex-wrap gap-3 mb-4;
  }
  
  .stat-item {
    @apply flex items-center space-x-1 text-sm;
  }
  
  .stat-badge {
    @apply inline-block px-2 py-1 text-xs font-medium rounded;
  }
  
  .stat-badge--green {
    @apply bg-green-100 text-green-800;
  }
  
  .stat-badge--yellow {
    @apply bg-yellow-100 text-yellow-800;
  }
  
  .stat-badge--purple {
    @apply bg-purple-100 text-purple-800;
  }
  
  .stat-badge--blue {
    @apply bg-blue-100 text-blue-800;
  }
  
  .stat-link {
    @apply text-sm font-medium text-blue-600 hover:text-blue-700;
  }
  
  /* Section Layout */
  .section {
    @apply bg-white rounded-lg shadow;
  }
  
  .section-header {
    @apply flex items-center justify-between p-6 border-b border-gray-200;
  }
  
  .section-title {
    @apply text-lg font-semibold text-gray-900;
  }
  
  .section-action {
    @apply text-sm font-medium text-blue-600 hover:text-blue-700;
  }
  
  /* Quick Actions */
  .actions-grid {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 p-6;
  }
  
  .action-card {
    @apply flex items-center space-x-4 p-4 rounded-lg border-2 border-transparent;
    @apply hover:border-current transition-colors duration-200;
  }
  
  .action-card--blue {
    @apply text-blue-600 hover:bg-blue-50;
  }
  
  .action-card--green {
    @apply text-green-600 hover:bg-green-50;
  }
  
  .action-card--purple {
    @apply text-purple-600 hover:bg-purple-50;
  }
  
  .action-card--orange {
    @apply text-orange-600 hover:bg-orange-50;
  }
  
  .action-icon {
    @apply w-8 h-8 flex-shrink-0;
  }
  
  .action-content h3 {
    @apply font-semibold text-gray-900;
  }
  
  .action-content p {
    @apply text-sm text-gray-600;
  }
  
  /* Activity List */
  .activity-list {
    @apply divide-y divide-gray-200;
  }
  
  .activity-item {
    @apply flex items-start justify-between p-6;
  }
  
  .activity-content {
    @apply flex-1 min-w-0;
  }
  
  .activity-title {
    @apply font-medium mb-1;
  }
  
  .activity-title a {
    @apply text-gray-900 hover:text-blue-600;
  }
  
  .activity-meta {
    @apply text-sm text-gray-500 mb-2;
  }
  
  .activity-excerpt {
    @apply text-sm text-gray-600;
  }
  
  .activity-actions {
    @apply flex space-x-2 ml-4;
  }
  
  .activity-action {
    @apply text-sm font-medium text-blue-600 hover:text-blue-700;
  }
  
  /* Empty State */
  .empty-state {
    @apply text-center py-12 px-6;
  }
  
  .empty-icon {
    @apply w-12 h-12 mx-auto text-gray-400 mb-4;
  }
  
  .empty-state h3 {
    @apply text-lg font-medium text-gray-900 mb-2;
  }
  
  .empty-state p {
    @apply text-gray-500 mb-4;
  }
  
  .btn {
    @apply inline-flex items-center px-4 py-2 border rounded-md font-medium;
    @apply focus:outline-none focus:ring-2 focus:ring-offset-2;
    @apply transition-colors duration-150;
  }
  
  .btn--primary {
    @apply border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500;
  }
</style>