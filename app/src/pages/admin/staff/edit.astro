---
/**
 * Staff Editor
 * 
 * Handles both creating new staff members and editing existing ones.
 * Provides form for managing all staff profile information.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import FormField from '../../../components/forms/FormField.astro';
import TextInput from '../../../components/forms/TextInput.astro';
import TextArea from '../../../components/forms/TextArea.astro';
import SelectField from '../../../components/forms/SelectField.astro';
import ImageUpload from '../../../components/forms/ImageUpload.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';
import { getEntry } from '@lib/content-db';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect(`/auth/login?redirect=${  Astro.url.pathname}`);
}

// Get slug from URL
const slug = Astro.url.searchParams.get('slug');
const isEdit = !!slug;

// Load existing staff member if editing
let staffMember = null;
let errors = {};

if (isEdit) {
  staffMember = await getEntry('staff', slug);
  if (!staffMember) {
    return Astro.redirect('/admin/staff?error=Staff member not found');
  }
}

// Handle form submission
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    // Extract form data
    const data = {
      name: formData.get('name')?.toString().trim() || '',
      slug: formData.get('slug')?.toString().trim() || '',
      role: formData.get('role')?.toString().trim() || '',
      email: formData.get('email')?.toString().trim() || '',
      photo: formData.get('photo')?.toString() || '',
      bio: formData.get('bio')?.toString() || '',
      credentials: formData.get('credentials')?.toString().split(',').map(cred => cred.trim()).filter(Boolean) || [],
      languages: formData.get('languages')?.toString().split(',').map(lang => lang.trim()).filter(Boolean) || ['English'],
      startYear: parseInt(formData.get('startYear')?.toString()) || new Date().getFullYear(),
      order: parseInt(formData.get('order')?.toString()) || 99,
      active: formData.get('active') === 'on'
    };
    
    // Validation
    if (!data.name) errors.name = 'Name is required';
    if (!data.slug) errors.slug = 'Slug is required';
    if (!data.role) errors.role = 'Role is required';
    if (data.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) {
      errors.email = 'Please enter a valid email address';
    }
    if (data.startYear < 1900 || data.startYear > new Date().getFullYear() + 1) {
      errors.startYear = 'Please enter a valid start year';
    }
    
    // Generate slug from name if not provided
    if (data.name && !data.slug) {
      data.slug = data.name
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '');
    }
    
    if (Object.keys(errors).length === 0) {
      // Prepare data for database
      const contentData = {
        type: 'staff',
        slug: data.slug,
        title: data.name,
        data: {
          name: data.name,
          role: data.role,
          email: data.email || undefined,
          photo: data.photo || '/images/teachers/placeholder.jpg',
          credentials: data.credentials,
          languages: data.languages,
          startYear: data.startYear,
          order: data.order,
          active: data.active,
          body: data.bio
        },
        status: 'published',
        author_email: 'admin@spicebushmontessori.org' // TODO: Get from session
      };
      
      // Save to database via API
      const apiEndpoint = '/api/cms/entry';
      const response = await fetch(apiEndpoint, {
        method: isEdit ? 'PUT' : 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(contentData)
      });
      
      if (response.ok) {
        const action = isEdit ? 'updated' : 'created';
        return Astro.redirect(`/admin/staff?success=Staff member ${action} successfully`);
      } else {
        errors.general = 'Failed to save staff member. Please try again.';
      }
    }
  } catch (error) {
    console.error('Form submission error:', error);
    errors.general = 'An unexpected error occurred. Please try again.';
  }
}

// Default values
const defaultData = staffMember ? {
  name: staffMember.data.name || '',
  slug: staffMember.slug || '',
  role: staffMember.data.role || '',
  email: staffMember.data.email || '',
  photo: staffMember.data.photo || '',
  bio: staffMember.body || '',
  credentials: staffMember.data.credentials?.join(', ') || '',
  languages: staffMember.data.languages?.join(', ') || 'English',
  startYear: staffMember.data.startYear || new Date().getFullYear(),
  order: staffMember.data.order || 99,
  active: staffMember.data.active !== false
} : {
  name: '',
  slug: '',
  role: '',
  email: '',
  photo: '',
  bio: '',
  credentials: '',
  languages: 'English',
  startYear: new Date().getFullYear(),
  order: 99,
  active: true
};

// Role options
const roleOptions = [
  { value: '', label: 'Select role...' },
  { value: 'Lead Teacher', label: 'Lead Teacher' },
  { value: 'Assistant Teacher', label: 'Assistant Teacher' },
  { value: 'Head of School', label: 'Head of School' },
  { value: 'Director', label: 'Director' },
  { value: 'Administrator', label: 'Administrator' },
  { value: 'Support Staff', label: 'Support Staff' }
];

const pageTitle = isEdit ? `Edit: ${staffMember?.data.name}` : 'New Staff Member';
---

<AdminLayout title={pageTitle} description={isEdit ? 'Edit staff member information' : 'Add a new staff member'}>
  <div class="staff-editor">
    {errors.general && (
      <div class="error-banner" role="alert">
        {errors.general}
      </div>
    )}
    
    <form class="staff-form" method="POST" data-auto-save>
      <div class="form-grid">
        <!-- Left Column: Main Information -->
        <div class="form-main">
          <FormField
            label="Full Name"
            name="name"
            required
            help="The staff member's full name"
            error={errors.name}
          >
            <TextInput
              name="name"
              value={defaultData.name}
              placeholder="Enter full name..."
              required
              maxLength={100}
              data-slug-source
            />
          </FormField>
          
          <FormField
            label="URL Slug"
            name="slug"
            required
            help="URL-friendly version of the name"
            error={errors.slug}
          >
            <TextInput
              name="slug"
              value={defaultData.slug}
              pattern="^[a-z0-9-]+$"
              placeholder="url-friendly-name"
              required
              data-slug-target
            />
          </FormField>
          
          <FormField
            label="Role/Position"
            name="role"
            required
            help="The staff member's position or title"
            error={errors.role}
          >
            <SelectField
              name="role"
              value={defaultData.role}
              options={roleOptions}
              required
            />
          </FormField>
          
          <FormField
            label="Email Address"
            name="email"
            help="Contact email (optional)"
            error={errors.email}
          >
            <TextInput
              name="email"
              type="email"
              value={defaultData.email}
              placeholder="email@spicebushmontessori.org"
            />
          </FormField>
          
          <FormField
            label="Biography"
            name="bio"
            help="Staff member's background and bio (Markdown supported)"
          >
            <TextArea
              name="bio"
              value={defaultData.bio}
              rows={12}
              autoResize
              placeholder="Write about the staff member's background, education, experience, and interests..."
            />
          </FormField>
        </div>
        
        <!-- Right Column: Photo & Details -->
        <div class="form-sidebar">
          <!-- Photo -->
          <div class="form-section">
            <h3 class="section-title">Photo</h3>
            
            <FormField
              label="Profile Photo"
              name="photo"
              help="Staff member's professional photo"
            >
              <ImageUpload
                name="photo"
                value={defaultData.photo}
              />
            </FormField>
          </div>
          
          <!-- Professional Details -->
          <div class="form-section">
            <h3 class="section-title">Professional Details</h3>
            
            <FormField
              label="Credentials"
              name="credentials"
              help="Degrees, certifications (comma-separated)"
            >
              <TextInput
                name="credentials"
                value={defaultData.credentials}
                placeholder="B.A. Education, Montessori Certificate, etc."
              />
            </FormField>
            
            <FormField
              label="Languages"
              name="languages"
              help="Languages spoken (comma-separated)"
            >
              <TextInput
                name="languages"
                value={defaultData.languages}
                placeholder="English, Spanish, French, etc."
              />
            </FormField>
            
            <FormField
              label="Start Year"
              name="startYear"
              required
              help="Year they started at the school"
              error={errors.startYear}
            >
              <TextInput
                name="startYear"
                type="number"
                value={defaultData.startYear.toString()}
                min="1900"
                max={new Date().getFullYear() + 1}
                required
              />
            </FormField>
          </div>
          
          <!-- Display Settings -->
          <div class="form-section">
            <h3 class="section-title">Display Settings</h3>
            
            <FormField
              label="Display Order"
              name="order"
              help="Lower numbers appear first"
            >
              <TextInput
                name="order"
                type="number"
                value={defaultData.order.toString()}
                min="0"
                max="999"
              />
            </FormField>
            
            <FormField
              label="Status"
              name="active"
              help="Whether this staff member appears on the website"
            >
              <label class="toggle-wrapper">
                <input
                  type="checkbox"
                  name="active"
                  checked={defaultData.active}
                  class="toggle-input"
                />
                <span class="toggle-slider"></span>
                <span class="toggle-label">Active (visible on website)</span>
              </label>
            </FormField>
          </div>
          
          <!-- Actions -->
          <div class="form-actions">
            <button type="submit" class="btn btn--primary">
              {isEdit ? 'Update Staff Member' : 'Add Staff Member'}
            </button>
            <a href="/admin/staff" class="btn btn--secondary">Cancel</a>
          </div>
        </div>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  // Auto-generate slug from name
  const nameInput = document.querySelector('[data-slug-source]');
  const slugInput = document.querySelector('[data-slug-target]');
  
  if (nameInput && slugInput) {
    nameInput.addEventListener('input', () => {
      if (!slugInput.value || slugInput.dataset.autoGenerated === 'true') {
        const slug = nameInput.value
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, '');
        slugInput.value = slug;
        slugInput.dataset.autoGenerated = 'true';
      }
    });
    
    slugInput.addEventListener('input', () => {
      delete slugInput.dataset.autoGenerated;
    });
  }
  
  // Auto-save functionality
  const form = document.querySelector('[data-auto-save]');
  let autoSaveTimer;
  let isDirty = false;
  
  if (form) {
    // Track changes
    form.addEventListener('input', () => {
      isDirty = true;
      clearTimeout(autoSaveTimer);
      autoSaveTimer = setTimeout(autoSave, 30000); // 30 seconds
    });
    
    // Warn before leaving if unsaved changes
    window.addEventListener('beforeunload', (e) => {
      if (isDirty) {
        e.preventDefault();
        e.returnValue = 'You have unsaved changes. Are you sure you want to leave?';
      }
    });
    
    // Auto-save function (save as draft for auto-save)
    async function autoSave() {
      if (!isDirty) return;
      
      const formData = new FormData(form);
      
      try {
        const response = await fetch(window.location.href, {
          method: 'POST',
          body: formData
        });
        
        if (response.ok) {
          isDirty = false;
          showAutoSaveStatus('Changes saved automatically');
        }
      } catch (error) {
        console.error('Auto-save failed:', error);
      }
    }
    
    function showAutoSaveStatus(message) {
      // Remove existing status
      const existing = document.querySelector('.auto-save-status');
      if (existing) existing.remove();
      
      // Create new status
      const status = document.createElement('div');
      status.className = 'auto-save-status';
      status.textContent = message;
      document.body.appendChild(status);
      
      // Auto-remove after 3 seconds
      setTimeout(() => status.remove(), 3000);
    }
  }
</script>

<style>
  .staff-editor {
    @apply max-w-7xl mx-auto;
  }
  
  .error-banner {
    @apply bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-6;
  }
  
  .staff-form {
    @apply bg-white rounded-lg shadow;
  }
  
  .form-grid {
    @apply grid grid-cols-1 lg:grid-cols-3 gap-8 p-8;
  }
  
  .form-main {
    @apply lg:col-span-2 space-y-6;
  }
  
  .form-sidebar {
    @apply space-y-6;
  }
  
  .form-section {
    @apply bg-gray-50 rounded-lg p-6;
  }
  
  .section-title {
    @apply text-lg font-semibold text-gray-900 mb-4;
  }
  
  .form-actions {
    @apply sticky top-8 bg-white border border-gray-200 rounded-lg p-6 space-y-3;
  }
  
  /* Toggle Switch */
  .toggle-wrapper {
    @apply flex items-center;
  }
  
  .toggle-input {
    @apply sr-only;
  }
  
  .toggle-slider {
    @apply relative inline-flex items-center h-6 rounded-full w-11 mr-3;
    @apply bg-gray-200 transition-colors duration-200 ease-in-out;
    @apply focus-within:ring-2 focus-within:ring-blue-500 focus-within:ring-offset-2;
  }
  
  .toggle-slider::before {
    @apply inline-block w-4 h-4 transform rounded-full bg-white transition duration-200 ease-in-out;
    @apply translate-x-1;
    content: '';
  }
  
  .toggle-input:checked + .toggle-slider {
    @apply bg-blue-600;
  }
  
  .toggle-input:checked + .toggle-slider::before {
    @apply translate-x-6;
  }
  
  .toggle-label {
    @apply text-sm font-medium text-gray-700;
  }
  
  /* Buttons */
  .btn {
    @apply w-full px-4 py-2 rounded-md font-medium text-center transition-colors duration-200;
    @apply focus:outline-none focus:ring-2 focus:ring-offset-2;
  }
  
  .btn--primary {
    @apply bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500;
  }
  
  .btn--secondary {
    @apply bg-gray-600 text-white hover:bg-gray-700 focus:ring-gray-500;
  }
  
  .auto-save-status {
    @apply fixed bottom-4 right-4 bg-green-500 text-white px-4 py-2 rounded-md shadow-lg;
    @apply text-sm font-medium;
    z-index: 1000;
  }
</style>