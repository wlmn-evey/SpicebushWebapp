---
/**
 * Staff Management - List View
 * 
 * Displays all staff members in a manageable list with options to edit, 
 * add new staff, and manage their status.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '../../../lib/admin-auth-check';
import { getCollection } from '../../../lib/content-db';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect('/auth/login?redirect=' + Astro.url.pathname);
}

// Load staff members
const staffMembers = await getCollection('staff');

// Sort by order, then by name
const sortedStaff = staffMembers.sort((a, b) => {
  if (a.data.order !== b.data.order) {
    return a.data.order - b.data.order;
  }
  return a.data.name.localeCompare(b.data.name);
});

// Get status from URL
const status = Astro.url.searchParams.get('status');
const message = Astro.url.searchParams.get('success') || Astro.url.searchParams.get('error');

// Helper functions
function formatStartYear(year: number): string {
  const currentYear = new Date().getFullYear();
  const yearsOfService = currentYear - year;
  if (yearsOfService === 0) return `Started ${year} (New this year)`;
  if (yearsOfService === 1) return `Started ${year} (1 year)`;
  return `Started ${year} (${yearsOfService} years)`;
}

function getStatusBadge(active: boolean): string {
  return active 
    ? 'bg-green-100 text-green-800' 
    : 'bg-gray-100 text-gray-800';
}

function getStatusText(active: boolean): string {
  return active ? 'Active' : 'Inactive';
}
---

<AdminLayout title="Staff Management" description="Manage staff profiles and information">
  <div class="staff-management">
    <!-- Status Messages -->
    {message && (
      <div class={`status-message ${status === 'error' ? 'status-message--error' : 'status-message--success'}`} role="alert">
        {message}
      </div>
    )}
    
    <!-- Header -->
    <div class="page-header">
      <div class="page-header__content">
        <h1 class="page-title">Staff Management</h1>
        <p class="page-description">
          Manage staff profiles, roles, and information displayed on the website.
        </p>
      </div>
      <div class="page-header__actions">
        <a href="/admin/staff/edit" class="btn btn--primary">
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add Staff Member
        </a>
      </div>
    </div>
    
    <!-- Stats Summary -->
    <div class="stats-bar">
      <div class="stat">
        <span class="stat-number">{sortedStaff.length}</span>
        <span class="stat-label">Total Staff</span>
      </div>
      <div class="stat">
        <span class="stat-number">{sortedStaff.filter(member => member.data.active !== false).length}</span>
        <span class="stat-label">Active</span>
      </div>
      <div class="stat">
        <span class="stat-number">{sortedStaff.filter(member => member.data.active === false).length}</span>
        <span class="stat-label">Inactive</span>
      </div>
    </div>
    
    <!-- Staff List -->
    <div class="content-section">
      {sortedStaff.length > 0 ? (
        <div class="staff-grid">
          {sortedStaff.map(member => (
            <div class="staff-card">
              <div class="staff-card__header">
                <div class="staff-photo">
                  {member.data.photo ? (
                    <img 
                      src={member.data.photo} 
                      alt={member.data.name} 
                      class="staff-photo__image"
                    />
                  ) : (
                    <div class="staff-photo__placeholder">
                      <svg class="staff-photo__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                    </div>
                  )}
                </div>
                <div class="staff-card__info">
                  <h3 class="staff-name">{member.data.name}</h3>
                  <p class="staff-role">{member.data.role}</p>
                  {member.data.email && (
                    <p class="staff-email">{member.data.email}</p>
                  )}
                </div>
                <div class="staff-card__status">
                  <span class={`status-badge ${getStatusBadge(member.data.active !== false)}`}>
                    {getStatusText(member.data.active !== false)}
                  </span>
                </div>
              </div>
              
              <div class="staff-card__content">
                {member.data.credentials && member.data.credentials.length > 0 && (
                  <div class="staff-credentials">
                    <span class="label">Credentials:</span>
                    <span class="credentials-list">
                      {member.data.credentials.join(', ')}
                    </span>
                  </div>
                )}
                
                <div class="staff-meta">
                  <span class="meta-item">
                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    {formatStartYear(member.data.startYear)}
                  </span>
                  <span class="meta-item">
                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                    </svg>
                    Order: {member.data.order}
                  </span>
                </div>
              </div>
              
              <div class="staff-card__actions">
                <a href={`/admin/staff/edit?slug=${member.slug}`} class="action-btn action-btn--edit">
                  <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                  Edit
                </a>
                <button 
                  class="action-btn action-btn--delete" 
                  data-delete-staff={member.slug}
                  data-staff-name={member.data.name}
                >
                  <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                  Delete
                </button>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <svg class="empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <h3>No Staff Members Yet</h3>
          <p>Add your first staff member to get started building your team directory.</p>
          <a href="/admin/staff/edit" class="btn btn--primary">Add First Staff Member</a>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  // Handle delete confirmations
  document.addEventListener('DOMContentLoaded', () => {
    const deleteButtons = document.querySelectorAll('[data-delete-staff]');
    
    deleteButtons.forEach(button => {
      button.addEventListener('click', async (e) => {
        const slug = e.currentTarget.dataset.deleteStaff;
        const name = e.currentTarget.dataset.staffName;
        
        if (!confirm(`Are you sure you want to delete ${name}? This action cannot be undone.`)) {
          return;
        }
        
        try {
          const response = await fetch('/api/cms/entry', {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              type: 'staff',
              slug: slug
            })
          });
          
          if (response.ok) {
            window.location.href = '/admin/staff?success=Staff member deleted successfully';
          } else {
            alert('Failed to delete staff member. Please try again.');
          }
        } catch (error) {
          console.error('Delete error:', error);
          alert('An error occurred while deleting. Please try again.');
        }
      });
    });
  });
</script>

<style>
  .staff-management {
    @apply space-y-8;
  }
  
  /* Status Messages */
  .status-message {
    @apply px-4 py-3 rounded-lg border;
  }
  
  .status-message--success {
    @apply bg-green-50 border-green-200 text-green-800;
  }
  
  .status-message--error {
    @apply bg-red-50 border-red-200 text-red-800;
  }
  
  /* Page Header */
  .page-header {
    @apply flex items-start justify-between;
  }
  
  .page-header__content {
    @apply flex-1;
  }
  
  .page-title {
    @apply text-3xl font-bold text-gray-900 mb-2;
  }
  
  .page-description {
    @apply text-gray-600 max-w-2xl;
  }
  
  .page-header__actions {
    @apply flex-shrink-0 ml-6;
  }
  
  /* Stats Bar */
  .stats-bar {
    @apply flex space-x-8 bg-white rounded-lg shadow p-6;
  }
  
  .stat {
    @apply text-center;
  }
  
  .stat-number {
    @apply block text-2xl font-bold text-gray-900;
  }
  
  .stat-label {
    @apply text-sm text-gray-500 uppercase tracking-wide;
  }
  
  /* Content Section */
  .content-section {
    @apply bg-white rounded-lg shadow;
  }
  
  /* Staff Grid */
  .staff-grid {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 p-6;
  }
  
  .staff-card {
    @apply border border-gray-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow;
  }
  
  .staff-card__header {
    @apply flex items-start p-4 border-b border-gray-100;
  }
  
  .staff-photo {
    @apply w-16 h-16 rounded-full overflow-hidden flex-shrink-0 bg-gray-100;
  }
  
  .staff-photo__image {
    @apply w-full h-full object-cover;
  }
  
  .staff-photo__placeholder {
    @apply w-full h-full bg-gray-200 flex items-center justify-center;
  }
  
  .staff-photo__icon {
    @apply w-8 h-8 text-gray-400;
  }
  
  .staff-card__info {
    @apply flex-1 ml-4 min-w-0;
  }
  
  .staff-name {
    @apply font-semibold text-gray-900 truncate;
  }
  
  .staff-role {
    @apply text-sm text-blue-600 font-medium;
  }
  
  .staff-email {
    @apply text-xs text-gray-500 truncate;
  }
  
  .staff-card__status {
    @apply flex-shrink-0;
  }
  
  .status-badge {
    @apply inline-flex px-2 py-1 text-xs font-medium rounded-full;
  }
  
  /* Staff Card Content */
  .staff-card__content {
    @apply p-4 space-y-3;
  }
  
  .staff-credentials {
    @apply text-sm;
  }
  
  .label {
    @apply font-medium text-gray-700;
  }
  
  .credentials-list {
    @apply text-gray-600;
  }
  
  .staff-meta {
    @apply flex flex-col space-y-1;
  }
  
  .meta-item {
    @apply flex items-center text-xs text-gray-500;
  }
  
  .meta-icon {
    @apply w-4 h-4 mr-1;
  }
  
  /* Staff Card Actions */
  .staff-card__actions {
    @apply flex border-t border-gray-100;
  }
  
  .action-btn {
    @apply flex-1 flex items-center justify-center px-4 py-3 text-sm font-medium;
    @apply border-r border-gray-100 last:border-r-0 transition-colors;
  }
  
  .action-btn--edit {
    @apply text-blue-600 hover:bg-blue-50;
  }
  
  .action-btn--delete {
    @apply text-red-600 hover:bg-red-50;
  }
  
  .action-icon {
    @apply w-4 h-4 mr-2;
  }
  
  /* Buttons */
  .btn {
    @apply inline-flex items-center px-4 py-2 border rounded-md font-medium;
    @apply focus:outline-none focus:ring-2 focus:ring-offset-2;
    @apply transition-colors duration-150;
  }
  
  .btn--primary {
    @apply border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500;
  }
  
  .btn-icon {
    @apply w-4 h-4 mr-2;
  }
  
  /* Empty State */
  .empty-state {
    @apply text-center py-12 px-6;
  }
  
  .empty-icon {
    @apply w-12 h-12 mx-auto text-gray-400 mb-4;
  }
  
  .empty-state h3 {
    @apply text-lg font-medium text-gray-900 mb-2;
  }
  
  .empty-state p {
    @apply text-gray-500 mb-4 max-w-sm mx-auto;
  }
</style>