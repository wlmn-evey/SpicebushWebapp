---
/**
 * School Hours Management - List View
 * 
 * Displays all school hours in a manageable list with options to edit
 * each day's schedule and settings.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';
import { getCollection } from '@lib/content-db';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect(`/auth/sign-in?redirect=${  Astro.url.pathname}`);
}

// Load hours
const hoursEntries = await getCollection('hours');

// Sort by order (Monday=1, Sunday=7)
const dayOrder = {
  'Monday': 1,
  'Tuesday': 2,
  'Wednesday': 3,
  'Thursday': 4,
  'Friday': 5,
  'Saturday': 6,
  'Sunday': 7
};

const sortedHours = hoursEntries.sort((a, b) => {
  return dayOrder[a.data.day] - dayOrder[b.data.day];
});

// Get status from URL
const status = Astro.url.searchParams.get('status');
const message = Astro.url.searchParams.get('success') || Astro.url.searchParams.get('error');

// Helper functions
function formatTime(timeStr: string): string {
  if (!timeStr) return 'Not set';
  
  try {
    const [hours, minutes] = timeStr.split(':');
    const hour24 = parseInt(hours);
    const hour12 = hour24 === 0 ? 12 : hour24 > 12 ? hour24 - 12 : hour24;
    const ampm = hour24 >= 12 ? 'PM' : 'AM';
    return `${hour12}:${minutes} ${ampm}`;
  } catch {
    return timeStr;
  }
}

function getStatusBadge(isClosed: boolean): string {
  return isClosed 
    ? 'bg-red-100 text-red-800' 
    : 'bg-green-100 text-green-800';
}

function getStatusText(isClosed: boolean): string {
  return isClosed ? 'Closed' : 'Open';
}

function getDayIcon(day: string): string {
  const weekdayIcons = {
    'Monday': '📚',
    'Tuesday': '🎨',
    'Wednesday': '🌱',
    'Thursday': '🔬',
    'Friday': '🎵',
    'Saturday': '🏠',
    'Sunday': '🏠'
  };
  return weekdayIcons[day] || '📅';
}
---

<AdminLayout title="School Hours Management" description="Manage daily schedules and operating hours">
  <div class="hours-management">
    <!-- Status Messages -->
    {message && (
      <div class={`status-message ${status === 'error' ? 'status-message--error' : 'status-message--success'}`} role="alert">
        {message}
      </div>
    )}
    
    <!-- Header -->
    <div class="page-header">
      <div class="page-header__content">
        <h1 class="page-title">School Hours Management</h1>
        <p class="page-description">
          Manage daily schedules, operating hours, and special notes for each day of the week.
        </p>
      </div>
      <div class="page-header__actions">
        <a href="/admin/hours/edit" class="btn btn--primary">
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          Add New Day
        </a>
      </div>
    </div>
    
    <!-- Stats Summary -->
    <div class="stats-bar">
      <div class="stat">
        <span class="stat-number">{sortedHours.length}</span>
        <span class="stat-label">Days Configured</span>
      </div>
      <div class="stat">
        <span class="stat-number">{sortedHours.filter(day => !day.data.is_closed).length}</span>
        <span class="stat-label">Operating Days</span>
      </div>
      <div class="stat">
        <span class="stat-number">{sortedHours.filter(day => day.data.is_closed).length}</span>
        <span class="stat-label">Closed Days</span>
      </div>
    </div>
    
    <!-- Weekly Schedule -->
    <div class="content-section">
      {sortedHours.length > 0 ? (
        <div class="weekly-schedule">
          <div class="schedule-header">
            <h2 class="schedule-title">Weekly Schedule</h2>
            <p class="schedule-subtitle">Current operating hours and schedules</p>
          </div>
          
          <div class="schedule-grid">
            {sortedHours.map(dayEntry => (
              <div class="day-card">
                <div class="day-card__header">
                  <div class="day-info">
                    <span class="day-icon">{getDayIcon(dayEntry.data.day)}</span>
                    <div class="day-details">
                      <h3 class="day-name">{dayEntry.data.day}</h3>
                      <span class={`status-badge ${getStatusBadge(dayEntry.data.is_closed)}`}>
                        {getStatusText(dayEntry.data.is_closed)}
                      </span>
                    </div>
                  </div>
                  <div class="day-actions">
                    <a href={`/admin/hours/edit?slug=${dayEntry.slug}`} class="action-btn action-btn--edit">
                      <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    </a>
                  </div>
                </div>
                
                <div class="day-card__content">
                  {dayEntry.data.is_closed ? (
                    <div class="closed-info">
                      <svg class="closed-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                      <span class="closed-text">School Closed</span>
                    </div>
                  ) : (
                    <div class="hours-info">
                      <div class="time-display">
                        <svg class="time-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="time-range">
                          {formatTime(dayEntry.data.open_time)} - {formatTime(dayEntry.data.close_time)}
                        </span>
                      </div>
                      
                      {dayEntry.data.note && (
                        <div class="day-note">
                          <svg class="note-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                          </svg>
                          <span class="note-text">{dayEntry.data.note}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
                
                <div class="day-card__footer">
                  <span class="day-order">Order: {dayEntry.data.order}</span>
                  <button 
                    class="action-btn action-btn--delete" 
                    data-delete-day={dayEntry.slug}
                    data-day-name={dayEntry.data.day}
                  >
                    <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Delete
                  </button>
                </div>
              </div>
            ))}
          </div>
          
          <!-- Quick Actions -->
          <div class="quick-actions">
            <h3 class="quick-actions__title">Quick Actions</h3>
            <div class="quick-actions__grid">
              <button class="quick-action" data-quick-action="standard-week">
                <svg class="quick-action__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span>Set Standard Week</span>
                <small>Mon-Fri 8:30-3:00, Weekends Closed</small>
              </button>
              
              <button class="quick-action" data-quick-action="summer-hours">
                <svg class="quick-action__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <span>Summer Schedule</span>
                <small>Mon-Thu 8:00-4:00, Fri 8:00-1:00</small>
              </button>
            </div>
          </div>
        </div>
      ) : (
        <div class="empty-state">
          <svg class="empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h3>No Schedule Configured</h3>
          <p>Set up your weekly schedule by adding operating hours for each day.</p>
          <a href="/admin/hours/edit" class="btn btn--primary">Configure First Day</a>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  // Handle delete confirmations
  document.addEventListener('DOMContentLoaded', () => {
    const deleteButtons = document.querySelectorAll('[data-delete-day]');
    
    deleteButtons.forEach(button => {
      button.addEventListener('click', async (e) => {
        const slug = e.currentTarget.dataset.deleteDay;
        const dayName = e.currentTarget.dataset.dayName;
        
        if (!confirm(`Are you sure you want to delete the schedule for ${dayName}? This action cannot be undone.`)) {
          return;
        }
        
        try {
          const response = await fetch('/api/cms/entry', {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              type: 'hours',
              slug
            })
          });
          
          if (response.ok) {
            window.location.href = '/admin/hours?success=Day schedule deleted successfully';
          } else {
            alert('Failed to delete day schedule. Please try again.');
          }
        } catch (error) {
          console.error('Delete error:', error);
          alert('An error occurred while deleting. Please try again.');
        }
      });
    });
    
    // Handle quick actions
    const quickActionButtons = document.querySelectorAll('[data-quick-action]');
    
    quickActionButtons.forEach(button => {
      button.addEventListener('click', async (e) => {
        const action = e.currentTarget.dataset.quickAction;
        
        if (!confirm(`Apply ${action.replace('-', ' ')} schedule? This will update existing day configurations.`)) {
          return;
        }
        
        try {
          let schedules = [];
          
          if (action === 'standard-week') {
            schedules = [
              { day: 'Monday', open_time: '08:30', close_time: '15:00', is_closed: false, order: 1 },
              { day: 'Tuesday', open_time: '08:30', close_time: '15:00', is_closed: false, order: 2 },
              { day: 'Wednesday', open_time: '08:30', close_time: '15:00', is_closed: false, order: 3 },
              { day: 'Thursday', open_time: '08:30', close_time: '15:00', is_closed: false, order: 4 },
              { day: 'Friday', open_time: '08:30', close_time: '15:00', is_closed: false, order: 5 },
              { day: 'Saturday', open_time: '', close_time: '', is_closed: true, order: 6 },
              { day: 'Sunday', open_time: '', close_time: '', is_closed: true, order: 7 }
            ];
          } else if (action === 'summer-hours') {
            schedules = [
              { day: 'Monday', open_time: '08:00', close_time: '16:00', is_closed: false, order: 1 },
              { day: 'Tuesday', open_time: '08:00', close_time: '16:00', is_closed: false, order: 2 },
              { day: 'Wednesday', open_time: '08:00', close_time: '16:00', is_closed: false, order: 3 },
              { day: 'Thursday', open_time: '08:00', close_time: '16:00', is_closed: false, order: 4 },
              { day: 'Friday', open_time: '08:00', close_time: '13:00', is_closed: false, order: 5 },
              { day: 'Saturday', open_time: '', close_time: '', is_closed: true, order: 6 },
              { day: 'Sunday', open_time: '', close_time: '', is_closed: true, order: 7 }
            ];
          }
          
          // Create all schedules
          for (const schedule of schedules) {
            const contentData = {
              type: 'hours',
              slug: schedule.day.toLowerCase(),
              title: schedule.day,
              data: schedule,
              status: 'published',
              author_email: (Astro.locals as any)?.userEmail || 'admin@spicebushmontessori.org'
            };
            
            await fetch('/api/cms/entry', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(contentData)
            });
          }
          
          window.location.href = `/admin/hours?success=${action.replace('-', ' ')} schedule applied successfully`;
          
        } catch (error) {
          console.error('Quick action error:', error);
          alert('An error occurred while applying the schedule. Please try again.');
        }
      });
    });
  });
</script>

<style>
  .hours-management {
    @apply space-y-8;
  }
  
  /* Status Messages */
  .status-message {
    @apply px-4 py-3 rounded-lg border;
  }
  
  .status-message--success {
    @apply bg-green-50 border-green-200 text-green-800;
  }
  
  .status-message--error {
    @apply bg-red-50 border-red-200 text-red-800;
  }
  
  /* Page Header */
  .page-header {
    @apply flex items-start justify-between;
  }
  
  .page-header__content {
    @apply flex-1;
  }
  
  .page-title {
    @apply text-3xl font-bold text-gray-900 mb-2;
  }
  
  .page-description {
    @apply text-gray-600 max-w-2xl;
  }
  
  .page-header__actions {
    @apply flex-shrink-0 ml-6;
  }
  
  /* Stats Bar */
  .stats-bar {
    @apply flex space-x-8 bg-white rounded-lg shadow p-6;
  }
  
  .stat {
    @apply text-center;
  }
  
  .stat-number {
    @apply block text-2xl font-bold text-gray-900;
  }
  
  .stat-label {
    @apply text-sm text-gray-500 uppercase tracking-wide;
  }
  
  /* Content Section */
  .content-section {
    @apply bg-white rounded-lg shadow;
  }
  
  /* Weekly Schedule */
  .weekly-schedule {
    @apply p-6;
  }
  
  .schedule-header {
    @apply mb-6;
  }
  
  .schedule-title {
    @apply text-2xl font-bold text-gray-900 mb-2;
  }
  
  .schedule-subtitle {
    @apply text-gray-600;
  }
  
  .schedule-grid {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-8;
  }
  
  /* Day Cards */
  .day-card {
    @apply border border-gray-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow;
  }
  
  .day-card__header {
    @apply flex items-center justify-between p-4 bg-gray-50 border-b border-gray-200;
  }
  
  .day-info {
    @apply flex items-center space-x-3;
  }
  
  .day-icon {
    @apply text-2xl;
  }
  
  .day-details {
    @apply flex flex-col;
  }
  
  .day-name {
    @apply font-semibold text-gray-900 text-lg;
  }
  
  .status-badge {
    @apply inline-flex px-2 py-1 text-xs font-medium rounded-full;
  }
  
  .day-actions {
    @apply flex space-x-1;
  }
  
  .action-btn {
    @apply p-2 rounded-md transition-colors;
  }
  
  .action-btn--edit {
    @apply text-blue-600 hover:bg-blue-50;
  }
  
  .action-btn--delete {
    @apply text-red-600 hover:bg-red-50;
  }
  
  .action-icon {
    @apply w-4 h-4;
  }
  
  /* Day Card Content */
  .day-card__content {
    @apply p-4;
  }
  
  .closed-info {
    @apply flex items-center justify-center space-x-2 text-red-600 py-4;
  }
  
  .closed-icon {
    @apply w-5 h-5;
  }
  
  .closed-text {
    @apply font-medium;
  }
  
  .hours-info {
    @apply space-y-3;
  }
  
  .time-display {
    @apply flex items-center space-x-2;
  }
  
  .time-icon {
    @apply w-5 h-5 text-blue-600;
  }
  
  .time-range {
    @apply font-semibold text-gray-900;
  }
  
  .day-note {
    @apply flex items-start space-x-2;
  }
  
  .note-icon {
    @apply w-4 h-4 text-gray-400 mt-0.5 flex-shrink-0;
  }
  
  .note-text {
    @apply text-sm text-gray-600;
  }
  
  /* Day Card Footer */
  .day-card__footer {
    @apply flex items-center justify-between px-4 py-3 bg-gray-50 border-t border-gray-200;
  }
  
  .day-order {
    @apply text-xs text-gray-500;
  }
  
  /* Quick Actions */
  .quick-actions {
    @apply border-t border-gray-200 pt-6;
  }
  
  .quick-actions__title {
    @apply text-lg font-semibold text-gray-900 mb-4;
  }
  
  .quick-actions__grid {
    @apply grid grid-cols-1 md:grid-cols-2 gap-4;
  }
  
  .quick-action {
    @apply flex items-start space-x-3 p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors;
  }
  
  .quick-action__icon {
    @apply w-6 h-6 text-blue-600 flex-shrink-0 mt-1;
  }
  
  .quick-action span {
    @apply font-medium text-gray-900;
  }
  
  .quick-action small {
    @apply block text-sm text-gray-500 mt-1;
  }
  
  /* Buttons */
  .btn {
    @apply inline-flex items-center px-4 py-2 border rounded-md font-medium;
    @apply focus:outline-none focus:ring-2 focus:ring-offset-2;
    @apply transition-colors duration-150;
  }
  
  .btn--primary {
    @apply border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500;
  }
  
  .btn-icon {
    @apply w-4 h-4 mr-2;
  }
  
  /* Empty State */
  .empty-state {
    @apply text-center py-12 px-6;
  }
  
  .empty-icon {
    @apply w-12 h-12 mx-auto text-gray-400 mb-4;
  }
  
  .empty-state h3 {
    @apply text-lg font-medium text-gray-900 mb-2;
  }
  
  .empty-state p {
    @apply text-gray-500 mb-4 max-w-sm mx-auto;
  }
</style>
