---
/**
 * School Hours Editor
 * 
 * Handles both creating new day schedules and editing existing ones.
 * Provides form for managing daily operating hours and special notes.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import FormField from '../../../components/forms/FormField.astro';
import TextInput from '../../../components/forms/TextInput.astro';
import TextArea from '../../../components/forms/TextArea.astro';
import SelectField from '../../../components/forms/SelectField.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';
import { getEntry } from '@lib/content-db';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect(`/auth/login?redirect=${  Astro.url.pathname}`);
}

// Get slug from URL
const slug = Astro.url.searchParams.get('slug');
const isEdit = !!slug;

// Load existing hours entry if editing
let hoursEntry = null;
let errors = {};

if (isEdit) {
  hoursEntry = await getEntry('hours', slug);
  if (!hoursEntry) {
    return Astro.redirect('/admin/hours?error=Day schedule not found');
  }
}

// Handle form submission
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    // Extract form data
    const data = {
      day: formData.get('day')?.toString().trim() || '',
      slug: formData.get('slug')?.toString().trim() || '',
      open_time: formData.get('open_time')?.toString() || '',
      close_time: formData.get('close_time')?.toString() || '',
      is_closed: formData.get('is_closed') === 'on',
      note: formData.get('note')?.toString().trim() || '',
      order: parseInt(formData.get('order')?.toString()) || 1
    };
    
    // Validation
    if (!data.day) errors.day = 'Day is required';
    if (!data.slug) errors.slug = 'Slug is required';
    
    if (!data.is_closed) {
      if (!data.open_time) errors.open_time = 'Open time is required when school is open';
      if (!data.close_time) errors.close_time = 'Close time is required when school is open';
      
      // Validate time format and logic
      if (data.open_time && data.close_time) {
        const openTime = new Date(`1970-01-01T${data.open_time}:00`);
        const closeTime = new Date(`1970-01-01T${data.close_time}:00`);
        
        if (openTime >= closeTime) {
          errors.close_time = 'Close time must be after open time';
        }
      }
    }
    
    if (data.order < 1 || data.order > 7) {
      errors.order = 'Order must be between 1 and 7';
    }
    
    // Generate slug from day if not provided
    if (data.day && !data.slug) {
      data.slug = data.day.toLowerCase();
    }
    
    if (Object.keys(errors).length === 0) {
      // Prepare data for database
      const contentData = {
        type: 'hours',
        slug: data.slug,
        title: data.day,
        data: {
          day: data.day,
          open_time: data.is_closed ? '' : data.open_time,
          close_time: data.is_closed ? '' : data.close_time,
          is_closed: data.is_closed,
          note: data.note || undefined,
          order: data.order
        },
        status: 'published',
        author_email: 'admin@spicebushmontessori.org' // TODO: Get from session
      };
      
      // Save to database via API
      const apiEndpoint = '/api/cms/entry';
      const response = await fetch(apiEndpoint, {
        method: isEdit ? 'PUT' : 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(contentData)
      });
      
      if (response.ok) {
        const action = isEdit ? 'updated' : 'created';
        return Astro.redirect(`/admin/hours?success=Day schedule ${action} successfully`);
      } else {
        errors.general = 'Failed to save day schedule. Please try again.';
      }
    }
  } catch (error) {
    console.error('Form submission error:', error);
    errors.general = 'An unexpected error occurred. Please try again.';
  }
}

// Default values
const defaultData = hoursEntry ? {
  day: hoursEntry.data.day || '',
  slug: hoursEntry.slug || '',
  open_time: hoursEntry.data.open_time || '08:30',
  close_time: hoursEntry.data.close_time || '15:00',
  is_closed: hoursEntry.data.is_closed || false,
  note: hoursEntry.data.note || '',
  order: hoursEntry.data.order || 1
} : {
  day: '',
  slug: '',
  open_time: '08:30',
  close_time: '15:00',
  is_closed: false,
  note: '',
  order: 1
};

// Day options
const dayOptions = [
  { value: '', label: 'Select day...' },
  { value: 'Monday', label: 'Monday' },
  { value: 'Tuesday', label: 'Tuesday' },
  { value: 'Wednesday', label: 'Wednesday' },
  { value: 'Thursday', label: 'Thursday' },
  { value: 'Friday', label: 'Friday' },
  { value: 'Saturday', label: 'Saturday' },
  { value: 'Sunday', label: 'Sunday' }
];

// Order options (1=Monday, 7=Sunday)
const orderOptions = [
  { value: '1', label: '1 (Monday)' },
  { value: '2', label: '2 (Tuesday)' },
  { value: '3', label: '3 (Wednesday)' },
  { value: '4', label: '4 (Thursday)' },
  { value: '5', label: '5 (Friday)' },
  { value: '6', label: '6 (Saturday)' },
  { value: '7', label: '7 (Sunday)' }
];

const pageTitle = isEdit ? `Edit: ${hoursEntry?.data.day} Hours` : 'New Day Schedule';
---

<AdminLayout title={pageTitle} description={isEdit ? 'Edit day schedule' : 'Add a new day schedule'}>
  <div class="hours-editor">
    {errors.general && (
      <div class="error-banner" role="alert">
        {errors.general}
      </div>
    )}
    
    <form class="hours-form" method="POST">
      <div class="form-grid">
        <!-- Left Column: Main Information -->
        <div class="form-main">
          <FormField
            label="Day of Week"
            name="day"
            required
            help="Select the day of the week"
            error={errors.day}
          >
            <SelectField
              name="day"
              value={defaultData.day}
              options={dayOptions}
              required
              data-day-source
            />
          </FormField>
          
          <FormField
            label="URL Slug"
            name="slug"
            required
            help="URL-friendly version of the day (usually lowercase day name)"
            error={errors.slug}
          >
            <TextInput
              name="slug"
              value={defaultData.slug}
              pattern="^[a-z0-9-]+$"
              placeholder="monday"
              required
              data-slug-target
            />
          </FormField>
          
          <FormField
            label="Status"
            name="is_closed"
            help="Whether the school is closed on this day"
          >
            <label class="toggle-wrapper">
              <input
                type="checkbox"
                name="is_closed"
                checked={defaultData.is_closed}
                class="toggle-input"
                data-closed-toggle
              />
              <span class="toggle-slider"></span>
              <span class="toggle-label">School is closed on this day</span>
            </label>
          </FormField>
          
          <div class="hours-section" data-hours-section style={defaultData.is_closed ? 'display: none;' : ''}>
            <div class="hours-grid">
              <FormField
                label="Opening Time"
                name="open_time"
                required={!defaultData.is_closed}
                help="When the school opens"
                error={errors.open_time}
              >
                <TextInput
                  name="open_time"
                  type="time"
                  value={defaultData.open_time}
                  required={!defaultData.is_closed}
                />
              </FormField>
              
              <FormField
                label="Closing Time"
                name="close_time"
                required={!defaultData.is_closed}
                help="When the school closes"
                error={errors.close_time}
              >
                <TextInput
                  name="close_time"
                  type="time"
                  value={defaultData.close_time}
                  required={!defaultData.is_closed}
                />
              </FormField>
            </div>
          </div>
          
          <FormField
            label="Special Notes"
            name="note"
            help="Any special notes or details about this day (optional)"
          >
            <TextArea
              name="note"
              value={defaultData.note}
              rows={3}
              placeholder="e.g., Extended hours during summer, Early dismissal for staff meetings, etc."
            />
          </FormField>
        </div>
        
        <!-- Right Column: Settings & Preview -->
        <div class="form-sidebar">
          <!-- Display Settings -->
          <div class="form-section">
            <h3 class="section-title">Display Settings</h3>
            
            <FormField
              label="Display Order"
              name="order"
              required
              help="Order in weekly schedule (1=Monday, 7=Sunday)"
              error={errors.order}
            >
              <SelectField
                name="order"
                value={defaultData.order.toString()}
                options={orderOptions}
                required
              />
            </FormField>
          </div>
          
          <!-- Schedule Preview -->
          <div class="form-section">
            <h3 class="section-title">Schedule Preview</h3>
            
            <div class="schedule-preview" data-schedule-preview>
              <div class="preview-day">
                <span class="preview-day-name" data-preview-day>{defaultData.day || 'Select Day'}</span>
                <div class="preview-status" data-preview-status>
                  {defaultData.is_closed ? (
                    <span class="preview-closed">🔒 Closed</span>
                  ) : (
                    <span class="preview-open">
                      🕒 {defaultData.open_time} - {defaultData.close_time}
                    </span>
                  )}
                </div>
                {defaultData.note && (
                  <div class="preview-note" data-preview-note>
                    📝 {defaultData.note}
                  </div>
                )}
              </div>
            </div>
          </div>
          
          <!-- Quick Time Presets -->
          <div class="form-section">
            <h3 class="section-title">Quick Presets</h3>
            
            <div class="preset-buttons">
              <button type="button" class="preset-btn" data-preset="standard">
                Standard Day
                <small>8:30 AM - 3:00 PM</small>
              </button>
              
              <button type="button" class="preset-btn" data-preset="early">
                Early Day
                <small>8:00 AM - 2:30 PM</small>
              </button>
              
              <button type="button" class="preset-btn" data-preset="extended">
                Extended Day
                <small>7:30 AM - 4:00 PM</small>
              </button>
              
              <button type="button" class="preset-btn" data-preset="half">
                Half Day
                <small>8:30 AM - 12:00 PM</small>
              </button>
            </div>
          </div>
          
          <!-- Actions -->
          <div class="form-actions">
            <button type="submit" class="btn btn--primary">
              {isEdit ? 'Update Schedule' : 'Add Day Schedule'}
            </button>
            <a href="/admin/hours" class="btn btn--secondary">Cancel</a>
          </div>
        </div>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  // Auto-generate slug from day
  const daySelect = document.querySelector('[data-day-source]');
  const slugInput = document.querySelector('[data-slug-target]');
  
  if (daySelect && slugInput) {
    daySelect.addEventListener('change', () => {
      if (!slugInput.value || slugInput.dataset.autoGenerated === 'true') {
        const slug = daySelect.value.toLowerCase();
        slugInput.value = slug;
        slugInput.dataset.autoGenerated = 'true';
        updatePreview();
      }
    });
    
    slugInput.addEventListener('input', () => {
      delete slugInput.dataset.autoGenerated;
    });
  }
  
  // Handle closed toggle
  const closedToggle = document.querySelector('[data-closed-toggle]');
  const hoursSection = document.querySelector('[data-hours-section]');
  const openTimeInput = document.querySelector('input[name="open_time"]');
  const closeTimeInput = document.querySelector('input[name="close_time"]');
  
  if (closedToggle && hoursSection) {
    closedToggle.addEventListener('change', () => {
      const isClosed = closedToggle.checked;
      hoursSection.style.display = isClosed ? 'none' : 'block';
      
      // Update required attributes
      if (openTimeInput) openTimeInput.required = !isClosed;
      if (closeTimeInput) closeTimeInput.required = !isClosed;
      
      updatePreview();
    });
  }
  
  // Handle preset buttons
  const presetButtons = document.querySelectorAll('[data-preset]');
  
  presetButtons.forEach(button => {
    button.addEventListener('click', (e) => {
      e.preventDefault();
      const preset = e.currentTarget.dataset.preset;
      
      // Uncheck closed toggle and show hours section
      if (closedToggle) {
        closedToggle.checked = false;
        hoursSection.style.display = 'block';
        if (openTimeInput) openTimeInput.required = true;
        if (closeTimeInput) closeTimeInput.required = true;
      }
      
      // Set times based on preset
      const presets = {
        standard: { open: '08:30', close: '15:00' },
        early: { open: '08:00', close: '14:30' },
        extended: { open: '07:30', close: '16:00' },
        half: { open: '08:30', close: '12:00' }
      };
      
      const times = presets[preset];
      if (times && openTimeInput && closeTimeInput) {
        openTimeInput.value = times.open;
        closeTimeInput.value = times.close;
        updatePreview();
      }
    });
  });
  
  // Update preview function
  function updatePreview() {
    const previewDay = document.querySelector('[data-preview-day]');
    const previewStatus = document.querySelector('[data-preview-status]');
    const previewNote = document.querySelector('[data-preview-note]');
    
    if (previewDay) {
      previewDay.textContent = daySelect.value || 'Select Day';
    }
    
    if (previewStatus) {
      const isClosed = closedToggle?.checked || false;
      const openTime = openTimeInput?.value || '';
      const closeTime = closeTimeInput?.value || '';
      
      if (isClosed) {
        previewStatus.innerHTML = '<span class="preview-closed">🔒 Closed</span>';
      } else if (openTime && closeTime) {
        previewStatus.innerHTML = `<span class="preview-open">🕒 ${openTime} - ${closeTime}</span>`;
      } else {
        previewStatus.innerHTML = '<span class="preview-pending">⏰ Set times</span>';
      }
    }
    
    const noteInput = document.querySelector('textarea[name="note"]');
    if (previewNote && noteInput) {
      const note = noteInput.value.trim();
      if (note) {
        previewNote.textContent = `📝 ${note}`;
        previewNote.style.display = 'block';
      } else {
        previewNote.style.display = 'none';
      }
    }
  }
  
  // Add event listeners to update preview
  if (openTimeInput) openTimeInput.addEventListener('change', updatePreview);
  if (closeTimeInput) closeTimeInput.addEventListener('change', updatePreview);
  
  const noteInput = document.querySelector('textarea[name="note"]');
  if (noteInput) noteInput.addEventListener('input', updatePreview);
  
  // Initial preview update
  updatePreview();
</script>

<style>
  .hours-editor {
    @apply max-w-7xl mx-auto;
  }
  
  .error-banner {
    @apply bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-6;
  }
  
  .hours-form {
    @apply bg-white rounded-lg shadow;
  }
  
  .form-grid {
    @apply grid grid-cols-1 lg:grid-cols-3 gap-8 p-8;
  }
  
  .form-main {
    @apply lg:col-span-2 space-y-6;
  }
  
  .form-sidebar {
    @apply space-y-6;
  }
  
  .form-section {
    @apply bg-gray-50 rounded-lg p-6;
  }
  
  .section-title {
    @apply text-lg font-semibold text-gray-900 mb-4;
  }
  
  .form-actions {
    @apply sticky top-8 bg-white border border-gray-200 rounded-lg p-6 space-y-3;
  }
  
  /* Hours Section */
  .hours-section {
    @apply transition-all duration-200;
  }
  
  .hours-grid {
    @apply grid grid-cols-1 md:grid-cols-2 gap-6;
  }
  
  /* Toggle Switch */
  .toggle-wrapper {
    @apply flex items-center;
  }
  
  .toggle-input {
    @apply sr-only;
  }
  
  .toggle-slider {
    @apply relative inline-flex items-center h-6 rounded-full w-11 mr-3;
    @apply bg-gray-200 transition-colors duration-200 ease-in-out;
    @apply focus-within:ring-2 focus-within:ring-blue-500 focus-within:ring-offset-2;
  }
  
  .toggle-slider::before {
    @apply inline-block w-4 h-4 transform rounded-full bg-white transition duration-200 ease-in-out;
    @apply translate-x-1;
    content: '';
  }
  
  .toggle-input:checked + .toggle-slider {
    @apply bg-red-600;
  }
  
  .toggle-input:checked + .toggle-slider::before {
    @apply translate-x-6;
  }
  
  .toggle-label {
    @apply text-sm font-medium text-gray-700;
  }
  
  /* Schedule Preview */
  .schedule-preview {
    @apply border border-gray-200 rounded-lg p-4 bg-white;
  }
  
  .preview-day {
    @apply text-center;
  }
  
  .preview-day-name {
    @apply block text-lg font-semibold text-gray-900 mb-2;
  }
  
  .preview-status {
    @apply mb-2;
  }
  
  .preview-open {
    @apply text-green-600 font-medium;
  }
  
  .preview-closed {
    @apply text-red-600 font-medium;
  }
  
  .preview-pending {
    @apply text-gray-500;
  }
  
  .preview-note {
    @apply text-sm text-gray-600 italic;
  }
  
  /* Preset Buttons */
  .preset-buttons {
    @apply grid grid-cols-2 gap-2;
  }
  
  .preset-btn {
    @apply flex flex-col items-center p-3 border border-gray-200 rounded-lg;
    @apply hover:bg-gray-50 transition-colors text-sm;
  }
  
  .preset-btn small {
    @apply text-xs text-gray-500 mt-1;
  }
  
  /* Buttons */
  .btn {
    @apply w-full px-4 py-2 rounded-md font-medium text-center transition-colors duration-200;
    @apply focus:outline-none focus:ring-2 focus:ring-offset-2;
  }
  
  .btn--primary {
    @apply bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500;
  }
  
  .btn--secondary {
    @apply bg-gray-600 text-white hover:bg-gray-700 focus:ring-gray-500;
  }
</style>