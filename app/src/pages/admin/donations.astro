---
import AdminLayout from '@layouts/AdminLayout.astro';
import { donationTemplateOptions, getDonationAdminData } from '@lib/donation-thank-you';

const savedKey = Astro.url.searchParams.get('saved');
const errorKey = Astro.url.searchParams.get('error');

const toDateTimeInputValue = (value: string | null): string => {
  if (!value) return '';
  const parsed = Date.parse(value);
  if (!Number.isFinite(parsed)) return '';
  const date = new Date(parsed);
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  const hours = String(date.getHours()).padStart(2, '0');
  const minutes = String(date.getMinutes()).padStart(2, '0');
  return `${year}-${month}-${day}T${hours}:${minutes}`;
};

const formatDateTime = (value: string | null): string => {
  if (!value) return '—';
  const parsed = Date.parse(value);
  if (!Number.isFinite(parsed)) return value;
  return new Intl.DateTimeFormat('en-US', {
    dateStyle: 'medium',
    timeStyle: 'short'
  }).format(new Date(parsed));
};

const formatAmount = (amountCents: number | null, currency: string | null): string => {
  if (typeof amountCents !== 'number') return 'Unknown amount';
  const code = (currency || 'USD').toUpperCase();
  try {
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: code
    }).format(amountCents / 100);
  } catch {
    return `$${(amountCents / 100).toFixed(2)}`;
  }
};

const donationKindLabel: Record<string, string> = {
  'one-time': 'One-Time',
  'recurring-start': 'Recurring Start',
  'recurring-renewal': 'Recurring Renewal'
};

const eventStatusClass = (status: string): string => {
  if (status === 'sent') return 'border-green-200 bg-green-50 text-green-700';
  if (status === 'failed') return 'border-red-200 bg-red-50 text-red-700';
  if (status === 'skipped') return 'border-gray-200 bg-gray-50 text-earth-brown/80';
  return 'border-amber-200 bg-amber-50 text-amber-700';
};

const jobStatusClass = (status: string): string => {
  if (status === 'sent') return 'border-green-200 bg-green-50 text-green-700';
  if (status === 'failed') return 'border-red-200 bg-red-50 text-red-700';
  if (status === 'cancelled') return 'border-gray-200 bg-gray-50 text-earth-brown/80';
  if (status === 'processing') return 'border-blue-200 bg-blue-50 text-blue-700';
  return 'border-amber-200 bg-amber-50 text-amber-700';
};

const adminData = await getDonationAdminData();
const defaultReminderDateTime = (() => {
  const reminderDate = new Date(Date.now() + adminData.settings.defaultReminderHours * 60 * 60 * 1000);
  reminderDate.setMinutes(0, 0, 0);
  return toDateTimeInputValue(reminderDate.toISOString());
})();

const sentCount = adminData.events.filter((event) => event.thankYouEmailStatus === 'sent').length;
const failedCount = adminData.events.filter((event) => event.thankYouEmailStatus === 'failed').length;
const pendingCount = adminData.events.filter((event) => event.thankYouEmailStatus === 'pending').length;
---

<AdminLayout title="Donation Thank-You Emails">
  {
    savedKey && (
      <p class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
        Saved: <strong>{savedKey}</strong>
      </p>
    )
  }

  {
    errorKey && (
      <p class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
        Error: <strong>{errorKey}</strong>
      </p>
    )
  }

  <div class="space-y-6">
    <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-xl font-semibold text-earth-brown">Delivery Overview</h2>
      <p class="mt-1 text-sm text-earth-brown/80">
        Keep donor thank-you notes warm, prompt, and easy to manage for one-time and recurring gifts.
      </p>
      <div class="mt-4 grid gap-3 md:grid-cols-4">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Recent Donations</p>
          <p class="text-2xl font-semibold text-earth-brown">{adminData.events.length}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Thank-Yous Sent</p>
          <p class="text-2xl font-semibold text-green-700">{sentCount}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Pending</p>
          <p class="text-2xl font-semibold text-amber-700">{pendingCount}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Needs Attention</p>
          <p class="text-2xl font-semibold text-red-700">{failedCount}</p>
        </div>
      </div>
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h3 class="text-lg font-semibold text-earth-brown">Automation Settings</h3>
      <p class="mt-1 text-sm text-earth-brown/80">
        Control automatic sends and reminder timing from one place.
      </p>

      <form method="post" action="/api/admin/donations" class="mt-4 grid gap-3 lg:grid-cols-3">
        <input type="hidden" name="action" value="save-donation-thank-you-settings" />
        <input type="hidden" name="redirectTo" value="/admin/donations" />

        <label class="block text-sm font-medium text-earth-brown">
          Thank-You Emails
          <select name="enabled" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
            <option value="true" selected={adminData.settings.enabled}>
              Enabled
            </option>
            <option value="false" selected={!adminData.settings.enabled}>
              Disabled
            </option>
          </select>
        </label>

        <label class="block text-sm font-medium text-earth-brown">
          Recurring Renewal Emails
          <select
            name="sendRecurringRenewals"
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
          >
            <option value="true" selected={adminData.settings.sendRecurringRenewals}>
              Enabled
            </option>
            <option value="false" selected={!adminData.settings.sendRecurringRenewals}>
              Disabled
            </option>
          </select>
        </label>

        <label class="block text-sm font-medium text-earth-brown">
          Default Reminder Delay (hours)
          <input
            type="number"
            name="defaultReminderHours"
            min="1"
            max="720"
            step="1"
            value={String(adminData.settings.defaultReminderHours)}
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
          />
        </label>

        <div class="lg:col-span-3">
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Donation Email Settings
          </button>
        </div>
      </form>
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h3 class="text-lg font-semibold text-earth-brown">Thank-You Templates</h3>
      <p class="mt-1 text-sm text-earth-brown/80">
        Personalize each donor message type while keeping tone and contact details consistent.
      </p>

      <div class="mt-4 grid gap-4">
        {adminData.templates.map((template) => (
          <form method="post" action="/api/admin/donations" class="rounded-xl border border-gray-200 p-4">
            <input type="hidden" name="action" value="save-donation-template" />
            <input type="hidden" name="redirectTo" value="/admin/donations" />
            <input type="hidden" name="templateKey" value={template.key} />

            <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
              <div>
                <p class="text-sm font-semibold text-earth-brown">{template.name}</p>
                <p class="text-xs text-earth-brown/70">Source: {template.source}</p>
              </div>
              <span class="rounded-full border border-gray-200 bg-gray-50 px-2 py-1 text-xs font-semibold text-earth-brown/80">
                {template.key}
              </span>
            </div>

            <label class="block text-sm font-medium text-earth-brown">
              Subject Template
              <input
                type="text"
                name="subjectTemplate"
                value={template.subjectTemplate}
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              />
            </label>

            <label class="mt-3 block text-sm font-medium text-earth-brown">
              Message Template
              <textarea
                name="contentTemplate"
                rows="8"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">{template.contentTemplate}</textarea>
            </label>

            <p class="mt-2 text-xs text-earth-brown/70">
              Variables you can use: <code>{'{{first_name}}'}</code>, <code>{'{{donor_name}}'}</code>, <code>{'{{amount}}'}</code>, <code>{'{{donation_date}}'}</code>, <code>{'{{frequency_label}}'}</code>, <code>{'{{school_name}}'}</code>.
            </p>

            <button
              type="submit"
              class="mt-3 rounded-lg border border-forest-canopy px-3 py-2 text-sm font-semibold text-forest-canopy hover:bg-forest-canopy hover:text-white"
            >
              Save Template
            </button>
          </form>
        ))}
      </div>
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h3 class="text-lg font-semibold text-earth-brown">Recent Donation Events</h3>
      <p class="mt-1 text-sm text-earth-brown/80">
        Send a thank-you immediately, or schedule a follow-up reminder for any donor.
      </p>

      {adminData.events.length === 0 ? (
        <p class="mt-4 rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-earth-brown/80">
          No donation webhook events have been recorded yet.
        </p>
      ) : (
        <div class="mt-4 space-y-4">
          {adminData.events.map((event) => (
            <article class="rounded-xl border border-gray-200 p-4">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-earth-brown">
                    {event.donorName || 'Unnamed donor'} • {event.donorEmail || 'No email'}
                  </p>
                  <p class="mt-1 text-xs text-earth-brown/70">
                    {formatAmount(event.amountCents, event.currency)} • {donationKindLabel[event.donationKind] || event.donationKind}
                  </p>
                  <p class="mt-1 text-xs text-earth-brown/70">
                    Stripe Event: <code>{event.stripeEventId}</code>
                  </p>
                  <p class="mt-1 text-xs text-earth-brown/70">
                    Donation Date: {formatDateTime(event.eventCreatedAt)}
                  </p>
                  {event.thankYouEmailError && (
                    <p class="mt-1 text-xs text-red-700">Last error: {event.thankYouEmailError}</p>
                  )}
                </div>
                <span
                  class={`inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold ${eventStatusClass(event.thankYouEmailStatus)}`}
                >
                  {event.thankYouEmailStatus}
                </span>
              </div>

              <div class="mt-4 grid gap-3 xl:grid-cols-3">
                <form method="post" action="/api/admin/donations" class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                  <input type="hidden" name="action" value="send-donation-thank-you-now" />
                  <input type="hidden" name="redirectTo" value="/admin/donations" />
                  <input type="hidden" name="eventId" value={event.id} />
                  <label class="block text-xs font-semibold uppercase tracking-wide text-earth-brown/70">
                    Send Now
                    <select
                      name="templateSelection"
                      class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
                    >
                      {donationTemplateOptions.map((option) => (
                        <option value={option.key}>{option.label}</option>
                      ))}
                    </select>
                  </label>
                  <button
                    type="submit"
                    class="mt-2 w-full rounded-lg bg-forest-canopy px-3 py-2 text-sm font-semibold text-white hover:bg-moss-green"
                  >
                    Send Thank-You
                  </button>
                </form>

                <form method="post" action="/api/admin/donations" class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                  <input type="hidden" name="action" value="schedule-donation-email-reminder" />
                  <input type="hidden" name="redirectTo" value="/admin/donations" />
                  <input type="hidden" name="eventId" value={event.id} />
                  <input type="hidden" name="jobKind" value="manual-resend" />
                  <label class="block text-xs font-semibold uppercase tracking-wide text-earth-brown/70">
                    Custom Reminder Time
                    <input
                      type="datetime-local"
                      name="scheduledFor"
                      required
                      value={defaultReminderDateTime}
                      class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
                    />
                  </label>
                  <label class="mt-2 block text-xs font-semibold uppercase tracking-wide text-earth-brown/70">
                    Template
                    <select
                      name="templateSelection"
                      class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
                    >
                      {donationTemplateOptions.map((option) => (
                        <option value={option.key}>{option.label}</option>
                      ))}
                    </select>
                  </label>
                  <button
                    type="submit"
                    class="mt-2 w-full rounded-lg border border-forest-canopy px-3 py-2 text-sm font-semibold text-forest-canopy hover:bg-forest-canopy hover:text-white"
                  >
                    Schedule Reminder
                  </button>
                </form>

                <form method="post" action="/api/admin/donations" class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                  <input type="hidden" name="action" value="schedule-donation-default-reminder" />
                  <input type="hidden" name="redirectTo" value="/admin/donations" />
                  <input type="hidden" name="eventId" value={event.id} />
                  <p class="text-xs font-semibold uppercase tracking-wide text-earth-brown/70">
                    Quick Schedule
                  </p>
                  <p class="mt-2 text-sm text-earth-brown/80">
                    Queue a reminder using your default delay of {adminData.settings.defaultReminderHours} hours.
                  </p>
                  <button
                    type="submit"
                    class="mt-4 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-earth-brown hover:bg-gray-100"
                  >
                    Use Default Delay
                  </button>
                </form>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <div>
          <h3 class="text-lg font-semibold text-earth-brown">Scheduled Email Jobs</h3>
          <p class="mt-1 text-sm text-earth-brown/80">
            Review queued retries and reminders for donor follow-up.
          </p>
        </div>
        <form method="post" action="/api/admin/donations">
          <input type="hidden" name="action" value="run-donation-email-jobs" />
          <input type="hidden" name="redirectTo" value="/admin/donations" />
          <button
            type="submit"
            class="rounded-lg border border-gray-300 px-3 py-1.5 text-xs font-semibold text-earth-brown hover:bg-gray-100"
          >
            Process Due Jobs Now
          </button>
        </form>
      </div>

      {adminData.jobs.length === 0 ? (
        <p class="mt-4 rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-earth-brown/80">
          No donation email jobs are currently scheduled.
        </p>
      ) : (
        <div class="mt-4 space-y-2">
          {adminData.jobs.map((job) => (
            <div class="flex flex-wrap items-center justify-between gap-3 rounded-lg border border-gray-200 p-3">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-earth-brown">
                  {job.donorName || 'Unnamed donor'} • {job.donorEmail || 'No email'}
                </p>
                <p class="mt-1 text-xs text-earth-brown/70">
                  {job.jobKind} • {job.templateKey} • {formatAmount(job.amountCents, job.currency)}
                </p>
                <p class="mt-1 text-xs text-earth-brown/70">
                  Scheduled: {formatDateTime(job.scheduledFor)} • Attempts: {job.attemptCount}
                </p>
                <p class="mt-1 text-xs text-earth-brown/70">
                  Stripe Event: <code>{job.donationStripeEventId || 'unknown'}</code>
                </p>
                {job.lastError && <p class="mt-1 text-xs text-red-700">Error: {job.lastError}</p>}
              </div>

              <div class="flex items-center gap-2">
                <span
                  class={`inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold ${jobStatusClass(job.status)}`}
                >
                  {job.status}
                </span>
                {(job.status === 'scheduled' || job.status === 'failed') && (
                  <form method="post" action="/api/admin/donations">
                    <input type="hidden" name="action" value="cancel-donation-email-job" />
                    <input type="hidden" name="redirectTo" value="/admin/donations" />
                    <input type="hidden" name="jobId" value={job.id} />
                    <button
                      type="submit"
                      class="rounded-lg border border-red-200 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50"
                    >
                      Cancel
                    </button>
                  </form>
                )}
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </div>
</AdminLayout>
