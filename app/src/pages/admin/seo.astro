---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@lib/db';
import { getAnalyticsConfig } from '@lib/analytics-config';
import { getGa4OverviewReport } from '@lib/ga4-reporting';
import {
  SEO_MANAGED_PAGES,
  parseSeoGlobalSettings,
  parseSeoPageOverrides,
  type SeoPageOverride
} from '@lib/seo-config';

const rawWindow = Astro.url.searchParams.get('window');
const parsedWindow = rawWindow ? Number.parseInt(rawWindow, 10) : 30;
const windowDays = [7, 30, 90].includes(parsedWindow) ? parsedWindow : 30;
const rawTab = Astro.url.searchParams.get('tab');
const currentTab = ['studio', 'analytics', 'spend', 'events'].includes(rawTab ?? '')
  ? (rawTab as 'studio' | 'analytics' | 'spend' | 'events')
  : 'studio';

const savedKey = Astro.url.searchParams.get('saved');
const errorCode = Astro.url.searchParams.get('error');
const redirectBase = `/admin/seo?window=${windowDays}&tab=${currentTab}`;

const analyticsConfig = await getAnalyticsConfig();
const [
  overview,
  recentEvents,
  ga4EnabledSetting,
  ga4MeasurementSetting,
  ga4PropertySetting,
  adSpendSummary,
  recentAdSpend,
  campaignValueRows,
  ga4Report,
  rawSeoGlobal,
  rawSeoPageOverrides
] = await Promise.all([
  db.analytics.getAnalyticsOverview(windowDays),
  db.analytics.getRecentAnalyticsEvents(24),
  db.content.getSetting('ga4_enabled'),
  db.content.getSetting('ga4_measurement_id'),
  db.content.getSetting('ga4_property_id'),
  db.adSpend.getAdSpendSummary(windowDays),
  db.adSpend.getRecentAdSpendEntries(24),
  db.adSpend.getCampaignValueRows(windowDays),
  getGa4OverviewReport(analyticsConfig.propertyId, windowDays),
  db.content.getSetting('seo_global'),
  db.content.getSetting('seo_page_overrides')
]);

const parseBoolean = (value: unknown): boolean => {
  if (typeof value === 'boolean') return value;
  if (typeof value === 'number') return value === 1;
  if (typeof value === 'string') {
    return ['true', '1', 'yes', 'on'].includes(value.trim().toLowerCase());
  }
  return false;
};

const toStringValue = (value: unknown): string => {
  if (typeof value === 'string') return value.trim();
  if (typeof value === 'number' && Number.isFinite(value)) return String(Math.trunc(value));
  return '';
};

const formatNumber = (value: number): string => value.toLocaleString('en-US');
const formatCurrency = (value: number): string =>
  new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 2
  }).format(value);
const formatDate = (value: string): string => {
  const parsed = new Date(value);
  if (Number.isNaN(parsed.getTime())) return value;
  return new Intl.DateTimeFormat('en-US', { dateStyle: 'medium', timeStyle: 'short' }).format(
    parsed
  );
};

const configuredGaEnabled = parseBoolean(ga4EnabledSetting);
const configuredGaMeasurementId = toStringValue(ga4MeasurementSetting);
const configuredGaPropertyId = toStringValue(ga4PropertySetting);
const seoGlobal = parseSeoGlobalSettings(rawSeoGlobal);
const seoPageOverrides = parseSeoPageOverrides(rawSeoPageOverrides);
const seoManagedRows = SEO_MANAGED_PAGES.map(page => ({
  ...page,
  override: seoPageOverrides[page.path] as SeoPageOverride | undefined
}));
const robotsDisallowText = seoGlobal.robotsDisallowPaths.join('\n');
const overrideCount = Object.keys(seoPageOverrides).length;
const pageCoverage = `${overrideCount}/${seoManagedRows.length}`;
const overrideCoveragePercent =
  seoManagedRows.length > 0 ? Math.round((overrideCount / seoManagedRows.length) * 100) : 0;

const isTrackingLive = analyticsConfig.enabled;
const hasMeasurementId = analyticsConfig.measurementId.length > 0;
const estimatedCostPerLead =
  overview.totals.attributedLeads > 0
    ? adSpendSummary.totalSpend / overview.totals.attributedLeads
    : null;

const toPercent = (value: number, total: number): number => {
  if (value <= 0 || total <= 0) return 0;
  return Math.min(100, Math.round((value / total) * 100));
};

const toBarWidth = (value: number, maxValue: number): number => {
  if (value <= 0 || maxValue <= 0) return 0;
  return Math.max(8, Math.min(100, Math.round((value / maxValue) * 100)));
};

const funnelSteps = [
  { label: 'Tracked Page Views', value: overview.totals.pageViews, note: 'Top-of-funnel traffic.' },
  {
    label: 'Outbound Clicks',
    value: overview.totals.outboundClicks,
    note: 'Tour, enrollment, CTA, and other outbound clicks.'
  },
  {
    label: 'Form Submissions',
    value: overview.totals.formSubmissions,
    note: 'Contact and coming soon forms submitted.'
  },
  {
    label: 'Leads Captured',
    value: overview.totals.leads,
    note: 'Leads stored in your contact submissions table.'
  }
];
const funnelStartValue = funnelSteps[0]?.value ?? 0;
const funnelRows = funnelSteps.map((step, index) => {
  const previousValue = index > 0 ? (funnelSteps[index - 1]?.value ?? 0) : step.value;
  return {
    ...step,
    index,
    widthPercent: toBarWidth(step.value, funnelStartValue > 0 ? funnelStartValue : 1),
    fromStartPercent: toPercent(step.value, funnelStartValue),
    fromPreviousPercent: toPercent(step.value, previousValue)
  };
});

const maxOnSiteEventCount = Math.max(1, ...overview.topEvents.map(entry => entry.count));
const topEventRows = overview.topEvents.map(entry => ({
  ...entry,
  widthPercent: toBarWidth(entry.count, maxOnSiteEventCount)
}));

const maxOnSiteCampaignLeads = Math.max(1, ...overview.topCampaigns.map(entry => entry.leads));
const topOnSiteCampaignRows = overview.topCampaigns.map(entry => ({
  ...entry,
  widthPercent: toBarWidth(entry.leads, maxOnSiteCampaignLeads)
}));

const maxOnSitePageViews = Math.max(1, ...overview.topPages.map(entry => entry.views));
const topOnSitePageRows = overview.topPages.map(entry => ({
  ...entry,
  widthPercent: toBarWidth(entry.views, maxOnSitePageViews)
}));

const maxGa4PageViews = Math.max(1, ...ga4Report.topPages.map(entry => entry.views));
const topGa4PageRows = ga4Report.topPages.map(entry => ({
  ...entry,
  widthPercent: toBarWidth(entry.views, maxGa4PageViews)
}));

const maxGa4CampaignSessions = Math.max(1, ...ga4Report.topCampaigns.map(entry => entry.sessions));
const topGa4CampaignRows = ga4Report.topCampaigns.map(entry => ({
  ...entry,
  widthPercent: toBarWidth(entry.sessions, maxGa4CampaignSessions)
}));

const attributedLeadRate = toPercent(overview.totals.attributedLeads, overview.totals.leads);
const ga4NewUserRate = toPercent(ga4Report.summary.newUsers, ga4Report.summary.totalUsers);
const ga4ReturningUsers = Math.max(0, ga4Report.summary.totalUsers - ga4Report.summary.newUsers);
const onSiteVsGa4PageViews = toPercent(overview.totals.pageViews, ga4Report.summary.pageViews);

const mapSavedMessage = (value: string | null): string | null => {
  if (!value) return null;
  if (value.startsWith('ad_spend_imported_')) {
    const count = Number.parseInt(value.slice('ad_spend_imported_'.length), 10);
    if (Number.isFinite(count)) {
      return `Imported ${count} ad spend row${count === 1 ? '' : 's'}.`;
    }
  }
  if (value === 'ad_spend_added') return 'Added ad spend entry.';
  if (value === 'ad_spend_deleted') return 'Deleted ad spend entry.';
  if (value === 'seo_global') return 'Saved global SEO settings.';
  if (value.startsWith('seo_gemini_page_')) {
    const path = decodeURIComponent(value.slice('seo_gemini_page_'.length) || '/');
    return `Gemini updated SEO for ${path}.`;
  }
  if (value.startsWith('seo_gemini_all_')) {
    const parts = value.split('_');
    const applied = Number.parseInt(parts[3] ?? '0', 10);
    const failed = Number.parseInt(parts[4] ?? '0', 10);
    if (Number.isFinite(applied) && Number.isFinite(failed)) {
      return `Gemini updated ${applied} page${applied === 1 ? '' : 's'} (${failed} failed).`;
    }
    return 'Gemini applied SEO recommendations.';
  }
  if (value.startsWith('seo_page_')) {
    const path = decodeURIComponent(value.slice('seo_page_'.length) || '/');
    return `Saved SEO settings for ${path}.`;
  }
  return `Saved setting: ${value}`;
};

const mapErrorMessage = (value: string | null): string | null => {
  if (!value) return null;
  if (value === 'gemini_key_missing') {
    return 'Gemini API key is missing. Add GEMINI_API_KEY in Netlify environment variables for production functions.';
  }
  if (value === 'gemini_all_failed') {
    return 'Gemini could not generate recommendations for any managed pages. Check page availability and API key permissions.';
  }
  if (value === 'gemini_partial_failure') {
    return 'Gemini updated some pages, but not all. Review page cards and retry where needed.';
  }
  if (value === 'gemini_request_failed') {
    return 'Gemini SEO request failed. Please retry; if it persists, check function logs.';
  }
  if (value === 'invalid_page_path') {
    return 'Invalid page path for SEO recommendation.';
  }
  return value;
};

const savedMessage = mapSavedMessage(savedKey);
const errorMessage = mapErrorMessage(errorCode);
---

<AdminLayout title="SEO & Analytics">
  {
    savedMessage && (
      <p class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
        {savedMessage}
      </p>
    )
  }

  {
    errorMessage && (
      <p class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
        {errorMessage}
      </p>
    )
  }

  <div class="space-y-6">
    <section
      class="overflow-hidden rounded-2xl border border-forest-canopy/20 bg-gradient-to-br from-forest-canopy via-moss-green to-forest-canopy p-6 text-white shadow-md"
    >
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="space-y-2">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/80">
            SEO Command Center
          </p>
          <h2 class="text-2xl font-bold tracking-tight">
            Manage Search Visibility And Growth In One Place
          </h2>
          <p class="max-w-2xl text-sm text-white/90">
            Use Gemini suggestions, per-page overrides, and live analytics together so edits are
            easier to review and safer to ship.
          </p>
        </div>
        <div class="rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-sm backdrop-blur">
          <p class="text-xs uppercase tracking-wide text-white/75">Current Window</p>
          <p class="text-lg font-semibold">Last {windowDays} days</p>
        </div>
      </div>
      <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-white/20 bg-white/10 p-3">
          <p class="text-xs uppercase tracking-wide text-white/75">Managed Pages</p>
          <p class="text-xl font-semibold">{seoManagedRows.length}</p>
        </div>
        <div class="rounded-xl border border-white/20 bg-white/10 p-3">
          <p class="text-xs uppercase tracking-wide text-white/75">SEO Overrides</p>
          <p class="text-xl font-semibold">{pageCoverage}</p>
        </div>
        <div class="rounded-xl border border-white/20 bg-white/10 p-3">
          <p class="text-xs uppercase tracking-wide text-white/75">GA4 Data API</p>
          <p class="text-xl font-semibold">{ga4Report.available ? 'Connected' : 'Needs setup'}</p>
        </div>
        <div class="rounded-xl border border-white/20 bg-white/10 p-3">
          <p class="text-xs uppercase tracking-wide text-white/75">Ad Spend</p>
          <p class="text-xl font-semibold">{formatCurrency(adSpendSummary.totalSpend)}</p>
        </div>
      </div>
    </section>

    <section
      class="sticky top-[88px] z-10 rounded-xl border border-gray-200 bg-white/95 p-3 shadow-sm backdrop-blur"
    >
      <div class="flex flex-wrap gap-2" role="tablist" aria-label="SEO admin sections">
        <button
          type="button"
          class="seo-tab-btn rounded-lg border px-3 py-1.5 text-sm font-semibold transition"
          data-tab-btn
          data-tab="studio"
          role="tab"
          aria-selected={currentTab === 'studio' ? 'true' : 'false'}
        >
          SEO Studio
        </button>
        <button
          type="button"
          class="seo-tab-btn rounded-lg border px-3 py-1.5 text-sm font-semibold transition"
          data-tab-btn
          data-tab="analytics"
          role="tab"
          aria-selected={currentTab === 'analytics' ? 'true' : 'false'}
        >
          Analytics
        </button>
        <button
          type="button"
          class="seo-tab-btn rounded-lg border px-3 py-1.5 text-sm font-semibold transition"
          data-tab-btn
          data-tab="spend"
          role="tab"
          aria-selected={currentTab === 'spend' ? 'true' : 'false'}
        >
          Ad Spend
        </button>
        <button
          type="button"
          class="seo-tab-btn rounded-lg border px-3 py-1.5 text-sm font-semibold transition"
          data-tab-btn
          data-tab="events"
          role="tab"
          aria-selected={currentTab === 'events' ? 'true' : 'false'}
        >
          Event Stream
        </button>
      </div>
    </section>

    <div class="space-y-6" data-tab-panel="studio">
      <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-semibold mb-2">SEO Management</h2>
        <p class="text-sm text-earth-brown/80 mb-4">
          Set global SEO defaults and indexing behavior. These values now drive live page metadata
          and
          <code> /robots.txt</code>.
        </p>

        <form method="post" action="/api/admin/seo/config" class="space-y-4">
          <input type="hidden" name="action" value="save-global" />
          <input type="hidden" name="redirectTo" value={redirectBase} />

          <div class="grid gap-4 xl:grid-cols-2">
            <label class="block text-sm font-medium">
              Default Site Title
              <input
                type="text"
                name="defaultTitle"
                value={seoGlobal.defaultTitle}
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              />
            </label>

            <label class="block text-sm font-medium">
              Title Suffix (optional)
              <input
                type="text"
                name="titleSuffix"
                value={seoGlobal.titleSuffix}
                placeholder="Spicebush Montessori School"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              />
            </label>

            <label class="block text-sm font-medium xl:col-span-2">
              Default Meta Description
              <textarea
                name="defaultDescription"
                rows="3"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              >
                {seoGlobal.defaultDescription}
              </textarea>
            </label>

            <label class="block text-sm font-medium xl:col-span-2">
              Default Keywords
              <textarea
                name="defaultKeywords"
                rows="2"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              >
                {seoGlobal.defaultKeywords}
              </textarea>
            </label>

            <label class="block text-sm font-medium">
              Default Social Share Image URL
              <input
                type="text"
                name="ogImageUrl"
                value={seoGlobal.ogImageUrl}
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              />
            </label>

            <label class="block text-sm font-medium">
              Twitter Card Type
              <select
                name="twitterCard"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              >
                <option
                  value="summary_large_image"
                  selected={seoGlobal.twitterCard === 'summary_large_image'}
                >
                  summary_large_image
                </option>
                <option value="summary" selected={seoGlobal.twitterCard === 'summary'}>
                  summary
                </option>
              </select>
            </label>

            <label class="block text-sm font-medium">
              Sitewide No-Index
              <select
                name="siteNoIndex"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              >
                <option value="false" selected={!seoGlobal.siteNoIndex}>false</option>
                <option value="true" selected={seoGlobal.siteNoIndex}>true</option>
              </select>
            </label>

            <label class="block text-sm font-medium">
              Robots Disallow Paths
              <textarea
                name="robotsDisallowPaths"
                rows="4"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-xs"
                placeholder="/admin
/api
/private-page">{robotsDisallowText}</textarea
              >
            </label>
          </div>

          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Global SEO Settings
          </button>
        </form>
      </section>

      <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-semibold mb-2">Gemini SEO Assistant</h2>
        <p class="text-sm text-earth-brown/80 mb-4">
          Gemini reads each page HTML and recommends title, description, keywords, canonical path,
          and no-index flags. You can run it for all managed pages or one page at a time.
        </p>

        <form method="post" action="/api/admin/seo/gemini-suggest" class="space-y-3">
          <input type="hidden" name="action" value="apply-all" />
          <input type="hidden" name="redirectTo" value={redirectBase} />
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Run Gemini For All Managed Pages
          </button>
          <p class="text-xs text-earth-brown/70">
            Tip: after global run, review each page card below before publishing additional edits.
          </p>
        </form>
      </section>

      <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-semibold mb-2">Per-Page SEO Overrides</h2>
        <p class="text-sm text-earth-brown/80 mb-4">
          Override title, description, canonical URL, and indexing for specific pages.
        </p>

        <div class="mb-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-xs uppercase tracking-wide text-earth-brown/70">Coverage</p>
              <p class="text-sm text-earth-brown/90">
                {overrideCount} of {seoManagedRows.length} pages have custom SEO overrides.
              </p>
            </div>
            <p class="rounded-full bg-white px-3 py-1 text-sm font-semibold text-earth-brown">
              {overrideCoveragePercent}% configured
            </p>
          </div>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-white">
            <div
              class="h-full rounded-full bg-gradient-to-r from-forest-canopy to-moss-green"
              style={`width: ${overrideCoveragePercent}%`}
            >
            </div>
          </div>
        </div>

        <div class="mb-4 grid gap-3 xl:grid-cols-[minmax(0,2fr)_minmax(0,1fr)_auto]">
          <label class="block text-sm font-medium">
            Filter Pages
            <input
              type="search"
              placeholder="Search by page label or path"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              data-seo-page-filter
            />
          </label>
          <label class="block text-sm font-medium">
            Show
            <select
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
              data-seo-page-status-filter
            >
              <option value="all">All pages</option>
              <option value="overrides">Overrides only</option>
              <option value="defaults">Global defaults only</option>
            </select>
          </label>
          <div class="flex flex-col justify-end gap-2 sm:flex-row">
            <button
              type="button"
              class="rounded-lg border border-gray-300 px-3 py-2 text-xs font-semibold text-earth-brown hover:bg-gray-100"
              data-seo-expand-all
            >
              Expand all
            </button>
            <button
              type="button"
              class="rounded-lg border border-gray-300 px-3 py-2 text-xs font-semibold text-earth-brown hover:bg-gray-100"
              data-seo-collapse-all
            >
              Collapse all
            </button>
          </div>
        </div>

        <p class="mb-3 text-xs text-earth-brown/80" data-seo-page-results>
          {seoManagedRows.length} pages shown
        </p>

        <div class="space-y-3">
          {
            seoManagedRows.map(page => (
              <details
                class="rounded-xl border border-gray-200 bg-white shadow-sm"
                data-seo-page-card
                data-page-label={page.label.toLowerCase()}
                data-page-path={page.path.toLowerCase()}
                data-has-override={page.override ? 'true' : 'false'}
                open={Boolean(page.override)}
              >
                <summary class="cursor-pointer list-none p-4">
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div>
                      <p class="font-semibold text-earth-brown">{page.label}</p>
                      <p class="text-xs text-earth-brown/70">
                        <code>{page.path}</code>
                        {page.note && ` - ${page.note}`}
                      </p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                      <span
                        class={`rounded-full px-2.5 py-1 text-xs font-semibold ${
                          page.override
                            ? 'bg-green-100 text-green-800'
                            : 'bg-gray-100 text-earth-brown/80'
                        }`}
                      >
                        {page.override ? 'Override active' : 'Using defaults'}
                      </span>
                      <span class="text-xs text-earth-brown/70">Click to edit</span>
                    </div>
                  </div>
                </summary>

                <div class="border-t border-gray-200 p-4">
                  <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
                    <p class="text-xs text-earth-brown/75">
                      Edit SEO fields, run Gemini for this page, then save.
                    </p>
                    <a
                      href={page.path}
                      target="_blank"
                      rel="noreferrer"
                      class="text-sm font-medium text-forest-canopy hover:underline"
                    >
                      Open Page
                    </a>
                  </div>

                  <form method="post" action="/api/admin/seo/config" class="space-y-3">
                    <input type="hidden" name="action" value="save-page" />
                    <input type="hidden" name="path" value={page.path} />
                    <input type="hidden" name="redirectTo" value={redirectBase} />

                    <div class="grid gap-3 xl:grid-cols-2">
                      <label class="block text-sm font-medium">
                        SEO Title Override
                        <input
                          type="text"
                          name="title"
                          value={page.override?.title ?? ''}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>

                      <label class="block text-sm font-medium">
                        Canonical URL Override (optional)
                        <input
                          type="text"
                          name="canonicalUrl"
                          value={page.override?.canonicalUrl ?? ''}
                          placeholder="https://spicebushmontessori.org/example"
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>

                      <label class="block text-sm font-medium xl:col-span-2">
                        SEO Description Override
                        <textarea
                          name="description"
                          rows="2"
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        >
                          {page.override?.description ?? ''}
                        </textarea>
                      </label>

                      <label class="block text-sm font-medium xl:col-span-2">
                        Keywords Override
                        <input
                          type="text"
                          name="keywords"
                          value={page.override?.keywords ?? ''}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>

                      <label class="block text-sm font-medium">
                        Social Share Image URL Override
                        <input
                          type="text"
                          name="ogImageUrl"
                          value={page.override?.ogImageUrl ?? ''}
