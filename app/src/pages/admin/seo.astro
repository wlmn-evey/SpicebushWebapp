          <p class="mb-2 text-sm text-earth-brown/75">
            Headers supported:
            <code>spend_date, channel, campaign, amount, currency, notes</code>.
          </p>
          <form method="post" action="/api/admin/seo/ad-spend" class="space-y-3">
            <input type="hidden" name="redirectTo" value={redirectBase} />
            <textarea
              name="csvData"
              rows="8"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-xs"
              placeholder={'spend_date,channel,campaign,amount,currency,notes\n2026-02-18,Google Ads,Spring Enrollment Search,145.23,USD,Daily budget\n2026-02-18,Meta,Open House Awareness,89.50,USD,Boosted post'}
            ></textarea>
            <button
              type="submit"
              class="rounded-lg border border-forest-canopy px-4 py-2 text-sm font-semibold text-forest-canopy hover:bg-forest-canopy hover:text-white"
            >
              Import CSV
            </button>
          </form>
        </div>
      </section>

      <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold">Campaign Value (Spend vs Leads)</h2>
        {
          campaignValueRows.length === 0 ? (
            <p class="text-sm text-earth-brown/70">
              No campaign value data yet. Add spend or collect attributed leads first.
            </p>
          ) : (
            <div class="overflow-x-auto">
              <table class="min-w-full border-collapse text-sm">
                <thead>
                  <tr class="bg-gray-50 text-left text-xs uppercase tracking-wide text-earth-brown/70">
                    <th class="border border-gray-200 px-3 py-2">Campaign</th>
                    <th class="border border-gray-200 px-3 py-2">Spend</th>
                    <th class="border border-gray-200 px-3 py-2">Leads</th>
                    <th class="border border-gray-200 px-3 py-2">Cost / Lead</th>
                  </tr>
                </thead>
                <tbody>
                  {campaignValueRows.map(row => (
                    <tr>
                      <td class="border border-gray-200 px-3 py-2">{row.campaign}</td>
                      <td class="border border-gray-200 px-3 py-2">{formatCurrency(row.spend)}</td>
                      <td class="border border-gray-200 px-3 py-2">{formatNumber(row.leads)}</td>
                      <td class="border border-gray-200 px-3 py-2">
                        {row.costPerLead === null ? '—' : formatCurrency(row.costPerLead)}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )
        }
      </section>

      <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold">Recent Ad Spend Entries</h2>
        {
          recentAdSpend.length === 0 ? (
            <p class="text-sm text-earth-brown/70">No ad spend entries saved yet.</p>
          ) : (
            <div class="overflow-x-auto">
              <table class="min-w-full border-collapse text-sm">
                <thead>
                  <tr class="bg-gray-50 text-left text-xs uppercase tracking-wide text-earth-brown/70">
                    <th class="border border-gray-200 px-3 py-2">Date</th>
                    <th class="border border-gray-200 px-3 py-2">Channel</th>
                    <th class="border border-gray-200 px-3 py-2">Campaign</th>
                    <th class="border border-gray-200 px-3 py-2">Amount</th>
                    <th class="border border-gray-200 px-3 py-2">Added</th>
                    <th class="border border-gray-200 px-3 py-2">Action</th>
                  </tr>
                </thead>
                <tbody>
                  {recentAdSpend.map(entry => (
                    <tr>
                      <td class="border border-gray-200 px-3 py-2">{entry.spendDate}</td>
                      <td class="border border-gray-200 px-3 py-2">{entry.channel}</td>
                      <td class="border border-gray-200 px-3 py-2">{entry.campaign}</td>
                      <td class="border border-gray-200 px-3 py-2">
                        {formatCurrency(entry.amount)}
                      </td>
                      <td class="border border-gray-200 px-3 py-2 text-xs text-earth-brown/80">
                        {formatDate(entry.createdAt)}
                      </td>
                      <td class="border border-gray-200 px-3 py-2">
                        <form method="post" action="/api/admin/seo/ad-spend">
                          <input type="hidden" name="action" value="delete" />
                          <input type="hidden" name="entryId" value={entry.id} />
                          <input type="hidden" name="redirectTo" value={redirectBase} />
                          <button
                            type="submit"
                            class="rounded border border-red-300 px-2 py-1 text-xs font-semibold text-red-700 hover:bg-red-50"
                          >
                            Delete
                          </button>
                        </form>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )
        }
      </section>
    </div>

    <div class="space-y-6" data-tab-panel="events">
      <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold">Recent Tracking Events</h2>
        {
          recentEvents.length === 0 ? (
            <p class="text-sm text-earth-brown/70">No recent tracking events found.</p>
          ) : (
            <div class="overflow-x-auto">
              <table class="min-w-full border-collapse text-sm">
                <thead>
                  <tr class="bg-gray-50 text-left text-xs uppercase tracking-wide text-earth-brown/70">
                    <th class="border border-gray-200 px-3 py-2">Time</th>
                    <th class="border border-gray-200 px-3 py-2">Event</th>
                    <th class="border border-gray-200 px-3 py-2">Path</th>
                    <th class="border border-gray-200 px-3 py-2">Details</th>
                  </tr>
                </thead>
                <tbody>
                  {recentEvents.map(event => {
                    const label =
                      typeof event.properties.label === 'string' ? event.properties.label : '';
                    const href =
                      typeof event.properties.href === 'string' ? event.properties.href : '';

                    return (
                      <tr>
                        <td class="border border-gray-200 px-3 py-2 text-xs text-earth-brown/80">
                          {formatDate(event.createdAt)}
                        </td>
                        <td class="border border-gray-200 px-3 py-2 font-medium">
                          {event.eventName}
                        </td>
                        <td class="border border-gray-200 px-3 py-2 text-earth-brown/80">
                          {event.pagePath || '(unknown)'}
                        </td>
                        <td class="border border-gray-200 px-3 py-2 text-earth-brown/80">
                          {label || href || '—'}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )
        }
      </section>
    </div>
  </div>

  <script is:inline define:vars={{ currentTab }}>
    (() => {
      const tabButtons = Array.from(document.querySelectorAll('[data-tab-btn]'));
      const tabPanels = Array.from(document.querySelectorAll('[data-tab-panel]'));
      const allowedTabs = new Set(['studio', 'analytics', 'spend', 'events']);
      const activeClasses = ['border-forest-canopy', 'bg-forest-canopy', 'text-white'];
      const inactiveClasses = ['border-gray-300', 'bg-white', 'text-earth-brown'];

      const setActiveTab = nextTab => {
        const tab = allowedTabs.has(nextTab) ? nextTab : 'studio';

        tabPanels.forEach(panel => {
          const panelTab = panel.getAttribute('data-tab-panel');
          panel.classList.toggle('hidden', panelTab !== tab);
        });

        tabButtons.forEach(button => {
          const isActive = button.getAttribute('data-tab') === tab;
          button.setAttribute('aria-selected', isActive ? 'true' : 'false');
          button.classList.toggle('shadow-sm', isActive);
          activeClasses.forEach(className => button.classList.toggle(className, isActive));
          inactiveClasses.forEach(className => button.classList.toggle(className, !isActive));
        });

        try {
          const url = new URL(window.location.href);
          url.searchParams.set('tab', tab);
          window.history.replaceState({}, '', url.toString());
        } catch {
          // no-op
        }
      };

      tabButtons.forEach(button => {
        button.addEventListener('click', () => {
          setActiveTab(button.getAttribute('data-tab') || 'studio');
        });
      });

      setActiveTab(currentTab || 'studio');

      const filterInput = document.querySelector('[data-seo-page-filter]');
      const statusFilter = document.querySelector('[data-seo-page-status-filter]');
      const expandAllButton = document.querySelector('[data-seo-expand-all]');
      const collapseAllButton = document.querySelector('[data-seo-collapse-all]');
      const pageCards = Array.from(document.querySelectorAll('[data-seo-page-card]'));
      const resultsLabel = document.querySelector('[data-seo-page-results]');

      if (pageCards.length > 0) {
        const getStatusFilter = () => {
          if (statusFilter && 'value' in statusFilter) {
            return String(statusFilter.value || 'all');
          }
          return 'all';
        };

        const getFilterTerm = () => {
          if (filterInput && 'value' in filterInput) {
            return String(filterInput.value || '')
              .trim()
              .toLowerCase();
          }
          return '';
        };

        const applyFilter = () => {
          const term = getFilterTerm();
          const status = getStatusFilter();
          let visibleCount = 0;

          pageCards.forEach(card => {
            const label = (card.getAttribute('data-page-label') || '').toLowerCase();
            const path = (card.getAttribute('data-page-path') || '').toLowerCase();
            const hasOverride = card.getAttribute('data-has-override') === 'true';
            const matchTerm = term.length === 0 || label.includes(term) || path.includes(term);
            const matchStatus =
              status === 'all' ||
              (status === 'overrides' && hasOverride) ||
              (status === 'defaults' && !hasOverride);
            const isVisible = matchTerm && matchStatus;
            card.classList.toggle('hidden', !isVisible);
            if (isVisible) visibleCount += 1;
          });

          if (resultsLabel) {
            resultsLabel.textContent = `${visibleCount} of ${pageCards.length} page${pageCards.length === 1 ? '' : 's'} shown`;
          }
        };

        if (filterInput) {
          filterInput.addEventListener('input', applyFilter);
        }
        if (statusFilter) {
          statusFilter.addEventListener('change', applyFilter);
        }
        if (expandAllButton) {
          expandAllButton.addEventListener('click', () => {
            pageCards.forEach(card => {
              if (!card.classList.contains('hidden') && card instanceof HTMLDetailsElement) {
                card.open = true;
              }
            });
          });
        }
        if (collapseAllButton) {
          collapseAllButton.addEventListener('click', () => {
            pageCards.forEach(card => {
              if (card instanceof HTMLDetailsElement) {
                card.open = false;
              }
            });
          });
        }

        applyFilter();
      }
    })();
  </script>

  <style>
    [data-tab-panel] {
      animation: fadeInPanel 240ms ease-out;
    }

    [data-seo-page-card] summary {
      position: relative;
      padding-right: 2.25rem;
    }

    [data-seo-page-card] summary::-webkit-details-marker {
      display: none;
    }

    [data-seo-page-card] summary::after {
      align-items: center;
      color: #2f5d50;
      content: '+';
      display: inline-flex;
      font-size: 1.4rem;
      font-weight: 500;
      height: 1.5rem;
      justify-content: center;
      position: absolute;
      right: 0.75rem;
      top: calc(50% - 0.75rem);
      width: 1.5rem;
    }

    [data-seo-page-card][open] summary::after {
      content: '−';
    }

    @keyframes fadeInPanel {
      from {
        opacity: 0;
        transform: translateY(4px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</AdminLayout>
