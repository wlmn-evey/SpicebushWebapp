---
/**
 * Tuition Editor
 * 
 * Handles both creating new tuition programs/rates and editing existing ones.
 * Supports two types: programs (educational offerings) and rates (pricing).
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import FormField from '../../../components/forms/FormField.astro';
import TextInput from '../../../components/forms/TextInput.astro';
import TextArea from '../../../components/forms/TextArea.astro';
import SelectField from '../../../components/forms/SelectField.astro';
import { Fragment } from 'astro/jsx-runtime';
import { checkAdminAuth } from '@lib/admin-auth-check';
import { getEntry, getCollection } from '@lib/content-db';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect('/auth/netlify-login?redirect=' + Astro.url.pathname);
}

// Get parameters from URL
const slug = Astro.url.searchParams.get('slug');
const type = Astro.url.searchParams.get('type') || 'program'; // 'program' or 'rate'
const isEdit = !!slug;

// Load existing entry if editing
let tuitionEntry = null;
let errors = {};

if (isEdit) {
  tuitionEntry = await getEntry('tuition', slug);
  if (!tuitionEntry || tuitionEntry.data.type !== type) {
    return Astro.redirect(`/admin/tuition?error=${type.charAt(0).toUpperCase() + type.slice(1)} not found`);
  }
}

// Load all programs for rate assignment
const allTuitionEntries = await getCollection('tuition');
const programs = allTuitionEntries.filter(entry => entry.data.type === 'program');

// Handle form submission
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    // Common fields
    const baseData = {
      type: type,
      slug: formData.get('slug')?.toString().trim() || '',
      active: formData.get('active') === 'on',
      display_order: parseInt(formData.get('display_order')?.toString()) || 0,
    };
    
    let specificData = {};
    
    if (type === 'program') {
      // Program-specific fields
      specificData = {
        name: formData.get('name')?.toString().trim() || '',
        program_type: formData.get('program_type')?.toString() || '',
        days_per_week: parseInt(formData.get('days_per_week')?.toString()) || 5,
        daily_hours: parseFloat(formData.get('daily_hours')?.toString()) || 6.5,
        description: formData.get('description')?.toString().trim() || '',
      };
      
      // Validation for programs
      if (!specificData.name) errors.name = 'Program name is required';
      if (!specificData.program_type) errors.program_type = 'Program type is required';
      if (specificData.days_per_week < 1 || specificData.days_per_week > 7) {
        errors.days_per_week = 'Days per week must be between 1 and 7';
      }
      if (specificData.daily_hours < 0.5 || specificData.daily_hours > 12) {
        errors.daily_hours = 'Daily hours must be between 0.5 and 12';
      }
      
      // Generate slug from name if not provided
      if (specificData.name && !baseData.slug) {
        baseData.slug = specificData.name
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, '');
      }
      
    } else if (type === 'rate') {
      // Rate-specific fields
      specificData = {
        rate_label: formData.get('rate_label')?.toString().trim() || '',
        program_id: formData.get('program_id')?.toString() || '',
        tuition_price: parseFloat(formData.get('tuition_price')?.toString()) || 0,
        extended_care_price: parseFloat(formData.get('extended_care_price')?.toString()) || 0,
        extended_care_available: formData.get('extended_care_available') === 'on',
        is_constant_rate: formData.get('is_constant_rate') === 'on',
        school_year: formData.get('school_year')?.toString() || '2025-2026',
        income_threshold_type: formData.get('income_threshold_type')?.toString() || 'Greater Than or Equal To',
        // Income thresholds (only if not constant rate)
        income_threshold_family_2: formData.get('is_constant_rate') === 'on' ? undefined : parseFloat(formData.get('income_threshold_family_2')?.toString()) || undefined,
        income_threshold_family_3: formData.get('is_constant_rate') === 'on' ? undefined : parseFloat(formData.get('income_threshold_family_3')?.toString()) || undefined,
        income_threshold_family_4: formData.get('is_constant_rate') === 'on' ? undefined : parseFloat(formData.get('income_threshold_family_4')?.toString()) || undefined,
        income_threshold_family_5: formData.get('is_constant_rate') === 'on' ? undefined : parseFloat(formData.get('income_threshold_family_5')?.toString()) || undefined,
        income_threshold_family_6: formData.get('is_constant_rate') === 'on' ? undefined : parseFloat(formData.get('income_threshold_family_6')?.toString()) || undefined,
        income_threshold_family_7: formData.get('is_constant_rate') === 'on' ? undefined : parseFloat(formData.get('income_threshold_family_7')?.toString()) || undefined,
        income_threshold_family_8_plus: formData.get('is_constant_rate') === 'on' ? undefined : parseFloat(formData.get('income_threshold_family_8_plus')?.toString()) || undefined,
      };
      
      // Validation for rates
      if (!specificData.rate_label) errors.rate_label = 'Rate label is required';
      if (specificData.tuition_price <= 0) errors.tuition_price = 'Tuition price must be greater than 0';
      if (specificData.extended_care_available && specificData.extended_care_price < 0) {
        errors.extended_care_price = 'Extended care price cannot be negative';
      }
      
      // Generate slug from rate label if not provided
      if (specificData.rate_label && !baseData.slug) {
        baseData.slug = specificData.rate_label
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, '');
      }
    }
    
    // Combine all data
    const data = { ...baseData, ...specificData };
    
    // Common validation
    if (!data.slug) errors.slug = 'Slug is required';
    
    if (Object.keys(errors).length === 0) {
      // Prepare data for database
      const contentData = {
        type: 'tuition',
        slug: data.slug,
        title: type === 'program' ? data.name : data.rate_label,
        data: data,
        status: 'published',
        author_email: 'admin@spicebushmontessori.org' // TODO: Get from session
      };
      
      // Save to database via API
      const apiEndpoint = '/api/cms/entry';
      const response = await fetch(apiEndpoint, {
        method: isEdit ? 'PUT' : 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(contentData)
      });
      
      if (response.ok) {
        const action = isEdit ? 'updated' : 'created';
        return Astro.redirect(`/admin/tuition?success=${type.charAt(0).toUpperCase() + type.slice(1)} ${action} successfully`);
      } else {
        errors.general = `Failed to save ${type}. Please try again.`;
      }
    }
  } catch (error) {
    console.error('Form submission error:', error);
    errors.general = 'An unexpected error occurred. Please try again.';
  }
}

// Default values
const defaultData = tuitionEntry ? {
  // Common fields
  slug: tuitionEntry.slug || '',
  active: tuitionEntry.data.active !== false,
  display_order: tuitionEntry.data.display_order || 0,
  
  // Program fields
  name: tuitionEntry.data.name || '',
  program_type: tuitionEntry.data.program_type || '',
  days_per_week: tuitionEntry.data.days_per_week || 5,
  daily_hours: tuitionEntry.data.daily_hours || 6.5,
  description: tuitionEntry.data.description || '',
  
  // Rate fields
  rate_label: tuitionEntry.data.rate_label || '',
  program_id: tuitionEntry.data.program_id || '',
  tuition_price: tuitionEntry.data.tuition_price || 0,
  extended_care_price: tuitionEntry.data.extended_care_price || 0,
  extended_care_available: tuitionEntry.data.extended_care_available || false,
  is_constant_rate: tuitionEntry.data.is_constant_rate || false,
  school_year: tuitionEntry.data.school_year || '2025-2026',
  income_threshold_type: tuitionEntry.data.income_threshold_type || 'Greater Than or Equal To',
  income_threshold_family_2: tuitionEntry.data.income_threshold_family_2 || '',
  income_threshold_family_3: tuitionEntry.data.income_threshold_family_3 || '',
  income_threshold_family_4: tuitionEntry.data.income_threshold_family_4 || '',
  income_threshold_family_5: tuitionEntry.data.income_threshold_family_5 || '',
  income_threshold_family_6: tuitionEntry.data.income_threshold_family_6 || '',
  income_threshold_family_7: tuitionEntry.data.income_threshold_family_7 || '',
  income_threshold_family_8_plus: tuitionEntry.data.income_threshold_family_8_plus || '',
} : {
  // Default values for new entries
  slug: '',
  active: true,
  display_order: 0,
  
  // Program defaults
  name: '',
  program_type: '',
  days_per_week: 5,
  daily_hours: 6.5,
  description: '',
  
  // Rate defaults
  rate_label: '',
  program_id: '',
  tuition_price: 0,
  extended_care_price: 0,
  extended_care_available: false,
  is_constant_rate: false,
  school_year: '2025-2026',
  income_threshold_type: 'Greater Than or Equal To',
  income_threshold_family_2: '',
  income_threshold_family_3: '',
  income_threshold_family_4: '',
  income_threshold_family_5: '',
  income_threshold_family_6: '',
  income_threshold_family_7: '',
  income_threshold_family_8_plus: '',
};

// Options
const programTypeOptions = [
  { value: '', label: 'Select program type...' },
  { value: 'Full Day', label: 'Full Day' },
  { value: 'Half Day', label: 'Half Day' },
  { value: 'Extended Care', label: 'Extended Care' },
];

const programOptions = [
  { value: '', label: 'Select program...' },
  ...programs.map(program => ({
    value: program.slug,
    label: program.data.name || program.slug
  }))
];

const thresholdTypeOptions = [
  { value: 'Greater Than or Equal To', label: 'Greater Than or Equal To' },
  { value: 'Less Than', label: 'Less Than' },
];

const pageTitle = isEdit 
  ? `Edit: ${type === 'program' ? tuitionEntry?.data.name : tuitionEntry?.data.rate_label}` 
  : `New ${type === 'program' ? 'Program' : 'Tuition Rate'}`;

// Generate threshold form fields for family sizes 2-8+
const thresholdFields = Array.from({ length: 7 }, (_, i) => {
  const familySize = i + 2;
  const fieldName = (familySize <= 7) ? `income_threshold_family_${familySize}` : 'income_threshold_family_8_plus';
  const label = (familySize <= 7) ? `Family of ${familySize}` : 'Family of 8+';
  return { fieldName, label };
});
---

<AdminLayout title={pageTitle} description={isEdit ? `Edit ${type}` : `Add a new ${type}`}>
  <div class="tuition-editor">
    {errors.general && (
      <div class="error-banner" role="alert">
        {errors.general}
      </div>
    )}
    
    <form class="tuition-form" method="POST">
      <input type="hidden" name="type" value={type} />
      
      <div class="form-grid">
        <!-- Left Column: Main Information -->
        <div class="form-main">
          {type === 'program' ? (
            <!-- Program Fields -->
            <Fragment>
              <FormField
                label="Program Name"
                name="name"
                required
                help="The name of the educational program"
                error={errors.name}
              >
                <TextInput
                  name="name"
                  value={defaultData.name}
                  placeholder="Enter program name..."
                  required
                  maxLength={100}
                  data-slug-source
                />
              </FormField>
              
              <FormField
                label="Program Type"
                name="program_type"
                required
                help="The type of educational program"
                error={errors.program_type}
              >
                <SelectField
                  name="program_type"
                  value={defaultData.program_type}
                  options={programTypeOptions}
                  required
                />
              </FormField>
              
              <div class="form-row">
                <FormField
                  label="Days per Week"
                  name="days_per_week"
                  required
                  help="Number of operating days"
                  error={errors.days_per_week}
                >
                  <TextInput
                    name="days_per_week"
                    type="number"
                    value={defaultData.days_per_week.toString()}
                    min="1"
                    max="7"
                    required
                  />
                </FormField>
                
                <FormField
                  label="Daily Hours"
                  name="daily_hours"
                  required
                  help="Hours per day"
                  error={errors.daily_hours}
                >
                  <TextInput
                    name="daily_hours"
                    type="number"
                    step="0.5"
                    value={defaultData.daily_hours.toString()}
                    min="0.5"
                    max="12"
                    required
                  />
                </FormField>
              </div>
              
              <FormField
                label="Description"
                name="description"
                help="Detailed description of the program"
              >
                <TextArea
                  name="description"
                  value={defaultData.description}
                  rows={4}
                  placeholder="Describe the program, its focus, and what makes it unique..."
                />
              </FormField>
            </Fragment>
          ) : (
            <!-- Rate Fields -->
            <Fragment>
              <FormField
                label="Rate Label"
                name="rate_label"
                required
                help="A descriptive name for this rate"
                error={errors.rate_label}
              >
                <TextInput
                  name="rate_label"
                  value={defaultData.rate_label}
                  placeholder="e.g., Standard Rate, Income-Based Rate A, etc."
                  required
                  maxLength={100}
                  data-slug-source
                />
              </FormField>
              
              <FormField
                label="Associated Program"
                name="program_id"
                help="Link this rate to a specific program (optional)"
              >
                <SelectField
                  name="program_id"
                  value={defaultData.program_id}
                  options={programOptions}
                />
              </FormField>
              
              <div class="form-row">
                <FormField
                  label="Base Tuition Price"
                  name="tuition_price"
                  required
                  help="Monthly tuition amount"
                  error={errors.tuition_price}
                >
                  <TextInput
                    name="tuition_price"
                    type="number"
                    step="0.01"
                    value={defaultData.tuition_price.toString()}
                    min="0"
                    required
                  />
                </FormField>
                
                <FormField
                  label="School Year"
                  name="school_year"
                  required
                  help="Academic year for this rate"
                >
                  <TextInput
                    name="school_year"
                    value={defaultData.school_year}
                    placeholder="2025-2026"
                    required
                  />
                </FormField>
              </div>
              
              <FormField
                label="Rate Type"
                name="is_constant_rate"
                help="Whether this is a fixed rate or income-based"
              >
                <label class="toggle-wrapper">
                  <input
                    type="checkbox"
                    name="is_constant_rate"
                    checked={defaultData.is_constant_rate}
                    class="toggle-input"
                    data-constant-toggle
                  />
                  <span class="toggle-slider"></span>
                  <span class="toggle-label">Fixed Rate (no income thresholds)</span>
                </label>
              </FormField>
              
              <!-- Extended Care Section -->
              <div class="extended-care-section">
                <FormField
                  label="Extended Care Available"
                  name="extended_care_available"
                  help="Whether extended care is available for this rate"
                >
                  <label class="toggle-wrapper">
                    <input
                      type="checkbox"
                      name="extended_care_available"
                      checked={defaultData.extended_care_available}
                      class="toggle-input"
                      data-extended-toggle
                    />
                    <span class="toggle-slider"></span>
                    <span class="toggle-label">Extended care available</span>
                  </label>
                </FormField>
                
                <div class="extended-care-price" data-extended-section style={defaultData.extended_care_available ? '' : 'display: none;'}>
                  <FormField
                    label="Extended Care Price"
                    name="extended_care_price"
                    help="Additional monthly cost for extended care"
                    error={errors.extended_care_price}
                  >
                    <TextInput
                      name="extended_care_price"
                      type="number"
                      step="0.01"
                      value={defaultData.extended_care_price.toString()}
                      min="0"
                    />
                  </FormField>
                </div>
              </div>
              
              <!-- Income Thresholds Section -->
              <div class="income-thresholds-section" data-thresholds-section style={defaultData.is_constant_rate ? 'display: none;' : ''}>
                <h3 class="subsection-title">Income Thresholds</h3>
                <p class="subsection-description">
                  Set income thresholds for family sizes. Families with income matching the threshold type will qualify for this rate.
                </p>
                
                <FormField
                  label="Threshold Type"
                  name="income_threshold_type"
                  help="How family income is compared to thresholds"
                >
                  <SelectField
                    name="income_threshold_type"
                    value={defaultData.income_threshold_type}
                    options={thresholdTypeOptions}
                  />
                </FormField>
                
                <div class="thresholds-grid">
                  {thresholdFields.map(({ fieldName, label }) => (
                    <FormField
                      label={label}
                      name={fieldName}
                      help={`Income threshold for ${label.toLowerCase()}`}
                    >
                      <TextInput
                        name={fieldName}
                        type="number"
                        step="0.01"
                        value={defaultData[fieldName].toString()}
                        min="0"
                        placeholder="0"
                      />
                    </FormField>
                  ))}
                </div>
              </div>
            </Fragment>
          )}
        </div>
        
        <!-- Right Column: Settings & Actions -->
        <div class="form-sidebar">
          <!-- Common Settings -->
          <div class="form-section">
            <h3 class="section-title">Settings</h3>
            
            <FormField
              label="URL Slug"
              name="slug"
              required
              help="URL-friendly identifier"
              error={errors.slug}
            >
              <TextInput
                name="slug"
                value={defaultData.slug}
                pattern="^[a-z0-9-]+$"
                placeholder="url-friendly-slug"
                required
                data-slug-target
              />
            </FormField>
            
            <FormField
              label="Display Order"
              name="display_order"
              help="Order in lists (lower numbers first)"
            >
              <TextInput
                name="display_order"
                type="number"
                value={defaultData.display_order.toString()}
                min="0"
                max="999"
              />
            </FormField>
            
            <FormField
              label="Status"
              name="active"
              help="Whether this item is active and visible"
            >
              <label class="toggle-wrapper">
                <input
                  type="checkbox"
                  name="active"
                  checked={defaultData.active}
                  class="toggle-input"
                />
                <span class="toggle-slider"></span>
                <span class="toggle-label">Active (visible to users)</span>
              </label>
            </FormField>
          </div>
          
          <!-- Preview -->
          <div class="form-section">
            <h3 class="section-title">Preview</h3>
            
            <div class="preview-card" data-preview-card>
              <div class="preview-header">
                <h4 class="preview-title" data-preview-title>
                  {type === 'program' ? defaultData.name || 'Program Name' : defaultData.rate_label || 'Rate Label'}
                </h4>
                <div class="preview-badges">
                  {type === 'program' ? (
                    <span class="preview-badge" data-preview-type>{defaultData.program_type || 'Type'}</span>
                  ) : (
                    <span class="preview-badge" data-preview-rate-type">
                      {defaultData.is_constant_rate ? 'Fixed Rate' : 'Income-Based'}
                    </span>
                  )}
                  <span class={`preview-badge ${defaultData.active ? 'active' : 'inactive'}`} data-preview-status>
                    {defaultData.active ? 'Active' : 'Inactive'}
                  </span>
                </div>
              </div>
              
              <div class="preview-content">
                {type === 'program' ? (
                  <div class="preview-program-info" data-preview-program-info>
                    <p>{defaultData.days_per_week} days/week • {defaultData.daily_hours} hours/day</p>
                    {defaultData.description && (
                      <p class="preview-description">{defaultData.description}</p>
                    )}
                  </div>
                ) : (
                  <div class="preview-rate-info" data-preview-rate-info>
                    <div class="preview-price">
                      <span class="price-amount" data-preview-price">${defaultData.tuition_price || 0}/month</span>
                    </div>
                    {defaultData.extended_care_available && (
                      <div class="preview-extended">
                        <span class="extended-price" data-preview-extended">+${defaultData.extended_care_price || 0} Extended Care</span>
                      </div>
                    )}
                  </div>
                )}
              </div>
            </div>
          </div>
          
          <!-- Actions -->
          <div class="form-actions">
            <button type="submit" class="btn btn--primary">
              {isEdit ? `Update ${type === 'program' ? 'Program' : 'Rate'}` : `Add ${type === 'program' ? 'Program' : 'Rate'}`}
            </button>
            <a href="/admin/tuition" class="btn btn--secondary">Cancel</a>
          </div>
        </div>
      </div>
    </form>
  </div>
</AdminLayout>

<script define:vars={{ type }}>
  // Auto-generate slug from name/label
  const nameInput = document.querySelector('[data-slug-source]');
  const slugInput = document.querySelector('[data-slug-target]');
  
  if (nameInput && slugInput) {
    nameInput.addEventListener('input', () => {
      if (!slugInput.value || slugInput.dataset.autoGenerated === 'true') {
        const slug = nameInput.value
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, '');
        slugInput.value = slug;
        slugInput.dataset.autoGenerated = 'true';
        updatePreview();
      }
    });
    
    slugInput.addEventListener('input', () => {
      delete slugInput.dataset.autoGenerated;
    });
  }
  
  // Handle constant rate toggle for rates
  if (type === 'rate') {
    const constantToggle = document.querySelector('[data-constant-toggle]');
    const thresholdsSection = document.querySelector('[data-thresholds-section]');
    
    if (constantToggle && thresholdsSection) {
      constantToggle.addEventListener('change', () => {
        const isConstant = constantToggle.checked;
        thresholdsSection.style.display = isConstant ? 'none' : 'block';
        updatePreview();
      });
    }
    
    // Handle extended care toggle
    const extendedToggle = document.querySelector('[data-extended-toggle]');
    const extendedSection = document.querySelector('[data-extended-section]');
    
    if (extendedToggle && extendedSection) {
      extendedToggle.addEventListener('change', () => {
        const isExtended = extendedToggle.checked;
        extendedSection.style.display = isExtended ? 'block' : 'none';
        updatePreview();
      });
    }
  }
  
  // Update preview function
  function updatePreview() {
    const previewTitle = document.querySelector('[data-preview-title]');
    const previewStatus = document.querySelector('[data-preview-status]');
    
    if (type === 'program') {
      const nameInput = document.querySelector('input[name="name"]');
      const typeSelect = document.querySelector('select[name="program_type"]');
      const daysInput = document.querySelector('input[name="days_per_week"]');
      const hoursInput = document.querySelector('input[name="daily_hours"]');
      const previewType = document.querySelector('[data-preview-type]');
      const previewProgramInfo = document.querySelector('[data-preview-program-info]');
      
      if (previewTitle && nameInput) {
        previewTitle.textContent = nameInput.value || 'Program Name';
      }
      
      if (previewType && typeSelect) {
        previewType.textContent = typeSelect.value || 'Type';
      }
      
      if (previewProgramInfo && daysInput && hoursInput) {
        const days = daysInput.value || 5;
        const hours = hoursInput.value || 6.5;
        previewProgramInfo.querySelector('p').textContent = `${days} days/week • ${hours} hours/day`;
      }
      
    } else if (type === 'rate') {
      const labelInput = document.querySelector('input[name="rate_label"]');
      const priceInput = document.querySelector('input[name="tuition_price"]');
      const extendedPriceInput = document.querySelector('input[name="extended_care_price"]');
      const constantToggle = document.querySelector('[data-constant-toggle]');
      const extendedToggle = document.querySelector('[data-extended-toggle]');
      const previewRateType = document.querySelector('[data-preview-rate-type]');
      const previewPrice = document.querySelector('[data-preview-price]');
      const previewExtended = document.querySelector('[data-preview-extended]');
      
      if (previewTitle && labelInput) {
        previewTitle.textContent = labelInput.value || 'Rate Label';
      }
      
      if (previewRateType && constantToggle) {
        previewRateType.textContent = constantToggle.checked ? 'Fixed Rate' : 'Income-Based';
      }
      
      if (previewPrice && priceInput) {
        const price = parseFloat(priceInput.value) || 0;
        previewPrice.textContent = `$${price}/month`;
      }
      
      if (previewExtended && extendedPriceInput && extendedToggle) {
        if (extendedToggle.checked) {
          const extendedPrice = parseFloat(extendedPriceInput.value) || 0;
          previewExtended.textContent = `+$${extendedPrice} Extended Care`;
          previewExtended.parentElement.style.display = 'block';
        } else {
          previewExtended.parentElement.style.display = 'none';
        }
      }
    }
    
    // Update status badge
    const activeToggle = document.querySelector('input[name="active"]');
    if (previewStatus && activeToggle) {
      const isActive = activeToggle.checked;
      previewStatus.textContent = isActive ? 'Active' : 'Inactive';
      previewStatus.className = `preview-badge ${isActive ? 'active' : 'inactive'}`;
    }
  }
  
  // Add event listeners to update preview
  const formInputs = document.querySelectorAll('input, select, textarea');
  formInputs.forEach(input => {
    input.addEventListener('input', updatePreview);
    input.addEventListener('change', updatePreview);
  });
  
  // Initial preview update
  updatePreview();
</script>

