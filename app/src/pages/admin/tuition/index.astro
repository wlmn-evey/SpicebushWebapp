---
/**
 * Tuition Programs Management - List View
 * 
 * Displays all tuition programs and rates in a manageable list with options 
 * to edit, add new programs, and manage pricing structures.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '../../../lib/admin-auth-check';
import { getCollection } from '../../../lib/content-db';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect('/auth/login?redirect=' + Astro.url.pathname);
}

// Load tuition entries
const tuitionEntries = await getCollection('tuition');

// Separate programs and rates
const programs = tuitionEntries.filter(entry => entry.data.type === 'program');
const rates = tuitionEntries.filter(entry => entry.data.type === 'rate');

// Sort by display order
const sortedPrograms = programs.sort((a, b) => (a.data.display_order || 0) - (b.data.display_order || 0));
const sortedRates = rates.sort((a, b) => (a.data.display_order || 0) - (b.data.display_order || 0));

// Get status from URL
const status = Astro.url.searchParams.get('status');
const message = Astro.url.searchParams.get('success') || Astro.url.searchParams.get('error');

// Helper functions
function formatPrice(price: number | undefined): string {
  if (!price) return 'Not set';
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(price);
}

function getStatusBadge(active: boolean | undefined): string {
  return active !== false
    ? 'bg-green-100 text-green-800' 
    : 'bg-gray-100 text-gray-800';
}

function getStatusText(active: boolean | undefined): string {
  return active !== false ? 'Active' : 'Inactive';
}

function getProgramTypeBadge(type: string): string {
  const badges = {
    'Full Day': 'bg-blue-100 text-blue-800',
    'Half Day': 'bg-yellow-100 text-yellow-800',
    'Extended Care': 'bg-purple-100 text-purple-800'
  };
  return badges[type] || 'bg-gray-100 text-gray-800';
}

function getRateTypeBadge(isConstant: boolean | undefined): string {
  return isConstant 
    ? 'bg-green-100 text-green-800' 
    : 'bg-orange-100 text-orange-800';
}

function getRateTypeText(isConstant: boolean | undefined): string {
  return isConstant ? 'Fixed Rate' : 'Income-Based';
}
---

<AdminLayout title="Tuition Management" description="Manage tuition programs, rates, and pricing structures">
  <div class="tuition-management">
    <!-- Status Messages -->
    {message && (
      <div class={`status-message ${status === 'error' ? 'status-message--error' : 'status-message--success'}`} role="alert">
        {message}
      </div>
    )}
    
    <!-- Header -->
    <div class="page-header">
      <div class="page-header__content">
        <h1 class="page-title">Tuition Management</h1>
        <p class="page-description">
          Manage tuition programs, pricing rates, and calculator settings for the school.
        </p>
      </div>
      <div class="page-header__actions">
        <a href="/admin/tuition/edit?type=program" class="btn btn--secondary">
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          Add Program
        </a>
        <a href="/admin/tuition/edit?type=rate" class="btn btn--primary">
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
          </svg>
          Add Rate
        </a>
      </div>
    </div>
    
    <!-- Stats Summary -->
    <div class="stats-bar">
      <div class="stat">
        <span class="stat-number">{sortedPrograms.length}</span>
        <span class="stat-label">Programs</span>
      </div>
      <div class="stat">
        <span class="stat-number">{sortedRates.length}</span>
        <span class="stat-label">Rates</span>
      </div>
      <div class="stat">
        <span class="stat-number">{sortedPrograms.filter(p => p.data.active !== false).length}</span>
        <span class="stat-label">Active Programs</span>
      </div>
      <div class="stat">
        <span class="stat-number">{sortedRates.filter(r => r.data.active !== false).length}</span>
        <span class="stat-label">Active Rates</span>
      </div>
    </div>
    
    <!-- Programs Section -->
    <div class="content-section">
      <div class="section-header">
        <div class="section-header__content">
          <h2 class="section-title">
            <svg class="section-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            Programs
          </h2>
          <p class="section-description">Educational programs and their configurations</p>
        </div>
        <a href="/admin/tuition/edit?type=program" class="btn btn--secondary btn--sm">
          Add Program
        </a>
      </div>
      
      {sortedPrograms.length > 0 ? (
        <div class="programs-grid">
          {sortedPrograms.map(program => (
            <div class="program-card">
              <div class="program-card__header">
                <div class="program-info">
                  <h3 class="program-name">{program.data.name}</h3>
                  <div class="program-badges">
                    <span class={`badge ${getProgramTypeBadge(program.data.program_type || '')}`}>
                      {program.data.program_type}
                    </span>
                    <span class={`badge ${getStatusBadge(program.data.active)}`}>
                      {getStatusText(program.data.active)}
                    </span>
                  </div>
                </div>
                <div class="program-actions">
                  <a href={`/admin/tuition/edit?type=program&slug=${program.slug}`} class="action-btn action-btn--edit">
                    <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </a>
                  <button 
                    class="action-btn action-btn--delete" 
                    data-delete-program={program.slug}
                    data-program-name={program.data.name}
                  >
                    <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              </div>
              
              <div class="program-card__content">
                <div class="program-details">
                  <div class="detail-item">
                    <svg class="detail-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span>{program.data.days_per_week || 5} days/week</span>
                  </div>
                  <div class="detail-item">
                    <svg class="detail-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>{program.data.daily_hours || 6.5} hours/day</span>
                  </div>
                </div>
                
                {program.data.description && (
                  <p class="program-description">{program.data.description}</p>
                )}
              </div>
              
              <div class="program-card__footer">
                <span class="program-order">Order: {program.data.display_order || 0}</span>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <svg class="empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <h3>No Programs Configured</h3>
          <p>Add your first educational program to get started with tuition management.</p>
          <a href="/admin/tuition/edit?type=program" class="btn btn--primary">Add First Program</a>
        </div>
      )}
    </div>
    
    <!-- Rates Section -->
    <div class="content-section">
      <div class="section-header">
        <div class="section-header__content">
          <h2 class="section-title">
            <svg class="section-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
            </svg>
            Tuition Rates
          </h2>
          <p class="section-description">Pricing rates and income thresholds</p>
        </div>
        <a href="/admin/tuition/edit?type=rate" class="btn btn--primary btn--sm">
          Add Rate
        </a>
      </div>
      
      {sortedRates.length > 0 ? (
        <div class="rates-grid">
          {sortedRates.map(rate => (
            <div class="rate-card">
              <div class="rate-card__header">
                <div class="rate-info">
                  <h3 class="rate-name">{rate.data.rate_label}</h3>
                  <div class="rate-badges">
                    <span class={`badge ${getRateTypeBadge(rate.data.is_constant_rate)}`}>
                      {getRateTypeText(rate.data.is_constant_rate)}
                    </span>
                    <span class={`badge ${getStatusBadge(rate.data.active)}`}>
                      {getStatusText(rate.data.active)}
                    </span>
                  </div>
                </div>
                <div class="rate-actions">
                  <a href={`/admin/tuition/edit?type=rate&slug=${rate.slug}`} class="action-btn action-btn--edit">
                    <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </a>
                  <button 
                    class="action-btn action-btn--delete" 
                    data-delete-rate={rate.slug}
                    data-rate-name={rate.data.rate_label}
                  >
                    <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              </div>
              
              <div class="rate-card__content">
                <div class="price-display">
                  <span class="price-label">Base Tuition</span>
                  <span class="price-amount">{formatPrice(rate.data.tuition_price)}</span>
                </div>
                
                {rate.data.extended_care_available && (
                  <div class="price-display">
                    <span class="price-label">Extended Care</span>
                    <span class="price-amount">{formatPrice(rate.data.extended_care_price)}</span>
                  </div>
                )}
                
                <div class="rate-details">
                  <div class="detail-item">
                    <svg class="detail-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span>{rate.data.school_year || '2025-2026'}</span>
                  </div>
                  {rate.data.program_id && (
                    <div class="detail-item">
                      <svg class="detail-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                      </svg>
                      <span>Program: {rate.data.program_id}</span>
                    </div>
                  )}
                </div>
              </div>
              
              <div class="rate-card__footer">
                <span class="rate-order">Order: {rate.data.display_order || 0}</span>
                {!rate.data.is_constant_rate && (
                  <span class="income-based-note">
                    <svg class="note-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Income-based thresholds configured
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <svg class="empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
          </svg>
          <h3>No Rates Configured</h3>
          <p>Add your first tuition rate to enable the tuition calculator.</p>
          <a href="/admin/tuition/edit?type=rate" class="btn btn--primary">Add First Rate</a>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  // Handle delete confirmations
  document.addEventListener('DOMContentLoaded', () => {
    const deleteButtons = document.querySelectorAll('[data-delete-program], [data-delete-rate]');
    
    deleteButtons.forEach(button => {
      button.addEventListener('click', async (e) => {
        const isProgram = e.currentTarget.hasAttribute('data-delete-program');
        const slug = isProgram ? e.currentTarget.dataset.deleteProgram : e.currentTarget.dataset.deleteRate;
        const name = isProgram ? e.currentTarget.dataset.programName : e.currentTarget.dataset.rateName;
        const type = isProgram ? 'program' : 'rate';
        
        if (!confirm(`Are you sure you want to delete ${name}? This action cannot be undone.`)) {
          return;
        }
        
        try {
          const response = await fetch('/api/cms/entry', {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              type: 'tuition',
              slug: slug
            })
          });
          
          if (response.ok) {
            window.location.href = `/admin/tuition?success=${type.charAt(0).toUpperCase() + type.slice(1)} deleted successfully`;
          } else {
            alert(`Failed to delete ${type}. Please try again.`);
          }
        } catch (error) {
          console.error('Delete error:', error);
          alert('An error occurred while deleting. Please try again.');
        }
      });
    });
  });
</script>

<style>
