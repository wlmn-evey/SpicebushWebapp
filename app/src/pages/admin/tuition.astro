---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@lib/db';

const collection = 'tuition';
const entries = await db.content.getCollection(collection);
const sortedEntries = [...entries].sort((a, b) => a.slug.localeCompare(b.slug));

const savedSlug = Astro.url.searchParams.get('saved');
const errorMessage = Astro.url.searchParams.get('error');

const toJson = (value: unknown): string => JSON.stringify(value ?? {}, null, 2);
---

<AdminLayout title="Manage Tuition">
  {savedSlug && (
    <p class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
      Saved entry: <strong>{savedSlug}</strong>
    </p>
  )}

  {errorMessage && (
    <p class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
      {errorMessage}
    </p>
  )}

  <div class="space-y-6">
    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold mb-3">Create New Tuition Entry</h2>
      <form method="post" action="/api/admin/content" class="space-y-3">
        <input type="hidden" name="collection" value={collection} />
        <input type="hidden" name="redirectTo" value="/admin/tuition?saved=new" />
        <input
          type="text"
          name="slug"
          placeholder="Slug (example: full-day-5-days)"
          required
          class="w-full rounded-lg border border-gray-300 px-3 py-2"
        />
        <input
          type="text"
          name="title"
          placeholder="Title"
          class="w-full rounded-lg border border-gray-300 px-3 py-2"
        />
        <select name="status" class="w-full rounded-lg border border-gray-300 px-3 py-2">
          <option value="published">Published</option>
          <option value="draft">Draft</option>
        </select>
        <textarea
          name="dataJson"
          rows="12"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-sm"
        >{toJson({ type: 'program', name: 'Full Day - 5 Days', program_type: 'Full Day', days_per_week: 5, daily_hours: 6.5, description: 'Program description', display_order: 1, active: true })}</textarea>
        <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
          Create Entry
        </button>
      </form>
    </section>

    {sortedEntries.map((entry) => (
      <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <h3 class="text-lg font-semibold mb-3">Edit: {entry.slug}</h3>
        <form method="post" action="/api/admin/content" class="space-y-3">
          <input type="hidden" name="collection" value={collection} />
          <input type="hidden" name="redirectTo" value={`/admin/tuition?saved=${encodeURIComponent(entry.slug)}`} />

          <label class="block text-sm font-medium">
            Slug
            <input
              type="text"
              name="slug"
              value={entry.slug}
              required
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>

          <label class="block text-sm font-medium">
            Title
            <input
              type="text"
              name="title"
              value={entry.data.title ?? entry.slug}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>

          <label class="block text-sm font-medium">
            Status
            <select name="status" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="published">Published</option>
              <option value="draft">Draft</option>
            </select>
          </label>

          <label class="block text-sm font-medium">
            Data JSON
            <textarea
              name="dataJson"
              rows="14"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-sm"
            >{toJson(entry.data)}</textarea>
          </label>

          <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
            Save {entry.slug}
          </button>
        </form>
      </section>
    ))}
  </div>
</AdminLayout>

