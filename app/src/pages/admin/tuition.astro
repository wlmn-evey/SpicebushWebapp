---
// DEPRECATED: Use CMS instead at /admin/cms#/collections/tuition
return Astro.redirect('/admin/cms#/collections/tuition');

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TuitionQuickActions from '../../components/admin/TuitionQuickActions.astro';
import ProgramsManagement from '../../components/admin/ProgramsManagement.astro';
import TuitionRatesTable from '../../components/admin/TuitionRatesTable.astro';
import TuitionSettings from '../../components/admin/TuitionSettings.astro';
import { X, ArrowLeft } from 'lucide-astro';
---

<Layout 
  title="Manage Tuition Rates - Admin Panel"
  description="Administrative interface for managing tuition rates, programs, and calculator settings."
  keywords="admin, tuition management, rates, programs"
>
  <Header />
  
  <main id="main-content">
    <!-- Admin Auth Check -->
    <script>
      import { auth } from '../../lib/supabase.ts';
      
      document.addEventListener('DOMContentLoaded', async function() {
        try {
          const user = await auth.getCurrentUser();
          if (!user) {
            window.location.href = '/auth/login';
            return;
          }
        } catch (error) {
          console.error('Error checking authentication:', error);
          window.location.href = '/auth/login';
        }
      });
    </script>

    <!-- Header -->
    <section class="bg-gradient-to-br from-sunlight-gold to-orange-600 py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Back to Dashboard Navigation -->
          <div class="mb-6">
            <a href="/admin" class="inline-flex items-center text-orange-200 hover:text-white transition-colors group">
              <ArrowLeft className="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" />
              <span class="text-sm font-medium">Back to Admin Dashboard</span>
            </a>
          </div>
          
          <div>
            <h1 class="text-3xl lg:text-4xl font-heading font-bold text-white mb-4 tracking-tight">
            Manage Tuition System
          </h1>
            <p class="text-orange-100 text-lg max-w-3xl">
            Update tuition rates, programs, and calculator settings.
          </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Management Interface -->
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4 max-w-7xl">
        
        <TuitionQuickActions />
        <ProgramsManagement />
        <TuitionRatesTable />
        <TuitionSettings />
      </div>
    </section>

    <!-- Rate/Program Edit Modal -->
    <div id="edit-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
      <div class="relative top-20 mx-auto p-5 border w-11/12 md:w-3/4 lg:w-1/2 shadow-lg rounded-md bg-white">
        <div class="flex items-center justify-between pb-3 border-b border-gray-200">
          <h3 id="modal-title" class="text-lg font-bold text-earth-brown">Edit Item</h3>
          <button id="close-modal" class="text-gray-400 hover:text-gray-600">
            <X className="w-6 h-6" />
          </button>
        </div>
        <div id="modal-content" class="mt-4">
          <!-- Modal content will be populated here -->
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
  import { supabase } from '../../lib/supabase.ts';
  import { 
    createProgramForm, 
    createRateForm, 
    renderPrograms, 
    renderRates, 
    populateSettings 
  } from '../../lib/tuition-forms.ts';

  document.addEventListener('DOMContentLoaded', async function() {
    let programs: any[] = [];
    let rates: any[] = [];
    let settings: Record<string, any> = {};

    // Load all data
    async function loadData() {
      try {
        const [programsResponse, ratesResponse, settingsResponse] = await Promise.all([
          supabase.from('tuition_programs').select('*').order('display_order'),
          supabase.from('tuition_rates').select('*').order('display_order'),
          supabase.from('tuition_settings').select('*')
        ]);

        programs = programsResponse.data || [];
        rates = ratesResponse.data || [];
        
        // Convert settings array to object
        settings = {};
        (settingsResponse.data || []).forEach((setting: any) => {
          try {
            settings[setting.setting_key] = JSON.parse(setting.setting_value);
          } catch {
            settings[setting.setting_key] = setting.setting_value;
          }
        });

        renderPrograms(programs);
        renderRates(rates, programs);
        populateSettings(settings);
      } catch (error) {
        console.error('Error loading data:', error);
      }
    }

    // Functions moved to tuition-forms.ts utility

    // Global functions for editing/deleting
    (window as any).editProgram = function(id: string) {
      const program = programs.find((p: any) => p.id === id);
      showEditModal('Edit Program', createProgramForm(program));
    };

    (window as any).editRate = function(id: string) {
      const rate = rates.find((r: any) => r.id === id);
      showEditModal('Edit Tuition Rate', createRateForm(rate, programs));
    };

    (window as any).deleteProgram = async function(id: string) {
      if (!confirm('Are you sure you want to delete this program?')) return;
      
      try {
        const { error } = await supabase.from('tuition_programs').delete().eq('id', id);
        if (error) throw error;
        await loadData();
      } catch (error) {
        console.error('Error deleting program:', error);
        alert('Error deleting program');
      }
    };

    (window as any).deleteRate = async function(id: string) {
      if (!confirm('Are you sure you want to delete this rate?')) return;
      
      try {
        const { error } = await supabase.from('tuition_rates').delete().eq('id', id);
        if (error) throw error;
        await loadData();
      } catch (error) {
        console.error('Error deleting rate:', error);
        alert('Error deleting rate');
      }
    };

    // Modal functions
    function showEditModal(title, content) {
      document.getElementById('modal-title').textContent = title;
      document.getElementById('modal-content').innerHTML = content;
      document.getElementById('edit-modal').classList.remove('hidden');
    }

    function hideEditModal() {
      document.getElementById('edit-modal').classList.add('hidden');
    }

    // Form creation functions moved to tuition-forms.ts utility

    // Event listeners
    document.getElementById('close-modal').addEventListener('click', hideEditModal);
    
    document.getElementById('add-program-btn')?.addEventListener('click', () => {
      showEditModal('Add New Program', createProgramForm());
    });
    
    document.getElementById('add-rate-btn')?.addEventListener('click', () => {
      showEditModal('Add New Rate', createRateForm(null, programs));
    });

    // Form submission handlers
    document.addEventListener('submit', async function(e) {
      if (e.target.id === 'program-form') {
        e.preventDefault();
        const formData = new FormData(e.target);
        const programData = {
          name: formData.get('name') || document.getElementById('program-name').value,
          program_type: document.getElementById('program-type').value,
          days_per_week: parseInt(document.getElementById('program-days').value),
          daily_hours: parseFloat(document.getElementById('program-hours').value),
          description: document.getElementById('program-description').value
        };

        const programId = document.getElementById('program-id').value;
        
        try {
          if (programId) {
            const { error } = await supabase
              .from('tuition_programs')
              .update(programData)
              .eq('id', programId);
            if (error) throw error;
          } else {
            const { error } = await supabase
              .from('tuition_programs')
              .insert([programData]);
            if (error) throw error;
          }
          
          hideEditModal();
          await loadData();
        } catch (error) {
          console.error('Error saving program:', error);
          alert('Error saving program');
        }
      }
      
      if (e.target.id === 'rate-form') {
        e.preventDefault();
        const rateData = {
          rate_label: document.getElementById('rate-label').value,
          program_id: document.getElementById('rate-program').value,
          tuition_price: parseFloat(document.getElementById('rate-price').value),
          extended_care_price: parseFloat(document.getElementById('rate-extended-price').value) || 0,
          income_threshold_family_2: parseFloat(document.getElementById('rate-threshold-2').value) || null,
          income_threshold_family_3: parseFloat(document.getElementById('rate-threshold-3').value) || null,
          income_threshold_family_4: parseFloat(document.getElementById('rate-threshold-4').value) || null,
          income_threshold_family_5: parseFloat(document.getElementById('rate-threshold-5').value) || null,
          income_threshold_family_6: parseFloat(document.getElementById('rate-threshold-6').value) || null,
          income_threshold_family_7: parseFloat(document.getElementById('rate-threshold-7').value) || null,
          income_threshold_family_8_plus: parseFloat(document.getElementById('rate-threshold-8').value) || null,
          income_threshold_type: document.getElementById('rate-threshold-type').value,
          extended_care_available: document.getElementById('rate-extended-available').checked,
          is_constant_rate: document.getElementById('rate-constant').checked,
          school_year: document.getElementById('rate-school-year').value,
          active: document.getElementById('rate-active').checked,
          display_order: parseInt(document.getElementById('rate-display-order').value) || 0
        };

        const rateId = document.getElementById('rate-id').value;
        
        try {
          if (rateId) {
            const { error } = await supabase
              .from('tuition_rates')
              .update(rateData)
              .eq('id', rateId);
            if (error) throw error;
          } else {
            const { error } = await supabase
              .from('tuition_rates')
              .insert([rateData]);
            if (error) throw error;
          }
          
          hideEditModal();
          await loadData();
        } catch (error) {
          console.error('Error saving rate:', error);
          alert('Error saving rate');
        }
      }

      if (e.target.id === 'settings-form') {
        e.preventDefault();
        const settingsData = [
          { setting_key: 'current_school_year', setting_value: JSON.stringify(document.getElementById('school-year').value) },
          { setting_key: 'upfront_discount_rate', setting_value: (parseFloat(document.getElementById('upfront-discount').value) / 100).toString() },
          { setting_key: 'sibling_discount_rate', setting_value: (parseFloat(document.getElementById('sibling-discount').value) / 100).toString() },
          { setting_key: 'annual_increase_rate', setting_value: (parseFloat(document.getElementById('annual-increase').value) / 100).toString() }
        ];

        try {
          for (const setting of settingsData) {
            const { error } = await supabase
              .from('tuition_settings')
              .upsert(setting, { onConflict: 'setting_key' });
            if (error) throw error;
          }
          
          alert('Settings saved successfully!');
          await loadData();
        } catch (error) {
          console.error('Error saving settings:', error);
          alert('Error saving settings');
        }
      }
    });

    // Focus button handlers are now in individual components

    // Make functions globally available
    (window as any).hideEditModal = hideEditModal;

    // Initialize
    loadData();
  });
</script>