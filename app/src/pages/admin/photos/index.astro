---
/**
 * Photo Management - List View
 * 
 * Displays all uploaded photos in a manageable grid with options 
 * to view, edit metadata, and delete photos from the media library.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect(`/auth/netlify-login?redirect=${Astro.url.pathname}`);
}

// Load photos from media table
let photos = [];
let loadError = null;

try {
  const { supabase } = await import('@lib/supabase');
  const { data, error } = await supabase
    .from('media')
    .select('*')
    .order('uploaded_at', { ascending: false });
  
  if (error) throw error;
  
  photos = data || [];
} catch (error) {
  console.error('Error loading photos:', error);
  loadError = 'Failed to load photos. Please try refreshing the page.';
}

// Get status from URL
const status = Astro.url.searchParams.get('status');
const message = Astro.url.searchParams.get('success') || Astro.url.searchParams.get('error');

// Helper functions
function formatFileSize(bytes: number): string {
  if (bytes === 0) return '0 Bytes';
  const k = 1024;
  const sizes = ['Bytes', 'KB', 'MB', 'GB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return `${parseFloat((bytes / Math.pow(k, i)).toFixed(2))  } ${  sizes[i]}`;
}

function formatDate(dateString: string): string {
  try {
    return new Date(dateString).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  } catch {
    return 'Unknown date';
  }
}

function getFileTypeIcon(mimetype: string): string {
  if (mimetype.startsWith('image/')) {
    return 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z';
  }
  if (mimetype === 'application/pdf') {
    return 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z';
  }
  return 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z';
}

// Calculate stats
const totalPhotos = photos.length;
const totalSize = photos.reduce((sum, photo) => sum + (photo.size || 0), 0);
const imagePhotos = photos.filter(photo => photo.mimetype?.startsWith('image/')).length;
const recentPhotos = photos.filter(photo => {
  const uploadDate = new Date(photo.uploaded_at);
  const sevenDaysAgo = new Date();
  sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
  return uploadDate > sevenDaysAgo;
}).length;
---

<AdminLayout title="Photo Management" description="Manage uploaded photos and media library">
  <div class="photo-management">
    <!-- Status Messages -->
    {message && (
      <div class={`status-message ${status === 'error' ? 'status-message--error' : 'status-message--success'}`} role="alert">
        {message}
      </div>
    )}
    
    {loadError && (
      <div class="status-message status-message--error" role="alert">
        {loadError}
      </div>
    )}
    
    <!-- Header -->
    <div class="page-header">
      <div class="page-header__content">
        <h1 class="page-title">Photo Management</h1>
        <p class="page-description">
          Manage your uploaded photos and media files. View, organize, and delete photos from your media library.
        </p>
      </div>
      <div class="page-header__actions">
        <a href="/admin/photos/upload" class="btn btn--primary">
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          Upload Photos
        </a>
      </div>
    </div>
    
    <!-- Stats Summary -->
    <div class="stats-bar">
      <div class="stat">
        <span class="stat-number">{totalPhotos}</span>
        <span class="stat-label">Total Files</span>
      </div>
      <div class="stat">
        <span class="stat-number">{imagePhotos}</span>
        <span class="stat-label">Images</span>
      </div>
      <div class="stat">
        <span class="stat-number">{recentPhotos}</span>
        <span class="stat-label">Recent (7 days)</span>
      </div>
      <div class="stat">
        <span class="stat-number">{formatFileSize(totalSize)}</span>
        <span class="stat-label">Total Size</span>
      </div>
    </div>
    
    <!-- Photos Grid -->
    <div class="content-section">
      <div class="section-header">
        <div class="section-header__content">
          <h2 class="section-title">
            <svg class="section-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Media Library
          </h2>
          <p class="section-description">All uploaded photos and media files</p>
        </div>
        <div class="section-actions">
          <button class="btn btn--secondary btn--sm" id="grid-view-btn">
            <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
            Grid
          </button>
          <button class="btn btn--secondary btn--sm" id="list-view-btn">
            <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            List
          </button>
        </div>
      </div>
      
      {photos.length > 0 ? (
        <div class="photos-grid" id="photos-container">
          {photos.map(photo => (
            <div class="photo-card" data-photo-id={photo.id}>
              <div class="photo-card__preview">
                {photo.mimetype?.startsWith('image/') ? (
                  <img 
                    src={photo.url} 
                    alt={photo.title || photo.filename} 
                    class="photo-image"
                    loading="lazy"
                  />
                ) : (
                  <div class="file-icon">
                    <svg class="file-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={getFileTypeIcon(photo.mimetype)} />
                    </svg>
                    <span class="file-type">{photo.mimetype?.split('/')[1]?.toUpperCase()}</span>
                  </div>
                )}
                
                <div class="photo-overlay">
                  <div class="photo-actions">
                    <button 
                      class="action-btn action-btn--view" 
                      data-photo-url={photo.url}
                      data-photo-title={photo.title || photo.filename}
                      title="View full size"
                    >
                      <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                    </button>
                    <button 
                      class="action-btn action-btn--delete" 
                      data-delete-photo={photo.id}
                      data-photo-name={photo.title || photo.filename}
                      title="Delete photo"
                    >
                      <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
              
              <div class="photo-card__info">
                <h3 class="photo-title">{photo.title || photo.filename}</h3>
                {photo.description && (
                  <p class="photo-description">{photo.description}</p>
                )}
                
                <div class="photo-meta">
                  <div class="meta-item">
                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>{formatDate(photo.uploaded_at)}</span>
                  </div>
                  <div class="meta-item">
                    <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <span>{formatFileSize(photo.size || 0)}</span>
                  </div>
                </div>
                
                {photo.tags && photo.tags.length > 0 && (
                  <div class="photo-tags">
                    {photo.tags.map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <svg class="empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <h3>No Photos Yet</h3>
          <p>Upload your first photo to get started with the media library.</p>
          <a href="/admin/photos/upload" class="btn btn--primary">Upload First Photo</a>
        </div>
      )}
    </div>
  </div>

  <!-- Photo Viewer Modal -->
  <div id="photo-modal" class="modal" role="dialog" aria-hidden="true">
    <div class="modal-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title" id="modal-title">Photo View</h3>
        <button class="modal-close" aria-label="Close modal">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <img id="modal-image" src="" alt="" class="modal-image" />
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Photo viewer modal
  const modal = document.getElementById('photo-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalImage = document.getElementById('modal-image');
  const modalClose = document.querySelector('.modal-close');
  const modalBackdrop = document.querySelector('.modal-backdrop');

  // View photo functionality
  document.addEventListener('click', (e) => {
    const viewBtn = e.target.closest('[data-photo-url]');
    if (viewBtn) {
      const url = viewBtn.dataset.photoUrl;
      const title = viewBtn.dataset.photoTitle;
      
      modalTitle.textContent = title;
      modalImage.src = url;
      modalImage.alt = title;
      modal.classList.add('modal--open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
  });

  // Close modal
  function closeModal() {
    modal.classList.remove('modal--open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);

  // Escape key to close modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('modal--open')) {
      closeModal();
    }
  });

  // Delete functionality
  document.addEventListener('click', async (e) => {
    const deleteBtn = e.target.closest('[data-delete-photo]');
    if (deleteBtn) {
      const photoId = deleteBtn.dataset.deletePhoto;
      const photoName = deleteBtn.dataset.photoName;
      
      if (!confirm(`Are you sure you want to delete "${photoName}"? This action cannot be undone.`)) {
        return;
      }
      
      try {
        const response = await fetch('/api/cms/media', {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ id: photoId })
        });
        
        if (response.ok) {
          // Remove the photo card from the DOM
          const photoCard = deleteBtn.closest('[data-photo-id]');
          photoCard?.remove();
          
          // Update stats
          window.location.href = '/admin/photos?success=Photo deleted successfully';
        } else {
          alert('Failed to delete photo. Please try again.');
        }
      } catch (error) {
        console.error('Delete error:', error);
        alert('An error occurred while deleting. Please try again.');
      }
    }
  });

  // View toggle functionality
  const gridViewBtn = document.getElementById('grid-view-btn');
  const listViewBtn = document.getElementById('list-view-btn');
  const photosContainer = document.getElementById('photos-container');

  gridViewBtn?.addEventListener('click', () => {
    photosContainer?.classList.remove('photos-list');
    photosContainer?.classList.add('photos-grid');
    gridViewBtn.classList.add('btn--active');
    listViewBtn?.classList.remove('btn--active');
  });

  listViewBtn?.addEventListener('click', () => {
    photosContainer?.classList.remove('photos-grid');
    photosContainer?.classList.add('photos-list');
    listViewBtn.classList.add('btn--active');
    gridViewBtn?.classList.remove('btn--active');
  });
</script>

<style>
  .photo-management {
    @apply space-y-8;
  }
  
  /* Status Messages */
  .status-message {
    @apply px-4 py-3 rounded-lg border;
  }
  
  .status-message--success {
    @apply bg-green-50 border-green-200 text-green-800;
  }
  
  .status-message--error {
    @apply bg-red-50 border-red-200 text-red-800;
  }
  
  /* Page Header */
  .page-header {
    @apply flex items-start justify-between;
  }
  
  .page-header__content {
    @apply flex-1;
  }
  
  .page-title {
    @apply text-3xl font-bold text-gray-900 mb-2;
  }
  
  .page-description {
    @apply text-gray-600 max-w-2xl;
  }
  
  .page-header__actions {
    @apply flex-shrink-0 ml-6;
  }
  
  /* Stats Bar */
  .stats-bar {
    @apply flex space-x-8 bg-white rounded-lg shadow p-6;
  }
  
  .stat {
    @apply text-center;
  }
  
  .stat-number {
    @apply block text-2xl font-bold text-gray-900;
  }
  
  .stat-label {
    @apply text-sm text-gray-500 uppercase tracking-wide;
  }
  
  /* Content Section */
  .content-section {
    @apply bg-white rounded-lg shadow;
  }
  
  .section-header {
    @apply flex items-center justify-between p-6 border-b border-gray-200;
  }
  
  .section-header__content {
    @apply flex-1;
  }
  
  .section-title {
    @apply flex items-center text-xl font-semibold text-gray-900 mb-1;
  }
  
  .section-icon {
    @apply w-6 h-6 mr-3 text-blue-600;
  }
  
  .section-description {
    @apply text-gray-600;
  }
  
  .section-actions {
    @apply flex space-x-2;
  }
  
  /* Photos Grid */
  .photos-grid {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 p-6;
  }
  
  .photos-list {
    @apply space-y-4 p-6;
  }
  
  .photos-list .photo-card {
    @apply flex items-start space-x-4 p-4 border border-gray-200 rounded-lg;
  }
  
  .photos-list .photo-card__preview {
    @apply w-24 h-24 flex-shrink-0;
  }
  
  .photos-list .photo-card__info {
    @apply flex-1;
  }
  
  /* Photo Card */
  .photo-card {
    @apply bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow;
  }
  
  .photo-card__preview {
    @apply relative aspect-square bg-gray-100 overflow-hidden;
  }
  
  .photo-image {
    @apply w-full h-full object-cover;
  }
  
  .file-icon {
    @apply w-full h-full flex flex-col items-center justify-center text-gray-400;
  }
  
  .file-icon-svg {
    @apply w-12 h-12 mb-2;
  }
  
  .file-type {
    @apply text-xs font-medium;
  }
  
  /* Photo Overlay */
  .photo-overlay {
    @apply absolute inset-0 bg-black bg-opacity-75 opacity-0 hover:opacity-100;
    @apply flex items-center justify-center transition-opacity duration-200;
  }
  
  .photo-actions {
    @apply flex space-x-2;
  }
  
  .action-btn {
    @apply p-2 bg-white bg-opacity-20 rounded-md text-white hover:bg-opacity-30;
    @apply transition-colors duration-150;
  }
  
  .action-btn--view {
    @apply hover:text-blue-200;
  }
  
  .action-btn--delete {
    @apply hover:text-red-200;
  }
  
  .action-icon {
    @apply w-5 h-5;
  }
  
  /* Photo Info */
  .photo-card__info {
    @apply p-4 space-y-3;
  }
  
  .photo-title {
    @apply font-semibold text-gray-900 truncate;
  }
  
  .photo-description {
    @apply text-sm text-gray-600 line-clamp-2;
  }
  
  .photo-meta {
    @apply flex items-center justify-between text-xs text-gray-500;
  }
  
  .meta-item {
    @apply flex items-center space-x-1;
  }
  
  .meta-icon {
    @apply w-3 h-3;
  }
  
  /* Photo Tags */
  .photo-tags {
    @apply flex flex-wrap gap-1;
  }
  
  .tag {
    @apply inline-block px-2 py-1 text-xs bg-blue-100 text-blue-800 rounded-full;
  }
  
  /* Buttons */
  .btn {
    @apply inline-flex items-center px-4 py-2 border rounded-md font-medium;
    @apply focus:outline-none focus:ring-2 focus:ring-offset-2;
    @apply transition-colors duration-150;
  }
  
  .btn--primary {
    @apply border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500;
  }
  
  .btn--secondary {
    @apply border-gray-300 bg-white text-gray-700 hover:bg-gray-50 focus:ring-blue-500;
  }
  
  .btn--sm {
    @apply px-3 py-1.5 text-sm;
  }
  
  .btn--active {
    @apply bg-blue-50 text-blue-700 border-blue-300;
  }
  
  .btn-icon {
    @apply w-4 h-4 mr-2;
  }
  
  /* Empty State */
  .empty-state {
    @apply text-center py-12 px-6;
  }
  
  .empty-icon {
    @apply w-12 h-12 mx-auto text-gray-400 mb-4;
  }
  
  .empty-state h3 {
    @apply text-lg font-medium text-gray-900 mb-2;
  }
  
  .empty-state p {
    @apply text-gray-500 mb-4 max-w-sm mx-auto;
  }
  
  /* Modal */
  .modal {
    @apply fixed inset-0 z-50 hidden items-center justify-center p-4;
  }
  
  .modal--open {
    @apply flex;
  }
  
  .modal-backdrop {
    @apply absolute inset-0 bg-black bg-opacity-75;
  }
  
  .modal-content {
    @apply relative bg-white rounded-lg shadow-xl max-w-4xl max-h-full overflow-hidden;
  }
  
  .modal-header {
    @apply flex items-center justify-between p-4 border-b border-gray-200;
  }
  
  .modal-title {
    @apply text-lg font-semibold text-gray-900;
  }
  
  .modal-close {
    @apply p-1 text-gray-400 hover:text-gray-600;
  }
  
  .modal-close svg {
    @apply w-6 h-6;
  }
  
  .modal-body {
    @apply p-4;
  }
  
  .modal-image {
    @apply max-w-full max-h-96 mx-auto object-contain;
  }
</style>