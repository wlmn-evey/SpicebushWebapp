---
import AdminLayout from '@layouts/AdminLayout.astro';
import SettingsManagement from '@components/admin/SettingsManagement.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);

if (!isAuthenticated) {
  return Astro.redirect('/auth/login?redirect=/admin/settings');
}
---

<AdminLayout 
  title="Settings Management" 
  description="Configure site settings, coming soon mode, and financial policies."
>
  <div class="settings-page">
    <div class="page-header">
      <div>
        <h1 class="page-title">Site Settings</h1>
        <p class="page-description">
          Manage your website configuration, maintenance mode, and school policies.
        </p>
      </div>
    </div>
    
    <div class="page-content">
      <SettingsManagement />
    </div>
  </div>
</AdminLayout>

<style>
  .settings-page {
    @apply min-h-screen bg-gray-50;
  }
  
  .page-header {
    @apply bg-white border-b border-gray-200 px-6 py-8;
  }
  
  .page-title {
    @apply text-2xl font-bold text-gray-900;
  }
  
  .page-description {
    @apply mt-2 text-gray-600;
  }
  
  .page-content {
    @apply p-6;
  }
</style>