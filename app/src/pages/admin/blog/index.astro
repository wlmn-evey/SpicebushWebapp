---
/**
 * Blog Posts Listing
 * 
 * Displays all blog posts with search, filter, and management capabilities.
 * Provides quick actions for editing, deleting, and changing post status.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';
import { getCollection } from '@lib/content-db';

// Check authentication
const { isAuthenticated } = await checkAdminAuth(Astro);
if (!isAuthenticated) {
  return Astro.redirect(`/auth/netlify-login?redirect=${  Astro.url.pathname}`);
}

// Get search and filter parameters
const searchQuery = Astro.url.searchParams.get('search') || '';
const statusFilter = Astro.url.searchParams.get('status') || 'all';
const categoryFilter = Astro.url.searchParams.get('category') || 'all';
const sortBy = Astro.url.searchParams.get('sort') || 'date';
const sortOrder = Astro.url.searchParams.get('order') || 'desc';

// Load all blog posts
let posts = await getCollection('blog');

// Apply filters
if (searchQuery) {
  const query = searchQuery.toLowerCase();
  posts = posts.filter(post => 
    post.data.title.toLowerCase().includes(query) ||
    post.data.excerpt?.toLowerCase().includes(query) ||
    post.data.author?.toLowerCase().includes(query)
  );
}

if (statusFilter !== 'all') {
  posts = posts.filter(post => post.data.status === statusFilter);
}

if (categoryFilter !== 'all') {
  posts = posts.filter(post => post.data.category === categoryFilter);
}

// Sort posts
posts.sort((a, b) => {
  let aValue, bValue;
  
  switch (sortBy) {
  case 'title':
    aValue = a.data.title.toLowerCase();
    bValue = b.data.title.toLowerCase();
    break;
  case 'author':
    aValue = a.data.author?.toLowerCase() || '';
    bValue = b.data.author?.toLowerCase() || '';
    break;
  case 'status':
    aValue = a.data.status || 'draft';
    bValue = b.data.status || 'draft';
    break;
  case 'date':
  default:
    aValue = new Date(a.data.publish_date || a.data.created_at);
    bValue = new Date(b.data.publish_date || b.data.created_at);
    break;
  }
  
  if (aValue < bValue) return sortOrder === 'asc' ? -1 : 1;
  if (aValue > bValue) return sortOrder === 'asc' ? 1 : -1;
  return 0;
});

// Get unique categories for filter
const categories = [...new Set(posts.map(post => post.data.category).filter(Boolean))];

// Format date helper
function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}

// Truncate text helper
function truncate(text: string, length: number): string {
  return text.length > length ? `${text.substring(0, length)  }...` : text;
}
---

<AdminLayout title="Blog Posts" description="Manage your blog posts">
  <div class="blog-listing">
    <!-- Header Actions -->
    <div class="listing-header">
      <a href="/admin/blog/edit" class="btn btn--primary">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
        </svg>
        New Post
      </a>
    </div>
    
    <!-- Filters -->
    <div class="listing-filters">
      <form class="filters-form" method="GET">
        <div class="filter-group">
          <label for="search" class="sr-only">Search posts</label>
          <div class="search-input">
            <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              id="search"
              name="search"
              value={searchQuery}
              placeholder="Search posts..."
              class="search-field"
            />
          </div>
        </div>
        
        <div class="filter-group">
          <select name="status" class="filter-select">
            <option value="all" selected={statusFilter === 'all'}>All Status</option>
            <option value="published" selected={statusFilter === 'published'}>Published</option>
            <option value="draft" selected={statusFilter === 'draft'}>Draft</option>
          </select>
        </div>
        
        <div class="filter-group">
          <select name="category" class="filter-select">
            <option value="all" selected={categoryFilter === 'all'}>All Categories</option>
            {categories.map(category => (
              <option value={category} selected={categoryFilter === category}>
                {category.charAt(0).toUpperCase() + category.slice(1)}
              </option>
            ))}
          </select>
        </div>
        
        <div class="filter-group">
          <select name="sort" class="filter-select">
            <option value="date" selected={sortBy === 'date'}>Sort by Date</option>
            <option value="title" selected={sortBy === 'title'}>Sort by Title</option>
            <option value="author" selected={sortBy === 'author'}>Sort by Author</option>
            <option value="status" selected={sortBy === 'status'}>Sort by Status</option>
          </select>
          <input type="hidden" name="order" value={sortOrder} />
        </div>
        
        <button type="submit" class="btn btn--secondary">
          Filter
        </button>
        
        {(searchQuery || statusFilter !== 'all' || categoryFilter !== 'all') && (
          <a href="/admin/blog" class="btn btn--ghost">
            Clear
          </a>
        )}
      </form>
    </div>
    
    <!-- Results Summary -->
    <div class="listing-summary">
      <p class="text-sm text-gray-600">
        Showing {posts.length} post{posts.length !== 1 ? 's' : ''}
        {searchQuery && ` matching "${searchQuery}"`}
      </p>
    </div>
    
    <!-- Posts Table -->
    <div class="listing-table-container">
      <table class="listing-table">
        <thead>
          <tr>
            <th>
              <a href={`?${new URLSearchParams({...Object.fromEntries(Astro.url.searchParams), sort: 'title', order: sortBy === 'title' && sortOrder === 'asc' ? 'desc' : 'asc'}).toString()}`}>
                Title
                {sortBy === 'title' && (
                  <svg class={`sort-icon ${sortOrder === 'desc' ? 'sort-icon--desc' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                  </svg>
                )}
              </a>
            </th>
            <th>
              <a href={`?${new URLSearchParams({...Object.fromEntries(Astro.url.searchParams), sort: 'author', order: sortBy === 'author' && sortOrder === 'asc' ? 'desc' : 'asc'}).toString()}`}>
                Author
                {sortBy === 'author' && (
                  <svg class={`sort-icon ${sortOrder === 'desc' ? 'sort-icon--desc' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                  </svg>
                )}
              </a>
            </th>
            <th>Category</th>
            <th>
              <a href={`?${new URLSearchParams({...Object.fromEntries(Astro.url.searchParams), sort: 'status', order: sortBy === 'status' && sortOrder === 'asc' ? 'desc' : 'asc'}).toString()}`}>
                Status
                {sortBy === 'status' && (
                  <svg class={`sort-icon ${sortOrder === 'desc' ? 'sort-icon--desc' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                  </svg>
                )}
              </a>
            </th>
            <th>
              <a href={`?${new URLSearchParams({...Object.fromEntries(Astro.url.searchParams), sort: 'date', order: sortBy === 'date' && sortOrder === 'asc' ? 'desc' : 'asc'}).toString()}`}>
                Date
                {sortBy === 'date' && (
                  <svg class={`sort-icon ${sortOrder === 'desc' ? 'sort-icon--desc' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                  </svg>
                )}
              </a>
            </th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {posts.length === 0 ? (
            <tr>
              <td colspan="6" class="empty-state">
                <div class="empty-content">
                  <svg class="empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  <h3>No posts found</h3>
                  <p>
                    {searchQuery || statusFilter !== 'all' || categoryFilter !== 'all'
                      ? 'Try adjusting your filters or search terms.'
                      : 'Get started by creating your first blog post.'
                    }
                  </p>
                  {!(searchQuery || statusFilter !== 'all' || categoryFilter !== 'all') && (
                    <a href="/admin/blog/edit" class="btn btn--primary mt-4">
                      Create First Post
                    </a>
                  )}
                </div>
              </td>
            </tr>
          ) : (
            posts.map(post => (
              <tr>
                <td>
                  <div class="post-title">
                    <a href={`/admin/blog/edit?slug=${post.slug}`} class="title-link">
                      {post.data.title}
                    </a>
                    {post.data.excerpt && (
                      <p class="title-excerpt">
                        {truncate(post.data.excerpt, 100)}
                      </p>
                    )}
                  </div>
                </td>
                <td>
                  <span class="author-name">{post.data.author || 'Unknown'}</span>
                </td>
                <td>
                  {post.data.category && (
                    <span class="category-badge">
                      {post.data.category.charAt(0).toUpperCase() + post.data.category.slice(1)}
                    </span>
                  )}
                </td>
                <td>
                  <span class={`status-badge status-badge--${post.data.status || 'draft'}`}>
                    {post.data.status === 'published' ? 'Published' : 'Draft'}
                  </span>
                </td>
                <td>
                  <time class="post-date">
                    {formatDate(post.data.publish_date || post.data.created_at)}
                  </time>
                </td>
                <td>
                  <div class="actions-menu">
                    <a
                      href={`/admin/blog/edit?slug=${post.slug}`}
                      class="action-button"
                      title="Edit post"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    </a>
                    {post.data.status === 'published' && (
                      <a
                        href={`/blog/${post.slug}`}
                        target="_blank"
                        class="action-button"
                        title="View post"
                      >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                      </a>
                    )}
                    <button
                      type="button"
                      class="action-button action-button--danger"
                      title="Delete post"
                      data-delete-post={post.slug}
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  // Handle delete confirmation
  document.addEventListener('click', (e) => {
    const deleteButton = e.target.closest('[data-delete-post]');
    if (deleteButton) {
      const slug = deleteButton.dataset.deletePost;
      const confirmed = confirm('Are you sure you want to delete this post? This action cannot be undone.');
      
      if (confirmed) {
        // TODO: Implement delete functionality via API
        fetch('/api/cms/entry', {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ type: 'blog', slug })
        })
          .then(response => {
            if (response.ok) {
              window.location.reload();
            } else {
              alert('Failed to delete post. Please try again.');
            }
          })
          .catch(error => {
            console.error('Delete error:', error);
            alert('Failed to delete post. Please try again.');
          });
      }
    }
  });
  
  // Auto-submit search on input
  const searchInput = document.querySelector('.search-field');
  let searchTimeout;
  
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        searchInput.closest('form').submit();
      }, 500);
    });
  }
</script>

<style>
  .blog-listing {
    @apply space-y-6;
  }
  
  .listing-header {
    @apply flex justify-between items-center;
  }
  
  .listing-filters {
    @apply bg-white rounded-lg shadow p-6;
  }
  
  .filters-form {
    @apply flex flex-wrap gap-4 items-end;
  }
  
  .filter-group {
    @apply flex-1 min-w-48;
  }
  
  .search-input {
    @apply relative;
  }
  
  .search-icon {
    @apply absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400;
  }
  
  .search-field {
    @apply w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md;
    @apply focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500;
  }
  
  .filter-select {
    @apply w-full px-3 py-2 border border-gray-300 rounded-md;
    @apply focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500;
  }
  
  .listing-summary {
    @apply px-1;
  }
  
  .listing-table-container {
    @apply bg-white rounded-lg shadow overflow-hidden;
  }
  
  .listing-table {
    @apply w-full;
  }
  
  .listing-table th {
    @apply px-6 py-3 border-b border-gray-200 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider;
  }
  
  .listing-table th a {
    @apply flex items-center space-x-1 hover:text-gray-700;
  }
  
  .sort-icon {
    @apply w-4 h-4 transition-transform;
  }
  
  .sort-icon--desc {
    @apply transform rotate-180;
  }
  
  .listing-table td {
    @apply px-6 py-4 border-b border-gray-200;
  }
  
  .post-title {
    @apply space-y-1;
  }
  
  .title-link {
    @apply font-medium text-blue-600 hover:text-blue-800;
  }
  
  .title-excerpt {
    @apply text-sm text-gray-500;
  }
  
  .author-name {
    @apply text-sm text-gray-900;
  }
  
  .category-badge {
    @apply inline-block px-2 py-1 text-xs font-medium bg-blue-100 text-blue-800 rounded;
  }
  
  .status-badge {
    @apply inline-block px-2 py-1 text-xs font-medium rounded;
  }
  
  .status-badge--published {
    @apply bg-green-100 text-green-800;
  }
  
  .status-badge--draft {
    @apply bg-yellow-100 text-yellow-800;
  }
  
  .post-date {
    @apply text-sm text-gray-500;
  }
  
  .actions-menu {
    @apply flex items-center space-x-2;
  }
  
  .action-button {
    @apply p-2 text-gray-400 hover:text-gray-600 rounded-md hover:bg-gray-100;
    @apply transition-colors duration-150;
  }
  
  .action-button--danger {
    @apply hover:text-red-600 hover:bg-red-50;
  }
  
  .empty-state {
    @apply text-center py-12;
  }
  
  .empty-content {
    @apply max-w-md mx-auto;
  }
  
  .empty-icon {
    @apply w-12 h-12 mx-auto text-gray-400 mb-4;
  }
  
  .empty-content h3 {
    @apply text-lg font-medium text-gray-900 mb-2;
  }
  
  .empty-content p {
    @apply text-gray-500;
  }
  
  .btn {
    @apply inline-flex items-center px-4 py-2 border rounded-md font-medium;
    @apply focus:outline-none focus:ring-2 focus:ring-offset-2;
    @apply transition-colors duration-150;
  }
  
  .btn--primary {
    @apply border-transparent bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500;
  }
  
  .btn--secondary {
    @apply border-gray-300 bg-white text-gray-700 hover:bg-gray-50 focus:ring-blue-500;
  }
  
  .btn--ghost {
    @apply border-transparent text-gray-700 hover:text-gray-900 hover:bg-gray-100;
  }
</style>