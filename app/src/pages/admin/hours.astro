---
// DEPRECATED: Use CMS instead at /admin/cms#/collections/hours
return Astro.redirect('/admin/cms#/collections/hours');

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Clock, MessageSquare, Save, Plus, Trash2, ArrowLeft } from 'lucide-astro';
---

<Layout 
  title="Manage School Hours - Admin Panel"
  description="Administrative interface for managing school hours and special messages."
  keywords="admin, school hours, management"
>
  <Header />
  
  <main id="main-content">
    <!-- Admin Auth Check -->
    <script>
      import { auth } from '../../lib/supabase.ts';
      
      document.addEventListener('DOMContentLoaded', async function() {
        try {
          const user = await auth.getCurrentUser();
          if (!user) {
            window.location.href = '/auth/login';
            return;
          }
        } catch (error) {
          console.error('Error checking authentication:', error);
          window.location.href = '/auth/login';
        }
      });
    </script>

    <!-- Header -->
    <section class="bg-gradient-to-br from-forest-canopy to-moss-green py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Back to Dashboard Navigation -->
          <div class="mb-6">
            <a href="/admin" class="inline-flex items-center text-green-200 hover:text-white transition-colors group">
              <ArrowLeft className="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" />
              <span class="text-sm font-medium">Back to Admin Dashboard</span>
            </a>
          </div>
          
          <div>
            <h1 class="text-3xl lg:text-4xl font-heading font-bold text-white mb-4 tracking-tight">
            Manage School Hours
          </h1>
            <p class="text-green-100 text-lg max-w-3xl">
            Update school hours and manage special messages for the community.
          </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Management Interface -->
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          
          <!-- School Hours Management -->
          <div class="bg-white border border-gray-200 rounded-lg p-6">
            <div class="flex items-center mb-6">
              <Clock className="w-6 h-6 text-forest-canopy mr-3" />
              <h2 class="text-2xl font-bold text-earth-brown">School Hours</h2>
            </div>
            
            <form id="hours-form" class="space-y-6">
              <div id="hours-inputs"></div>
              
              <button 
                type="submit" 
                class="w-full bg-forest-canopy hover:bg-moss-green text-white px-6 py-3 rounded-lg font-semibold transition-colors focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2 flex items-center justify-center"
              >
                <Save className="w-5 h-5 mr-2" />
                Save Hours
              </button>
            </form>
          </div>

          <!-- Special Messages Management -->
          <div class="bg-white border border-gray-200 rounded-lg p-6">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center">
                <MessageSquare className="w-6 h-6 text-forest-canopy mr-3" />
                <h2 class="text-2xl font-bold text-earth-brown">Special Messages</h2>
              </div>
              <button 
                id="add-message-btn"
                class="bg-sunlight-gold hover:bg-orange-600 text-white px-4 py-2 rounded-lg font-medium transition-colors focus:ring-2 focus:ring-orange-300 focus:ring-offset-2 flex items-center"
              >
                <Plus className="w-4 h-4 mr-2" />
                Add Message
              </button>
            </div>
            
            <div id="messages-list" class="space-y-4 mb-6"></div>
            
            <!-- Add/Edit Message Form -->
            <div id="message-form" class="hidden border-t pt-6">
              <form id="message-form-element" class="space-y-4">
                <input type="hidden" id="message-id" />
                
                <div>
                  <label for="message-title" class="block text-sm font-medium text-earth-brown mb-2">
                    Title
                  </label>
                  <input 
                    type="text" 
                    id="message-title" 
                    required 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                    placeholder="Holiday Notice, Weather Alert, etc."
                  />
                </div>
                
                <div>
                  <label for="message-text" class="block text-sm font-medium text-earth-brown mb-2">
                    Message (Optional)
                  </label>
                  <textarea 
                    id="message-text" 
                    rows="3"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                    placeholder="Additional details about the notice..."
                  ></textarea>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="start-date" class="block text-sm font-medium text-earth-brown mb-2">
                      Start Date
                    </label>
                    <input 
                      type="date" 
                      id="start-date" 
                      required 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                    />
                  </div>
                  <div>
                    <label for="end-date" class="block text-sm font-medium text-earth-brown mb-2">
                      End Date
                    </label>
                    <input 
                      type="date" 
                      id="end-date" 
                      required 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent"
                    />
                  </div>
                </div>
                
                <div>
                  <label class="flex items-center">
                    <input 
                      type="checkbox" 
                      id="message-active" 
                      checked 
                      class="mr-2 text-forest-canopy focus:ring-forest-canopy"
                    />
                    <span class="text-sm text-earth-brown">Active (visible to public)</span>
                  </label>
                </div>
                
                <div class="flex space-x-3">
                  <button 
                    type="submit" 
                    class="flex-1 bg-forest-canopy hover:bg-moss-green text-white px-4 py-2 rounded-lg font-medium transition-colors focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2"
                  >
                    Save Message
                  </button>
                  <button 
                    type="button" 
                    id="quick-july4-btn"
                    class="px-4 py-2 bg-red-600 text-white rounded-lg font-medium hover:bg-red-700 transition-colors focus:ring-2 focus:ring-red-300 focus:ring-offset-2"
                  >
                    🇺🇸 Quick July 4th
                  </button>
                  <button 
                    type="button" 
                    id="cancel-message-btn"
                    class="px-4 py-2 border border-gray-300 text-earth-brown rounded-lg font-medium hover:bg-gray-50 transition-colors focus:ring-2 focus:ring-gray-300 focus:ring-offset-2"
                  >
                    Cancel
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script>
  import { supabase } from '../../lib/supabase.ts';

  document.addEventListener('DOMContentLoaded', async function() {
    const hoursForm = document.getElementById('hours-form');
    const hoursInputs = document.getElementById('hours-inputs');
    const messagesList = document.getElementById('messages-list');
    const messageForm = document.getElementById('message-form');
    const messageFormElement = document.getElementById('message-form-element');
    const addMessageBtn = document.getElementById('add-message-btn');
    const cancelMessageBtn = document.getElementById('cancel-message-btn');
    
    const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
    
    // Load and render hours
    async function loadHours() {
      try {
        const { data: hours, error } = await supabase
          .from('school_hours')
          .select('*')
          .order('id');
        
        if (error) throw error;
        
        // Create hours input form
        hoursInputs.innerHTML = '';
        
        days.forEach(day => {
          const dayData = hours.find(h => h.day_of_week === day) || { 
            day_of_week: day, 
            start_time: 8.5, 
            end_time: 15, 
            before_care_offset: 1, 
            after_care_offset: day === 'Friday' ? 0 : 2.5,
            aftercare_available: day !== 'Friday' && !['Saturday', 'Sunday'].includes(day),
            closed: ['Saturday', 'Sunday'].includes(day)
          };
          
          const dayDiv = document.createElement('div');
          dayDiv.className = 'border border-gray-200 rounded-lg p-4';
          dayDiv.innerHTML = `
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-earth-brown">${day}</h3>
              <div class="flex items-center space-x-4">
                <label class="flex items-center">
                  <input 
                    type="checkbox" 
                    name="${day}-aftercare" 
                    ${dayData.aftercare_available ? 'checked' : ''} 
                    class="mr-2 text-forest-canopy"
                    ${dayData.closed ? 'disabled' : ''}
                  />
                  <span class="text-sm">Aftercare Available</span>
                </label>
                <label class="flex items-center">
                  <input 
                    type="checkbox" 
                    name="${day}-closed" 
                    ${dayData.closed ? 'checked' : ''} 
                    class="mr-2 text-forest-canopy"
                  />
                  <span class="text-sm">Closed</span>
                </label>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3 hours-inputs ${dayData.closed ? 'opacity-50' : ''}">
              <div>
                <label class="block text-xs text-earth-brown mb-1">Start Time</label>
                <input 
                  type="time" 
                  name="${day}-start" 
                  value="${timeToHHMM(dayData.start_time)}" 
                  class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-1 focus:ring-forest-canopy"
                  ${dayData.closed ? 'disabled' : ''}
                />
              </div>
              <div>
                <label class="block text-xs text-earth-brown mb-1">End Time</label>
                <input 
                  type="time" 
                  name="${day}-end" 
                  value="${timeToHHMM(dayData.end_time)}" 
                  class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-1 focus:ring-forest-canopy"
                  ${dayData.closed ? 'disabled' : ''}
                />
              </div>
              <div>
                <label class="block text-xs text-earth-brown mb-1">Before Care (hrs)</label>
                <input 
                  type="number" 
                  name="${day}-before" 
                  value="${dayData.before_care_offset}" 
                  step="0.5" 
                  min="0" 
                  max="4"
                  class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-1 focus:ring-forest-canopy"
                  ${dayData.closed ? 'disabled' : ''}
                />
              </div>
              <div>
                <label class="block text-xs text-earth-brown mb-1">After Care (hrs)</label>
                <input 
                  type="number" 
                  name="${day}-after" 
                  value="${dayData.after_care_offset}" 
                  step="0.5" 
                  min="0" 
                  max="4"
                  class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-1 focus:ring-forest-canopy"
                  ${dayData.closed ? 'disabled' : ''}
                />
              </div>
            </div>
          `;
          
          // Add closed checkbox listener
          const closedCheckbox = dayDiv.querySelector(`input[name="${day}-closed"]`);
          const aftercareCheckbox = dayDiv.querySelector(`input[name="${day}-aftercare"]`);
          const hoursInputsDiv = dayDiv.querySelector('.hours-inputs');
          const inputs = hoursInputsDiv.querySelectorAll('input');
          
          closedCheckbox.addEventListener('change', function() {
            inputs.forEach(input => input.disabled = this.checked);
            aftercareCheckbox.disabled = this.checked;
            hoursInputsDiv.classList.toggle('opacity-50', this.checked);
          });
          
          hoursInputs.appendChild(dayDiv);
        });
        
      } catch (error) {
        console.error('Error loading hours:', error);
      }
    }
    
    // Load and render messages
    async function loadMessages() {
      try {
       const { data: messages, error } = await supabase
          .from('special_messages')
          .select('*')
          .order('created_at', { ascending: false });
        
        if (error) throw error;
        
        messagesList.innerHTML = '';
        
        messages.forEach(message => {
          const messageDiv = document.createElement('div');
          messageDiv.className = `border border-gray-200 rounded-lg p-4 ${message.active ? 'bg-green-50' : 'bg-gray-50'}`;
          messageDiv.innerHTML = `
            <div class="flex justify-between items-start mb-2">
              <h4 class="font-semibold text-earth-brown">${message.title}</h4>
              <div class="flex space-x-2">
                <button 
                  onclick="editMessage('${message.id}')" 
                  class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded hover:bg-blue-200 transition-colors"
                >
                  Edit
                </button>
                <button 
                  onclick="deleteMessage('${message.id}')" 
                  class="text-xs bg-red-100 text-red-800 px-2 py-1 rounded hover:bg-red-200 transition-colors"
                >
                  Delete
                </button>
              </div>
            </div>
            ${message.message ? `<p class="text-sm text-earth-brown mb-2">${message.message}</p>` : ''}
            <div class="text-xs text-gray-600">
              ${new Date(message.start_date).toLocaleDateString()} - ${new Date(message.end_date).toLocaleDateString()}
              <span class="ml-2 px-2 py-1 rounded text-xs ${message.active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'}">
                ${message.active ? 'Active' : 'Inactive'}
              </span>
            </div>
          `;
          messagesList.appendChild(messageDiv);
        });
        
      } catch (error) {
        console.error('Error loading messages:', error);
      }
    }
    
    // Helper function to convert decimal time to HH:MM format
    function timeToHHMM(decimalTime) {
      const hours = Math.floor(decimalTime);
      const minutes = Math.round((decimalTime - hours) * 60);
      return `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}`;
    }
    
    // Helper function to convert HH:MM to decimal
    function timeToDecimal(timeString) {
      const [hours, minutes] = timeString.split(':').map(Number);
      return hours + minutes / 60;
    }
    
    // Save hours
    hoursForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      try {
        const formData = new FormData(hoursForm);
        const updates = [];
        
        days.forEach(day => {
          const closed = formData.get(`${day}-closed`) === 'on';
          const aftercareAvailable = formData.get(`${day}-aftercare`) === 'on';
          const startTime = closed ? 0 : timeToDecimal(formData.get(`${day}-start`));
          const endTime = closed ? 0 : timeToDecimal(formData.get(`${day}-end`));
          const beforeCare = closed ? 0 : parseFloat(formData.get(`${day}-before`));
          const afterCare = closed ? 0 : parseFloat(formData.get(`${day}-after`));
          
          updates.push({
            day_of_week: day,
            start_time: startTime,
            end_time: endTime,
            before_care_offset: beforeCare,
            after_care_offset: afterCare,
            aftercare_available: aftercareAvailable && !closed,
            closed: closed
          });
        });
        
        const { error } = await supabase
          .from('school_hours')
          .upsert(updates, { onConflict: 'day_of_week' });
        
        if (error) throw error;
        
        alert('Hours updated successfully!');
        
      } catch (error) {
        console.error('Error saving hours:', error);
        alert('Error saving hours. Please try again.');
      }
    });
    
    // Message form handlers
    addMessageBtn.addEventListener('click', function() {
      messageForm.classList.remove('hidden');
      messageFormElement.reset();
      document.getElementById('message-id').value = '';
      document.getElementById('start-date').value = new Date().toISOString().split('T')[0];
      document.getElementById('end-date').value = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
    });
    
    // Quick July 4th button
    const quickJuly4Btn = document.getElementById('quick-july4-btn');
    if (quickJuly4Btn) {
      quickJuly4Btn.addEventListener('click', function() {
        const currentYear = new Date().getFullYear();
        const july4Date = `${currentYear}-07-04`;
        
        document.getElementById('message-id').value = '';
        document.getElementById('message-title').value = 'Independence Day - School Closed';
        document.getElementById('message-text').value = 'Happy 4th of July! School will be closed in observance of Independence Day. Regular hours resume the following school day.';
        document.getElementById('start-date').value = july4Date;
        document.getElementById('end-date').value = july4Date;
        document.getElementById('message-active').checked = true;
        
        messageForm.classList.remove('hidden');
      });
    }
    
    cancelMessageBtn.addEventListener('click', function() {
      messageForm.classList.add('hidden');
    });
    
    messageFormElement.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      try {
        const messageId = document.getElementById('message-id').value;
        const messageData = {
          title: document.getElementById('message-title').value,
          message: document.getElementById('message-text').value,
          start_date: document.getElementById('start-date').value,
          end_date: document.getElementById('end-date').value,
          active: document.getElementById('message-active').checked
        };
        
        if (messageId) {
          // Update existing message
          const { error } = await supabase
            .from('special_messages')
            .update(messageData)
            .eq('id', messageId);
          
          if (error) throw error;
        } else {
          // Create new message
          const { error } = await supabase
            .from('special_messages')
            .insert([messageData]);
          
          if (error) throw error;
        }
        
        messageForm.classList.add('hidden');
        loadMessages();
        
      } catch (error) {
        console.error('Error saving message:', error);
        alert('Error saving message. Please try again.');
      }
    });
    
    // Global functions for message actions
    window.editMessage = async function(id) {
      try {
       const { data: message, error } = await supabase
          .from('special_messages')
          .select('*')
          .eq('id', id)
          .single();
        
        if (error) throw error;
        
        document.getElementById('message-id').value = message.id;
        document.getElementById('message-title').value = message.title;
        document.getElementById('message-text').value = message.message || '';
        document.getElementById('start-date').value = message.start_date;
        document.getElementById('end-date').value = message.end_date;
        document.getElementById('message-active').checked = message.active;
        
        messageForm.classList.remove('hidden');
        
      } catch (error) {
        console.error('Error loading message:', error);
      }
    };
    
    window.deleteMessage = async function(id) {
      if (!confirm('Are you sure you want to delete this message?')) return;
      
      try {
       const { error } = await supabase
          .from('special_messages')
          .delete()
          .eq('id', id);
        
        if (error) throw error;
        
        loadMessages();
        
      } catch (error) {
        console.error('Error deleting message:', error);
        alert('Error deleting message. Please try again.');
      }
    };
    
    // Initialize
    loadHours();
    loadMessages();
  });
</script>
</Layout>