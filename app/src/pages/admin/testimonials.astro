---
import AdminLayout from '@layouts/AdminLayout.astro';
import {
  TESTIMONIAL_CATEGORY_OPTIONS,
  categoriesToSettingValue,
  filterTestimonialsForPlacement,
  getManagedTestimonials,
  getTestimonialDisplayRules
} from '@lib/testimonials-content';

const testimonials = await getManagedTestimonials();
const rules = await getTestimonialDisplayRules();

const savedKey = Astro.url.searchParams.get('saved');
const errorMessage = Astro.url.searchParams.get('error');

const asNumberString = (value: number): string => String(value);

const categoryLabel = (category: string): string =>
  category
    .split('-')
    .filter((part) => part.length > 0)
    .map((part) => `${part.charAt(0).toUpperCase()}${part.slice(1)}`)
    .join(' ');

const builtInCategorySet = new Set<string>(TESTIMONIAL_CATEGORY_OPTIONS);
const customCategories = [...new Set(
  testimonials
    .map((item) => item.category)
    .filter((category) => category.length > 0 && !builtInCategorySet.has(category))
)]
  .sort((a, b) => a.localeCompare(b));

const availableCategories = [...TESTIMONIAL_CATEGORY_OPTIONS, ...customCategories];
const availableCategoryCsv = availableCategories.join(', ');

const homepageVisible = filterTestimonialsForPlacement(testimonials, rules, 'homepage');
const comingSoonVisible = filterTestimonialsForPlacement(testimonials, rules, 'coming-soon');

const homepageVisibleSet = new Set(homepageVisible.map((item) => item.slug));
const comingSoonVisibleSet = new Set(comingSoonVisible.map((item) => item.slug));

const activeCount = testimonials.filter((item) => item.active).length;
const featuredCount = testimonials.filter((item) => item.featured).length;
const averageRating = testimonials.length > 0
  ? testimonials.reduce((total, item) => total + item.rating, 0) / testimonials.length
  : 0;

const defaultSlug = `testimonial-${Date.now().toString(36)}-${Math.floor(Math.random() * 9000 + 1000)}`;

const starsFor = (rating: number): string => '★'.repeat(Math.max(1, Math.min(5, rating)));
---

<AdminLayout title="Manage Testimonials">
  {savedKey && (
    <p class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
      Saved: <strong>{savedKey}</strong>
    </p>
  )}

  {errorMessage && (
    <p class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
      {errorMessage}
    </p>
  )}

  <div class="space-y-6">
    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Testimonial Manager</h2>
      <p class="mb-4 text-sm text-earth-brown/80">
        Manage testimonial content and control exactly where it appears. You can use page-level rules and per-testimonial switches together.
      </p>
      <div class="grid gap-3 md:grid-cols-4">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Testimonials</p>
          <p class="text-2xl font-semibold text-earth-brown">{testimonials.length}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Active</p>
          <p class="text-2xl font-semibold text-earth-brown">{activeCount}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Featured</p>
          <p class="text-2xl font-semibold text-earth-brown">{featuredCount}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Average Rating</p>
          <p class="text-2xl font-semibold text-earth-brown">
            {testimonials.length > 0 ? averageRating.toFixed(1) : '0.0'}
          </p>
        </div>
      </div>
    </section>

    <section class="grid gap-4 lg:grid-cols-2">
      <form method="post" action="/api/admin/settings" class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm space-y-4">
        <input type="hidden" name="redirectTo" value="/admin/testimonials?saved=homepage-rules" />
        <h3 class="text-base font-semibold">Homepage Display Rules</h3>
        <p class="text-sm text-earth-brown/80">
          Currently showing <strong>{homepageVisible.length}</strong> testimonial{homepageVisible.length === 1 ? '' : 's'} on the homepage.
        </p>
        <div class="grid gap-3 md:grid-cols-2">
          <label class="block text-sm font-medium">
            Show Testimonials
            <select name="testimonials_home_enabled" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="true" selected={rules.homepage.enabled}>Yes</option>
              <option value="false" selected={!rules.homepage.enabled}>No</option>
            </select>
          </label>

          <label class="block text-sm font-medium">
            Minimum Star Rating
            <input
              type="number"
              name="testimonials_home_min_rating"
              min="1"
              max="5"
              step="1"
              value={asNumberString(rules.homepage.minRating)}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>

          <label class="block text-sm font-medium">
            Max Testimonials
            <input
              type="number"
              name="testimonials_home_max_items"
              min="1"
              max="24"
              step="1"
              value={asNumberString(rules.homepage.maxItems)}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>

          <label class="block text-sm font-medium">
            Featured Only
            <select name="testimonials_home_require_featured" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="false" selected={!rules.homepage.requireFeatured}>No</option>
              <option value="true" selected={rules.homepage.requireFeatured}>Yes</option>
            </select>
          </label>

          <label class="block text-sm font-medium md:col-span-2">
            Allowed Categories (comma-separated, leave blank for all)
            <input
              type="text"
              name="testimonials_home_allowed_categories"
              value={categoriesToSettingValue(rules.homepage.allowedCategories)}
              placeholder="general, teachers"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>
        </div>
        <p class="text-xs text-earth-brown/70">
          Available categories: {availableCategoryCsv || 'general'}
        </p>
        <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
          Save Homepage Rules
        </button>
      </form>

      <form method="post" action="/api/admin/settings" class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm space-y-4">
        <input type="hidden" name="redirectTo" value="/admin/testimonials?saved=coming-soon-rules" />
        <h3 class="text-base font-semibold">Coming Soon Display Rules</h3>
        <p class="text-sm text-earth-brown/80">
          Currently showing <strong>{comingSoonVisible.length}</strong> testimonial{comingSoonVisible.length === 1 ? '' : 's'} on the coming-soon page.
        </p>
        <div class="grid gap-3 md:grid-cols-2">
          <label class="block text-sm font-medium">
            Show Testimonials
            <select name="testimonials_coming_soon_enabled" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="true" selected={rules['coming-soon'].enabled}>Yes</option>
              <option value="false" selected={!rules['coming-soon'].enabled}>No</option>
            </select>
          </label>

          <label class="block text-sm font-medium">
            Minimum Star Rating
            <input
              type="number"
              name="testimonials_coming_soon_min_rating"
              min="1"
              max="5"
              step="1"
              value={asNumberString(rules['coming-soon'].minRating)}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>

          <label class="block text-sm font-medium">
            Max Testimonials
            <input
              type="number"
              name="testimonials_coming_soon_max_items"
              min="1"
              max="24"
              step="1"
              value={asNumberString(rules['coming-soon'].maxItems)}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>

          <label class="block text-sm font-medium">
            Featured Only
            <select name="testimonials_coming_soon_require_featured" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="false" selected={!rules['coming-soon'].requireFeatured}>No</option>
              <option value="true" selected={rules['coming-soon'].requireFeatured}>Yes</option>
            </select>
          </label>

          <label class="block text-sm font-medium md:col-span-2">
            Allowed Categories (comma-separated, leave blank for all)
            <input
              type="text"
              name="testimonials_coming_soon_allowed_categories"
              value={categoriesToSettingValue(rules['coming-soon'].allowedCategories)}
              placeholder="general, values"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>
        </div>
        <p class="text-xs text-earth-brown/70">
          Available categories: {availableCategoryCsv || 'general'}
        </p>
        <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
          Save Coming Soon Rules
        </button>
      </form>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Placement Preview</h2>
      <p class="mb-4 text-sm text-earth-brown/80">
        These are the testimonials that pass your current page rules right now.
      </p>
      <div class="grid gap-3 md:grid-cols-2">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <h3 class="text-sm font-semibold text-earth-brown">Homepage</h3>
          {homepageVisible.length === 0 ? (
            <p class="mt-2 text-sm text-earth-brown/75">No testimonials currently visible.</p>
          ) : (
            <ul class="mt-2 space-y-1 text-sm text-earth-brown/85">
              {homepageVisible.map((item) => (
                <li>{item.author} ({starsFor(item.rating)})</li>
              ))}
            </ul>
          )}
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <h3 class="text-sm font-semibold text-earth-brown">Coming Soon</h3>
          {comingSoonVisible.length === 0 ? (
            <p class="mt-2 text-sm text-earth-brown/75">No testimonials currently visible.</p>
          ) : (
            <ul class="mt-2 space-y-1 text-sm text-earth-brown/85">
              {comingSoonVisible.map((item) => (
                <li>{item.author} ({starsFor(item.rating)})</li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </section>

    <section class="space-y-4">
      <details class="rounded-xl border border-gray-200 bg-white shadow-sm">
        <summary class="cursor-pointer px-5 py-4 text-base font-semibold text-earth-brown">
          Add Testimonial
        </summary>
        <div class="space-y-4 border-t border-gray-200 p-5">
          <p class="text-sm text-earth-brown/80">
            Add a testimonial and choose exactly where it can appear.
          </p>
          <form method="post" action="/api/admin/content" class="space-y-4">
            <input type="hidden" name="collection" value="testimonials" />
            <input type="hidden" name="redirectTo" value="/admin/testimonials?saved=new" />

            <div class="grid gap-3 md:grid-cols-2">
              <label class="block text-sm font-medium">
                Author Name
                <input
                  type="text"
                  name="data.author"
                  required
                  placeholder="Parent Name"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>

              <label class="block text-sm font-medium">
                Role / Relationship
                <input
                  type="text"
                  name="data.relationship"
                  value="Parent"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>

              <label class="block text-sm font-medium md:col-span-2">
                Quote
                <textarea
                  name="data.body"
                  rows="4"
                  required
                  placeholder="Write the testimonial quote here."
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                ></textarea>
              </label>

              <label class="block text-sm font-medium">
                Star Rating
                <select name="data.rating" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                  <option value="5">5 stars</option>
                  <option value="4">4 stars</option>
                  <option value="3">3 stars</option>
                  <option value="2">2 stars</option>
                  <option value="1">1 star</option>
                </select>
              </label>

              <label class="block text-sm font-medium">
                Category
                <select name="data.category" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                  {availableCategories.map((category) => (
                    <option value={category}>{categoryLabel(category)}</option>
                  ))}
                </select>
              </label>

              <label class="block text-sm font-medium">
                Active
                <select name="data.active" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                  <option value="true">Yes</option>
                  <option value="false">No</option>
                </select>
              </label>

              <label class="block text-sm font-medium">
                Featured
                <select name="data.featured" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                  <option value="false">No</option>
                  <option value="true">Yes</option>
                </select>
              </label>

              <label class="block text-sm font-medium">
                Show on Homepage
                <select name="data.show_on_homepage" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                  <option value="true">Yes</option>
                  <option value="false">No</option>
                </select>
              </label>

              <label class="block text-sm font-medium">
                Show on Coming Soon
                <select name="data.show_on_coming_soon" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                  <option value="false">No</option>
                  <option value="true">Yes</option>
                </select>
              </label>
            </div>

            <details class="rounded-lg border border-gray-200 bg-gray-50 p-3">
              <summary class="cursor-pointer text-sm font-semibold text-earth-brown">Advanced Options</summary>
              <div class="mt-3 grid gap-3 md:grid-cols-2">
                <label class="block text-sm font-medium">
                  URL Slug
                  <input
                    type="text"
                    name="slug"
                    value={defaultSlug}
                    required
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Internal Title
                  <input
                    type="text"
                    name="title"
                    placeholder="Same as author"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Display Order
                  <input
                    type="number"
                    name="data.display_order"
                    min="1"
                    step="1"
                    value="999"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Publish Status
                  <select name="status" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                    <option value="published">Published</option>
                    <option value="draft">Draft</option>
                  </select>
                </label>
                <label class="block text-sm font-medium">
                  Author Title
                  <input
                    type="text"
                    name="data.authorTitle"
                    placeholder="Parent"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Child Age
                  <input
                    type="text"
                    name="data.childAge"
                    placeholder="4 years old"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Years at Spicebush
                  <input
                    type="number"
                    name="data.yearsAtSpicebush"
                    min="0"
                    step="1"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium">
                  Date
                  <input
                    type="date"
                    name="data.date"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
                <label class="block text-sm font-medium md:col-span-2">
                  Author Photo URL
                  <input
                    type="text"
                    name="data.authorPhoto"
                    placeholder="/images/testimonials/author.jpg"
                    class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                  />
                </label>
              </div>
            </details>

            <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
              Add Testimonial
            </button>
          </form>
        </div>
      </details>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm" data-testimonial-manager>
      <h2 class="mb-2 text-lg font-semibold">Existing Testimonials</h2>
      <p class="mb-4 text-sm text-earth-brown/80">
        Use filters to find entries quickly, then open any card to edit visibility and content.
      </p>

      {testimonials.length > 0 && (
        <div class="mb-4 grid gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3 md:grid-cols-5">
          <label class="block text-sm font-medium md:col-span-2">
            Search
            <input
              type="search"
              data-filter-search
              placeholder="Search by author or quote"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>
          <label class="block text-sm font-medium">
            Placement
            <select data-filter-placement class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="all">All</option>
              <option value="homepage">Homepage enabled</option>
              <option value="coming-soon">Coming soon enabled</option>
            </select>
          </label>
          <label class="block text-sm font-medium">
            Status
            <select data-filter-status class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="all">All</option>
              <option value="active">Active only</option>
              <option value="inactive">Inactive only</option>
            </select>
          </label>
          <label class="block text-sm font-medium">
            Category
            <select data-filter-category class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="all">All</option>
              {availableCategories.map((category) => (
                <option value={category}>{categoryLabel(category)}</option>
              ))}
            </select>
          </label>
        </div>
      )}

      {testimonials.length === 0 ? (
        <p class="rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-earth-brown/80">
          No testimonials found yet.
        </p>
      ) : (
        <div class="space-y-3" data-testimonial-list>
          {testimonials.map((testimonial) => (
            <details
              class="rounded-lg border border-gray-200 bg-gray-50"
              data-testimonial-card
              data-search={`${testimonial.author} ${testimonial.relationship} ${testimonial.body}`.toLowerCase()}
              data-placement-homepage={testimonial.showOnHomepage ? 'true' : 'false'}
              data-placement-coming-soon={testimonial.showOnComingSoon ? 'true' : 'false'}
              data-status-active={testimonial.active ? 'true' : 'false'}
              data-category={testimonial.category}
            >
              <summary class="cursor-pointer px-4 py-3">
                <div class="flex flex-wrap items-start justify-between gap-2">
                  <div>
                    <p class="font-semibold text-earth-brown">{testimonial.author}</p>
                    <p class="text-xs text-earth-brown/75">
                      {starsFor(testimonial.rating)} | {categoryLabel(testimonial.category)} | {testimonial.relationship || 'Parent'}
                    </p>
                  </div>
                  <div class="flex flex-wrap gap-2 text-xs">
                    <span class={`rounded-full border px-2 py-1 ${testimonial.active ? 'border-green-200 bg-green-50 text-green-800' : 'border-gray-200 bg-white text-earth-brown'}`}>
                      {testimonial.active ? 'active' : 'inactive'}
                    </span>
                    <span class={`rounded-full border px-2 py-1 ${testimonial.featured ? 'border-yellow-200 bg-yellow-50 text-yellow-800' : 'border-gray-200 bg-white text-earth-brown'}`}>
                      {testimonial.featured ? 'featured' : 'standard'}
                    </span>
                    <span class={`rounded-full border px-2 py-1 ${homepageVisibleSet.has(testimonial.slug) ? 'border-green-200 bg-green-50 text-green-800' : 'border-gray-200 bg-white text-earth-brown'}`}>
                      home {homepageVisibleSet.has(testimonial.slug) ? 'visible' : 'hidden'}
                    </span>
                    <span class={`rounded-full border px-2 py-1 ${comingSoonVisibleSet.has(testimonial.slug) ? 'border-green-200 bg-green-50 text-green-800' : 'border-gray-200 bg-white text-earth-brown'}`}>
                      coming soon {comingSoonVisibleSet.has(testimonial.slug) ? 'visible' : 'hidden'}
                    </span>
                  </div>
                </div>
              </summary>

              <div class="border-t border-gray-200 bg-white p-4">
                <form method="post" action="/api/admin/content" class="space-y-4">
                  <input type="hidden" name="collection" value="testimonials" />
                  <input type="hidden" name="slug" value={testimonial.slug} />
                  <input type="hidden" name="redirectTo" value={`/admin/testimonials?saved=${encodeURIComponent(testimonial.slug)}`} />
                  <input
                    type="hidden"
                    name="baseDataJson"
                    value={JSON.stringify({
                      title: testimonial.title,
                      body: testimonial.body,
                      author: testimonial.author,
                      authorTitle: testimonial.authorTitle,
                      relationship: testimonial.relationship,
                      authorPhoto: testimonial.authorPhoto ?? '',
                      rating: testimonial.rating,
                      featured: testimonial.featured,
                      active: testimonial.active,
                      show_on_homepage: testimonial.showOnHomepage,
                      show_on_coming_soon: testimonial.showOnComingSoon,
                      display_order: testimonial.displayOrder,
                      category: testimonial.category,
                      childAge: testimonial.childAge ?? '',
                      yearsAtSpicebush: testimonial.yearsAtSpicebush ?? null,
                      date: testimonial.dateLabel ?? ''
                    })}
                  />

                  <div class="grid gap-3 md:grid-cols-2">
                    <label class="block text-sm font-medium">
                      Author Name
                      <input
                        type="text"
                        name="data.author"
                        required
                        value={testimonial.author}
                        class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                      />
                    </label>

                    <label class="block text-sm font-medium">
                      Role / Relationship
                      <input
                        type="text"
                        name="data.relationship"
                        value={testimonial.relationship}
                        class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                      />
                    </label>

                    <label class="block text-sm font-medium md:col-span-2">
                      Quote
                      <textarea
                        name="data.body"
                        rows="4"
                        required
                        class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                      >{testimonial.body}</textarea>
                    </label>

                    <label class="block text-sm font-medium">
                      Star Rating
                      <select name="data.rating" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                        <option value="5" selected={testimonial.rating === 5}>5 stars</option>
                        <option value="4" selected={testimonial.rating === 4}>4 stars</option>
                        <option value="3" selected={testimonial.rating === 3}>3 stars</option>
                        <option value="2" selected={testimonial.rating === 2}>2 stars</option>
                        <option value="1" selected={testimonial.rating === 1}>1 star</option>
                      </select>
                    </label>

                    <label class="block text-sm font-medium">
                      Category
                      <select name="data.category" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                        {availableCategories.map((category) => (
                          <option value={category} selected={category === testimonial.category}>
                            {categoryLabel(category)}
                          </option>
                        ))}
                      </select>
                    </label>

                    <label class="block text-sm font-medium">
                      Active
                      <select name="data.active" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                        <option value="true" selected={testimonial.active}>Yes</option>
                        <option value="false" selected={!testimonial.active}>No</option>
                      </select>
                    </label>

                    <label class="block text-sm font-medium">
                      Featured
                      <select name="data.featured" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                        <option value="true" selected={testimonial.featured}>Yes</option>
                        <option value="false" selected={!testimonial.featured}>No</option>
                      </select>
                    </label>

                    <label class="block text-sm font-medium">
                      Show on Homepage
                      <select name="data.show_on_homepage" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                        <option value="true" selected={testimonial.showOnHomepage}>Yes</option>
                        <option value="false" selected={!testimonial.showOnHomepage}>No</option>
                      </select>
                    </label>

                    <label class="block text-sm font-medium">
                      Show on Coming Soon
                      <select name="data.show_on_coming_soon" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                        <option value="true" selected={testimonial.showOnComingSoon}>Yes</option>
                        <option value="false" selected={!testimonial.showOnComingSoon}>No</option>
                      </select>
                    </label>
                  </div>

                  <details class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                    <summary class="cursor-pointer text-sm font-semibold text-earth-brown">Advanced Options</summary>
                    <div class="mt-3 grid gap-3 md:grid-cols-2">
                      <label class="block text-sm font-medium">
                        URL Slug
                        <input
                          type="text"
                          name="slug"
                          value={testimonial.slug}
                          required
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Internal Title
                        <input
                          type="text"
                          name="title"
                          value={testimonial.title}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Display Order
                        <input
                          type="number"
                          name="data.display_order"
                          min="1"
                          step="1"
                          value={asNumberString(testimonial.displayOrder)}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Publish Status
                        <select name="status" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
                          <option value="published">Published</option>
                          <option value="draft">Draft</option>
                        </select>
                      </label>
                      <label class="block text-sm font-medium">
                        Author Title
                        <input
                          type="text"
                          name="data.authorTitle"
                          value={testimonial.authorTitle}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Child Age
                        <input
                          type="text"
                          name="data.childAge"
                          value={testimonial.childAge ?? ''}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Years at Spicebush
                        <input
                          type="number"
                          name="data.yearsAtSpicebush"
                          min="0"
                          step="1"
                          value={testimonial.yearsAtSpicebush !== undefined ? asNumberString(testimonial.yearsAtSpicebush) : ''}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium">
                        Date
                        <input
                          type="date"
                          name="data.date"
                          value={testimonial.dateValue ? testimonial.dateValue.toISOString().slice(0, 10) : ''}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                      <label class="block text-sm font-medium md:col-span-2">
                        Author Photo URL
                        <input
                          type="text"
                          name="data.authorPhoto"
                          value={testimonial.authorPhoto ?? ''}
                          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                        />
                      </label>
                    </div>
                  </details>

                  <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
                    Save Testimonial
                  </button>
                </form>
              </div>
            </details>
          ))}
        </div>
      )}
      <p class="mt-3 text-xs text-earth-brown/70">
        <span data-visible-count>{testimonials.length}</span> of {testimonials.length} testimonials shown in this list.
      </p>
    </section>
  </div>

  <script>
    const manager = document.querySelector('[data-testimonial-manager]');
    if (manager) {
      const cards = [...manager.querySelectorAll('[data-testimonial-card]')] as HTMLElement[];
      const searchInput = manager.querySelector('[data-filter-search]');
      const placementSelect = manager.querySelector('[data-filter-placement]');
      const statusSelect = manager.querySelector('[data-filter-status]');
      const categorySelect = manager.querySelector('[data-filter-category]');
      const visibleCountEl = manager.querySelector('[data-visible-count]');

      const safeValue = (el: Element | null): string => (
        el instanceof HTMLInputElement || el instanceof HTMLSelectElement ? el.value : ''
      );

      const applyFilters = () => {
        const search = safeValue(searchInput).trim().toLowerCase();
        const placement = safeValue(placementSelect);
        const status = safeValue(statusSelect);
        const category = safeValue(categorySelect);

        let visibleCount = 0;

        cards.forEach((card) => {
          const searchText = (card.getAttribute('data-search') || '').toLowerCase();
          const active = card.getAttribute('data-status-active') === 'true';
          const showOnHomepage = card.getAttribute('data-placement-homepage') === 'true';
          const showOnComingSoon = card.getAttribute('data-placement-coming-soon') === 'true';
          const cardCategory = card.getAttribute('data-category') || '';

          const searchMatch = search.length === 0 || searchText.includes(search);
          const placementMatch = placement === 'all'
            || (placement === 'homepage' && showOnHomepage)
            || (placement === 'coming-soon' && showOnComingSoon);
          const statusMatch = status === 'all'
            || (status === 'active' && active)
            || (status === 'inactive' && !active);
          const categoryMatch = category === 'all' || category === cardCategory;

          const visible = searchMatch && placementMatch && statusMatch && categoryMatch;
          card.style.display = visible ? '' : 'none';
          if (visible) visibleCount += 1;
        });

        if (visibleCountEl) {
          visibleCountEl.textContent = String(visibleCount);
        }
      };

      [searchInput, placementSelect, statusSelect, categorySelect].forEach((input) => {
        if (!input) return;
        input.addEventListener('input', applyFilters);
        input.addEventListener('change', applyFilters);
      });

      applyFilters();
    }
  </script>
</AdminLayout>
