---
import AdminLayout from '@layouts/AdminLayout.astro';
import SettingInfo from '@components/admin/SettingInfo.astro';
import { db } from '@lib/db';

const settings = await db.content.getAllSettings();
const savedKey = Astro.url.searchParams.get('saved');
const errorMessage = Astro.url.searchParams.get('error');
const previewMode =
  Astro.cookies.get('sbms-preview-mode')?.value === 'site' ? 'site' : 'coming-soon';

const stringifyValue = (value: unknown): string => {
  if (value === null || value === undefined) return '';
  if (typeof value === 'string') return value;
  return JSON.stringify(value);
};

const boolFrom = (value: unknown): boolean => {
  if (typeof value === 'boolean') return value;
  if (typeof value === 'number') return value === 1;
  if (typeof value === 'string') {
    return ['true', '1', 'yes', 'on'].includes(value.trim().toLowerCase());
  }
  return false;
};

const boolFromSetting = (value: unknown, fallback: boolean): boolean => {
  if (value === undefined || value === null || value === '') return fallback;
  return boolFrom(value);
};

const stringifyEmailList = (value: unknown, fallback = ''): string => {
  if (Array.isArray(value)) {
    const normalized = value
      .map((entry) => (typeof entry === 'string' ? entry.trim() : ''))
      .filter((entry) => entry.length > 0);
    return normalized.join(', ');
  }
  const normalized = stringifyValue(value);
  return normalized || fallback;
};

const comingSoonEnabled = boolFrom(settings.coming_soon_enabled);
const comingSoonMessage = stringifyValue(settings.coming_soon_message);
const comingSoonLaunchDate = stringifyValue(settings.coming_soon_launch_date);
const donationLink = stringifyValue(settings.donation_external_link);
const enrollmentLink = stringifyValue(settings.enrollment_external_link);
const tourExternalLink = stringifyValue(settings.tour_external_link);
const schoolEmail = stringifyValue(
  settings.school_email || settings.main_email || settings.contact_email || 'information@spicebushmontessori.org'
);
const contactNotifyEmails = stringifyEmailList(settings.contact_form_notify_emails, schoolEmail);
const comingSoonNotifyEmails = stringifyEmailList(
  settings.coming_soon_form_notify_emails,
  schoolEmail
);
const campNotifyEmails = stringifyEmailList(settings.camp_form_notify_emails, schoolEmail);
const tourNotifyEmails = stringifyEmailList(settings.tour_request_notify_emails, schoolEmail);
const contactConfirmSubmitter = boolFromSetting(settings.contact_form_confirm_submitter, true);
const comingSoonConfirmSubmitter = boolFromSetting(settings.coming_soon_form_confirm_submitter, true);
const campConfirmSubmitter = boolFromSetting(settings.camp_form_confirm_submitter, true);
const tourConfirmSubmitter = boolFromSetting(settings.tour_request_confirm_submitter, true);
const contactNotifySubject =
  stringifyValue(settings.contact_form_notify_subject) || 'New Contact Form Inquiry - {{name}}';
const comingSoonNotifySubject =
  stringifyValue(settings.coming_soon_form_notify_subject) || 'New Coming Soon Inquiry - {{name}}';
const campNotifySubject =
  stringifyValue(settings.camp_form_notify_subject) || 'New Camp Question - {{name}}';
const tourNotifySubject =
  stringifyValue(settings.tour_request_notify_subject) || 'New Tour Request - {{name}}';
const contactConfirmSubject =
  stringifyValue(settings.contact_form_confirm_subject) || 'Thanks for contacting Spicebush Montessori';
const comingSoonConfirmSubject =
  stringifyValue(settings.coming_soon_form_confirm_subject) ||
  'Thanks for your interest in Spicebush Montessori';
const campConfirmSubject =
  stringifyValue(settings.camp_form_confirm_subject) || 'Thanks for your camp question';
const tourConfirmSubject =
  stringifyValue(settings.tour_request_confirm_subject) ||
  'Tour Request Confirmation - Spicebush Montessori';
const parseCampModeOverride = (value: unknown): 'auto' | 'on' | 'off' | 'prep' => {
  if (typeof value !== 'string') return 'off';
  const normalized = value.trim().toLowerCase();
  if (
    normalized === 'auto' ||
    normalized === 'on' ||
    normalized === 'off' ||
    normalized === 'prep'
  ) {
    return normalized as 'auto' | 'on' | 'off' | 'prep';
  }
  return 'off';
};
const campModeOverride = parseCampModeOverride(settings.camp_mode_override);
const campModeStartAt = stringifyValue(settings.camp_mode_start_at);
const campModeEndAt = stringifyValue(settings.camp_mode_end_at);
const campModeTimezone = stringifyValue(settings.camp_mode_timezone || 'America/New_York');
const campPromotionsEnabled = boolFrom(settings.camp_promotions_enabled);
const sortedEntries = Object.entries(settings).sort(([a], [b]) => a.localeCompare(b));

type SettingHelpContent = {
  title: string;
  description: string;
  format?: string;
  example?: string;
  defaultValue?: string;
  impact?: string;
};

const settingHelp: Record<string, SettingHelpContent> = {
  coming_soon_enabled: {
    title: 'Coming Soon Enabled',
    description: 'Turns the public site into coming-soon mode for visitors.',
    format: 'true or false',
    defaultValue: 'false',
    impact: 'Admins can still bypass based on existing auth logic.'
  },
  coming_soon_message: {
    title: 'Coming Soon Message',
    description: 'Main text families see on the coming-soon page.',
    format: 'Plain text',
    impact: 'Used as the primary enrollment/update message.'
  },
  coming_soon_launch_date: {
    title: 'Coming Soon Launch Date',
    description: 'Short launch/date label shown on the coming-soon page.',
    format: 'Plain text',
    example: 'Fall 2026'
  },
  camp_mode_override: {
    title: 'Camp Mode Override',
    description: 'Controls camp visibility state.',
    format: 'auto, prep, on, off',
    impact: '`prep` is admin-only preview, `off` hides camp for everyone.'
  },
  camp_mode_timezone: {
    title: 'Camp Timezone',
    description: 'Timezone used for auto camp mode scheduling.',
    format: 'IANA timezone string',
    example: 'America/New_York'
  },
  camp_mode_start_at: {
    title: 'Camp Auto Start',
    description: 'Date/time when camp mode can automatically activate.',
    format: 'ISO datetime',
    example: '2026-05-01T00:00:00-04:00'
  },
  camp_mode_end_at: {
    title: 'Camp Auto End',
    description: 'Date/time when camp mode can automatically turn off.',
    format: 'ISO datetime',
    example: '2026-08-31T23:59:59-04:00'
  },
  camp_promotions_enabled: {
    title: 'Camp Promotions Enabled',
    description: 'Shows or hides camp-related promo banners/CTAs around the site.',
    format: 'true or false',
    defaultValue: 'false'
  },
  donation_external_link: {
    title: 'Donation Link',
    description: 'External URL used for donation CTA fallback.',
    format: 'Absolute URL',
    example: 'https://example.org/donate'
  },
  enrollment_external_link: {
    title: 'Enrollment Link',
    description: 'External URL used for enrollment CTA.',
    format: 'Absolute URL',
    example: 'https://example.org/enroll'
  },
  tour_external_link: {
    title: 'Tour Link',
    description: 'External tour scheduling URL used across admissions and coming soon.',
    format: 'Absolute URL',
    example: 'https://calendly.com/...'
  },
  school_email: {
    title: 'School Email',
    description: 'Primary school email used as routing/sender fallback.',
    format: 'Email address',
    example: 'information@spicebushmontessori.org'
  },
  contact_form_notify_emails: {
    title: 'Contact Notification Recipients',
    description: 'Who gets notified when the contact form is submitted.',
    format: 'Comma-separated emails',
    example: 'admin@domain.org, admissions@domain.org'
  },
  coming_soon_form_notify_emails: {
    title: 'Coming Soon Notification Recipients',
    description: 'Who gets notified when the coming-soon inquiry form is submitted.',
    format: 'Comma-separated emails',
    example: 'information@domain.org, director@domain.org'
  },
  camp_form_notify_emails: {
    title: 'Camp Notification Recipients',
    description: 'Who gets notified when the camp Ask Admissions form is submitted.',
    format: 'Comma-separated emails',
    example: 'camp@domain.org, admissions@domain.org'
  },
  tour_request_notify_emails: {
    title: 'Tour Request Notification Recipients',
    description: 'Who gets notified when a tour request is submitted.',
    format: 'Comma-separated emails',
    example: 'information@domain.org, director@domain.org'
  },
  contact_form_notify_subject: {
    title: 'Contact Notification Subject',
    description: 'Subject line used for internal contact form alerts.',
    format: 'Plain text with optional placeholders',
    example: 'New Contact Form Inquiry - {{name}}'
  },
  coming_soon_form_notify_subject: {
    title: 'Coming Soon Notification Subject',
    description: 'Subject line used for internal coming-soon alerts.',
    format: 'Plain text with optional placeholders',
    example: 'New Coming Soon Inquiry - {{name}}'
  },
  camp_form_notify_subject: {
    title: 'Camp Notification Subject',
    description: 'Subject line used for internal camp inquiry alerts.',
    format: 'Plain text with optional placeholders',
    example: 'New Camp Question - {{name}}'
  },
  tour_request_notify_subject: {
    title: 'Tour Notification Subject',
    description: 'Subject line used for internal tour request alerts.',
    format: 'Plain text with optional placeholders',
    example: 'New Tour Request - {{name}}'
  },
  contact_form_confirm_submitter: {
    title: 'Contact Auto Confirmation',
    description: 'Send confirmation email to family after contact form submit.',
    format: 'true or false',
    defaultValue: 'true'
  },
  coming_soon_form_confirm_submitter: {
    title: 'Coming Soon Auto Confirmation',
    description: 'Send confirmation email to family after coming-soon inquiry submit.',
    format: 'true or false',
    defaultValue: 'true'
  },
  camp_form_confirm_submitter: {
    title: 'Camp Auto Confirmation',
    description: 'Send confirmation email to families after camp inquiry submit.',
    format: 'true or false',
    defaultValue: 'true'
  },
  tour_request_confirm_submitter: {
    title: 'Tour Auto Confirmation',
    description: 'Send confirmation email to families after tour request submit.',
    format: 'true or false',
    defaultValue: 'true'
  },
  contact_form_confirm_subject: {
    title: 'Contact Confirmation Subject',
    description: 'Subject line for family confirmation after contact submission.',
    format: 'Plain text with optional placeholders',
    example: 'Thanks for contacting Spicebush Montessori'
  },
  coming_soon_form_confirm_subject: {
    title: 'Coming Soon Confirmation Subject',
    description: 'Subject line for family confirmation after coming-soon submission.',
    format: 'Plain text with optional placeholders',
    example: 'Thanks for your interest in Spicebush Montessori'
  },
  camp_form_confirm_subject: {
    title: 'Camp Confirmation Subject',
    description: 'Subject line for family confirmation after camp inquiry submission.',
    format: 'Plain text with optional placeholders',
    example: 'Thanks for your camp question'
  },
  tour_request_confirm_subject: {
    title: 'Tour Confirmation Subject',
    description: 'Subject line for family confirmation after tour request submission.',
    format: 'Plain text with optional placeholders',
    example: 'Tour Request Confirmation - Spicebush Montessori'
  }
};

const getSettingHelp = (key: string): SettingHelpContent =>
  settingHelp[key] ?? {
    title: key,
    description: 'Raw setting stored in the database. Change carefully.',
    format: 'Plain text or valid JSON',
    impact: 'Used by whichever feature reads this key at runtime.'
  };
---

<AdminLayout title="Manage Settings">
  {
    savedKey && (
      <p class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
        Saved setting: <strong>{savedKey}</strong>
      </p>
    )
  }

  {
    errorMessage && (
      <p class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
        {errorMessage}
      </p>
    )
  }

  <div class="space-y-6">
    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold mb-3">Admin Preview Toggle</h2>
      <p class="text-sm text-earth-brown/80 mb-4">
        Current preview mode: <strong>{previewMode === 'site' ? 'Full Site' : 'Coming Soon'}</strong
        >
      </p>
      <SettingInfo
        title="Admin Preview Toggle"
        description="Switches your personal admin preview between full site and coming-soon mode."
        format="Button toggle"
        impact="Only affects your preview cookie while editing."
      />
      <form
        method="post"
        action={`/api/admin/preview-mode?mode=${previewMode === 'site' ? 'coming-soon' : 'site'}&redirect=${encodeURIComponent('/admin/settings')}`}
      >
        <button
          type="submit"
          class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green"
        >
          {previewMode === 'site' ? 'Switch To Coming Soon View' : 'Switch To Full Site View'}
        </button>
      </form>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold mb-3">Core Settings</h2>
      <div class="space-y-4">
        <form method="post" action="/api/admin/settings" class="space-y-2">
          <input type="hidden" name="key" value="coming_soon_enabled" />
          <input
            type="hidden"
            name="redirectTo"
            value="/admin/settings?saved=coming_soon_enabled"
          />
          <label class="block text-sm font-medium">
            Coming Soon Enabled
            <select name="value" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
              <option value="true" selected={comingSoonEnabled}>true</option>
              <option value="false" selected={!comingSoonEnabled}>false</option>
            </select>
          </label>
          <SettingInfo {...getSettingHelp('coming_soon_enabled')} />
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Coming Soon Toggle
          </button>
        </form>

        <form method="post" action="/api/admin/settings" class="space-y-2">
          <input type="hidden" name="key" value="coming_soon_message" />
          <input
            type="hidden"
            name="redirectTo"
            value="/admin/settings?saved=coming_soon_message"
          />
          <label class="block text-sm font-medium">
            Coming Soon Message
            <textarea
              name="value"
              rows="3"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            >{comingSoonMessage}</textarea
            >
          </label>
          <SettingInfo {...getSettingHelp('coming_soon_message')} />
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Message
          </button>
        </form>

        <form method="post" action="/api/admin/settings" class="space-y-2">
          <input type="hidden" name="key" value="coming_soon_launch_date" />
          <input
            type="hidden"
            name="redirectTo"
            value="/admin/settings?saved=coming_soon_launch_date"
          />
          <label class="block text-sm font-medium">
            Coming Soon Launch Date
            <input
              type="text"
              name="value"
              value={comingSoonLaunchDate}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>
          <SettingInfo {...getSettingHelp('coming_soon_launch_date')} />
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Launch Date
          </button>
        </form>

        <form
          method="post"
          action="/api/admin/settings"
          class="space-y-3 rounded-lg border border-gray-200 p-4"
        >
          <input type="hidden" name="redirectTo" value="/admin/settings?saved=camp_mode" />
          <h3 class="text-base font-semibold text-earth-brown">Camp Mode And Promotions</h3>
          <p class="text-xs text-earth-brown/80">
            `prep` keeps camp private for admins to preview. `auto` follows the schedule window.
            `on` makes camp live for everyone. `off` hides camp for everyone.
          </p>
          <div class="grid gap-3 md:grid-cols-2">
            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Camp Mode Override
                <select
                  name="camp_mode_override"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                >
                  <option value="auto" selected={campModeOverride === 'auto'}>auto</option>
                  <option value="prep" selected={campModeOverride === 'prep'}>prep</option>
                  <option value="on" selected={campModeOverride === 'on'}>on</option>
                  <option value="off" selected={campModeOverride === 'off'}>off</option>
                </select>
              </label>
              <SettingInfo {...getSettingHelp('camp_mode_override')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Camp Timezone
                <input
                  type="text"
                  name="camp_mode_timezone"
                  value={campModeTimezone}
                  placeholder="America/New_York"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('camp_mode_timezone')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Auto Start (ISO datetime)
                <input
                  type="text"
                  name="camp_mode_start_at"
                  value={campModeStartAt}
                  placeholder="2026-05-01T00:00:00-04:00"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('camp_mode_start_at')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Auto End (ISO datetime)
                <input
                  type="text"
                  name="camp_mode_end_at"
                  value={campModeEndAt}
                  placeholder="2026-08-31T23:59:59-04:00"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('camp_mode_end_at')} />
            </div>

            <div class="space-y-2 md:col-span-2">
              <label class="block text-sm font-medium">
                Enable Sitewide Camp Promotions
                <select
                  name="camp_promotions_enabled"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                >
                  <option value="true" selected={campPromotionsEnabled}>true</option>
                  <option value="false" selected={!campPromotionsEnabled}>false</option>
                </select>
              </label>
              <SettingInfo {...getSettingHelp('camp_promotions_enabled')} />
            </div>
          </div>
          <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 text-xs text-earth-brown/80">
            <p class="font-semibold text-earth-brown">Preview Links</p>
            <p class="mt-1">
              Camp page: <a href="/camp" class="text-forest-canopy hover:underline">/camp</a>
            </p>
            <p class="mt-1">
              Camp coming soon page: <a
                href="/camp-coming-soon"
                class="text-forest-canopy hover:underline">/camp-coming-soon</a
              >
            </p>
          </div>
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Camp Mode Settings
          </button>
        </form>

        <form method="post" action="/api/admin/settings" class="space-y-2">
          <input type="hidden" name="key" value="donation_external_link" />
          <input
            type="hidden"
            name="redirectTo"
            value="/admin/settings?saved=donation_external_link"
          />
          <label class="block text-sm font-medium">
            Donation Fallback Link (optional)
            <input
              type="text"
              name="value"
              value={donationLink}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>
          <SettingInfo {...getSettingHelp('donation_external_link')} />
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Donation Link
          </button>
        </form>

        <form method="post" action="/api/admin/settings" class="space-y-2">
          <input type="hidden" name="key" value="enrollment_external_link" />
          <input
            type="hidden"
            name="redirectTo"
            value="/admin/settings?saved=enrollment_external_link"
          />
          <label class="block text-sm font-medium">
            Enrollment External Link (future)
            <input
              type="text"
              name="value"
              value={enrollmentLink}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>
          <SettingInfo {...getSettingHelp('enrollment_external_link')} />
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Enrollment Link
          </button>
        </form>

        <form method="post" action="/api/admin/settings" class="space-y-2">
          <input type="hidden" name="key" value="tour_external_link" />
          <input type="hidden" name="redirectTo" value="/admin/settings?saved=tour_external_link" />
          <label class="block text-sm font-medium">
            Tour External Link
            <input
              type="text"
              name="value"
              value={tourExternalLink}
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>
          <SettingInfo {...getSettingHelp('tour_external_link')} />
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Tour Link
          </button>
        </form>

        <form
          method="post"
          action="/api/admin/settings"
          class="space-y-3 rounded-lg border border-gray-200 p-4"
        >
          <input type="hidden" name="redirectTo" value="/admin/settings?saved=email_routing" />
          <h3 class="text-base font-semibold text-earth-brown">Email Routing And Templates</h3>
          <p class="text-xs text-earth-brown/80">
            Configure who gets notified for each form and what subject lines families/admins see.
            Use comma-separated emails for recipient lists.
          </p>
          <div class="grid gap-3 md:grid-cols-2">
            <div class="space-y-2">
              <label class="block text-sm font-medium">
                School Email (sender fallback)
                <input
                  type="email"
                  name="school_email"
                  value={schoolEmail}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('school_email')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Contact Form Notification Recipients
                <input
                  type="text"
                  name="contact_form_notify_emails"
                  value={contactNotifyEmails}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('contact_form_notify_emails')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Coming Soon Notification Recipients
                <input
                  type="text"
                  name="coming_soon_form_notify_emails"
                  value={comingSoonNotifyEmails}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('coming_soon_form_notify_emails')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Camp Notification Recipients
                <input
                  type="text"
                  name="camp_form_notify_emails"
                  value={campNotifyEmails}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('camp_form_notify_emails')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Tour Request Notification Recipients
                <input
                  type="text"
                  name="tour_request_notify_emails"
                  value={tourNotifyEmails}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('tour_request_notify_emails')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Contact Notification Subject
                <input
                  type="text"
                  name="contact_form_notify_subject"
                  value={contactNotifySubject}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('contact_form_notify_subject')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Coming Soon Notification Subject
                <input
                  type="text"
                  name="coming_soon_form_notify_subject"
                  value={comingSoonNotifySubject}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('coming_soon_form_notify_subject')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Camp Notification Subject
                <input
                  type="text"
                  name="camp_form_notify_subject"
                  value={campNotifySubject}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('camp_form_notify_subject')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Tour Request Notification Subject
                <input
                  type="text"
                  name="tour_request_notify_subject"
                  value={tourNotifySubject}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('tour_request_notify_subject')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Send Contact Confirmation To Families
                <select
                  name="contact_form_confirm_submitter"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                >
                  <option value="true" selected={contactConfirmSubmitter}>true</option>
                  <option value="false" selected={!contactConfirmSubmitter}>false</option>
                </select>
              </label>
              <SettingInfo {...getSettingHelp('contact_form_confirm_submitter')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Send Coming Soon Confirmation To Families
                <select
                  name="coming_soon_form_confirm_submitter"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                >
                  <option value="true" selected={comingSoonConfirmSubmitter}>true</option>
                  <option value="false" selected={!comingSoonConfirmSubmitter}>false</option>
                </select>
              </label>
              <SettingInfo {...getSettingHelp('coming_soon_form_confirm_submitter')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Send Camp Confirmation To Families
                <select
                  name="camp_form_confirm_submitter"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                >
                  <option value="true" selected={campConfirmSubmitter}>true</option>
                  <option value="false" selected={!campConfirmSubmitter}>false</option>
                </select>
              </label>
              <SettingInfo {...getSettingHelp('camp_form_confirm_submitter')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Send Tour Confirmation To Families
                <select
                  name="tour_request_confirm_submitter"
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                >
                  <option value="true" selected={tourConfirmSubmitter}>true</option>
                  <option value="false" selected={!tourConfirmSubmitter}>false</option>
                </select>
              </label>
              <SettingInfo {...getSettingHelp('tour_request_confirm_submitter')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Contact Confirmation Subject
                <input
                  type="text"
                  name="contact_form_confirm_subject"
                  value={contactConfirmSubject}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('contact_form_confirm_subject')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Coming Soon Confirmation Subject
                <input
                  type="text"
                  name="coming_soon_form_confirm_subject"
                  value={comingSoonConfirmSubject}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('coming_soon_form_confirm_subject')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Camp Confirmation Subject
                <input
                  type="text"
                  name="camp_form_confirm_subject"
                  value={campConfirmSubject}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('camp_form_confirm_subject')} />
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-medium">
                Tour Confirmation Subject
                <input
                  type="text"
                  name="tour_request_confirm_subject"
                  value={tourConfirmSubject}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
                />
              </label>
              <SettingInfo {...getSettingHelp('tour_request_confirm_subject')} />
            </div>
          </div>
          <p class="text-xs text-earth-brown/75">
            Subject placeholders supported: <code>{'{{name}}'}</code>, <code>{'{{subject}}'}</code>, <code>{'{{source}}'}</code>
          </p>
          <button
            type="submit"
            class="rounded-lg bg-forest-canopy px-4 py-2 text-sm font-semibold text-white hover:bg-moss-green"
          >
            Save Email Routing
          </button>
        </form>
      </div>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold mb-3">All Settings</h2>
      <div class="space-y-4">
        {
          sortedEntries.map(([key, value]) => (
            <form
              method="post"
              action="/api/admin/settings"
              class="space-y-2 rounded-lg border border-gray-200 p-3"
            >
              <input type="hidden" name="key" value={key} />
              <input
                type="hidden"
                name="redirectTo"
                value={`/admin/settings?saved=${encodeURIComponent(key)}`}
              />
              <label class="block text-sm font-medium">{key}</label>
              <SettingInfo {...getSettingHelp(key)} />
              <textarea
                name="value"
                rows="2"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-sm"
              >
                {stringifyValue(value)}
              </textarea>
              <button
                type="submit"
                class="rounded-lg bg-forest-canopy px-3 py-1.5 text-sm font-semibold text-white hover:bg-moss-green"
              >
                Save {key}
              </button>
            </form>
          ))
        }
      </div>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold mb-3">Create New Setting</h2>
      <form method="post" action="/api/admin/settings" class="space-y-3">
        <input type="hidden" name="redirectTo" value="/admin/settings?saved=new" />
        <div class="space-y-2">
          <label class="block text-sm font-medium">
            Setting Key
            <input
              type="text"
              name="key"
              placeholder="new_setting_key"
              required
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
            />
          </label>
          <SettingInfo
            title="Setting Key"
            description="Unique identifier used in code to read this value."
            format="letters, numbers, and underscores only"
            example="contact_form_notify_emails"
          />
        </div>
        <div class="space-y-2">
          <label class="block text-sm font-medium">
            Setting Value
            <textarea
              name="value"
              rows="3"
              placeholder="Setting value (string or JSON)"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"></textarea>
          </label>
          <SettingInfo
            title="Setting Value"
            description="The value stored for this key."
            format="plain text, true/false, number, or JSON"
            example='["a@domain.org", "b@domain.org"]'
          />
        </div>
        <button
          type="submit"
          class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green"
        >
          Create Setting
        </button>
      </form>
    </section>
  </div>
</AdminLayout>
