<style>
  .settings-tab {
    @apply text-gray-500 border-transparent;
  }
  
  .settings-tab.active {
    @apply text-gray-900 border-gray-900;
  }
  
  .settings-tab:hover {
    @apply text-gray-700 border-gray-300;
  }
</style>

<script>
// Include Supabase client
import { supabase } from '@lib/supabase.ts';

document.addEventListener('DOMContentLoaded', function() {
  const tabs = document.querySelectorAll('.settings-tab');
  const panels = document.querySelectorAll('.settings-panel');
  
  // Load settings from database
  loadAllSettings();
  
  tabs.forEach(tab => {
    tab.addEventListener('click', function() {
      const targetTab = this.getAttribute('data-tab');
      
      // Update active tab
      tabs.forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      
      // Show corresponding panel
      panels.forEach(panel => {
        if (panel.id === `${targetTab}-settings`) {
          panel.classList.remove('hidden');
        } else {
          panel.classList.add('hidden');
        }
      });
    });
  });
  
  // Handle password/sensitive field visibility toggle
  document.querySelectorAll('.toggle-visibility').forEach(toggle => {
    toggle.addEventListener('click', function() {
      const targetId = this.getAttribute('data-target');
      const targetInput = document.getElementById(targetId);
      const eyeOpen = this.querySelector('.visible');
      const eyeClosed = this.querySelector('.hidden');
      
      if (targetInput.type === 'password') {
        targetInput.type = 'text';
        eyeOpen.classList.add('hidden');
        eyeOpen.classList.remove('visible');
        eyeClosed.classList.add('visible');
        eyeClosed.classList.remove('hidden');
      } else {
        targetInput.type = 'password';
        eyeOpen.classList.add('visible');
        eyeOpen.classList.remove('hidden');
        eyeClosed.classList.add('hidden');
        eyeClosed.classList.remove('visible');
      }
    });
  });
  
  // Load all settings from database
  async function loadAllSettings() {
    try {
      const { data, error } = await supabase
        .from('admin_settings')
        .select('*');
      
      if (error) throw error;
      
      if (data) {
        const settings = data.reduce((acc, setting) => {
          let value;
          try {
            value = JSON.parse(setting.setting_value);
          } catch {
            value = setting.setting_value;
          }
          
          acc[setting.setting_key] = {
            value,
            category: setting.setting_category,
            is_sensitive: setting.is_sensitive
          };
          return acc;
        }, {});
        
        populateFormFields(settings);
      }
    } catch (error) {
      console.error('Error loading settings:', error);
    }
  }
  
  // Populate form fields with loaded settings
  function populateFormFields(settings) {
    // General Settings - Site Configuration
    document.getElementById('school-name')?.setAttribute('value', settings.school_name?.value || 'Spicebush Montessori School');
    document.getElementById('contact-email')?.setAttribute('value', settings.contact_email?.value || 'information@spicebushmontessori.org');
    document.getElementById('phone-number')?.setAttribute('value', settings.phone_number?.value || '(484) 202-0712');
    document.getElementById('school-address').value = settings.school_address?.value || '827 Concord Road\nGlen Mills, PA 19342';
    document.getElementById('contact-form-recipient')?.setAttribute('value', settings.contact_form_recipient?.value || '');
    
    // System Preferences
    if (document.getElementById('timezone')) {
      const timezoneSelect = document.getElementById('timezone');
      const timezone = settings.timezone?.value || 'America/New_York';
      Array.from(timezoneSelect.options).forEach(option => {
        if (option.text.includes(timezone)) {
          option.selected = true;
        }
      });
    }
    
    if (document.getElementById('date-format')) {
      const formatSelect = document.getElementById('date-format');
      const format = settings.date_format?.value || 'MM/DD/YYYY';
      Array.from(formatSelect.options).forEach(option => {
        if (option.text === format) {
          option.selected = true;
        }
      });
    }
    
    document.getElementById('maintenance-mode').checked = settings.maintenance_mode?.value === true;
    document.getElementById('debug-mode').checked = settings.debug_mode?.value === true;
    
    // Security Settings
    if (settings.password_requirements?.value) {
      const requirements = settings.password_requirements.value;
      document.querySelector('input[name="password_min_length"]').checked = requirements.min_length;
      document.querySelector('input[name="password_uppercase"]').checked = requirements.uppercase;
      document.querySelector('input[name="password_number"]').checked = requirements.number;
      document.querySelector('input[name="password_special"]').checked = requirements.special;
    }
    
    if (document.querySelector('select[name="session_timeout"]')) {
      const timeoutSelect = document.querySelector('select[name="session_timeout"]');
      const timeout = settings.session_timeout?.value || '3600';
      Array.from(timeoutSelect.options).forEach(option => {
        if (option.value === timeout) {
          option.selected = true;
        }
      });
    }
    
    document.getElementById('two-factor').checked = settings.two_factor_auth?.value === true;
    document.getElementById('google-maps-key')?.setAttribute('value', settings.google_maps_api_key?.value || '');
    
    // Backup Settings
    if (settings.backup_settings?.value) {
      const backupSettings = settings.backup_settings.value;
      document.querySelector('input[name="daily_backups"]').checked = backupSettings.daily_backups;
      document.querySelector('input[name="retain_backups"]').checked = backupSettings.retain_30_days;
    }
    
    // Notification Settings
    document.querySelector('input[name="notify_user_reg"]').checked = settings.notify_user_reg?.value !== false;
    document.querySelector('input[name="notify_contact_form"]').checked = settings.notify_contact_form?.value !== false;
    document.querySelector('input[name="notify_tour_requests"]').checked = settings.notify_tour_requests?.value !== false;
    document.querySelector('input[name="notify_system_errors"]').checked = settings.notify_system_errors?.value !== false;
    document.querySelector('input[name="notify_weekly_analytics"]').checked = settings.notify_weekly_analytics?.value === true;
    
    document.querySelector('input[name="alert_high_traffic"]').checked = settings.alert_high_traffic?.value === true;
    document.querySelector('input[name="alert_backup_failures"]').checked = settings.alert_backup_failures?.value !== false;
    document.querySelector('input[name="alert_security_login"]').checked = settings.alert_security_login?.value !== false;
    document.querySelector('input[name="alert_maintenance"]').checked = settings.alert_maintenance?.value !== false;
    
    document.getElementById('notification-email')?.setAttribute('value', settings.notification_email?.value || '');
    document.querySelector('input[name="smtp_host"]')?.setAttribute('value', settings.smtp_host?.value || '');
    document.querySelector('input[name="smtp_port"]')?.setAttribute('value', settings.smtp_port?.value || '587');
    document.querySelector('input[name="smtp_username"]')?.setAttribute('value', settings.smtp_username?.value || '');
    document.getElementById('smtp-password')?.setAttribute('value', settings.smtp_password?.value || '');
    
    // Analytics Settings
    document.getElementById('google-analytics-id')?.setAttribute('value', settings.google_analytics_id?.value || '');
    document.getElementById('google-tag-manager-id')?.setAttribute('value', settings.google_tag_manager_id?.value || '');
    document.querySelector('input[name="track_user_sessions"]').checked = settings.track_user_sessions?.value !== false;
    document.querySelector('input[name="track_page_views"]').checked = settings.track_page_views?.value !== false;
    document.querySelector('input[name="track_events"]').checked = settings.track_events?.value !== false;
    document.querySelector('input[name="respect_dnt"]').checked = settings.respect_dnt?.value !== false;
    
    // Storage Settings
    const storageProvider = settings.storage_provider?.value || 'local';
    document.getElementById('storage-provider').value = storageProvider;
    
    // Local storage settings
    if (settings.max_file_size?.value) {
      document.querySelector('input[name="max_file_size"]').value = settings.max_file_size.value;
    }
    
    // Load provider-specific settings
    if (storageProvider === 'gcs' && settings.gcs_config?.value) {
      const gcsConfig = settings.gcs_config.value;
      document.querySelector('input[name="gcs_project_id"]').value = gcsConfig.project_id || '';
      document.querySelector('input[name="gcs_bucket_name"]').value = gcsConfig.bucket_name || '';
      document.querySelector('textarea[name="gcs_service_key"]').value = gcsConfig.service_key || '';
    }
    
    if (storageProvider === 'r2' && settings.r2_config?.value) {
      const r2Config = settings.r2_config.value;
      document.querySelector('input[name="r2_account_id"]').value = r2Config.account_id || '';
      document.querySelector('input[name="r2_bucket_name"]').value = r2Config.bucket_name || '';
      document.querySelector('input[name="r2_access_key_id"]').value = r2Config.access_key_id || '';
      document.querySelector('input[name="r2_secret_access_key"]').value = r2Config.secret_access_key || '';
    }
    
    if (storageProvider === 'b2' && settings.b2_config?.value) {
      const b2Config = settings.b2_config.value;
      document.querySelector('input[name="b2_key_id"]').value = b2Config.key_id || '';
      document.querySelector('input[name="b2_app_key"]').value = b2Config.app_key || '';
      document.querySelector('input[name="b2_bucket_name"]').value = b2Config.bucket_name || '';
    }
    
    // Update storage stats
    updateStorageStats();
  }
  
  // Set up form submission handlers
  setupFormHandlers();
  
  function setupFormHandlers() {
    // Site Config form
    const siteConfigForm = document.getElementById('site-config-form');
    if (siteConfigForm) {
      siteConfigForm.addEventListener('submit', function(e) {
        e.preventDefault();
        saveSettings(this, 'general', showSuccessMessage);
      });
    }
    
    // System Preferences form
    const systemPreferencesForm = document.getElementById('system-preferences-form');
    if (systemPreferencesForm) {
      systemPreferencesForm.addEventListener('submit', function(e) {
        e.preventDefault();
        saveSettings(this, 'system', showSuccessMessage);
      });
    }
    
    // Auth Settings form
    const authSettingsForm = document.getElementById('auth-settings-form');
    if (authSettingsForm) {
      authSettingsForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Create password requirements object
        const passwordRequirements = {
          min_length: this.querySelector('input[name="password_min_length"]').checked,
          uppercase: this.querySelector('input[name="password_uppercase"]').checked,
          number: this.querySelector('input[name="password_number"]').checked,
          special: this.querySelector('input[name="password_special"]').checked
        };
        
        const settings = [
          {
            setting_key: 'password_requirements',
            setting_value: JSON.stringify(passwordRequirements),
            setting_category: 'security'
          },
          {
            setting_key: 'session_timeout',
            setting_value: this.querySelector('select[name="session_timeout"]').value,
            setting_category: 'security'
          },
          {
            setting_key: 'two_factor_auth',
            setting_value: JSON.stringify(this.querySelector('#two-factor').checked),
            setting_category: 'security'
          }
        ];
        
        saveSettingsArray(settings, showSuccessMessage);
      });
    }
    
    // API Settings form
    const apiSettingsForm = document.getElementById('api-settings-form');
    if (apiSettingsForm) {
      apiSettingsForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Create backup settings object
        const backupSettings = {
          daily_backups: this.querySelector('input[name="daily_backups"]').checked,
          retain_30_days: this.querySelector('input[name="retain_backups"]').checked
        };
        
        const settings = [
          {
            setting_key: 'backup_settings',
            setting_value: JSON.stringify(backupSettings),
            setting_category: 'security'
          },
          {
            setting_key: 'google_maps_api_key',
            setting_value: JSON.stringify(this.querySelector('#google-maps-key').value),
            setting_category: 'maps',
            is_sensitive: true
          }
        ];
        
        saveSettingsArray(settings, showSuccessMessage);
      });
    }
    
    // Regenerate API Keys button
    const regenApiKeysBtn = document.getElementById('regen-api-keys-btn');
    if (regenApiKeysBtn) {
      regenApiKeysBtn.addEventListener('click', function() {
        if (confirm('Are you sure you want to regenerate the API keys? This may affect integrations and require reconfiguration.')) {
          alert('API keys would be regenerated in a production environment. This is a demo.');
        }
      });
    }
    
    // Notification Settings form
    const notificationSettingsForm = document.getElementById('notification-settings-form');
    if (notificationSettingsForm) {
      notificationSettingsForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const settings = [];
        
        // Email notification settings
        ['notify_user_reg', 'notify_contact_form', 'notify_tour_requests', 
         'notify_system_errors', 'notify_weekly_analytics'].forEach(key => {
           settings.push({
             setting_key: key,
             setting_value: JSON.stringify(this.querySelector(`input[name="${key}"]`).checked),
             setting_category: 'notifications'
           });
         });
        
        // Alert settings
        ['alert_high_traffic', 'alert_backup_failures', 
         'alert_security_login', 'alert_maintenance'].forEach(key => {
           settings.push({
             setting_key: key,
             setting_value: JSON.stringify(this.querySelector(`input[name="${key}"]`).checked),
             setting_category: 'notifications'
           });
         });
        
        // Email settings
        settings.push({
          setting_key: 'notification_email',
          setting_value: JSON.stringify(this.querySelector('#notification-email').value),
          setting_category: 'notifications'
        });
        
        // SMTP settings
        ['smtp_host', 'smtp_port', 'smtp_username'].forEach(key => {
          settings.push({
            setting_key: key,
            setting_value: JSON.stringify(this.querySelector(`input[name="${key}"]`).value),
            setting_category: 'email'
          });
        });
        
        settings.push({
          setting_key: 'smtp_password',
          setting_value: JSON.stringify(this.querySelector('#smtp-password').value),
          setting_category: 'email',
          is_sensitive: true
        });
        
        saveSettingsArray(settings, showSuccessMessage);
      });
    }
    
    // Analytics Settings form
    const analyticsSettingsForm = document.getElementById('analytics-settings-form');
    if (analyticsSettingsForm) {
      analyticsSettingsForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const settings = [];
        
        // Google Analytics and Tag Manager
        settings.push({
          setting_key: 'google_analytics_id',
          setting_value: JSON.stringify(this.querySelector('#google-analytics-id').value),
          setting_category: 'analytics'
        });
        
        settings.push({
          setting_key: 'google_tag_manager_id',
          setting_value: JSON.stringify(this.querySelector('#google-tag-manager-id').value),
          setting_category: 'analytics'
        });
        
        // Tracking options
        ['track_user_sessions', 'track_page_views', 'track_events', 'respect_dnt'].forEach(key => {
          settings.push({
            setting_key: key,
            setting_value: JSON.stringify(this.querySelector(`input[name="${key}"]`).checked),
            setting_category: 'analytics'
          });
        });
        
        saveSettingsArray(settings, showSuccessMessage);
      });
    }
    
    // Storage Provider form
    const storageProviderForm = document.getElementById('storage-provider-form');
    if (storageProviderForm) {
      storageProviderForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const provider = document.getElementById('storage-provider').value;
        const settings = [{
          setting_key: 'storage_provider',
          setting_value: JSON.stringify(provider),
          setting_category: 'storage'
        }];
        
        saveSettingsArray(settings, () => {
          showSuccessMessage(this);
          // Show/hide provider config forms
          updateProviderConfigVisibility(provider);
        });
      });
    }
    
    // Storage provider config forms
    const configForms = ['local-config-form', 'gcs-config-form', 'r2-config-form', 'b2-config-form'];
    configForms.forEach(formId => {
      const form = document.getElementById(formId);
      if (form) {
        const provider = formId.replace('-config-form', '');
        
        // Find the save button in the parent container
        const saveBtn = form.closest('.provider-config')?.parentElement?.querySelector('button[type="submit"]');
        if (saveBtn) {
          saveBtn.addEventListener('click', function(e) {
            e.preventDefault();
            saveProviderConfig(provider, form);
          });
        }
      }
    });
    
    // Storage provider dropdown change
    document.getElementById('storage-provider')?.addEventListener('change', function() {
      updateProviderConfigVisibility(this.value);
    });
    
    // Test connection buttons
    document.querySelectorAll('.test-connection-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const form = this.closest('form');
        const provider = form.id.replace('-config-form', '');
        await testStorageConnection(provider, form);
      });
    });
    
    // Initialize provider visibility
    const currentProvider = document.getElementById('storage-provider')?.value || 'local';
    updateProviderConfigVisibility(currentProvider);
  }
  
  // Helper to save form settings
  async function saveSettings(form, category, callback) {
    const formData = new FormData(form);
    const settings = [];
    
    for (const [key, value] of formData.entries()) {
      let processedValue = value;
      
      // Convert checkbox values to boolean
      if (form.querySelector(`input[name="${key}"]`)?.type === 'checkbox') {
        processedValue = form.querySelector(`input[name="${key}"]`).checked;
      }
      
      settings.push({
        setting_key: key,
        setting_value: JSON.stringify(processedValue),
        setting_category: category
      });
    }
    
    await saveSettingsArray(settings, callback, form);
  }
  
  // Helper to save array of settings
  async function saveSettingsArray(settings, callback, form) {
    try {
      // Update each setting
      for (const setting of settings) {
        const { error } = await supabase
          .from('admin_settings')
          .upsert(setting, { onConflict: 'setting_key' });
          
        if (error) throw error;
      }
      
      callback(form || document.activeElement?.closest('form'));
      
    } catch (error) {
      console.error('Error saving settings:', error);
      alert('Error saving settings. Please try again.');
    }
  }
  
  // Show success message for settings save
  function showSuccessMessage(form) {
    if (!form) return;
    
    const button = form.querySelector('button[type="submit"]');
    if (!button) return;
    
    const originalText = button.textContent.trim();
    const originalBg = button.className.match(/bg-[a-z]+-\d+/)[0];
    const originalHover = button.className.match(/hover:bg-[a-z]+-\d+/)[0];
    
    button.textContent = 'Saved!';
    button.classList.add('bg-green-600', 'hover:bg-green-700');
    
    // Remove original background classes
    button.classList.remove(originalBg, originalHover);
    
    setTimeout(() => {
      button.textContent = originalText;
      button.classList.remove('bg-green-600', 'hover:bg-green-700');
      
      // Restore original background classes
      button.classList.add(originalBg, originalHover);
    }, 2000);
  }
  
  // Storage provider helper functions
  function updateProviderConfigVisibility(provider) {
    // Hide all provider configs
    document.querySelectorAll('.provider-config').forEach(el => {
      el.classList.add('hidden');
    });
    
    // Show selected provider config
    const configEl = document.getElementById(`config-${provider}`);
    if (configEl) {
      configEl.classList.remove('hidden');
    }
    
    // Enable/disable migration button
    const migrateBtn = document.getElementById('migrate-storage-btn');
    if (migrateBtn) {
      migrateBtn.disabled = provider === 'local';
    }
  }
  
  async function saveProviderConfig(provider, form) {
    const formData = new FormData(form);
    const config = {};
    
    for (const [key, value] of formData.entries()) {
      // Remove provider prefix from key
      const cleanKey = key.replace(`${provider}_`, '');
      config[cleanKey] = value;
    }
    
    const settings = [];
    
    if (provider === 'local') {
      settings.push({
        setting_key: 'max_file_size',
        setting_value: JSON.stringify(parseInt(config.max_file_size)),
        setting_category: 'storage'
      });
    } else {
      // Save provider-specific config
      settings.push({
        setting_key: `${provider}_config`,
        setting_value: JSON.stringify(config),
        setting_category: 'storage',
        is_sensitive: true
      });
    }
    
    await saveSettingsArray(settings, () => {
      showSuccessMessage(form.closest('.bg-white'));
    });
  }
  
  async function testStorageConnection(provider, form) {
    const btn = form.querySelector('.test-connection-btn');
    const originalText = btn.textContent;
    
    btn.disabled = true;
    btn.textContent = 'Testing...';
    
    try {
      const formData = new FormData(form);
      const config = {};
      
      for (const [key, value] of formData.entries()) {
        config[key] = value;
      }
      
      const response = await fetch('/api/storage/test-connection', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ provider, config }),
        credentials: 'include'
      });
      
      const result = await response.json();
      
      if (result.success) {
        btn.classList.remove('bg-gray-600', 'hover:bg-gray-700');
        btn.classList.add('bg-green-600', 'hover:bg-green-700');
        btn.textContent = 'Connected!';
        
        setTimeout(() => {
          btn.classList.remove('bg-green-600', 'hover:bg-green-700');
          btn.classList.add('bg-gray-600', 'hover:bg-gray-700');
          btn.textContent = originalText;
          btn.disabled = false;
        }, 3000);
      } else {
        btn.classList.remove('bg-gray-600', 'hover:bg-gray-700');
        btn.classList.add('bg-red-600', 'hover:bg-red-700');
        btn.textContent = 'Connection Failed';
        
        alert(result.error || 'Connection test failed');
        
        setTimeout(() => {
          btn.classList.remove('bg-red-600', 'hover:bg-red-700');
          btn.classList.add('bg-gray-600', 'hover:bg-gray-700');
          btn.textContent = originalText;
          btn.disabled = false;
        }, 3000);
      }
    } catch (error) {
      console.error('Test connection error:', error);
      btn.textContent = originalText;
      btn.disabled = false;
      alert('Connection test failed: ' + error.message);
    }
  }
  
  async function updateStorageStats() {
    try {
      const response = await fetch('/api/storage/stats', {
        credentials: 'include'
      });
      
      if (response.ok) {
        const stats = await response.json();
        
        document.getElementById('current-storage-size').textContent = 
          `${(stats.totalSize / 1024 / 1024).toFixed(2)} MB`;
        document.getElementById('current-file-count').textContent = stats.fileCount;
      }
    } catch (error) {
      console.error('Error fetching storage stats:', error);
    }
  }
});
</script>