---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ImageManagementSettings from '../../components/admin/ImageManagementSettings.astro';
import { checkAdminAuth } from '@lib/admin-auth-check';
import { 
  ArrowLeft,
  Settings, 
  Shield, 
  Bell,
  Globe,
  Database,
  Key,
  Mail,
  Smartphone,
  Save,
  Eye,
  EyeOff,
  AlertTriangle,
  CheckCircle,
  Info,
  Image,
  BarChart4,
  CreditCard,
  MapPin,
  BarChart3,
  Send,
  Facebook,
  Instagram,
  Copy,
  ExternalLink,
  Edit
} from 'lucide-astro';

// Check if user is authenticated and has admin access
const { isAuthenticated } = await checkAdminAuth(Astro);

if (!isAuthenticated) {
  return Astro.redirect('/auth/login?redirect=/admin/settings');
}
---

<Layout 
  title="System Settings - Admin Panel"
  description="Configure system settings, security preferences, API keys, and administrative options."
  keywords="admin settings, system configuration, security settings, API keys"
>
  <Header />
  
  <main id="main-content">

    <!-- Header -->
    <section class="bg-gradient-to-br from-gray-600 to-gray-700 py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Back to Dashboard Navigation -->
          <div class="mb-6">
            <a href="/admin" class="inline-flex items-center text-gray-300 hover:text-white transition-colors group">
              <ArrowLeft className="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" />
              <span class="text-sm font-medium">Back to Admin Dashboard</span>
            </a>
          </div>
    <!-- Settings Content -->
    <section class="py-12 bg-gray-50 min-h-screen">
      <div class="container mx-auto px-4 max-w-6xl">
        
        <!-- Settings Navigation -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 mb-8">
          <div class="border-b border-gray-200">
            <nav class="flex space-x-8 px-6" aria-label="Settings navigation">
              <button class="settings-tab active py-4 px-2 border-b-2 font-medium text-sm" data-tab="general">
                General
              </button>
              <button class="settings-tab py-4 px-2 border-b-2 font-medium text-sm" data-tab="api-keys">
                API Keys
              </button>
              <button class="settings-tab py-4 px-2 border-b-2 font-medium text-sm" data-tab="security">
                Security
              </button>
              <button class="settings-tab py-4 px-2 border-b-2 font-medium text-sm" data-tab="notifications">
                Notifications
              </button>
              <button class="settings-tab py-4 px-2 border-b-2 font-medium text-sm" data-tab="analytics">
                Analytics
              </button>
              <button class="settings-tab py-4 px-2 border-b-2 font-medium text-sm" data-tab="database">
                Database
              </button>
              <button class="settings-tab py-4 px-2 border-b-2 font-medium text-sm" data-tab="image">
                Image Management
              </button>
              <button class="settings-tab py-4 px-2 border-b-2 font-medium text-sm" data-tab="storage">
                Storage
              </button>
            </nav>
          </div>
        </div>

        <!-- General Settings -->
        <div id="general-settings" class="settings-panel">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
              <div class="flex items-center mb-6">
                <Globe className="w-6 h-6 text-gray-600 mr-3" />
                <h3 class="text-xl font-semibold text-earth-brown">Site Configuration</h3>
              </div>
              
              <form id="site-config-form" class="space-y-6">
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">School Name</label>
                  <input 
                    type="text" 
                    id="school-name" 
                    name="school_name"
                    value="Spicebush Montessori School" 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent" 
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">Contact Email</label>
                  <input 
                    type="email" 
                    id="contact-email"
                    name="contact_email"
                    value="information@spicebushmontessori.org" 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent" 
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">Phone Number</label>
                  <input 
                    type="tel" 
                    id="phone-number"
                    name="phone_number"
                    value="(484) 202-0712" 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent" 
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">School Address</label>
                  <textarea 
                    rows="3" 
                    id="school-address"
                    name="school_address"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent"
                  >827 Concord Road
Glen Mills, PA 19342</textarea>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">Contact Form Recipient</label>
                  <input 
                    type="email" 
                    id="contact-form-recipient"
                    name="contact_form_recipient"
                    placeholder="Where contact form submissions are sent"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent" 
                  />
                  <p class="text-xs text-gray-500 mt-1">Email address to receive contact form submissions</p>
                </div>
                
                <button type="submit" class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-lg font-medium transition-colors">
                  Save Changes
                </button>
              </form>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
              <div class="flex items-center mb-6">
                <Settings className="w-6 h-6 text-gray-600 mr-3" />
                <h3 class="text-xl font-semibold text-earth-brown">System Preferences</h3>
              </div>
              
              <form id="system-preferences-form" class="space-y-6">
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">Timezone</label>
                  <select 
                    id="timezone"
                    name="timezone"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent"
                  >
                    <option selected>America/New_York (EST/EDT)</option>
                    <option>America/Chicago (CST/CDT)</option>
                    <option>America/Denver (MST/MDT)</option>
                    <option>America/Los_Angeles (PST/PDT)</option>
                  </select>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">Date Format</label>
                  <select 
                    id="date-format"
                    name="date_format"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent"
                  >
                    <option selected>MM/DD/YYYY</option>
                    <option>DD/MM/YYYY</option>
                    <option>YYYY-MM-DD</option>
                  </select>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">Maintenance Mode</label>
                  <div class="flex items-center space-x-3">
                    <input type="checkbox" id="maintenance-mode" name="maintenance_mode" class="text-gray-600 focus:ring-gray-500" />
                    <label for="maintenance-mode" class="text-sm text-gray-600">Enable maintenance mode</label>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">Temporarily restrict access to the website</p>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">Debug Mode</label>
                  <div class="flex items-center space-x-3">
                    <input type="checkbox" id="debug-mode" name="debug_mode" class="text-gray-600 focus:ring-gray-500" />
                    <label for="debug-mode" class="text-sm text-gray-600">Enable debug mode</label>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">Show detailed error messages and debugging information (not recommended for production)</p>
                </div>
                
                <button type="submit" class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-lg font-medium transition-colors">
                  Save Changes
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- API Keys Settings -->
        <div id="api-keys-settings" class="settings-panel hidden">
          <div class="mb-6">
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
              <div class="flex items-start">
                <Info className="w-5 h-5 text-blue-600 mt-0.5 mr-3 flex-shrink-0" />
                <div>
                  <h4 class="text-sm font-medium text-blue-800">API Keys Security Notice</h4>
                  <p class="text-sm text-blue-700 mt-1">
                    API keys are sensitive information. Keep them secure and never share them publicly. 
                    Keys are encrypted when stored and masked in this interface for security.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <!-- Payment & E-commerce -->
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
              <div class="flex items-center mb-6">
                <CreditCard className="w-6 h-6 text-green-600 mr-3" />
                <h3 class="text-xl font-semibold text-earth-brown">Payment Processing</h3>
              </div>
              
              <form class="space-y-6">
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Stripe Publishable Key</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('stripe-pub')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="stripe-pub"
                      placeholder="pk_test_..." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('stripe-pub')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">Used for client-side Stripe integration</p>
                </div>
                
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Stripe Secret Key</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('stripe-secret')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="stripe-secret"
                      placeholder="sk_test_..." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('stripe-secret')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">⚠️ Keep this secret! Server-side only</p>
                </div>

                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Stripe Webhook Secret</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('stripe-webhook')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="stripe-webhook"
                      placeholder="whsec_..." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('stripe-webhook')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">For webhook event verification</p>
                </div>

                <div class="pt-4 border-t border-gray-200">
                  <a href="https://dashboard.stripe.com/apikeys" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm text-green-600 hover:text-green-700">
                    <ExternalLink className="w-4 h-4 mr-1" />
                    Manage in Stripe Dashboard
                  </a>
                </div>
              </form>
            </div>

            <!-- Google Services -->
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
              <div class="flex items-center mb-6">
                <Globe className="w-6 h-6 text-blue-600 mr-3" />
                <h3 class="text-xl font-semibold text-earth-brown">Google Services</h3>
              </div>
              
              <form class="space-y-6">
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Google Maps API Key</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('google-maps')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="google-maps"
                      placeholder="AIza..." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('google-maps')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">For maps and location features</p>
                </div>
                
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Google Analytics Measurement ID</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('google-analytics')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="google-analytics"
                      placeholder="G-XXXXXXXXXX" 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('google-analytics')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">For website analytics tracking</p>
                </div>

                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Google Tag Manager ID</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('google-tag-manager')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="google-tag-manager"
                      placeholder="GTM-XXXXXXX" 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('google-tag-manager')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">For advanced tracking and tag management</p>
                </div>

                <div class="pt-4 border-t border-gray-200">
                  <a href="https://console.cloud.google.com/apis/credentials" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm text-blue-600 hover:text-blue-700">
                    <ExternalLink className="w-4 h-4 mr-1" />
                    Manage in Google Cloud Console
                  </a>
                </div>
              </form>
            </div>

            <!-- Email Services -->
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
              <div class="flex items-center mb-6">
                <Send className="w-6 h-6 text-purple-600 mr-3" />
                <h3 class="text-xl font-semibold text-earth-brown">Email Services</h3>
              </div>
              
              <form class="space-y-6">
                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">Email Service Provider</label>
                  <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent">
                    <option value="">Select Provider</option>
                    <option value="mailgun">Mailgun</option>
                    <option value="sendgrid">SendGrid</option>
                    <option value="ses">Amazon SES</option>
                    <option value="netlify">Netlify Forms (Current)</option>
                  </select>
                </div>

                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">SendGrid API Key</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('sendgrid-api')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="sendgrid-api"
                      placeholder="SG...." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('sendgrid-api')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">For transactional emails and notifications</p>
                </div>

                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Mailgun API Key</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('mailgun-api')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="mailgun-api"
                      placeholder="key-..." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('mailgun-api')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-earth-brown mb-2">From Email Address</label>
                  <input 
                    type="email" 
                    value="information@spicebushmontessori.org"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                  />
                  <p class="text-xs text-gray-500 mt-1">Default sender address for outgoing emails</p>
                </div>
              </form>
            </div>

            <!-- Social Media -->
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
              <div class="flex items-center mb-6">
                <Facebook className="w-6 h-6 text-blue-600 mr-3" />
                <h3 class="text-xl font-semibold text-earth-brown">Social Media Integration</h3>
              </div>
              
              <form class="space-y-6">
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Facebook App ID</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('facebook-app-id')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="facebook-app-id"
                      placeholder="123456789..." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('facebook-app-id')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">For Facebook integration and sharing</p>
                </div>

                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Instagram Basic Display App ID</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('instagram-app-id')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="instagram-app-id"
                      placeholder="123456789..." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('instagram-app-id')">
                      <Copy className="w-4 h-4" />
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">For Instagram feed integration</p>
                </div>

                <div class="pt-4 border-t border-gray-200">
                  <a href="https://developers.facebook.com/apps/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm text-blue-600 hover:text-blue-700">
                    <ExternalLink className="w-4 h-4 mr-1" />
                    Manage in Facebook Developer Console
                  </a>
                </div>
              </form>
            </div>

            <!-- Additional Services -->
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
              <div class="flex items-center mb-6">
                <BarChart3 className="w-6 h-6 text-orange-600 mr-3" />
                <h3 class="text-xl font-semibold text-earth-brown">Additional Services</h3>
              </div>
              
              <form class="space-y-6">
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Supabase URL</label>
                    <span class="text-xs text-green-600 bg-green-100 px-2 py-1 rounded">Connected</span>
                  </div>
                  <input 
                    type="text" 
                    value={import.meta.env.PUBLIC_SUPABASE_URL || ''}
                    readonly
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-600"
                  />
                  <p class="text-xs text-gray-500 mt-1">Database and authentication service</p>
                </div>

                <div>
                  <div class="flex items-center justify-between mb-2">
                    <label class="block text-sm font-medium text-earth-brown">Netlify Site ID</label>
                    <button type="button" class="text-xs text-blue-600 hover:text-blue-700" onclick="toggleVisibility('netlify-site-id')">
                      <Eye className="w-4 h-4 inline mr-1" />
                      Show
                    </button>
                  </div>
                  <div class="relative">
                    <input 
                      type="password" 
                      id="netlify-site-id"
                      placeholder="abc123def-456..." 
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent pr-10"
                    />
                    <button type="button" class="absolute right-2 top-2 text-gray-400 hover:text-gray-600" onclick="copyToClipboard('netlify-site-id')">
                      <Copy className="w-4 h-4" />
