---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@lib/db';

const PAGE_SIZE = 50;
const rawSearch = Astro.url.searchParams.get('q');
const search = typeof rawSearch === 'string' ? rawSearch.trim() : '';
const rawTour = Astro.url.searchParams.get('tour');
const tourFilter = rawTour === 'yes' || rawTour === 'no' ? rawTour : 'all';
const rawPage = Astro.url.searchParams.get('page');
const parsedPage = rawPage ? Number.parseInt(rawPage, 10) : 1;
const requestedPage = Number.isFinite(parsedPage) && parsedPage > 0 ? parsedPage : 1;
const tourInterest = tourFilter === 'yes' ? true : tourFilter === 'no' ? false : undefined;

const queryOptions = {
  pageSize: PAGE_SIZE,
  search,
  tourInterest
};

let result = await db.contact.getContactSubmissions({
  ...queryOptions,
  page: requestedPage
});

if (requestedPage > 1 && result.total > 0 && result.items.length === 0) {
  const fallbackPage = Math.max(1, Math.ceil(result.total / result.pageSize));
  result = await db.contact.getContactSubmissions({
    ...queryOptions,
    page: fallbackPage
  });
}

const currentPage = result.page;
const totalPages = Math.max(1, Math.ceil(result.total / result.pageSize));
const startIndex = result.total === 0 ? 0 : (currentPage - 1) * result.pageSize + 1;
const endIndex = result.total === 0 ? 0 : Math.min(result.total, currentPage * result.pageSize);

const hasFilters = search.length > 0 || tourFilter !== 'all';
const activeFilterCount = [search.length > 0, tourFilter !== 'all'].filter(Boolean).length;
const tourRequestsOnPage = result.items.filter((submission) => submission.tour_interest).length;

const submittedDateFormatter = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'medium',
  timeStyle: 'short'
});

const formatSubmittedAt = (value: string): string => {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return submittedDateFormatter.format(date);
};

const truncate = (value: string, maxLength = 180): string => {
  if (value.length <= maxLength) return value;
  return `${value.slice(0, maxLength - 1)}…`;
};

const normalizePhoneHref = (value: string): string => value.replace(/[^0-9+]/g, '');

const pageHref = (page: number): string => {
  const params = new URLSearchParams();
  if (search.length > 0) params.set('q', search);
  if (tourFilter !== 'all') params.set('tour', tourFilter);
  if (page > 1) params.set('page', String(page));
  const query = params.toString();
  return query.length > 0 ? `/admin/contact-submissions?${query}` : '/admin/contact-submissions';
};

const clearFiltersHref = '/admin/contact-submissions';
---

<AdminLayout title="Contact Form Submissions">
  <div class="space-y-6">
    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Incoming Messages</h2>
      <p class="mb-4 text-sm text-earth-brown/80">
        Review inquiries from the website contact form. Use filters below to quickly find a family message.
      </p>
      <div class="grid gap-3 md:grid-cols-3">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Total Submissions</p>
          <p class="text-2xl font-semibold text-earth-brown">{result.total}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Showing</p>
          <p class="text-sm font-semibold text-earth-brown">{startIndex}-{endIndex}</p>
          <p class="text-xs text-earth-brown/70">Page {currentPage} of {totalPages}</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-earth-brown/70">Tour Requests (on page)</p>
          <p class="text-2xl font-semibold text-earth-brown">{tourRequestsOnPage}</p>
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <form method="get" class="grid gap-3 md:grid-cols-[minmax(0,2fr)_minmax(180px,1fr)_auto] md:items-end">
        <label class="block text-sm font-medium">
          Search
          <input
            type="search"
            name="q"
            value={search}
            placeholder="Search name, email, subject, or message"
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2"
          />
        </label>

        <label class="block text-sm font-medium">
          Tour Interest
          <select name="tour" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2">
            <option value="all" selected={tourFilter === 'all'}>All submissions</option>
            <option value="yes" selected={tourFilter === 'yes'}>Tour requested</option>
            <option value="no" selected={tourFilter === 'no'}>No tour requested</option>
          </select>
        </label>

        <button type="submit" class="rounded-lg bg-forest-canopy px-4 py-2 font-semibold text-white hover:bg-moss-green">
          Apply Filters
        </button>
      </form>

      {hasFilters && (
        <div class="mt-3 flex flex-wrap items-center gap-2 text-sm">
          <span class="rounded-full border border-forest-canopy/20 bg-forest-canopy/10 px-2 py-1 text-forest-canopy">
            {activeFilterCount} active filter{activeFilterCount === 1 ? '' : 's'}
          </span>
          <a href={clearFiltersHref} class="text-forest-canopy hover:underline">Clear filters</a>
        </div>
      )}
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="mb-2 text-lg font-semibold">Submission Log</h2>
      <p class="mb-4 text-sm text-earth-brown/80">Newest messages appear first.</p>

      {result.items.length === 0 ? (
        <p class="rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-earth-brown/80">
          No contact form submissions found for the current filters.
        </p>
      ) : (
        <>
          <div class="hidden overflow-x-auto lg:block">
            <table class="min-w-[980px] w-full border-collapse text-sm">
              <thead>
                <tr class="bg-gray-50 text-left text-xs uppercase tracking-wide text-earth-brown/70">
                  <th class="border border-gray-200 px-3 py-2">Submitted</th>
                  <th class="border border-gray-200 px-3 py-2">Name & Child</th>
                  <th class="border border-gray-200 px-3 py-2">Contact</th>
                  <th class="border border-gray-200 px-3 py-2">Subject & Message</th>
                  <th class="border border-gray-200 px-3 py-2">Tour</th>
                </tr>
              </thead>
              <tbody>
                {result.items.map((submission) => {
                  const phoneHref = submission.phone ? normalizePhoneHref(submission.phone) : '';

                  return (
                    <tr class="align-top">
                      <td class="border border-gray-200 px-3 py-3 text-xs text-earth-brown/80">
                        {formatSubmittedAt(submission.submitted_at)}
                      </td>
                      <td class="border border-gray-200 px-3 py-3">
                        <p class="font-semibold text-earth-brown">{submission.name}</p>
                        <p class="mt-1 text-xs text-earth-brown/70">
                          {submission.child_age ? `Child age: ${submission.child_age}` : 'Child age not provided'}
                        </p>
                      </td>
                      <td class="border border-gray-200 px-3 py-3">
                        <a href={`mailto:${submission.email}`} class="text-forest-canopy hover:underline">{submission.email}</a>
                        {submission.phone && phoneHref ? (
                          <p class="mt-1">
                            <a href={`tel:${phoneHref}`} class="text-forest-canopy hover:underline">{submission.phone}</a>
                          </p>
                        ) : (
                          <p class="mt-1 text-xs text-earth-brown/70">No phone provided</p>
                        )}
                      </td>
                      <td class="border border-gray-200 px-3 py-3">
                        <p class="font-semibold text-earth-brown">{submission.subject || 'No subject'}</p>
                        <p class="mt-1 whitespace-pre-wrap text-xs text-earth-brown/80">{truncate(submission.message || '', 220)}</p>
                      </td>
                      <td class="border border-gray-200 px-3 py-3">
                        {submission.tour_interest ? (
                          <span class="inline-flex rounded-full border border-green-200 bg-green-50 px-2 py-1 text-xs font-semibold text-green-700">
                            Yes
                          </span>
                        ) : (
                          <span class="inline-flex rounded-full border border-gray-200 bg-gray-50 px-2 py-1 text-xs font-semibold text-earth-brown/70">
                            No
                          </span>
                        )}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>

          <div class="space-y-3 lg:hidden">
            {result.items.map((submission) => {
              const phoneHref = submission.phone ? normalizePhoneHref(submission.phone) : '';

              return (
                <article class="rounded-lg border border-gray-200 bg-gray-50 p-4">
                  <div class="flex flex-wrap items-start justify-between gap-2">
                    <div>
                      <p class="font-semibold text-earth-brown">{submission.name}</p>
                      <p class="text-xs text-earth-brown/70">{formatSubmittedAt(submission.submitted_at)}</p>
                    </div>
                    {submission.tour_interest ? (
                      <span class="inline-flex rounded-full border border-green-200 bg-green-50 px-2 py-1 text-xs font-semibold text-green-700">
                        Tour requested
                      </span>
                    ) : (
                      <span class="inline-flex rounded-full border border-gray-200 bg-white px-2 py-1 text-xs font-semibold text-earth-brown/70">
                        No tour request
                      </span>
                    )}
                  </div>

                  <p class="mt-2 text-sm font-semibold text-earth-brown">{submission.subject || 'No subject'}</p>
                  <p class="mt-1 text-sm text-earth-brown/80 whitespace-pre-wrap">{truncate(submission.message || '', 240)}</p>

                  <div class="mt-3 text-sm">
                    <p>
                      <a href={`mailto:${submission.email}`} class="text-forest-canopy hover:underline">{submission.email}</a>
                    </p>
                    {submission.phone && phoneHref ? (
                      <p class="mt-1">
                        <a href={`tel:${phoneHref}`} class="text-forest-canopy hover:underline">{submission.phone}</a>
                      </p>
                    ) : null}
                    {submission.child_age ? <p class="mt-1 text-earth-brown/70">Child age: {submission.child_age}</p> : null}
                  </div>
                </article>
              );
            })}
          </div>
        </>
      )}

      {totalPages > 1 && (
        <nav class="mt-5 flex items-center justify-between border-t border-gray-200 pt-4 text-sm">
          {currentPage > 1 ? (
            <a href={pageHref(currentPage - 1)} class="rounded-lg border border-gray-300 px-3 py-2 text-earth-brown hover:bg-gray-50">
              Previous
            </a>
          ) : (
            <span class="rounded-lg border border-gray-200 px-3 py-2 text-earth-brown/50">Previous</span>
          )}

          <span class="text-earth-brown/80">Page {currentPage} of {totalPages}</span>

          {currentPage < totalPages ? (
            <a href={pageHref(currentPage + 1)} class="rounded-lg border border-gray-300 px-3 py-2 text-earth-brown hover:bg-gray-50">
              Next
            </a>
          ) : (
            <span class="rounded-lg border border-gray-200 px-3 py-2 text-earth-brown/50">Next</span>
          )}
        </nav>
      )}
    </section>
  </div>
</AdminLayout>
