---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HoursWidget from '../components/HoursWidget.astro';
import CampPromoModule from '../components/CampPromoModule.astro';
import {
  Phone,
  Mail,
  MapPin,
  Clock,
  Send,
  MessageSquare,
  AlertCircle,
  CheckCircle,
  User,
  Baby,
  Calendar,
  Heart
} from 'lucide-astro';
import ErrorMessage from '../components/ErrorMessage.astro';
---

<Layout
  title="Contact Us - Spicebush Montessori School"
  description="Get in touch with Spicebush Montessori School. Schedule a tour, ask questions, or learn more about our inclusive education programs in Glen Mills, PA."
  keywords="contact Montessori school, schedule tour, school location, Glen Mills PA preschool, Montessori questions"
>
  <Header />

  <main id="main-content">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-forest-canopy to-moss-green py-16 lg:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="flex justify-center mb-6">
            <div
              class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center border border-white/30"
            >
              <MessageSquare className="w-8 h-8 text-white" aria-hidden="true" />
            </div>
          </div>
          <h1 class="text-4xl lg:text-5xl font-heading font-bold text-white mb-6 tracking-tight">
            Let's Connect
          </h1>
          <p
            class="text-lg lg:text-xl text-green-100 max-w-3xl mx-auto leading-relaxed-plus font-light"
          >
            We'd love to hear from you. Whether you're curious about our programs, want to schedule
            a tour, or have questions about our community, we're here to help.
          </p>
        </div>
      </div>
    </section>

    <CampPromoModule placement="contact" />

    <!-- Contact Methods Grid -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
          <!-- Phone Contact -->
          <div
            class="text-center p-8 bg-stone-beige rounded-xl border border-gray-200 hover:shadow-lg transition-all duration-300"
          >
            <div
              class="w-16 h-16 bg-forest-canopy rounded-full flex items-center justify-center mx-auto mb-6"
            >
              <Phone className="w-8 h-8 text-white" aria-hidden="true" />
            </div>
            <h3 class="text-xl font-semibold text-earth-brown mb-3">Call Us</h3>
            <p class="text-earth-brown mb-4 leading-relaxed">
              The quickest way to get answers and schedule a visit
            </p>
            <a
              href="tel:484-202-0712"
              class="text-2xl font-bold text-forest-canopy hover:text-moss-green transition-colors block mb-2"
            >
              (484) 202-0712
            </a>
            <p class="text-sm text-gray-600">Monday - Friday, 8:00 AM - 4:00 PM</p>
          </div>

          <!-- Email Contact -->
          <div
            class="text-center p-8 bg-stone-beige rounded-xl border border-gray-200 hover:shadow-lg transition-all duration-300"
          >
            <div
              class="w-16 h-16 bg-moss-green rounded-full flex items-center justify-center mx-auto mb-6"
            >
              <Mail className="w-8 h-8 text-white" aria-hidden="true" />
            </div>
            <h3 class="text-xl font-semibold text-earth-brown mb-3">Email Us</h3>
            <p class="text-earth-brown mb-4 leading-relaxed">
              Send us a message and we'll get back to you within 24 hours
            </p>
            <a
              href="mailto:information@spicebushmontessori.org"
              class="text-lg font-semibold text-forest-canopy hover:text-moss-green transition-colors block break-all"
            >
              information@spicebushmontessori.org
            </a>
          </div>

          <!-- Visit Us -->
          <div
            class="text-center p-8 bg-stone-beige rounded-xl border border-gray-200 hover:shadow-lg transition-all duration-300"
          >
            <div
              class="w-16 h-16 bg-sunlight-gold rounded-full flex items-center justify-center mx-auto mb-6"
            >
              <MapPin className="w-8 h-8 text-white" aria-hidden="true" />
            </div>
            <h3 class="text-xl font-semibold text-earth-brown mb-3">Visit Us</h3>
            <p class="text-earth-brown mb-4 leading-relaxed">
              Come see our beautiful learning environment in person
            </p>
            <address class="text-forest-canopy font-medium not-italic">
              827 Concord Road<br />
              Glen Mills, PA 19342
            </address>
            <a
              href="https://maps.google.com/?q=827+Concord+Road,+Glen+Mills,+PA+19342"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block mt-3 text-sm text-moss-green hover:text-forest-canopy transition-colors"
            >
              Get Directions →
            </a>
          </div>
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Form -->
          <div class="bg-white border border-gray-200 rounded-xl p-8 shadow-sm">
            <div class="flex items-center mb-6">
              <Send className="w-6 h-6 text-forest-canopy mr-3" aria-hidden="true" />
              <h2 class="text-2xl font-bold text-earth-brown">Send Us a Message</h2>
            </div>

            <!-- Form Alert Messages -->
            <div
              id="form-success"
              class="hidden mb-6 p-4 bg-green-50 border border-green-200 rounded-lg"
            >
              <div class="flex items-center">
                <CheckCircle className="w-5 h-5 text-green-600 mr-3" aria-hidden="true" />
                <p class="text-green-800 font-medium">
                  Thank you! Your message has been sent successfully. We'll get back to you within
                  24 hours.
                </p>
              </div>
            </div>

            <div id="form-error" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
              <div class="flex items-center">
                <AlertCircle className="w-5 h-5 text-red-600 mr-3" aria-hidden="true" />
                <p class="text-red-800 font-medium">
                  There was an error sending your message. Please try again or contact us directly.
                </p>
              </div>
            </div>

            <!-- Contact Form -->
            <form
              id="contact-form"
              name="contact-form"
              method="POST"
              action="/api/contact/submit"
              data-analytics-form="contact-form"
              data-analytics-event="contact_submit"
              class="space-y-6"
            >
              <input type="hidden" name="form-name" value="contact-form" />
              <input type="hidden" name="source" value="contact" />
              <input type="hidden" name="redirectTo" value="/contact-success" />
              <input type="hidden" name="analytics-attribution" value="" />
              <input type="hidden" name="analytics-session-id" value="" />
              <input type="hidden" name="analytics-client-id" value="" />
              <input type="hidden" name="analytics-landing-page" value="" />
              <input type="hidden" name="analytics-referrer-url" value="" />

              <!-- Honeypot field for spam protection -->
              <div style="display: none;" aria-hidden="true">
                <input name="bot-field" tabindex="-1" autocomplete="off" />
              </div>

              <!-- Name and Email Row -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="name" class="block text-sm font-medium text-earth-brown mb-2">
                    <User className="w-4 h-4 inline mr-1" aria-hidden="true" />
                    Your Name *
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                    placeholder="Enter your full name"
                  />
                  <ErrorMessage error={null} fieldId="name" />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-earth-brown mb-2">
                    <Mail className="w-4 h-4 inline mr-1" aria-hidden="true" />
                    Email Address *
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                    placeholder="your.email@example.com"
                  />
                  <ErrorMessage error={null} fieldId="email" />
                </div>
              </div>

              <!-- Phone and Child Age Row -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="phone" class="block text-sm font-medium text-earth-brown mb-2">
                    <Phone className="w-4 h-4 inline mr-1" aria-hidden="true" />
                    Phone Number
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                    placeholder="(555) 123-4567"
                  />
                  <ErrorMessage error={null} fieldId="phone" />
                </div>
                <div>
                  <label for="child-age" class="block text-sm font-medium text-earth-brown mb-2">
                    <Baby className="w-4 h-4 inline mr-1" aria-hidden="true" />
                    Child's Age (if applicable)
                  </label>
                  <select
                    id="child-age"
                    name="child-age"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                  >
                    <option value="">Select age</option>
                    <option value="under-3">Under 3 years old</option>
                    <option value="3">3 years old</option>
                    <option value="4">4 years old</option>
                    <option value="5">5 years old</option>
                    <option value="6">6 years old</option>
                    <option value="over-6">Over 6 years old</option>
                  </select>
                </div>
              </div>

              <!-- Subject -->
              <div>
                <label for="subject" class="block text-sm font-medium text-earth-brown mb-2">
                  <MessageSquare className="w-4 h-4 inline mr-1" aria-hidden="true" />
                  Subject *
                </label>
                <select
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors"
                >
                  <option value="">What can we help you with?</option>
                  <option value="tour">Schedule a Tour</option>
                  <option value="admissions">Admissions Questions</option>
                  <option value="tuition">Tuition and Financial Aid</option>
                  <option value="programs">Program Information</option>
                  <option value="special-needs">Special Needs Support</option>
                  <option value="general">General Questions</option>
                  <option value="other">Other</option>
                </select>
                <ErrorMessage error={null} fieldId="subject" />
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-earth-brown mb-2">
                  Your Message *
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-canopy focus:border-transparent transition-colors resize-vertical"
                  placeholder="Tell us about your questions, interests, or how we can help you and your family..."
                ></textarea>
                <ErrorMessage error={null} fieldId="message" />
              </div>

              <!-- Tour Interest -->
              <div class="bg-stone-beige rounded-lg p-4">
                <div class="flex items-center mb-3">
                  <Calendar className="w-5 h-5 text-forest-canopy mr-2" aria-hidden="true" />
                  <h3 class="text-lg font-semibold text-earth-brown">Interested in a Tour?</h3>
                </div>
                <p class="text-sm text-earth-brown mb-3">
                  The best way to understand our community is to experience it firsthand.
                </p>
                <label class="flex items-center">
                  <input
                    type="checkbox"
                    name="tour-interest"
                    value="yes"
                    class="mr-3 text-forest-canopy focus:ring-forest-canopy"
                  />
                  <span class="text-earth-brown"
                  >Yes, I'd like to schedule a tour of your school</span
                  >
                </label>
              </div>

              <!-- Submit Button -->
              <button
                type="submit"
                id="submit-btn"
                class="w-full bg-forest-canopy hover:bg-moss-green text-white px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300 flex items-center justify-center group disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <Send
                  className="w-5 h-5 mr-2 group-hover:translate-x-1 transition-transform"
                  aria-hidden="true"
                />
                <span id="submit-text">Send Message</span>
                <span id="submit-loading" class="hidden">Sending...</span>
              </button>

              <p class="text-xs text-gray-600 text-center">
                * Required fields. We'll respond within 24 hours during business days.
              </p>
            </form>
          </div>

          <!-- Contact Information & Hours -->
          <div class="space-y-8">
            <!-- School Hours Widget -->
            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
              <div class="flex items-center mb-4">
                <Clock className="w-6 h-6 text-forest-canopy mr-3" aria-hidden="true" />
                <h3 class="text-xl font-semibold text-earth-brown">When We're Here</h3>
              </div>
              <HoursWidget />
            </div>

            <!-- Additional Information -->
            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
              <div class="flex items-center mb-4">
                <Heart className="w-6 h-6 text-forest-canopy mr-3" aria-hidden="true" />
                <h3 class="text-xl font-semibold text-earth-brown">More Ways to Connect</h3>
              </div>

              <div class="space-y-4">
                <div>
                  <h4 class="font-semibold text-earth-brown mb-2">Admissions Questions</h4>
                  <p class="text-sm text-gray-600 mb-2">
                    Have questions about enrollment, tuition, or our programs?
                  </p>
                  <a
                    href="/admissions"
                    class="text-forest-canopy hover:text-moss-green font-medium text-sm transition-colors"
                  >
                    Visit our Admissions page →
                  </a>
                </div>

                <div>
                  <h4 class="font-semibold text-earth-brown mb-2">Tuition Calculator</h4>
                  <p class="text-sm text-gray-600 mb-2">
                    Find out what tuition might look like for your family with our sliding scale
                    calculator.
                  </p>
                  <a
                    href="/admissions/tuition-calculator"
                    class="text-forest-canopy hover:text-moss-green font-medium text-sm transition-colors"
                  >
                    Calculate your rate →
                  </a>
                </div>

                <div>
                  <h4 class="font-semibold text-earth-brown mb-2">Anonymous Feedback</h4>
                  <p class="text-sm text-gray-600 mb-2">
                    Share feedback about bias or discrimination confidentially.
                  </p>
                  <a
                    href="https://docs.google.com/forms/d/e/1FAIpQLSd9x0mdbCKXBjbWuVme2SeRX9enMfUAf7Y_80VqFUDFs4qfRg/viewform?usp=sf_link"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-forest-canopy hover:text-moss-green font-medium text-sm transition-colors"
                  >
                    Anonymous feedback form →
                  </a>
                </div>
              </div>
            </div>

            <!-- Emergency Contact -->
            <div class="bg-orange-50 border border-orange-200 rounded-xl p-6">
              <div class="flex items-start">
                <AlertCircle
                  className="w-6 h-6 text-orange-600 mr-3 flex-shrink-0 mt-1"
                  aria-hidden="true"
                />
                <div>
                  <h3 class="text-lg font-semibold text-orange-800 mb-2">Emergency Contact</h3>
                  <p class="text-orange-700 text-sm mb-3">
                    For urgent matters during school hours, please call our main number. For
                    after-hours emergencies involving enrolled children, families will receive
                    separate emergency contact information.
                  </p>
                  <a
                    href="tel:484-202-0712"
                    class="text-orange-800 font-semibold hover:text-orange-900 transition-colors"
                  >
                    (484) 202-0712
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Section -->
    <section class="py-16 bg-stone-beige">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-earth-brown mb-4">Find Us</h2>
          <p class="text-lg text-earth-brown max-w-2xl mx-auto">
            We're located in Glen Mills, Pennsylvania, easily accessible from the greater
            Philadelphia area.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          <!-- Map Embed -->
          <div class="lg:col-span-2">
            <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-200">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3049.8234567890123!2d-75.5234567!3d39.9123456!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s827%20Concord%20Road%2C%20Glen%20Mills%2C%20PA%2019342!5e0!3m2!1sen!2sus!4v1234567890123"
                width="100%"
                height="400"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Spicebush Montessori School Location Map"
                aria-describedby="school-address"></iframe>
            </div>
          </div>

          <!-- Directions & Parking -->
          <div class="space-y-6">
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200">
              <h3 class="text-xl font-semibold text-earth-brown mb-4">Getting Here</h3>

              <div class="space-y-4">
                <div id="school-address">
                  <h4 class="font-semibold text-earth-brown mb-2">Address</h4>
                  <address class="text-earth-brown not-italic">
                    827 Concord Road<br />
                    Glen Mills, PA 19342
                  </address>
                </div>

                <div>
                  <h4 class="font-semibold text-earth-brown mb-2">Parking</h4>
                  <p class="text-earth-brown text-sm">
                    Free parking is available on-site. Visitor spaces are clearly marked near the
                    main entrance.
                  </p>
                </div>

                <div>
                  <h4 class="font-semibold text-earth-brown mb-2">Public Transportation</h4>
                  <p class="text-earth-brown text-sm">
                    Limited public transit access. Driving is recommended for visiting our school.
                  </p>
                </div>
              </div>

              <div class="mt-6 pt-4 border-t border-gray-200">
                <a
                  href="https://maps.google.com/?q=827+Concord+Road,+Glen+Mills,+PA+19342"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center text-forest-canopy hover:text-moss-green font-medium transition-colors"
                >
                  <MapPin className="w-4 h-4 mr-2" aria-hidden="true" />
                  Get Directions
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const { enhanceForm } = await import('../lib/form-enhance');
    const { validators } = await import('../lib/form-validation');
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const submitText = document.getElementById('submit-text');
    const submitLoading = document.getElementById('submit-loading');

    // Simple form enhancement for loading state
    if (
      form instanceof HTMLFormElement &&
      submitBtn instanceof HTMLButtonElement &&
      submitText instanceof HTMLElement &&
      submitLoading instanceof HTMLElement
    ) {
      form.addEventListener('submit', () => {
        // Show loading state
        submitBtn.disabled = true;
        submitText.classList.add('hidden');
        submitLoading.classList.remove('hidden');

        // API route handles persistence and redirects to the success page.
        // The loading state will persist until page redirect.
      });
    }

    // Enhanced form validation
    if (form instanceof HTMLFormElement) {
      enhanceForm(form, {
        validationSchema: {
          name: [validators.required],
          email: [validators.required, validators.email],
          phone: [validators.phone],
          subject: [validators.required],
          message: [validators.required, validators.minLength(10)]
        }
      });
    }

    // Phone number formatting
    const phoneField = document.getElementById('phone');
    if (phoneField instanceof HTMLInputElement) {
      phoneField.addEventListener('input', () => {
        let value = phoneField.value.replace(/\D/g, '');
        if (value.length >= 6) {
          value = value.replace(/(\d{3})(\d{3})(\d{4})/, '($1) $2-$3');
        } else if (value.length >= 3) {
          value = value.replace(/(\d{3})(\d{0,3})/, '($1) $2');
        }
        phoneField.value = value;
      });
    }
  });
</script>
