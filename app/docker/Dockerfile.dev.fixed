# Development Dockerfile for Spicebush Montessori Astro Application
# Fixed version addressing npm dependency installation issues
# Bug #032 - Docker Missing Dependencies

FROM node:20-alpine AS base

# Install ALL required system dependencies for npm packages
RUN apk add --no-cache \
    git \
    vips-dev \
    fftw-dev \
    build-base \
    gcc \
    g++ \
    make \
    python3 \
    libc6-compat \
    # Additional dependencies for npm packages that need native compilation
    cairo-dev \
    jpeg-dev \
    pango-dev \
    giflib-dev \
    pixman-dev \
    pangomm-dev \
    libjpeg-turbo-dev \
    freetype-dev \
    # Useful for debugging
    bash \
    curl

# Set npm configurations for better reliability
RUN npm config set fetch-retries 5 && \
    npm config set fetch-retry-mintimeout 20000 && \
    npm config set fetch-retry-maxtimeout 120000 && \
    npm config set registry https://registry.npmjs.org/

WORKDIR /app

# Create user with specific UID/GID to match host user if needed
# Using 1001 to avoid conflicts with host user 1000
RUN addgroup -g 1001 -S nodejs && \
    adduser -S astro -u 1001 -G nodejs

# Stage 2: Install dependencies with verification
FROM base AS deps

# Copy package files with explicit ownership
COPY --chown=astro:nodejs package*.json ./

# Clear any potential cache issues
RUN npm cache clean --force

# Install dependencies as root to avoid permission issues during install
# Then fix ownership after
RUN npm ci --legacy-peer-deps --loglevel verbose 2>&1 | tee npm-install.log || \
    (echo "NPM install failed. Last 50 lines of log:" && tail -50 npm-install.log && exit 1)

# Verify critical packages are installed
RUN echo "=== Verifying installed packages ===" && \
    node -e " \
    const requiredPackages = [ \
        'astro', \
        'lucide-astro', \
        'bcryptjs', \
        'decap-cms-app', \
        'jsonwebtoken', \
        'sharp', \
        '@astrojs/node', \
        '@astrojs/react', \
        '@astrojs/tailwind', \
        '@astrojs/sitemap', \
        '@supabase/supabase-js', \
        '@stripe/stripe-js', \
        'tailwindcss', \
        'typescript' \
    ]; \
    let failed = false; \
    requiredPackages.forEach(pkg => { \
        try { \
            const resolved = require.resolve(pkg); \
            console.log('✓ ' + pkg + ' found at: ' + resolved); \
        } catch (e) { \
            console.error('✗ ' + pkg + ' NOT FOUND'); \
            failed = true; \
        } \
    }); \
    if (failed) { \
        console.error('\\nSome packages are missing!'); \
        process.exit(1); \
    } else { \
        console.log('\\nAll required packages verified ✓'); \
    } \
    "

# Fix ownership of everything
RUN chown -R astro:nodejs /app

# Stage 3: Development stage
FROM deps AS development

# Install global development tools
RUN npm install -g \
    npm-check-updates \
    node-gyp

# Copy the enhanced entrypoint script
COPY --chown=astro:nodejs docker-entrypoint-fixed.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Copy application source (will be overridden by volume mount in development)
# But we copy it to ensure the image is complete
COPY --chown=astro:nodejs . .

# Pre-create directories that need specific permissions
RUN mkdir -p .astro && \
    chown -R astro:nodejs .astro && \
    chmod -R 755 .astro && \
    # Also create other directories that might be needed
    mkdir -p public/images && \
    mkdir -p src/content && \
    chown -R astro:nodejs public src

# Switch to non-root user
USER astro

# Set environment variables
ENV NODE_ENV=development
ENV PATH=/app/node_modules/.bin:$PATH
ENV NODE_PATH=/app/node_modules

# Expose the development server port
EXPOSE 4321

# Health check with longer start period for npm dev startup
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=5 \
    CMD curl -f http://localhost:4321 || exit 1

# Use the enhanced entrypoint
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]

# Development command
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "4321"]