{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@lib/*": ["./src/lib/*"],
      "@utils/*": ["./src/utils/*"],
      "@styles/*": ["./src/styles/*"],
      "@content/*": ["./src/content/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src",
    "netlify/functions",
    "vitest.config.ts",
    "vitest.config.aliases.ts"
  ],
  "exclude": [
    "dist",
    "coverage",
    "playwright-report",
    "archived-directories",
    "archive"
  ]
}
