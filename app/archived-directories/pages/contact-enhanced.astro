---
import Layout from '@layouts/Layout.astro';
import PageHero from '@components/PageHero.astro';
import ContactInfo from '@components/ContactInfo.astro';
import FormField from '@components/forms/FormField.astro';
import TextInput from '@components/forms/TextInput.astro';
import TextArea from '@components/forms/TextArea.astro';
import SelectField from '@components/forms/SelectField.astro';
import { validateForm, validators, formatPhoneNumber } from '@lib/form-validation';

// Define validation schema
const contactFormSchema = {
  name: [validators.required],
  email: [validators.required, validators.email],
  phone: [validators.phone], // Optional
  subject: [validators.required],
  message: [validators.required, validators.minLength(10)]
};

let errors: Record<string, string> = {};
let success = false;

// Handle form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  
  // Validate form
  errors = validateForm(formData, contactFormSchema);
  
  if (Object.keys(errors).length === 0) {
    // Form is valid - submit to Netlify Forms
    // (In production, this would be handled by Netlify)
    success = true;
  }
}
---

<Layout 
  title="Contact Us" 
  description="Get in touch with Spicebush Montessori School. We're here to answer your questions about enrollment, programs, and our approach to early childhood education."
>
  <PageHero
    title="Get in Touch"
    description="We'd love to hear from you and answer any questions about our school."
    image="/images/contact-hero.jpg"
  />

  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Information -->
        <div>
          <ContactInfo />
        </div>

        <!-- Contact Form -->
        <div class="bg-white rounded-lg shadow-lg p-8">
          <h2 class="text-2xl font-bold text-forest-canopy mb-6">Send Us a Message</h2>
          
          {success ? (
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg" role="alert">
              <p class="font-medium">Thank you for your message!</p>
              <p>We'll get back to you within 1-2 business days.</p>
            </div>
          ) : (
            <form 
              name="contact" 
              method="POST" 
              data-netlify="true" 
              netlify-honeypot="bot-field"
              class="space-y-6"
            >
              <input type="hidden" name="form-name" value="contact" />
              
              <!-- Honeypot -->
              <div style="display: none;">
                <input name="bot-field" />
              </div>

              <div class="grid md:grid-cols-2 gap-4">
                <FormField
                  label="Your Name"
                  name="name"
                  required
                  error={errors.name}
                >
                  <TextInput
                    name="name"
                    placeholder="Enter your full name"
                    required
                  />
                </FormField>

                <FormField
                  label="Email Address"
                  name="email"
                  required
                  error={errors.email}
                >
                  <TextInput
                    name="email"
                    type="email"
                    placeholder="your.email@example.com"
                    required
                  />
                </FormField>
              </div>

              <div class="grid md:grid-cols-2 gap-4">
                <FormField
                  label="Phone Number"
                  name="phone"
                  error={errors.phone}
                  help="Optional - for faster response"
                >
                  <TextInput
                    name="phone"
                    type="tel"
                    placeholder="(555) 123-4567"
                    data-phone-format
                  />
                </FormField>

                <FormField
                  label="Child's Age"
                  name="childAge"
                  help="If applicable"
                >
                  <SelectField
                    name="childAge"
                    options={[
                      { value: '', label: 'Select age' },
                      { value: 'under-3', label: 'Under 3 years old' },
                      { value: '3', label: '3 years old' },
                      { value: '4', label: '4 years old' },
                      { value: '5', label: '5 years old' },
                      { value: '6', label: '6 years old' },
                      { value: 'over-6', label: 'Over 6 years old' }
                    ]}
                  />
                </FormField>
              </div>

              <FormField
                label="Subject"
                name="subject"
                required
                error={errors.subject}
              >
                <SelectField
                  name="subject"
                  required
                  options={[
                    { value: '', label: 'What can we help you with?' },
                    { value: 'tour', label: 'Schedule a Tour' },
                    { value: 'admissions', label: 'Admissions Questions' },
                    { value: 'tuition', label: 'Tuition and Financial Aid' },
                    { value: 'programs', label: 'Program Information' },
                    { value: 'special-needs', label: 'Special Needs Support' },
                    { value: 'general', label: 'General Questions' },
                    { value: 'other', label: 'Other' }
                  ]}
                />
              </FormField>

              <FormField
                label="Message"
                name="message"
                required
                error={errors.message}
                help="Please share your questions or comments"
              >
                <TextArea
                  name="message"
                  rows={5}
                  placeholder="Tell us how we can help..."
                  required
                />
              </FormField>

              <button 
                type="submit" 
                class="w-full bg-forest-canopy text-white font-semibold py-3 px-6 rounded-lg hover:bg-opacity-90 transition-colors focus:outline-none focus:ring-2 focus:ring-forest-canopy focus:ring-offset-2"
              >
                Send Message
              </button>
            </form>
          )}
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Simple phone formatting
  import { formatPhoneNumber } from '@lib/form-validation';
  
  document.addEventListener('DOMContentLoaded', () => {
    const phoneInput = document.querySelector('[data-phone-format]') as HTMLInputElement;
    
    if (phoneInput) {
      phoneInput.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        target.value = formatPhoneNumber(target.value);
      });
    }
  });
</script>