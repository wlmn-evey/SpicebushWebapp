# Spicebush Montessori Web App - Production Environment Template
# 
# IMPORTANT: This is a template file. Copy to .env.production and fill in actual values.
# Never commit actual credentials to version control.

# Database - Read-only user for frontend queries
DB_READONLY_USER=your_readonly_database_user
DB_READONLY_PASSWORD=your_secure_readonly_password
DB_READONLY_HOST=your_production_database_host
DB_READONLY_PORT=5432
DB_READONLY_DATABASE=your_database_name

# Supabase Configuration (Production)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# JWT Secret (Generate a secure random string)
JWT_SECRET=generate_a_secure_64_character_string

# Analytics (Optional)
LOGFLARE_API_KEY=your_logflare_api_key_if_using_analytics
SECRET_KEY_BASE=your_secret_key_base_for_logflare

# Email Configuration (Production SMTP)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Admin Configuration (Optional)
ADMIN_EMAILS=admin@spicebushmontessori.org
ADMIN_DOMAINS=spicebushmontessori.org

# Stripe Configuration (If using donations)
STRIPE_SECRET_KEY=your_stripe_secret_key
PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Image Optimization
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Security Headers (Optional but recommended)
CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';

# Application Settings
NODE_ENV=production
SITE_URL=https://spicebushmontessori.org

# Notes:
# 1. Generate secure passwords using: openssl rand -base64 32
# 2. Store production credentials securely (e.g., Google Secret Manager)
# 3. Never commit this file with actual values to version control
# 4. Ensure all URLs use HTTPS in production
# 5. Set up proper database user with minimal required permissions