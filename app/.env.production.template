# ========================================
# 🚀 PRODUCTION ENVIRONMENT TEMPLATE
# ========================================
# Copy this file to .env.production and fill in your values
# DO NOT commit .env.production to version control!

# === REQUIRED VARIABLES ===

# Supabase Configuration (get from Supabase Dashboard → Settings → API)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLIC_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === PAYMENT PROCESSING (if accepting donations) ===

# Stripe API Keys (get from Stripe Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# === EMAIL SERVICE (choose one) ===

# Option 1: SendGrid
SENDGRID_API_KEY=SG.xxxx
EMAIL_FROM=noreply@yourdomain.org
EMAIL_FROM_NAME=Your Organization

# Option 2: Postmark
# POSTMARK_SERVER_TOKEN=xxxx
# POSTMARK_FROM_EMAIL=noreply@yourdomain.org

# Option 3: Resend
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=noreply@yourdomain.org

# === OPTIONAL SERVICES ===

# Google Analytics (if using)
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Error Tracking with Sentry (if using)
# SENTRY_DSN=https://xxxx@sentry.io/xxxx
# SENTRY_ENVIRONMENT=production

# === BUILD CONFIGURATION ===

# Node environment
NODE_ENV=production

# === NOTES ===
# 1. In Netlify, add these via: Site Settings → Environment Variables
# 2. Mark sensitive values (API keys) as "Secret" in Netlify
# 3. Variables prefixed with PUBLIC_ are exposed to the client
# 4. All others are server-side only
# 5. Netlify automatically provides: URL, DEPLOY_URL, CONTEXT, NETLIFY_SITE_ID