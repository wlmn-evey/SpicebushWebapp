# ========================================
# 🚀 ENVIRONMENT VARIABLES TEMPLATE
# ========================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# === PUBLIC VARIABLES (Safe for client-side) ===

# Supabase Configuration
# Note: Supabase now uses new key formats with sb_ prefixes
# Old JWT format (starts with eyJ) still works but new format is recommended
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx  # New format: sb_publishable_
# Or legacy format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === PRIVATE VARIABLES (Server-side only) ===

# Supabase Service Role (NEVER expose this)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx  # New format: sb_secret_
# Or legacy format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database Direct Access (if needed)
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_DATABASE=postgres

# Site Configuration
PUBLIC_SITE_URL=http://localhost:4321

# Coming Soon Mode (Testing/Staging Only)
# Set to 'true' to force the site into coming soon mode
# This overrides the database setting and is useful for testing environments
# COMING_SOON_MODE=true

# === OPTIONAL SERVICES ===

# Stripe Payment Processing
# For testing, use these test keys (no real charges will occur):
# PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51L7M83HrcKFotQYJ4K8mA2nG5LPbSrPwCXqVtZPzPfVD6xnlMgWPKzVqC5sKGJ5F5wYtWoGPKwPGE3N8wj6Qvfmr00Uw5Wn8Jq
# STRIPE_SECRET_KEY=sk_test_51L7M83HrcKFotQYJkHqVzN8oVGn5J9ZTJ9TPCzNnPKqMKKG8WhGnCzFhGWqVtZPzPfVD6xnlMgWPKzVqC5sKGJ5F5w
# 
# For production, get your keys from: https://dashboard.stripe.com/apikeys
# PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx  # Starts with pk_live_ (client-side)
# STRIPE_SECRET_KEY=rk_live_xxx or sk_live_xxx  # Restricted or secret key (server-side)
# STRIPE_WEBHOOK_SECRET=whsec_xxx  # From webhook endpoint in Stripe dashboard
#
# Note: Restricted keys (rk_live_) are recommended for server-side operations
# They provide limited permissions for better security

# === EMAIL SERVICE CONFIGURATION ===
# 
# NOTE: Magic links use Supabase's built-in email service (FREE, no configuration needed!)
# The settings below are OPTIONAL and only needed for non-authentication emails
# (e.g., tour scheduling, contact forms, newsletters)
#
# Optional: External Email Service (for non-auth transactional emails)
# Choose one of: unione, sendgrid, postmark, resend
# EMAIL_SERVICE=resend
#
# Option 1: Unione.io (https://unione.io)
# UNIONE_API_KEY=your-api-key-here
# UNIONE_REGION=us  # or 'eu'
#
# Option 2: Resend (https://resend.com) - Recommended
# RESEND_API_KEY=your-resend-key-here
#
# Option 3: SendGrid (https://sendgrid.com)
# SENDGRID_API_KEY=your-sendgrid-key-here
#
# Option 4: Postmark (https://postmarkapp.com)
# POSTMARK_SERVER_TOKEN=your-postmark-token-here
#
# Default sender information (for transactional emails)
# EMAIL_FROM=noreply@spicebushmontessori.org
# EMAIL_FROM_NAME=Spicebush Montessori School

# === CLERK AUTHENTICATION ===
# 
# Sign up for free at https://clerk.com
# Get your keys from the Clerk Dashboard
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# === COMING SOON MODE ===
# 
# Set to 'true' to force the site into coming soon mode
# This overrides any database settings
# COMING_SOON_MODE=false

# === AUTHENTICATION PROVIDER ===
# 
# Feature flag for auth migration
# Set to 'clerk' to use Clerk, 'supabase' for Supabase (during migration)
USE_CLERK_AUTH=clerk

# === DEPLOYMENT NOTES ===
# 
# For Vercel deployment:
# - Add these in dashboard: https://vercel.com/dashboard/[project]/settings/environment-variables
# 
# For Netlify deployment:
# - Add these in: Site Settings > Environment variables
#
# NEVER commit real credentials to git!