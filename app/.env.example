# ========================================
# 🚀 ENVIRONMENT VARIABLES TEMPLATE
# ========================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# === PUBLIC VARIABLES (Safe for client-side) ===

# No public database credentials are needed with Netlify DB + server-side queries.

# === PRIVATE VARIABLES (Server-side only) ===

# Netlify DB / Neon connection string (primary)
# Example format:
# NETLIFY_DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
NETLIFY_DATABASE_URL=

# Optional local/dev fallback if NETLIFY_DATABASE_URL is not set
DATABASE_URL=

# Site Configuration
PUBLIC_SITE_URL=http://localhost:4321

# === ANALYTICS (GOOGLE ANALYTICS 4) ===
#
# Optional: Client-side tracking + admin analytics monitoring.
# You can also set these values from Admin > SEO & Analytics.
# PUBLIC_GA4_ENABLED=true
# PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Optional GA4 property ID for future API reporting workflows:
# GA4_PROPERTY_ID=123456789
# Optional GA4 Data API service account (for admin reporting):
# Option A (single JSON blob):
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
# Option B (split values):
# GA4_SERVICE_ACCOUNT_EMAIL=analytics-reader@project.iam.gserviceaccount.com
# GA4_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === OPTIONAL SERVICES ===

# === SMART ADJUST (AI IMAGE PLACEMENT) ===
#
# Optional: Enables AI-assisted focal/crop placement for inline media editing.
# If not set, Smart Adjust falls back to built-in heuristic placement.
# Preferred provider:
# SMART_ADJUST_PROVIDER=gemini
#
# Gemini:
# GEMINI_API_KEY=your-gemini-api-key-here
# Optional model override:
# GEMINI_MODEL=gemini-2.5-flash
# Optional timeout override in ms (default: 24000):
# SMART_ADJUST_GEMINI_TIMEOUT_MS=24000
# Optional fallback model when Gemini primary aborts/times out:
# GEMINI_FALLBACK_MODEL=gemini-2.0-flash
#
# OpenAI (fallback/alternative):
# CODEX_API_KEY=your-api-key-here
# OPENAI_API_KEY=your-api-key-here
# Optional model override:
# SMART_ADJUST_MODEL=gpt-4.1-mini

# === EMAIL SERVICE CONFIGURATION ===
# 
# NOTE: The settings below are OPTIONAL and only needed for transactional emails
# (e.g., tour scheduling and contact forms)
#
# Standard provider: SendGrid (https://sendgrid.com)
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=SG.your-sendgrid-key-here
#
# Optional sender override (if omitted, runtime uses EMAIL_FROM, then settings.school_email, then hard fallback)
# SENDGRID_FROM_EMAIL=noreply@spicebushmontessori.org
# Optional API tuning
# SENDGRID_TIMEOUT_MS=15000
# SENDGRID_API_BASE_URL=https://api.sendgrid.com/v3
#
# Legacy fallback (optional while migrating old environments)
# UNIONE_API_KEY=your-unione-api-key-here
# UNIONE_REGION=eu  # or 'us'
#
# Optional sender information override
# EMAIL_FROM=noreply@spicebushmontessori.org
# EMAIL_FROM_NAME=Spicebush Montessori School

# === DONATIONS (STRIPE CHECKOUT) ===
#
# Required for the on-site /donate checkout flow (restricted key preferred):
# STRIPE_RESTRICTED_KEY=rk_live_xxx
# Backward-compatible fallback:
# STRIPE_SECRET_KEY=sk_live_xxx
# Required to verify incoming Stripe webhooks at /api/webhooks/stripe:
# STRIPE_WEBHOOK_SECRET=whsec_xxx
#
# Optional backup portal link (managed in Admin Settings as donation_external_link):
# If Stripe checkout is unavailable, donors can be redirected there.

# === ADMIN AUTHENTICATION (NETLIFY + NEON) ===
#
# Supported providers:
# - auth0
# - netlify-magic-link
AUTH_PROVIDER=auth0

# Auth0 configuration (required when AUTH_PROVIDER=auth0)
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
# Optional override if your callback is not /auth/callback:
# AUTH0_CALLBACK_URL=https://spicebushmontessori.org/auth/callback
# Optional custom API audience:
# AUTH0_AUDIENCE=
# Optional custom logout return URL (must be allowed in Auth0):
# AUTH0_LOGOUT_RETURN_TO=https://spicebushmontessori.org/auth/sign-in?notice=signed-out

# Magic-link email delivery (required when AUTH_PROVIDER=netlify-magic-link)
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=SG.your-sendgrid-key-here
# Optional sender override (otherwise settings.school_email / default sender is used)
# EMAIL_FROM=information@spicebushmontessori.org

# Optional explicit admin allow-lists (comma-separated).
# If omitted, defaults from app/src/lib/admin-config.ts are used.
# ADMIN_EMAILS=admin@spicebushmontessori.org,director@spicebushmontessori.org
# ADMIN_DOMAINS=@spicebushmontessori.org,@eveywinters.com
# Note: domain-based admin access should be used only when necessary.

# Optional recipient for public tour request notifications.
# If omitted, defaults to information@spicebushmontessori.org
# SCHOOL_CONTACT_EMAIL=information@spicebushmontessori.org

# === COMING SOON MODE ===
# 
# Set to 'true' to force the site into coming soon mode
# This overrides any database settings
COMING_SOON_MODE=false

# === DEPLOYMENT NOTES ===
# 
# For Netlify deployment:
# - Add these in: Site Settings > Environment variables
#
# NEVER commit real credentials to git!
