# ========================================
# 🚀 ENVIRONMENT VARIABLES TEMPLATE
# ========================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# === PUBLIC VARIABLES (Safe for client-side) ===

# No public database credentials are needed with Netlify DB + server-side queries.

# === PRIVATE VARIABLES (Server-side only) ===

# Netlify DB / Neon connection string (primary)
# Example format:
# NETLIFY_DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
NETLIFY_DATABASE_URL=

# Optional local/dev fallback if NETLIFY_DATABASE_URL is not set
DATABASE_URL=

# Site Configuration
PUBLIC_SITE_URL=http://localhost:4321

# === OPTIONAL SERVICES ===

# === EMAIL SERVICE CONFIGURATION ===
# 
# NOTE: The settings below are OPTIONAL and only needed for transactional emails
# (e.g., tour scheduling and contact forms)
#
# Optional: External Email Service (for non-auth transactional emails)
# Choose one of: unione, sendgrid, postmark, resend
# EMAIL_SERVICE=resend
#
# Option 1: Unione.io (https://unione.io)
# UNIONE_API_KEY=your-api-key-here
# UNIONE_REGION=us  # or 'eu'
#
# Option 2: Resend (https://resend.com) - Recommended
# RESEND_API_KEY=your-resend-key-here
#
# Option 3: SendGrid (https://sendgrid.com)
# SENDGRID_API_KEY=your-sendgrid-key-here
#
# Option 4: Postmark (https://postmarkapp.com)
# POSTMARK_SERVER_TOKEN=your-postmark-token-here
#
# Default sender information (for transactional emails)
# EMAIL_FROM=noreply@spicebushmontessori.org
# EMAIL_FROM_NAME=Spicebush Montessori School

# === ADMIN AUTHENTICATION (NETLIFY + NEON) ===
#
# Supported providers:
# - auth0
# - netlify-magic-link
AUTH_PROVIDER=auth0

# Auth0 configuration (required when AUTH_PROVIDER=auth0)
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
# Optional override if your callback is not /auth/callback:
# AUTH0_CALLBACK_URL=https://spicebushmontessori.org/auth/callback
# Optional custom API audience:
# AUTH0_AUDIENCE=
# Optional custom logout return URL (must be allowed in Auth0):
# AUTH0_LOGOUT_RETURN_TO=https://spicebushmontessori.org/auth/sign-in?notice=signed-out

# Magic-link email delivery (required when AUTH_PROVIDER=netlify-magic-link)
# UNIONE_API_KEY=your-api-key-here
# EMAIL_FROM=noreply@spicebushmontessori.org

# Optional explicit admin allow-lists (comma-separated).
# If omitted, defaults from app/src/lib/admin-config.ts are used.
# ADMIN_EMAILS=admin@spicebushmontessori.org,director@spicebushmontessori.org
# ADMIN_DOMAINS=@spicebushmontessori.org,@eveywinters.com
# Note: domain-based admin access should be used only when necessary.

# Optional recipient for public tour request notifications.
# If omitted, defaults to information@spicebushmontessori.org
# SCHOOL_CONTACT_EMAIL=information@spicebushmontessori.org

# === COMING SOON MODE ===
# 
# Set to 'true' to force the site into coming soon mode
# This overrides any database settings
COMING_SOON_MODE=false

# === DEPLOYMENT NOTES ===
# 
# For Netlify deployment:
# - Add these in: Site Settings > Environment variables
#
# NEVER commit real credentials to git!
