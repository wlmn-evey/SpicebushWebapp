{
  "name": "settings-tests",
  "version": "1.0.0",
  "description": "Test suite for settings management implementation",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:api": "jest settings-api.test.js",
    "test:validation": "jest settings-validation.test.js", 
    "test:audit": "jest settings-audit.test.js",
    "test:browser": "playwright test settings-browser.test.js",
    "test:all": "npm run test && npm run test:browser",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.40.0",
    "jest": "^29.7.0",
    "node-fetch": "^3.3.2"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "extensionsToTreatAsEsm": [".js"],
    "globals": {
      "fetch": "node-fetch"
    },
    "testTimeout": 30000,
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"]
  }
}