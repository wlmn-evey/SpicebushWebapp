# ========================================
# 🚀 PRODUCTION ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env.production and fill in your production values
# 
# SECURITY WARNING: Never commit .env.production to version control!
# ========================================

# === REQUIRED FOR PRODUCTION ===

# Supabase Configuration (production values)
# Get these from your Supabase project settings
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key-here

# === OPTIONAL FEATURES ===

# Strapi CMS (if using external CMS)
# PUBLIC_STRAPI_URL=https://your-strapi-instance.com

# Stripe (for donation features)
# PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
# STRIPE_SECRET_KEY=sk_live_your_key_here

# === DEPLOYMENT SETTINGS ===

# Docker image tag (optional, defaults to spicebush-montessori:latest)
# DOCKER_TAG=spicebush-montessori:v1.0.0

# Build target (optional, defaults to production)
# BUILD_TARGET=production

# === SECURITY REMINDERS ===
# 1. Use strong, unique keys for production
# 2. Enable Row Level Security (RLS) in Supabase
# 3. Configure CORS policies appropriately
# 4. Set up proper backup strategies
# 5. Monitor your application logs