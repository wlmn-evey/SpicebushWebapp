# ========================================
# 🚨 PRODUCTION ENVIRONMENT TEMPLATE
# ========================================
# CRITICAL: Never commit actual credentials!
# 
# Instructions:
# 1. Copy this file to .env.production.local
# 2. Replace all placeholder values with actual credentials
# 3. NEVER commit .env.production.local to version control
# ========================================

# === SUPABASE PRODUCTION ===
# Get these from your Supabase project dashboard
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
# CRITICAL: Service role key should NEVER be exposed client-side
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# === DATABASE CREDENTIALS ===
# Only needed for direct database access (migrations, etc.)
DB_HOST=db.YOUR_PROJECT_ID.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD_HERE
DB_DATABASE=postgres

# === OPTIONAL: READ-ONLY DATABASE USER ===
# Recommended for content queries
# DB_READONLY_HOST=db.YOUR_PROJECT_ID.supabase.co
# DB_READONLY_PORT=5432
# DB_READONLY_DATABASE=postgres
# DB_READONLY_USER=readonly_user
# DB_READONLY_PASSWORD=YOUR_READONLY_PASSWORD_HERE

# === CMS CONFIGURATION ===
# If using Strapi or other CMS
PUBLIC_STRAPI_URL=https://your-cms-domain.com

# === OPTIONAL: PAYMENT PROCESSING ===
# PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
# STRIPE_SECRET_KEY=sk_live_your_key_here

# === SECURITY REMINDERS ===
# ✅ All production .env files must be in .gitignore
# ✅ Rotate credentials if exposed
# ✅ Use environment variables in CI/CD
# ✅ Never log sensitive values
# ✅ Use read-only database users when possible