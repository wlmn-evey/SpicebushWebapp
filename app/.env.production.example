# Production Environment Variables for Spicebush Montessori
# Copy this file to .env.production and fill in the actual values

# Supabase Configuration
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLIC_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Unione.io Email Service Configuration
UNIONE_API_KEY=your-unione-api-key
UNIONE_REGION=eu  # or 'us' for US region
EMAIL_FROM=noreply@spicebushmontessori.org
EMAIL_FROM_NAME=Spicebush Montessori
EMAIL_SERVICE=unione  # Preferred email service

# Supabase Custom SMTP Configuration (for magic links)
# These will be used if you configure custom SMTP in Supabase dashboard
GOTRUE_SMTP_HOST=smtp.eu1.unione.io
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=your-unione-smtp-username
GOTRUE_SMTP_PASS=your-unione-smtp-password
GOTRUE_SMTP_ADMIN_EMAIL=noreply@spicebushmontessori.org
GOTRUE_SMTP_MAX_FREQUENCY=1s

# Site Configuration
PUBLIC_SITE_URL=https://spicebushmontessori.org
SITE_URL=https://spicebushmontessori.org

# Analytics (optional)
PUBLIC_GOOGLE_ANALYTICS_ID=
PUBLIC_GOOGLE_TAG_MANAGER_ID=

# Admin Configuration
ADMIN_DOMAINS=@spicebushmontessori.org,@eveywinters.com

# Test Configuration (optional, for production testing)
TEST_EMAIL=admin@spicebushmontessori.org