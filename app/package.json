{
  "name": "spicebush-montessori",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/ --ext .ts,.astro,.js",
    "lint:fix": "eslint src/ --ext .ts,.astro,.js --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/test/lib src/test/components",
    "test:integration": "vitest run src/test/integration",
    "test:accessibility": "vitest run src/test/accessibility",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:quickactions": "playwright test tests/quickactions.test.js",
    "test:quickactions:ui": "playwright test tests/quickactions.test.js --ui",
    "test:quickactions:debug": "playwright test tests/quickactions.test.js --debug",
    "test:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:visual:update": "playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "npm run test:coverage && npm run test:e2e",
    "test:aliases": "vitest run -c vitest.config.aliases.ts src/test/path-aliases.test.ts",
    "test:performance": "vitest run src/test/performance/",
    "test:performance:watch": "vitest src/test/performance/",
    "test:performance:full": "node scripts/run-performance-tests.js",
    "bundle:analyze": "node scripts/bundle-analysis.js",
    "images:audit": "node scripts/image-audit.js",
    "refine": "tsx scripts/refine-command.ts",
    "refine:dry-run": "tsx scripts/refine-command.ts --dry-run",
    "thinking-check": "tsx scripts/thinking-matrix-check.ts",
    "thinking-check:interactive": "tsx scripts/thinking-matrix-check.ts --interactive",
    "docker:dev": "docker-compose up --build",
    "docker:dev:bg": "docker-compose up --build -d",
    "docker:down": "docker-compose down",
    "docker:reset": "docker-compose down -v && docker-compose up --build",
    "docker:logs": "docker-compose logs -f app",
    "setup:dev": "cp .env.example .env.local && echo 'Please update .env.local with your values'",
    "optimize:images": "node scripts/optimize-images.js",
    "cms:local": "npx netlify-cms-proxy-server"
  },
  "dependencies": {
    "@astrojs/node": "^9.3.0",
    "@astrojs/react": "^4.3.0",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.2",
    "@stripe/react-stripe-js": "^3.8.0",
    "@stripe/stripe-js": "^7.6.1",
    "@supabase/supabase-js": "^2.39.1",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.4",
    "astro": "^5.2.5",
    "bcryptjs": "^3.0.2",
    "csv-parse": "^6.1.0",
    "decap-cms-app": "^3.8.2",
    "dotenv": "^17.2.1",
    "isomorphic-dompurify": "^2.26.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-astro": "^0.468.0",
    "marked": "^16.1.1",
    "nanoid": "^5.1.5",
    "nodemailer": "^7.0.5",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.3",
    "stripe": "^18.3.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.5.10",
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.41.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.4.0",
    "@vitest/ui": "^1.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^0.31.4",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "glob": "^11.0.3",
    "gray-matter": "^4.0.3",
    "jsdom": "^24.0.0",
    "netlify-cms-proxy-server": "^1.3.24",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "tsx": "^4.7.1",
    "vitest": "^1.4.0"
  }
}
