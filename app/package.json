{
  "name": "spicebush-montessori",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:production": "astro build",
    "typecheck:loose": "astro check --tsconfig tsconfig.production.json",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/ --ext .ts,.astro,.js",
    "lint:fix": "eslint src/ --ext .ts,.astro,.js --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e:quick": "playwright test e2e/quick-smoke-test.spec.ts",
    "test:a11y": "playwright test e2e/accessibility-compliance-test.spec.ts",
    "test:performance": "playwright test e2e/performance-metrics.spec.ts",
    "validate:config": "node scripts/verify-deployment.cjs",
    "db:migrate": "bash scripts/apply-migrations.sh",
    "db:seed": "node scripts/insert-critical-data.js",
    "db:seed:netlify": "bash scripts/seed-netlify-db.sh",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:email": "node scripts/test-email-service.js",
    "setup:deployment": "node scripts/setup-deployment-automation.js",
    "deploy:staging": "npm run build && netlify deploy --dir=dist",
    "deploy:production": "npm run build && netlify deploy --dir=dist --prod",
    "deploy:preview": "npm run build && netlify deploy --dir=dist --alias=preview",
    "test:db": "node verify-database-connection.cjs",
    "test:db:verify": "node verify-database-connection.cjs",
    "test:db:full": "node verify-database-connection.cjs",
    "test:visual:update": "playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "npm run test:coverage && npm run test:e2e",
    "test:performance:full": "node scripts/run-performance-tests.js",
    "bundle:analyze": "node scripts/bundle-analysis.js",
    "images:audit": "node scripts/image-audit.js",
    "refine": "tsx scripts/refine-command.ts",
    "refine:dry-run": "tsx scripts/refine-command.ts --dry-run",
    "thinking-check": "tsx scripts/thinking-matrix-check.ts",
    "thinking-check:interactive": "tsx scripts/thinking-matrix-check.ts --interactive",
    "test:smoke": "playwright test e2e/critical/quick-smoke.spec.ts",
    "test:smoke:critical": "playwright test e2e/critical/quick-smoke.spec.ts --grep @critical",
    "test:comprehensive": "playwright test e2e/critical/comprehensive-smoke.spec.ts",
    "test:docker:health": "playwright test e2e/critical/docker-health-check.spec.ts",
    "test:browser:all": "playwright test e2e/critical/",
    "test:browser:report": "playwright show-report test-results/html-report",
    "test:browser": "tsx scripts/run-browser-tests.ts",
    "docker:dev": "docker-compose up --build",
    "docker:dev:bg": "docker-compose up --build -d",
    "docker:down": "docker-compose down",
    "docker:reset": "docker-compose down -v && docker-compose up --build",
    "docker:logs": "docker-compose logs -f app",
    "setup:dev": "cp .env.example .env.local && echo 'Please update .env.local with your values'",
    "optimize:images": "node scripts/optimize-images.js"
  },
  "dependencies": {
    "@astrojs/netlify": "^6.5.3",
    "@astrojs/react": "^4.3.0",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.2",
    "@netlify/functions": "^4.2.1",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/pg": "^8.15.4",
    "astro": "^5.2.5",
    "csv-parse": "^6.1.0",
    "isomorphic-dompurify": "^2.26.0",
    "lucide-astro": "^0.468.0",
    "marked": "^16.1.1",
    "nanoid": "^5.1.5",
    "pg": "^8.16.3",
    "playwright": "^1.54.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.5.10",
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.0",
    "@types/node-fetch": "^2.6.12",
    "@types/react": "^19.1.15",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.4.0",
    "@vitest/ui": "^1.4.0",
    "axe-core": "^4.9.1",
    "dotenv": "^17.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^0.31.4",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "glob": "^11.0.3",
    "gray-matter": "^4.0.3",
    "jsdom": "^24.0.0",
    "netlify-cli": "^23.1.4",
    "node-fetch": "^2.7.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "puppeteer": "^24.22.3",
    "tsx": "^4.7.1",
    "vitest": "^1.4.0"
  }
}
