# Development Dockerfile for Spicebush Montessori Astro Application
# Optimized for fast rebuilds and hot reload support

FROM node:20-alpine

# Install system dependencies for sharp and other native modules
RUN apk add --no-cache \
    git \
    vips-dev \
    fftw-dev \
    build-base \
    gcc \
    g++ \
    make \
    python3 \
    libc6-compat \
    # Add bash for better debugging
    bash

# Set working directory
WORKDIR /app

# The node:20-alpine image already has a 'node' user with UID 1000
# We'll use that to avoid permission issues

# Install global packages for better development experience
RUN npm install -g npm@latest

# Copy package files only (for better caching)
COPY --chown=node:node package*.json ./

# Install dependencies with legacy peer deps flag
# We do this as root to avoid permission issues during install
RUN npm ci --legacy-peer-deps && \
    # Fix permissions after install
    chown -R node:node /app && \
    # Pre-create .astro directory with correct ownership and permissions
    mkdir -p /app/.astro && \
    chown -R node:node /app/.astro && \
    chmod -R 775 /app/.astro && \
    # Ensure node_modules has correct permissions
    chmod -R 755 /app/node_modules

# Copy entrypoint script
COPY --chown=node:node docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Switch to non-root user
USER node

# Expose the development server port
EXPOSE 4321

# Health check for development
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
    CMD node -e "require('http').get('http://localhost:4321', (r) => {if (r.statusCode !== 200 && r.statusCode !== 404) throw new Error(r.statusCode)})" || exit 1

# Use entrypoint script
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]

# Development command
# The source code will be mounted via volume, so we don't copy it here
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "4321"]