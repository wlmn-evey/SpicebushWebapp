{
  "$ref": "#/definitions/announcements",
  "definitions": {
    "announcements": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "notice",
            "closure",
            "event",
            "update"
          ],
          "default": "notice"
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "normal",
            "high",
            "urgent"
          ],
          "default": "normal"
        },
        "startDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "endDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "audience": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "all",
              "parents",
              "staff",
              "community"
            ]
          },
          "default": [
            "all"
          ]
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "startDate",
        "endDate"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}