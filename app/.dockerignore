# Docker build context exclusions

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build outputs
dist/
.astro/
.astro-docker/
build/
out/

# Environment files
.env
.env.local
.env.*.local
.env.production
.env.development

# Version control
.git/
.gitignore
.gitattributes

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.swn

# Docker files
docker-compose*.yml
Dockerfile*
.dockerignore
docker/volumes/

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
e2e/screenshots/
e2e/videos/

# Documentation
*.md
docs/
archive/
journal/

# Development files
.eslintrc*
.prettierrc*
.editorconfig
tsconfig*.json
vitest.config.ts
playwright.config.ts

# Temporary files
*.log
*.tmp
*.temp
.cache/
tmp/
temp/
logs/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Backup files
*.backup
*.bak
*~

# Scripts that shouldn't be in the image
scripts/test-*
scripts/setup-*

# Large media files that are handled separately
public/images/gallery-staging/
*.mp4
*.mov
*.avi

# Supabase local development
supabase/.branches/
supabase/.temp/

# Misc
*.tgz
*.tar.gz