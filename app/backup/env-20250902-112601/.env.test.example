# Test Environment Variables Template
# Copy this file to .env.test and update with your test credentials
# These should be safe test/demo credentials only - never production values

# Supabase Test Instance
TEST_SUPABASE_URL=http://localhost:54321
TEST_SUPABASE_ANON_KEY=your-test-anon-key-here

# Test Database Credentials (for local Docker environment)
DB_READONLY_USER=test_readonly_user
DB_READONLY_PASSWORD=test_readonly_password

# Note: These are ONLY for testing. Never use production credentials here!