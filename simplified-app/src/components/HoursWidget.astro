---
// Hours Widget Component
// Styled specifically for footer integration
// Modified to use JSON data instead of Supabase
---

<div id="sbms-hours-widget" class="bg-white rounded-lg p-4 text-earth-brown shadow-sm">
  <h3 class="text-xl font-bold text-center text-forest-canopy mb-2">School Hours</h3>
  <div id="current-time-container" class="text-center text-xs opacity-80 mb-3">
    Current Time: <span id="current-time" class="font-medium text-forest-canopy"></span>
  </div>
  
  <!-- Legend -->
  <div id="sbms-legend" class="flex justify-around mb-4 text-xs">
    <span class="flex items-center">
      <span class="w-2.5 h-2.5 bg-moss-green rounded-sm mr-1"></span>
      Before Care
    </span>
    <span class="flex items-center">
      <span class="w-2.5 h-2.5 bg-forest-canopy rounded-sm mr-1"></span>
      Regular Hours
    </span>
    <span class="flex items-center">
      <span class="w-2.5 h-2.5 bg-sunlight-gold rounded-sm mr-1"></span>
      After Care
    </span>
    <span class="flex items-center lg:hidden">
      <span class="w-2.5 h-2.5 bg-orange-600 rounded-sm mr-1"></span>
      Holiday
    </span>
  </div>
  
  <!-- Loading State -->
  <div id="loading-state" class="text-center py-4 text-sm text-gray-500">
    Loading hours...
  </div>
  
  <!-- Hours List -->
  <ul id="hours-list" class="space-y-2 hidden"></ul>
  
  <!-- Holiday Messages -->
  <div id="holiday-messages" class="mt-4"></div>
  
  <!-- Debug Info (hidden by default) -->
  <div id="debug-info" class="hidden mt-4 p-2 bg-gray-100 rounded text-xs">
    <div>Data Source: <span id="data-source">Loading...</span></div>
    <div>Days Loaded: <span id="days-count">0</span></div>
    <div>Holidays Found: <span id="holidays-count">0</span></div>
  </div>
</div>

<script>
  // Import hours data from JSON
  import hoursData from '../data/school-hours.json';
  
  // Utility functions that were in hours-utils.ts
  function formatTime(value) {
    if (value === 0) return '';
    
    const hours = Math.floor(value);
    const minutes = Math.round((value - hours) * 60);
    const ampm = hours >= 12 ? 'PM' : 'AM';
    const displayHours = hours > 12 ? hours - 12 : hours === 0 ? 12 : hours;
    
    if (minutes === 0) {
      return `${displayHours}${ampm}`;
    }
    return `${displayHours}:${minutes.toString().padStart(2, '0')}${ampm}`;
  }
  
  document.addEventListener('DOMContentLoaded', async function() {
    const list = document.getElementById('hours-list');
    const timeEl = document.getElementById('current-time');
    const holidayMessagesEl = document.getElementById('holiday-messages');
    const loadingEl = document.getElementById('loading-state');
    const debugInfo = document.getElementById('debug-info');
    
    const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    
    let processedHours = {};
    let upcomingHolidays = hoursData.holidays || [];
    let dataSource = 'json';
    
    // Enable debug mode if URL contains ?debug=true
    const urlParams = new URLSearchParams(window.location.search);
    const debugMode = urlParams.get('debug') === 'true';
    if (debugMode) {
      debugInfo.classList.remove('hidden');
    }
    
    // Convert JSON hours to the format expected by the widget
    function processHoursData() {
      const dayMap = {
        'sunday': 0,
        'monday': 1,
        'tuesday': 2,
        'wednesday': 3,
        'thursday': 4,
        'friday': 5,
        'saturday': 6
      };
      
      Object.entries(hoursData.regularHours).forEach(([dayName, dayData]) => {
        const dayOfWeek = dayMap[dayName];
        if (dayData.closed) {
          processedHours[days[dayOfWeek]] = { closed: true };
        } else {
          // Convert time strings to decimal hours
          const parseTime = (timeStr) => {
            const [time, period] = timeStr.split(' ');
            const [hours, minutes] = time.split(':').map(Number);
            let decimalHours = hours + (minutes || 0) / 60;
            if (period === 'PM' && hours !== 12) decimalHours += 12;
            if (period === 'AM' && hours === 12) decimalHours = 0;
            return decimalHours;
          };
          
          processedHours[days[dayOfWeek]] = {
            start: 8.5, // 8:30 AM
            end: 15, // 3:00 PM
            before_care_offset: 1, // 7:30 AM is 1 hour before 8:30 AM
            after_care_offset: dayData.afterCare ? 2.5 : 0, // 5:30 PM is 2.5 hours after 3:00 PM
            aftercare_available: dayData.afterCare,
            closed: false
          };
        }
      });
    }
    
    // Update current time
    function updateCurrentTime() {
      const now = new Date();
      const hours = now.getHours();
      const minutes = now.getMinutes();
      const ampm = hours >= 12 ? 'PM' : 'AM';
      const displayHours = hours > 12 ? hours - 12 : hours === 0 ? 12 : hours;
      
      timeEl.textContent = `${displayHours}:${minutes.toString().padStart(2, '0')} ${ampm}`;
    }
    
    // Render the widget with all the animations and features
    function renderWidget() {
      // Hide loading state and show list
      loadingEl.classList.add('hidden');
      list.classList.remove('hidden');
      list.innerHTML = '';
      
      const now = new Date();
      const todayIdx = now.getDay();
      const currentTime = now.getHours() + now.getMinutes() / 60;
      
      // Reorder days starting with today, then continue through the week
      const orderedDays = [...days.slice(todayIdx), ...days.slice(0, todayIdx)];
      
      orderedDays.forEach((day, index) => {
        const info = processedHours[day];
        const li = document.createElement('li');
        li.className = 'p-3 rounded-lg transition-all duration-300';
        
        // Add today highlight
        if (day === days[todayIdx]) {
          li.classList.add('bg-white', 'shadow-md', 'border', 'border-stone-beige');
        }
        
        if (!info || info.closed) {
          li.classList.add('opacity-60');
          li.innerHTML = `
            <div class="flex justify-between items-center">
              <span class="font-semibold text-sm">${day}</span>
              <span class="text-xs opacity-75">Closed</span>
            </div>
          `;
        } else {
          const beforeCareStart = Math.max(0, info.start - info.before_care_offset);
          
          // Check if aftercare is available for this day
          const aftercareAvailable = info.aftercare_available === true;
          const actualAfterCareOffset = aftercareAvailable ? (info.after_care_offset || 0) : 0;
          const afterCareEnd = info.end + actualAfterCareOffset;
          
          // Calculate total span for percentage calculations
          const totalSpan = afterCareEnd - beforeCareStart;
          
          // Calculate widths for visual bars
          const beforeCareWidth = totalSpan > 0 ? (info.before_care_offset / totalSpan) * 100 : 0;
          const regularWidth = totalSpan > 0 ? ((info.end - info.start) / totalSpan) * 100 : 0;
          const afterCareWidth = (totalSpan > 0 && aftercareAvailable) ? (actualAfterCareOffset / totalSpan) * 100 : 0;
          
          li.innerHTML = `
            <div class="flex justify-between items-center mb-2">
              <span class="font-semibold text-sm">${day}</span>
              <span class="text-xs opacity-85">${formatTime(beforeCareStart)}${afterCareEnd > beforeCareStart ? '–' + formatTime(afterCareEnd) : ''}</span>
            </div>
            <div class="relative h-3 bg-gray-200 rounded-full overflow-hidden">
              ${beforeCareWidth > 0 ? `
                <div class="absolute h-full bg-moss-green flex items-center justify-center text-xs text-white font-medium" 
                     style="width: ${beforeCareWidth}%; left: 0%">
                  ${beforeCareWidth > 15 ? formatTime(beforeCareStart) : ''}
                </div>
              ` : ''}
              <div class="absolute h-full bg-forest-canopy flex items-center justify-center text-xs text-white font-medium" 
                   style="width: ${regularWidth}%; left: ${beforeCareWidth}%; min-width: 20%;">
                ${regularWidth > 20 ? formatTime(info.start) : ''}
              </div>
              ${afterCareWidth > 0 ? `
                <div class="absolute h-full bg-sunlight-gold flex items-center justify-center text-xs text-white font-medium" 
                     style="width: ${afterCareWidth}%; left: ${beforeCareWidth + regularWidth}%">
                  ${afterCareWidth > 15 ? formatTime(info.end) : ''}
                </div>
              ` : ''}
            </div>
            ${!aftercareAvailable ? `
              <div class="text-xs text-center mt-1 opacity-60">
                ${day === 'Friday' ? '⏰ Closes at 3:00 PM' : '🚫 No aftercare available'}
              </div>
            ` : ''}
          `;
          
          // Add current time indicator for today
          if (day === days[todayIdx] && currentTime >= beforeCareStart && currentTime <= afterCareEnd) {
            const position = ((currentTime - beforeCareStart) / totalSpan) * 100;
            const indicator = document.createElement('div');
            indicator.className = 'absolute w-0.5 h-5 bg-red-500 shadow-lg rounded-sm -top-1 z-10';
            indicator.style.left = `${Math.min(98, Math.max(1, position))}%`;
            li.querySelector('.relative').appendChild(indicator);
            
            // Add current time tooltip
            const tooltip = document.createElement('div');
            tooltip.className = 'absolute -top-8 left-1/2 transform -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded whitespace-nowrap';
            tooltip.textContent = `Now: ${formatTime(currentTime)}`;
            indicator.appendChild(tooltip);
          }
        }
        
        // Add staggered fade-in animation
        li.style.opacity = '0';
        li.style.transform = 'translateY(10px)';
        li.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        li.style.transitionDelay = `${index * 100}ms`;
        
        list.appendChild(li);
        
        // Trigger animation
        setTimeout(() => {
          li.style.opacity = '1';
          li.style.transform = 'translateY(0)';
        }, 50 + index * 100);
      });
      
      // Update debug info
      if (debugMode) {
        document.getElementById('data-source').textContent = dataSource;
        document.getElementById('days-count').textContent = Object.keys(processedHours).length;
        document.getElementById('holidays-count').textContent = upcomingHolidays.length;
      }
    }
    
    // Initialize
    processHoursData();
    updateCurrentTime();
    renderWidget();
    
    // Update time every minute
    setInterval(updateCurrentTime, 60000);
  });
</script>