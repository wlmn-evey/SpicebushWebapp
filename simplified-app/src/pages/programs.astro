---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

// Get all active programs, sorted by order
const programs = (await getCollection('programs'))
  .filter(program => program.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Our Programs">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-8">Our Programs</h1>
    
    <div class="space-y-12">
      {programs.map((program) => (
        <section class="bg-white rounded-lg shadow-md overflow-hidden">
          <div class="md:flex">
            {program.data.image && (
              <div class="md:w-1/3">
                <img 
                  src={program.data.image} 
                  alt={program.data.title}
                  class="w-full h-64 md:h-full object-cover"
                />
              </div>
            )}
            <div class="p-8 md:w-2/3">
              <h2 class="text-3xl font-semibold mb-2">{program.data.title}</h2>
              <div class="text-gray-600 mb-4 space-y-1">
                <p><strong>Ages:</strong> {program.data.ageRange}</p>
                <p><strong>Schedule:</strong> {program.data.schedule}</p>
              </div>
              <p class="text-lg mb-6">{program.data.shortDescription}</p>
              <a 
                href={`/programs/${program.slug}`}
                class="inline-block bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 transition-colors"
              >
                Learn More
              </a>
            </div>
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>