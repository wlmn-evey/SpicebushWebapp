---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

// Get all active teachers, sorted by order
const teachers = (await getCollection('teachers'))
  .filter(teacher => teacher.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Our Teachers">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-8">Our Teachers</h1>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {teachers.map(async (teacher) => {
        const { Content } = await teacher.render();
        return (
          <article class="bg-white rounded-lg shadow-md overflow-hidden">
            <img 
              src={teacher.data.image} 
              alt={teacher.data.name}
              class="w-full h-64 object-cover"
            />
            <div class="p-6">
              <h2 class="text-2xl font-semibold mb-1">{teacher.data.name}</h2>
              <p class="text-gray-600 mb-4">{teacher.data.role}</p>
              
              {teacher.data.credentials.length > 0 && (
                <div class="mb-4">
                  <h3 class="font-semibold text-sm text-gray-700 mb-2">Credentials:</h3>
                  <ul class="text-sm text-gray-600 space-y-1">
                    {teacher.data.credentials.map(cred => (
                      <li>• {cred}</li>
                    ))}
                  </ul>
                </div>
              )}
              
              {teacher.data.email && (
                <a 
                  href={`mailto:${teacher.data.email}`}
                  class="text-blue-600 hover:text-blue-800 text-sm"
                >
                  Contact {teacher.data.name.split(' ')[0]}
                </a>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </main>
</BaseLayout>